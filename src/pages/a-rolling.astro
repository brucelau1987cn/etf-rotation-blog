---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import AStockSubnav from '../components/AStockSubnav.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type BuyCycle = {
  cycle_code: string;
  segment: string;
  timeframe_minutes: number;
  timeframe_label: string;
  buy_state: 'BUY' | 'STOPPED' | 'INACTIVE' | 'UNKNOWN';
  buy_triggered_at: string | null;
};

type SellStar = {
  code: string;
  timeframe_minutes: number;
  timeframe_label: string;
  sell_state: 'SELL' | 'INACTIVE';
  triggered_at: string | null;
};

type SellNode = {
  code: string;
  timeframe_minutes: number;
  timeframe_label: string;
  sell_state: 'SELL' | 'OBSERVING' | 'INACTIVE';
  triggered_at: string | null;
};

type SellAlert = {
  alert_id: string;
  cycle_code: string;
  timeframe_minutes: number;
  triggered_at: string;
  transmission_position: string | null;
  remaining_session_minutes: number;
  analysis_state: 'pending' | 'ready' | 'unavailable';
  analysis: string;
};

type Payload = {
  schema_version: string;
  mode: 'demo' | 'live';
  generated_at: string;
  data_as_of: string;
  freshness: string;
  stale_after_seconds: number;
  notice: string;
  delivery: { state: string; reason: string | null };
  instrument: { instrument_name: string; exchange: string; symbol: string };
  transmission: {
    state: string;
    basis: string;
    current_cycle_code: string | null;
    stopped_at_code?: string | null;
    started_at: string | null;
    lit_count: number;
    continuous_confirmed: boolean;
  };
  buy_cycles: BuyCycle[];
  sell_chain: {
    window_type: string;
    window_description: string;
    warning_star: SellStar;
    nodes: SellNode[];
  };
  sell_alerts: SellAlert[];
};

const payload = JSON.parse(readFileSync(join(process.cwd(), 'public/data/a-rolling-signals.json'), 'utf-8')) as Payload;

const formatTime = (value: string | null, includeDate = true, includeSeconds = false) => {
  if (!value) return '—';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  
  const options: Intl.DateTimeFormatOptions = {
    timeZone: 'Asia/Shanghai',
    hour12: false,
    hour: '2-digit',
    minute: '2-digit',
  };
  if (includeSeconds) options.second = '2-digit';
  if (includeDate) {
    options.month = '2-digit';
    options.day = '2-digit';
  }
  return date.toLocaleString('zh-CN', options);
};

const pageTitle = `A股滚动策略｜多空能量传导链 | ${SITE_TITLE}`;
const pageDescription = 'A股滚动策略多空能量传导终端，以105分钟预备窗口和A至G共34个周期观察点展示买方力量与卖方预警的动态延伸。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <style>
      main {
        width: min(1180px, calc(100% - 1.5rem));
        padding: 1rem 0 3rem;
        margin: 0 auto;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      }
      .card {
        border: 1px solid var(--border);
        border-radius: 16px;
        background: #fff;
        box-shadow: var(--shadow-sm);
      }
      .dashboard-hero {
        padding: clamp(1rem, 2.5vw, 1.35rem);
        background: linear-gradient(135deg, #fffcfb 0%, #fff 100%);
        margin-bottom: 1rem;
      }
      .hero-top {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        flex-wrap: wrap;
      }
      .hero-copy h1 {
        margin: 0.35rem 0 0.35rem;
        font-size: clamp(1.6rem, 4vw, 2.2rem);
        letter-spacing: -0.03em;
        font-weight: 800;
        color: #0f172a;
      }
      .hero-copy p {
        margin: 0;
        color: rgb(var(--gray-dark));
        font-size: 0.92rem;
        line-height: 1.5;
      }
      
      /* 胶囊标签系统 */
      .meta-line {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.4rem;
      }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.2rem 0.6rem;
        border-radius: 9999px;
        background: var(--warm-2);
        border: 1px solid var(--border);
        font-size: 0.75rem;
        font-weight: 700;
        color: rgb(var(--gray-dark));
      }
      .pill-red {
        background: #fff1f0;
        border-color: #ffa39e;
        color: #cf1322;
      }
      .pill-green {
        background: #f6ffed;
        border-color: #b7eb8f;
        color: #389e0d;
      }
      .pill-amber {
        background: #fffbe6;
        border-color: #ffe58f;
        color: #d48806;
      }
      .pill-blue {
        background: #e6f4ff;
        border-color: #91caff;
        color: #0958d9;
      }

      /* 4列统计核心条 */
      .count-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.6rem;
        margin-top: 1rem;
      }
      .count-box {
        padding: 0.75rem 0.9rem;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: #fff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }
      .count-box span {
        font-size: 0.75rem;
        font-weight: 700;
        color: rgb(var(--gray));
      }
      .count-box strong {
        font-size: 1.35rem;
        font-weight: 800;
        line-height: 1.1;
        margin-top: 0.25rem;
      }
      .count-box em {
        font-size: 0.7rem;
        font-style: normal;
        margin-top: 0.2rem;
        color: rgb(var(--gray));
      }
      .count-box.buy-box {
        background: linear-gradient(180deg, #fff1f0 0%, #fff 100%);
        border-color: rgba(207, 19, 34, 0.2);
      }
      .count-box.buy-box strong { color: #cf1322; }

      .count-box.stop-box {
        background: linear-gradient(180deg, #fffbe6 0%, #fff 100%);
        border-color: rgba(212, 136, 6, 0.2);
      }
      .count-box.stop-box strong { color: #d48806; }

      .count-box.sell-box {
        background: linear-gradient(180deg, #f6ffed 0%, #fff 100%);
        border-color: rgba(56, 158, 13, 0.2);
      }
      .count-box.sell-box strong { color: #389e0d; }

      /* 核心矩阵区域 */
      .matrix-section {
        margin-top: 1.25rem;
        padding: 1.25rem;
      }
      .matrix-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 1rem;
      }
      .matrix-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .view-toggle-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.25rem 0.65rem;
        border-radius: 6px;
        background: #f1f5f9;
        border: 1px solid #cbd5e1;
        font-size: 0.78rem;
        font-weight: 700;
        color: #334155;
        cursor: pointer;
        transition: all 0.15s ease;
      }
      .view-toggle-btn:hover {
        background: #e2e8f0;
        border-color: #94a3b8;
      }
      .table-outer.compact-mode .cell-badge.buy-inactive,
      .table-outer.compact-mode .cell-badge.sell-inactive {
        display: none !important;
      }
      .section-head-title h2 {
        font-size: 1.2rem;
        font-weight: 800;
        margin: 0;
        color: #0f172a;
      }
      .legend-list {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.78rem;
        color: #475569;
      }
      .legend-item {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }
      .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
      }
      .dot-red { background: #ff4d4f; }
      .dot-amber { background: #faad14; }
      .dot-green { background: #52c41a; }
      .dot-gray { background: #d9d9d9; }

      /* 卷轴式双层表格 */
      .table-outer {
        width: 100%;
        overflow-x: auto;
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        background: #f8fafc;
        box-shadow: inset 0 1px 3px rgba(0,0,0,0.02);
      }
      .table-grid {
        display: flex;
        min-width: 1160px;
      }
      
      /* 左侧固定标的列 */
      .stock-sticky {
        position: sticky;
        left: 0;
        width: 130px;
        background: #ffffff;
        border-right: 1px solid #cbd5e1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 1rem 0.5rem;
        flex-shrink: 0;
        z-index: 10;
        box-shadow: 2px 0 4px rgba(0,0,0,0.04);
      }
      .stock-name-title {
        font-size: 1.2rem;
        font-weight: 800;
        color: #0f172a;
      }
      .stock-code-tag {
        font-size: 0.78rem;
        background: #f1f5f9;
        color: #475569;
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
        margin-top: 0.25rem;
        font-family: monospace;
      }

      /* 右侧双行信号轴 */
      .signals-axis {
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      
      .axis-row {
        display: flex;
        align-items: center;
        min-height: 76px;
      }
      .axis-row.sell-axis {
        background: #fcfdfe;
        border-bottom: 1px dashed #cbd5e1;
      }
      .axis-row.buy-axis {
        background: #ffffff;
      }
      .axis-label {
        width: 90px;
        padding-left: 0.8rem;
        font-size: 0.8rem;
        font-weight: 800;
        flex-shrink: 0;
      }
      .axis-label.sell-label { color: #276749; }
      .axis-label.buy-label { color: #9b2c2c; }

      .cells-scroll {
        display: flex;
        gap: 0.4rem;
        padding: 0.6rem 0.8rem;
        flex: 1;
      }

      /* Badge 卡片基础 */
      .cell-badge {
        min-width: 82px;
        padding: 0.4rem 0.5rem;
        border-radius: 8px;
        text-align: center;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border: 1px solid transparent;
        transition: all 0.15s ease;
      }
      .badge-code {
        font-weight: 800;
        font-size: 0.9rem;
        line-height: 1.2;
      }
      .badge-time {
        font-size: 0.7rem;
        margin-top: 0.25rem;
        line-height: 1.1;
      }

      /* 多头配色 */
      .cell-badge.buy-active {
        background: #fff1f0;
        border-color: #ffa39e;
        color: #cf1322;
      }
      .cell-badge.buy-stopped {
        background: #fffbe6;
        border-color: #ffe58f;
        color: #d48806;
      }
      .cell-badge.buy-inactive {
        background: #f5f5f5;
        border-color: #e8e8e8;
        color: #bfbfbf;
      }

      /* 空头配色 */
      .cell-badge.sell-star {
        background: #f6ffed;
        border-color: #b7eb8f;
        color: #389e0d;
      }
      .cell-badge.sell-star .badge-code {
        font-size: 1.1rem;
      }
      .cell-badge.sell-active {
        background: #f6ffed;
        border-color: #b7eb8f;
        color: #389e0d;
      }
      .cell-badge.sell-observing {
        background: #ffffff;
        border: 1px dashed #b7eb8f;
        color: #52c41a;
      }
      .cell-badge.sell-inactive {
        background: #f5f5f5;
        border-color: #e8e8e8;
        color: #bfbfbf;
      }

      /* AI 解读与底栏 */
      .ai-wrapper {
        margin-top: 1.25rem;
        padding: 1.25rem;
      }
      .ai-head {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
      }
      .ai-head h3 {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 800;
        color: #0f172a;
      }
      .ai-alert-box {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-left: 5px solid #16a34a;
        padding: 1rem 1.25rem;
        border-radius: 8px;
      }
      .ai-alert-meta {
        display: flex;
        gap: 1.5rem;
        font-size: 0.82rem;
        color: #166534;
        font-weight: 700;
        margin-bottom: 0.5rem;
      }
      .ai-alert-text {
        font-size: 0.9rem;
        color: #14532d;
        line-height: 1.6;
        margin: 0;
      }

      @media (max-width: 768px) {
        main {
          width: min(100% - 1rem, 1180px);
        }
        .count-strip { grid-template-columns: repeat(2, 1fr); }
      }
    </style>
  </head>
  <body>
    <Header />
    <main id="main-content">
      <AStockSubnav active="rolling" />

      <!-- Dashboard Hero 顶部导航与元数据 -->
      <section class="dashboard-hero card" aria-labelledby="page-title">
        <div class="hero-top">
          <div class="hero-copy">
            <div class="meta-line">
              <span class="pill pill-red">🇨🇳 A股 · 滚动策略</span>
              <span class="pill" id="pill-stock-quote" style="background:#f1f5f9; color:#334155; border-color:#cbd5e1;">行情获取中...</span>
              <span class="pill pill-amber" id="pill-as-of">数据时点：{formatTime(payload.data_as_of)}</span>
              <span class="pill pill-blue" id="pill-mode">模式：{payload.mode === 'demo' ? '基准演示' : '实时数据'}</span>
              <span class="pill">协议：a-rolling-energy-v3</span>
              <span class="pill live-pill" id="live-status-pill" style="background:#e6f4ff; color:#0958d9; border-color:#91caff;">实时连接中</span>
            </div>
            <h1 id="page-title">多空能量传导链</h1>
            <p>基于 TradingBox AI 4.0 信号的 34 周期买方能量传导与动态卖出预警中枢</p>
          </div>
        </div>

        <!-- 4 列精美指标卡片 -->
        <div class="count-strip" aria-label="核心指标看板">
          <div class="count-box buy-box">
            <span>🔴 当前多头位置</span>
            <strong id="stat-current-code">{payload.transmission.current_cycle_code}</strong>
            <em id="stat-lit-count">连续点亮 {payload.transmission.lit_count} 格 <span id="stat-lit-time" style="font-style:normal; margin-left:0.25rem; color:#cf1322; font-weight:700;">{payload.transmission.latest_triggered_at ? `(${formatTime(payload.transmission.latest_triggered_at, true, true)})` : ''}</span></em>
          </div>
          <div class="count-box stop-box">
            <span>🟡 传导停止节点</span>
            <strong id="stat-stopped-code">{payload.transmission.stopped_at_code || 'G'}</strong>
            <em>暂未出现买入确认</em>
          </div>
          <div class="count-box sell-box">
            <span>🟢 卖出预警窗口</span>
            <strong id="stat-star-code">{payload.sell_chain.warning_star.code} ({payload.sell_chain.window_type})</strong>
            <em id="stat-star-time">{formatTime(payload.sell_chain.warning_star.triggered_at, false)} 预警点亮</em>
          </div>
          <div class="count-box sell-box">
            <span>🟢 正式卖出节点</span>
            <strong id="stat-sell-summary">Ⅰ · Ⅱ 级</strong>
            <em id="stat-sell-note">Ⅲ 节点观察中</em>
          </div>
        </div>
      </section>

      <!-- 核心双层横向矩阵卡片 -->
      <section class="matrix-section card" aria-labelledby="matrix-title">
        <div class="matrix-top">
          <div class="section-head-title">
            <h2 id="matrix-title">双向能量传导轨道</h2>
          </div>
          <div class="matrix-controls">
            <button id="toggle-view-btn" class="view-toggle-btn" type="button">
              ⚡ 模式：精简按需点亮
            </button>
            <div class="legend-list">
              <span class="legend-item"><i class="dot dot-red"></i>买方点亮</span>
              <span class="legend-item"><i class="dot dot-amber"></i>传导停止</span>
              <span class="legend-item"><i class="dot dot-green"></i>卖方预警/确认</span>
              <span class="legend-item"><i class="dot dot-gray"></i>未激活/观察中</span>
            </div>
          </div>
        </div>

        <!-- 卷轴横向双层表格 -->
        <div class="table-outer compact-mode" id="table-outer-wrapper">
          <div class="table-grid">
            <!-- 左侧固定标的列 -->
            <div class="stock-sticky">
              <div class="stock-name-title" id="inst-name">{payload.instrument.instrument_name}</div>
              <div class="stock-code-tag" id="inst-symbol">{payload.instrument.symbol}</div>
              <div class="stock-price-tag" id="stock-quote-badge" style="font-size: 0.78rem; font-weight: 700; margin-top: 0.35rem; color: #64748b; font-family: monospace;">
                加载行情...
              </div>
            </div>

            <!-- 右侧双行信号轴 -->
            <div class="signals-axis">
              
              <!-- 上层：卖出信号链（绿） -->
              <div class="axis-row sell-axis">
                <div class="axis-label sell-label">空方力量</div>
                <div class="cells-scroll" id="sell-cells-container">
                  <!-- 预警五角星 -->
                  <div class="cell-badge sell-star">
                    <div class="badge-code">{payload.sell_chain.warning_star.code}</div>
                    <div class="badge-time">{formatTime(payload.sell_chain.warning_star.triggered_at, true, true)}</div>
                  </div>

                  <!-- 罗马数字节点 -->
                  {payload.sell_chain.nodes.map((node) => (
                    <div class={`cell-badge sell-${node.sell_state.toLowerCase()}`} data-sell-code={node.code}>
                      <div class="badge-code">{node.code}</div>
                      <div class="badge-time">
                        {node.sell_state === 'SELL' ? formatTime(node.triggered_at, true, true) : node.sell_state === 'OBSERVING' ? '观察中' : '未激活'}
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- 下层：买入信号链（红） -->
              <div class="axis-row buy-axis">
                <div class="axis-label buy-label">多方力量</div>
                <div class="cells-scroll" id="buy-cells-container">
                  {(payload.cycles || payload.buy_cycles).map((cycle) => (
                    <div class={`cell-badge buy-${cycle.buy_state.toLowerCase()}`} data-buy-code={cycle.cycle_code}>
                      <div class="badge-code">{cycle.cycle_code}</div>
                      <div class="badge-time">
                        {cycle.buy_state === 'BUY' ? formatTime(cycle.buy_triggered_at, true, true) : cycle.buy_state === 'STOPPED' ? '未确认' : '未激活'}
                      </div>
                    </div>
                  ))}
                </div>
              </div>

            </div>
          </div>
        </div>
      </section>

      <!-- 下方：AI 卖出预警研判区域 -->
      <section class="ai-wrapper card" aria-labelledby="ai-title">
        <div class="ai-head">
          <span style="font-size: 1.25rem;">⚡</span>
          <h3 id="ai-title">AI 卖出预警实时研判</h3>
        </div>
        <div id="ai-alerts-container">
          {payload.sell_alerts.length > 0 ? (
            payload.sell_alerts.map((alert) => (
              <div class="ai-alert-box">
                <div class="ai-alert-meta">
                  <span>触发节点：<strong>{alert.cycle_code} ({alert.timeframe_minutes}分钟)</strong></span>
                  <span>多头极限位置：<strong>{alert.transmission_position}</strong></span>
                  <span>今日剩余交易时间：<strong>{alert.remaining_session_minutes}分钟</strong></span>
                </div>
                <p class="ai-alert-text">{alert.analysis}</p>
              </div>
            ))
          ) : (
            <div style="color: #64748b; font-size: 0.88rem; text-align: center; padding: 1.5rem;">
              当前多头传导有序，暂无空方卖出预警。
            </div>
          )}
        </div>
      </section>
    </main>
    <Footer />

    <!-- 客户端后台自动轮询刷新脚本：支持 TradingView Webhook 推送后无缝点亮 -->
    <script is:inline>
      (() => {
        const formatTime = (value, includeDate = true, includeSeconds = false) => {
          if (!value) return '—';
          const date = new Date(value);
          if (Number.isNaN(date.getTime())) return String(value);
          const options = {
            timeZone: 'Asia/Shanghai',
            hour12: false,
            hour: '2-digit',
            minute: '2-digit'
          };
          if (includeSeconds) options.second = '2-digit';
          if (includeDate) {
            options.month = '2-digit';
            options.day = '2-digit';
          }
          return date.toLocaleString('zh-CN', options);
        };

        const updateUI = (data) => {
          if (!data) return;

          // 1. 更新顶部元数据
          const pillAsOf = document.getElementById('pill-as-of');
          if (pillAsOf) pillAsOf.textContent = `数据时点：${formatTime(data.data_as_of)}`;
          
          const pillMode = document.getElementById('pill-mode');
          if (pillMode) pillMode.textContent = `模式：${data.mode === 'demo' ? '基准演示' : '实时数据'}`;

          const liveStatus = document.getElementById('live-status-pill');
          if (liveStatus) {
            liveStatus.textContent = '● 实时已同步';
            liveStatus.style.color = '#389e0d';
            liveStatus.style.borderColor = '#b7eb8f';
            liveStatus.style.background = '#f6ffed';
          }

          // 2. 更新 4 列统计条
          if (data.transmission) {
            const elCurrent = document.getElementById('stat-current-code');
            if (elCurrent) elCurrent.textContent = data.transmission.current_cycle_code || '—';
            
            const elLit = document.getElementById('stat-lit-count');
            if (elLit) {
              const litText = `连续点亮 ${data.transmission.lit_count} 格`;
              const latestTime = data.transmission.latest_triggered_at ? `(${formatTime(data.transmission.latest_triggered_at, true, true)})` : '';
              elLit.innerHTML = `${litText} <span id="stat-lit-time" style="font-style:normal; margin-left:0.25rem; color:#cf1322; font-weight:700;">${latestTime}</span>`;
            }

            const elStopped = document.getElementById('stat-stopped-code');
            if (elStopped) elStopped.textContent = data.transmission.stopped_at_code || 'G';
          }

          if (data.sell_chain) {
            const elStar = document.getElementById('stat-star-code');
            if (elStar && data.sell_chain.warning_star) {
              elStar.textContent = `${data.sell_chain.warning_star.code} (${data.sell_chain.window_type})`;
            }

            const elStarTime = document.getElementById('stat-star-time');
            if (elStarTime && data.sell_chain.warning_star) {
              elStarTime.textContent = `${formatTime(data.sell_chain.warning_star.triggered_at, true, true)} 预警点亮`;
            }
          }

          // 3. 更新多头买入节点
          const cycles = Array.isArray(data.cycles) ? data.cycles : data.buy_cycles;
          if (Array.isArray(cycles)) {
            cycles.forEach(cycle => {
              const el = document.querySelector(`[data-buy-code="${cycle.cycle_code}"]`);
              if (el) {
                el.className = `cell-badge buy-${(cycle.buy_state || 'inactive').toLowerCase()}`;
                const timeEl = el.querySelector('.badge-time');
                if (timeEl) {
                  const displayTime = cycle.buy_state === 'BUY'
                    ? formatTime(cycle.buy_triggered_at, true, true)
                    : cycle.buy_state === 'STOPPED' ? '未确认' : '未激活';
                  timeEl.textContent = displayTime;
                }
              }
            });
          }

          // 5. 安全更新 AI 分析卡片 (使用 DOM 构建防御 XSS)
          if (Array.isArray(data.sell_alerts)) {
            const container = document.getElementById('ai-alerts-container');
            if (container) {
              container.replaceChildren();
              if (data.sell_alerts.length === 0) {
                const empty = document.createElement('div');
                empty.style.cssText = 'color: #64748b; font-size: 0.88rem; text-align: center; padding: 1.5rem;';
                empty.textContent = '当前多头传导有序，暂无空方卖出预警。';
                container.appendChild(empty);
              } else {
                data.sell_alerts.forEach(alert => {
                  const box = document.createElement('div');
                  box.className = 'ai-alert-box';

                  const meta = document.createElement('div');
                  meta.className = 'ai-alert-meta';

                  const span1 = document.createElement('span');
                  span1.textContent = '触发节点：';
                  const s1 = document.createElement('strong');
                  s1.textContent = `${alert.cycle_code} (${alert.timeframe_minutes}分钟)`;
                  span1.appendChild(s1);

                  const span2 = document.createElement('span');
                  span2.textContent = '多头极限位置：';
                  const s2 = document.createElement('strong');
                  s2.textContent = alert.transmission_position || '—';
                  span2.appendChild(s2);

                  const span3 = document.createElement('span');
                  span3.textContent = '今日剩余交易时间：';
                  const s3 = document.createElement('strong');
                  s3.textContent = `${alert.remaining_session_minutes}分钟`;
                  span3.appendChild(s3);

                  meta.append(span1, span2, span3);

                  const p = document.createElement('p');
                  p.className = 'ai-alert-text';
                  p.textContent = alert.analysis;

                  box.append(meta, p);
                  container.appendChild(box);
                });
              }
            }
          }
        };

        const updateQuoteUI = (quote) => {
          if (!quote || quote.status !== 'ok' || typeof quote.price !== 'number') return;
          const badge = document.getElementById('stock-quote-badge');
          const pill = document.getElementById('pill-stock-quote');
          
          const isUp = quote.change_percent > 0;
          const isDown = quote.change_percent < 0;
          const color = isUp ? '#cf1322' : isDown ? '#389e0d' : '#475569';
          const bg = isUp ? '#fff1f0' : isDown ? '#f6ffed' : '#f1f5f9';
          const border = isUp ? '#ffa39e' : isDown ? '#b7eb8f' : '#cbd5e1';

          const sign = isUp ? '+' : '';
          const text = `¥${quote.price.toFixed(2)} ${sign}${quote.change_percent.toFixed(2)}%`;

          if (badge) {
            badge.textContent = text;
            badge.style.color = color;
          }

          if (pill) {
            pill.textContent = `实时行情：${text}`;
            pill.style.color = color;
            pill.style.background = bg;
            pill.style.borderColor = border;
          }
        };

        const fetchStockQuote = async () => {
          if (document.hidden) return;
          try {
            const res = await fetch('/api/public/v1/quote?symbol=600021&exchange=SSE');
            if (!res.ok) return;
            const data = await res.json();
            updateQuoteUI(data);
          } catch (e) {
            // 静默失败
          }
        };

        let inFlight = false;
        const fetchLatestSignals = async () => {
          if (inFlight || document.hidden) return;
          inFlight = true;
          try {
            const res = await fetch('/api/public/v1/rolling-signals');
            if (!res.ok) return;
            const data = await res.json();
            updateUI(data);
          } catch (e) {
            // 静默失败，保持 DOM 现状
          } finally {
            inFlight = false;
          }
        };

        // 模式切换与记忆
        const tableWrapper = document.getElementById('table-outer-wrapper');
        const toggleBtn = document.getElementById('toggle-view-btn');
        let isCompact = localStorage.getItem('rolling_view_mode') !== 'full';

        const applyViewMode = () => {
          if (!tableWrapper || !toggleBtn) return;
          if (isCompact) {
            tableWrapper.classList.add('compact-mode');
            toggleBtn.textContent = '⚡ 模式：精简按需点亮';
          } else {
            tableWrapper.classList.remove('compact-mode');
            toggleBtn.textContent = '📊 模式：显示完整 34 轨道';
          }
        };

        if (toggleBtn) {
          toggleBtn.addEventListener('click', () => {
            isCompact = !isCompact;
            localStorage.setItem('rolling_view_mode', isCompact ? 'compact' : 'full');
            applyViewMode();
          });
        }
        applyViewMode();

        setTimeout(function() {
          fetchLatestSignals();
          fetchStockQuote();
        }, 500);

        setInterval(fetchLatestSignals, 30000);
        setInterval(fetchStockQuote, 15000);
      })();

    </script>
  </body>
</html>
