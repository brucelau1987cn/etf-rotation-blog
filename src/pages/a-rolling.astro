---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import AStockSubnav from '../components/AStockSubnav.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type Cycle = {
  cycle_code: string;
  segment: string;
  timeframe_minutes: number;
  timeframe_label: string;
  buy_state: 'BUY' | 'INACTIVE' | 'UNKNOWN';
  buy_triggered_at: string | null;
  source: string;
};
type SellAlert = {
  alert_id: string;
  cycle_code: string;
  timeframe_minutes: number;
  triggered_at: string;
  transmission_position: string | null;
  remaining_session_minutes: number;
  analysis_state: 'pending' | 'ready' | 'unavailable';
  analysis: string;
};
type Payload = {
  schema_version: 'a-rolling-energy-v2';
  mode: 'demo' | 'live';
  generated_at: string;
  data_as_of: string;
  freshness: 'fresh' | 'stale' | 'unknown';
  stale_after_seconds: number;
  notice: string;
  delivery: { state: 'live' | 'lkg'; reason: string | null };
  instrument: { instrument_name: string; exchange: string; symbol: string };
  transmission: { state: string; basis: 'latest_buy_by_cycle' | 'single_run'; current_cycle_code: string | null; started_at: string | null; lit_count: number; continuous_confirmed: boolean };
  cycles: Cycle[];
  sell_alerts: SellAlert[];
};

const payload = JSON.parse(readFileSync(join(process.cwd(), 'public/data/a-rolling-signals.json'), 'utf-8')) as Payload;
const segments = [
  { key: '预备', title: '预备观察', subtitle: '105分钟启动窗口' },
  { key: 'A', title: 'A段', subtitle: '2小时 · 每15分钟' },
  { key: 'B', title: 'B段', subtitle: '3小时 · 每15分钟' },
  { key: 'C', title: 'C段', subtitle: '4小时 · 每10分钟' },
  { key: 'D', title: 'D段', subtitle: '5小时 · 每10分钟' },
  { key: 'E', title: 'E段', subtitle: '6小时 · 每10分钟' },
  { key: 'F', title: 'F段', subtitle: '7小时 · 每10分钟' },
  { key: 'G', title: 'G段', subtitle: '8小时 · 日周期' },
];
const formatTime = (value: string | null, includeYear = false) => {
  if (!value) return '尚未启动';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleString('zh-CN', {
    timeZone: 'Asia/Shanghai', hour12: false,
    ...(includeYear ? { year: 'numeric' as const } : {}),
    month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit',
  });
};
const transmissionLabel = payload.transmission.basis === 'single_run'
  ? payload.transmission.state === 'complete' ? '单轮传导完成' : payload.transmission.state === 'transmitting' ? '正在连续传导' : '等待传导启动'
  : '最近BUY覆盖至全周期';
const statusCopy = payload.transmission.continuous_confirmed
  ? '同一轮触发顺序已经上游确认'
  : '跨日期最近信号覆盖，尚未确认为同一轮连续传导';
const pageTitle = `A股滚动策略｜买方能量传导 | ${SITE_TITLE}`;
const pageDescription = 'A股滚动策略买方能量传导终端，以105分钟预备窗口和A至G共34个周期观察点展示买方力量向长周期延续的位置。';
---

<!doctype html>
<html lang="zh-CN">
  <head><BaseHead title={pageTitle} description={pageDescription} /></head>
  <body>
    <Header />
    <main id="main-content" tabindex="-1">
      <AStockSubnav active="rolling" />

      <section class="energy-hero" aria-labelledby="energy-title">
        <div class="hero-main">
          <div class="eyebrow"><span class="pulse" aria-hidden="true"></span><span>A股 · 买方能量传导</span><b data-field="environment">{payload.mode === 'demo' ? '演示快照' : payload.delivery.state === 'live' ? '实时数据' : '有效快照'}</b></div>
          <h1 id="energy-title">滚动策略</h1>
          <div class="instrument"><strong data-field="instrument-name">{payload.instrument.instrument_name}</strong><code data-field="symbol">{payload.instrument.symbol}</code><span data-field="exchange">{payload.instrument.exchange}</span></div>
        </div>
        <div class="hero-status">
          <span>当前能量位置</span>
          <strong data-field="current-position">{payload.transmission.current_cycle_code || '等待启动'}</strong>
          <small data-field="transmission-label">{transmissionLabel}</small>
        </div>
      </section>

      <section class="status-strip" aria-label="当前能量状态">
        <article><span>本轮/记录起点</span><strong data-field="started-at">{formatTime(payload.transmission.started_at, true)}</strong></article>
        <article><span>已点亮</span><strong class="red" data-field="lit-count">{payload.transmission.lit_count}<i>/34</i></strong></article>
        <article><span>最新周期</span><strong data-field="latest-cycle">{payload.transmission.current_cycle_code || '—'}</strong></article>
        <article><span>传导状态</span><strong data-field="transmission-state">{payload.transmission.state === 'complete' ? '全周期覆盖' : payload.transmission.state === 'transmitting' ? '继续传导' : '观察中'}</strong></article>
        <article><span>数据时点</span><strong data-field="data-as-of">{formatTime(payload.data_as_of, true)}</strong></article>
      </section>

      <aside class:list={['basis-notice', payload.transmission.continuous_confirmed && 'confirmed']}>
        <strong data-field="basis-title">{payload.transmission.continuous_confirmed ? '连续传导已确认' : '演示口径说明'}</strong>
        <p data-field="basis-copy">{statusCopy}</p>
      </aside>

      <section class="transmission-section" aria-labelledby="transmission-title">
        <header class="section-head">
          <div><span>BUY ENERGY PATH</span><h2 id="transmission-title">34周期能量传导图</h2></div>
          <p>红色表示该周期存在BUY记录；中性格表示尚未激活</p>
        </header>
        <div class="energy-board" data-energy-board>
          {segments.map((segment) => {
            const rows = payload.cycles.filter((cycle) => cycle.segment === segment.key);
            return (
              <section class="segment" data-segment={segment.key} aria-labelledby={`segment-${segment.key}`}>
                <header><div><span>{segment.subtitle}</span><h3 id={`segment-${segment.key}`}>{segment.title}</h3>{segment.key === 'D' && <small>后两格为更早历史记录</small>}</div><b data-segment-count>{rows.filter((row) => row.buy_state === 'BUY').length}/{rows.length}</b></header>
                <div class="cycle-grid">
                  {rows.map((cycle) => (
                    <article class:list={['energy-cell', cycle.buy_state === 'BUY' && 'active', cycle.buy_state === 'UNKNOWN' && 'unknown', cycle.cycle_code === payload.transmission.current_cycle_code && 'current']} data-cycle-code={cycle.cycle_code}>
                      <div class="cell-code"><strong>{cycle.cycle_code}</strong><span>{cycle.timeframe_minutes}m</span></div>
                      <p>{cycle.timeframe_label}</p>
                      <div class="cell-state"><i aria-hidden="true"></i><b data-cycle-state>{cycle.buy_state === 'BUY' ? 'BUY' : cycle.buy_state === 'UNKNOWN' ? '待确认' : '未激活'}</b></div>
                      <time data-cycle-time datetime={cycle.buy_triggered_at || undefined}>{cycle.buy_triggered_at ? formatTime(cycle.buy_triggered_at) : '等待信号'}</time>
                    </article>
                  ))}
                </div>
              </section>
            );
          })}
        </div>
      </section>

      <section class="sell-section" aria-labelledby="sell-title">
        <header class="section-head sell-head">
          <div><span>SELL SIGNAL ANALYSIS</span><h2 id="sell-title">AI卖出信号提醒</h2></div>
          <p>卖出信号独立分析，不改变原始信号与买方能量格</p>
        </header>
        <div class="sell-list" data-sell-list>
          {payload.sell_alerts.length ? payload.sell_alerts.map((alert) => (
            <article class="sell-alert">
              <header><div><span>AI信号提醒</span><h3>{payload.instrument.instrument_name}</h3></div><time>{formatTime(alert.triggered_at, true)}</time></header>
              <dl><div><dt>卖出周期</dt><dd>{alert.cycle_code} · {alert.timeframe_minutes}分钟</dd></div><div><dt>能量位置</dt><dd>{alert.transmission_position || '未进入传导'}</dd></div><div><dt>剩余交易时间</dt><dd>{alert.remaining_session_minutes}分钟</dd></div></dl>
              <p>{alert.analysis_state === 'ready' ? alert.analysis : 'AI分析尚未生成，保留原始卖出信号事实。'}</p>
            </article>
          )) : (
            <div class="sell-empty" data-sell-empty><div aria-hidden="true">!</div><strong>当前没有卖出提醒</strong><p>尚未收到符合 v2 合同的SELL事件。接入34周期Webhook后，提醒将按触发时间倒序显示。</p></div>
          )}
        </div>
      </section>

      <aside class="data-boundary" aria-label="数据边界">
        <div aria-hidden="true">i</div>
        <section><strong data-field="boundary-title">{payload.mode === 'demo' ? '演示隔离模式' : payload.delivery.state === 'live' ? '实时数据运行' : '最后有效快照'}</strong><p><span data-field="notice">{payload.notice}</span> 页面不生成仓位或交易指令。</p><small data-refresh-state role="status" aria-live="polite">页面已载入有效快照，正在后台检查更新</small></section>
        <details><summary>查看数据边界</summary><p>BUY格只表达对应周期的信号事实。只有上游提供同一run_id并通过连续性校验时，才标记为单轮连续传导。AI提醒只承担分析提示，不改变TradingBox原始信号。</p></details>
      </aside>
    </main>
    <Footer />

    <script is:inline>
      (() => {
        const CODES = ['PRE','A1','A2','A3','A4','B1','B2','B3','B4','C1','C2','C3','C4','C5','C6','D1','D2','D3','D4','D5','D6','E1','E2','E3','E4','E5','E6','F1','F2','F3','F4','F5','F6','G'];
        const field = name => document.querySelector(`[data-field="${name}"]`);
        const setText = (node, value) => { if (node) node.textContent = value; };
        const formatTime = (value, includeYear = false) => {
          if (!value) return '尚未启动';
          const date = new Date(value);
          if (Number.isNaN(date.getTime())) return String(value);
          return date.toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai', hour12: false, ...(includeYear ? { year: 'numeric' } : {}), month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' });
        };
        let inFlight = false;
        const escapeHtml = value => String(value ?? '').replace(/[&<>"']/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[char]);
        const renderAlerts = (alerts, instrument) => {
          const list = document.querySelector('[data-sell-list]');
          if (!list) return;
          if (!alerts.length) {
            list.innerHTML = '<div class="sell-empty" data-sell-empty><div aria-hidden="true">!</div><strong>当前没有卖出提醒</strong><p>尚未收到符合 v2 合同的SELL事件。接入34周期Webhook后，提醒将按触发时间倒序显示。</p></div>';
            return;
          }
          list.innerHTML = alerts.map(alert => `<article class="sell-alert"><header><div><span>AI信号提醒</span><h3>${escapeHtml(instrument.instrument_name)}</h3></div><time>${escapeHtml(formatTime(alert.triggered_at, true))}</time></header><dl><div><dt>卖出周期</dt><dd>${escapeHtml(alert.cycle_code)} · ${escapeHtml(alert.timeframe_minutes)}分钟</dd></div><div><dt>能量位置</dt><dd>${escapeHtml(alert.transmission_position || '未进入传导')}</dd></div><div><dt>剩余交易时间</dt><dd>${escapeHtml(alert.remaining_session_minutes)}分钟</dd></div></dl><p>${escapeHtml(alert.analysis_state === 'ready' ? alert.analysis : 'AI分析尚未生成，保留原始卖出信号事实。')}</p></article>`).join('');
        };
        const render = payload => {
          if (!payload || payload.schema_version !== 'a-rolling-energy-v2' || !Array.isArray(payload.cycles) || payload.cycles.length !== 34) throw new Error('invalid payload');
          if (payload.cycles.some((cycle, index) => cycle.cycle_code !== CODES[index])) throw new Error('invalid sequence');
          setText(field('environment'), payload.mode === 'demo' ? '演示快照' : payload.delivery.state === 'live' ? '实时数据' : '有效快照');
          setText(field('instrument-name'), payload.instrument.instrument_name); setText(field('symbol'), payload.instrument.symbol); setText(field('exchange'), payload.instrument.exchange);
          setText(field('current-position'), payload.transmission.current_cycle_code || '等待启动');
          setText(field('transmission-label'), payload.transmission.basis === 'single_run' ? payload.transmission.state === 'complete' ? '单轮传导完成' : '正在连续传导' : '最近BUY覆盖至全周期');
          setText(field('started-at'), formatTime(payload.transmission.started_at, true)); setText(field('lit-count'), `${payload.transmission.lit_count}/34`); setText(field('latest-cycle'), payload.transmission.current_cycle_code || '—');
          setText(field('transmission-state'), payload.transmission.state === 'complete' ? '全周期覆盖' : payload.transmission.state === 'transmitting' ? '继续传导' : '观察中'); setText(field('data-as-of'), formatTime(payload.data_as_of, true));
          setText(field('basis-title'), payload.transmission.continuous_confirmed ? '连续传导已确认' : '演示口径说明'); setText(field('basis-copy'), payload.transmission.continuous_confirmed ? '同一轮触发顺序已经上游确认' : '跨日期最近信号覆盖，尚未确认为同一轮连续传导');
          for (const cycle of payload.cycles) {
            const cell = document.querySelector(`[data-cycle-code="${cycle.cycle_code}"]`); if (!cell) continue;
            cell.classList.toggle('active', cycle.buy_state === 'BUY'); cell.classList.toggle('unknown', cycle.buy_state === 'UNKNOWN'); cell.classList.toggle('current', cycle.cycle_code === payload.transmission.current_cycle_code);
            setText(cell.querySelector('[data-cycle-state]'), cycle.buy_state === 'BUY' ? 'BUY' : cycle.buy_state === 'UNKNOWN' ? '待确认' : '未激活'); setText(cell.querySelector('[data-cycle-time]'), cycle.buy_triggered_at ? formatTime(cycle.buy_triggered_at) : '等待信号');
          }
          for (const segment of ['预备','A','B','C','D','E','F','G']) { const box = document.querySelector(`[data-segment="${segment}"]`); if (box) setText(box.querySelector('[data-segment-count]'), `${payload.cycles.filter(c => c.segment === segment && c.buy_state === 'BUY').length}/${payload.cycles.filter(c => c.segment === segment).length}`); }
          renderAlerts(payload.sell_alerts || [], payload.instrument);
          setText(field('boundary-title'), payload.mode === 'demo' ? '演示隔离模式' : payload.delivery.state === 'live' ? '实时数据运行' : '最后有效快照'); setText(field('notice'), payload.notice);
          setText(document.querySelector('[data-refresh-state]'), payload.delivery.state === 'live' ? `实时数据已更新 · ${formatTime(payload.data_as_of)}` : `显示最后有效快照 · ${payload.delivery.reason || '实时源暂不可用'}`);
        };
        const refresh = async () => { if (inFlight || document.hidden) return; inFlight = true; try { const response = await fetch('/api/public/v1/rolling-signals', { headers: { accept: 'application/json' } }); if (!response.ok) throw new Error(); render(await response.json()); } catch { setText(document.querySelector('[data-refresh-state]'), '实时检查失败，继续保留当前有效快照'); } finally { inFlight = false; } };
        refresh(); window.setInterval(refresh, 60000);
      })();
    </script>
  </body>
</html>

<style>
  main{width:min(1180px,calc(100% - 1.5rem));padding:1rem 0 3rem}.energy-hero{display:grid;grid-template-columns:minmax(0,1fr) 280px;border:1px solid #dce2e8;border-radius:8px 8px 0 0;background:#fff;box-shadow:0 10px 32px rgba(28,38,48,.06)}.hero-main{padding:1rem 1.15rem}.eyebrow{display:flex;align-items:center;flex-wrap:wrap;gap:.45rem;color:#59636e;font-size:.7rem;font-weight:850}.eyebrow b{padding:.14rem .4rem;border:1px solid #e8c57a;border-radius:4px;background:#fff8e9;color:#8d5b00;font-size:.65rem}.pulse{width:.48rem;height:.48rem;border-radius:50%;background:#d63d2e;box-shadow:0 0 0 4px rgba(214,61,46,.12)}h1{margin:.16rem 0 .1rem;font-size:2rem;letter-spacing:0}.instrument{display:flex;align-items:center;gap:.45rem;color:#6b747d;font-size:.76rem}.instrument strong{font-size:.88rem}.instrument code{padding:.08rem .3rem;background:#f1f3f5}.hero-status{display:grid;align-content:center;padding:.9rem 1.1rem;border-left:1px solid #e2e7eb;background:#f8fafb}.hero-status span,.status-strip span{color:#747d86;font-size:.67rem;font-weight:800}.hero-status strong{color:#b52e23;font-size:2rem;line-height:1.1}.hero-status small{margin-top:.2rem;color:#69737d;font-size:.68rem}.status-strip{display:grid;grid-template-columns:1.35fr repeat(4,1fr);border:1px solid #dce2e8;border-top:0;border-radius:0 0 8px 8px;background:#fff}.status-strip article{min-width:0;padding:.62rem .85rem;border-right:1px solid #e5e9ed}.status-strip article:last-child{border-right:0}.status-strip strong{display:block;margin-top:.15rem;overflow-wrap:anywhere;font-size:.8rem}.status-strip .red{color:#b52e23;font-size:1.1rem}.status-strip .red i{margin-left:.15rem;color:#7a838b;font-size:.68rem;font-style:normal}.basis-notice{display:flex;align-items:center;gap:.8rem;margin-top:.7rem;padding:.65rem .8rem;border-left:4px solid #b87900;background:#fff8e8;color:#6f541f}.basis-notice.confirmed{border-left-color:#159447;background:#eff9f2;color:#116d36}.basis-notice strong{flex:0 0 auto;font-size:.74rem}.basis-notice p{margin:0;font-size:.7rem}.section-head{display:flex;align-items:flex-end;justify-content:space-between;gap:1rem;margin:1.45rem 0 .65rem}.section-head span{color:#7b838b;font-size:.64rem;font-weight:900}.section-head h2{margin:.08rem 0 0;font-size:1.25rem;letter-spacing:0}.section-head p{margin:0;color:#737c85;font-size:.72rem}.energy-board{display:grid;gap:.7rem}.segment{overflow:hidden;border:1px solid #dce2e8;border-radius:7px;background:#fff}.segment>header{display:flex;align-items:center;justify-content:space-between;padding:.55rem .72rem;border-bottom:1px solid #e5e9ed;background:#f7f9fa}.segment>header span{color:#7b838b;font-size:.62rem}.segment h3{margin:.04rem 0 0;font-size:.83rem;letter-spacing:0}.segment>header small{display:block;margin-top:.08rem;color:#9a6e1c;font-size:.6rem}.segment>header b{color:#a6291f;font-size:.72rem}.cycle-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1px;background:#e6eaed}.segment[data-segment="预备"] .cycle-grid,.segment[data-segment="G"] .cycle-grid{grid-template-columns:minmax(180px,1fr)}.energy-cell{position:relative;min-width:0;min-height:116px;padding:.62rem .68rem;background:#fff}.energy-cell.active{background:#fff3f1}.energy-cell.active::before{content:'';position:absolute;inset:0 auto 0 0;width:4px;background:#d63d2e}.energy-cell.current{z-index:1;box-shadow:inset 0 0 0 2px #24364b}.energy-cell.current::after{content:'当前';position:absolute;top:.42rem;right:.52rem;padding:.08rem .25rem;border-radius:3px;background:#24364b;color:#fff;font-size:.55rem;font-weight:900}.cell-code{display:flex;align-items:flex-start;justify-content:space-between;gap:.4rem}.cell-code strong{font-size:1rem}.cell-code span{color:#7b838b;font:700 .63rem ui-monospace,SFMono-Regular,Menlo,monospace}.energy-cell p{margin:.12rem 0 .5rem;color:#5d6872;font-size:.66rem}.cell-state{display:flex;align-items:center;gap:.3rem}.cell-state i{width:.48rem;height:.48rem;border-radius:50%;background:#aab2ba}.cel