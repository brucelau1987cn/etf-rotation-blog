---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import AStockSubnav from '../components/AStockSubnav.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MarketClock from '../components/MarketClock.astro';
import { SITE_TITLE } from '../consts';

type Direction = 'BUY' | 'SELL' | 'UNKNOWN' | 'CONFLICT';
type Signal = {
  instrument_name: string;
  exchange: 'SSE' | 'SZSE';
  symbol: string;
  timeframe: string;
  direction: Direction;
  latest_signal_at: string | null;
  source: string;
  duration: string;
  phase_code: string;
  phase_label: string;
  alert_configured_count: number;
  live_verified_count: number;
};
type Payload = {
  schema_version: string;
  mode: 'demo' | 'live';
  generated_at: string;
  notice: string;
  signals: Signal[];
};
type CycleGroup = {
  key: 'short' | 'medium' | 'long';
  label: string;
  note: string;
  timeframes: string[];
};

const payload = JSON.parse(
  readFileSync(join(process.cwd(), 'public/data/a-rolling-signals-demo.json'), 'utf-8'),
) as Payload;
const timeframeOrder = ['10m', '30m', '1h', '2h', '3h', '4h', '5h', '6h', '1D'];
const timeframeLabels: Record<string, string> = {
  '10m': '10分钟', '30m': '30分钟', '1h': '1小时', '2h': '2小时', '3h': '3小时',
  '4h': '4小时', '5h': '5小时', '6h': '6小时', '1D': '日线',
};
const timeframeWeights: Record<string, number> = {
  '10m': 1, '30m': 1, '1h': 2, '2h': 2, '3h': 3, '4h': 3, '5h': 4, '6h': 5, '1D': 7,
};
const cycleGroups: CycleGroup[] = [
  { key: 'short', label: '短周期', note: '执行节奏', timeframes: ['10m', '30m', '1h'] },
  { key: 'medium', label: '中周期', note: '趋势确认', timeframes: ['2h', '3h', '4h', '5h'] },
  { key: 'long', label: '长周期', note: '方向约束', timeframes: ['6h', '1D'] },
];
const signals = [...payload.signals].sort((a, b) => timeframeOrder.indexOf(a.timeframe) - timeframeOrder.indexOf(b.timeframe));
const primary = signals[0];
const generatedAtMs = Date.parse(payload.generated_at);
const buyCount = signals.filter((item) => item.direction === 'BUY').length;
const sellCount = signals.filter((item) => item.direction === 'SELL').length;
const unresolvedCount = signals.filter((item) => ['UNKNOWN', 'CONFLICT'].includes(item.direction)).length;
const totalWeight = signals.reduce((sum, item) => sum + (timeframeWeights[item.timeframe] || 1), 0);
const directionScore = signals.reduce((sum, item) => {
  const sign = item.direction === 'BUY' ? 1 : item.direction === 'SELL' ? -1 : 0;
  return sum + sign * (timeframeWeights[item.timeframe] || 1);
}, 0);
const weightedPct = totalWeight ? Math.round((directionScore / totalWeight) * 100) : 0;
const weightedTone = weightedPct >= 20 ? 'buy' : weightedPct <= -20 ? 'sell' : 'mixed';
const weightedLabel = weightedPct >= 20 ? '偏多' : weightedPct <= -20 ? '偏空' : '多空拉锯';
const latestSignal = [...signals]
  .filter((item) => item.latest_signal_at && Number.isFinite(Date.parse(item.latest_signal_at)))
  .sort((a, b) => Date.parse(b.latest_signal_at!) - Date.parse(a.latest_signal_at!))[0];
const latestWindowMs = 6 * 60 * 60 * 1000;
const latestCutoff = Number.isFinite(generatedAtMs) ? generatedAtMs - latestWindowMs : Number.NEGATIVE_INFINITY;
const latestTimeframes = signals
  .filter((item) => item.latest_signal_at && Date.parse(item.latest_signal_at) >= latestCutoff)
  .map((item) => item.timeframe);

const rowsFor = (group: CycleGroup) => signals.filter((item) => group.timeframes.includes(item.timeframe));
const groupState = (rows: Signal[]) => {
  const buys = rows.filter((item) => item.direction === 'BUY').length;
  const sells = rows.filter((item) => item.direction === 'SELL').length;
  const unresolved = rows.length - buys - sells;
  if (unresolved > 0) return { label: '待确认', tone: 'mixed', summary: `${unresolved}个信号未决` };
  if (buys === rows.length) return { label: '全部偏多', tone: 'buy', summary: `${buys}/${rows.length} 买入` };
  if (sells === rows.length) return { label: '全部偏空', tone: 'sell', summary: `${sells}/${rows.length} 卖出` };
  if (buys > sells) return { label: '偏多', tone: 'buy', summary: `${buys}买 · ${sells}卖` };
  if (sells > buys) return { label: '偏空', tone: 'sell', summary: `${buys}买 · ${sells}卖` };
  return { label: '方向分化', tone: 'mixed', summary: `${buys}买 · ${sells}卖` };
};
const longState = groupState(rowsFor(cycleGroups[2]));
const formatTime = (value: string | null, includeYear = false) => {
  if (!value) return '等待信号';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return value;
  return date.toLocaleString('zh-CN', {
    timeZone: 'Asia/Shanghai', hour12: false,
    ...(includeYear ? { year: 'numeric' as const } : {}),
    month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit',
  });
};
const freshness = (value: string | null) => {
  if (!value || !Number.isFinite(generatedAtMs)) return '时间未知';
  const signalMs = Date.parse(value);
  if (!Number.isFinite(signalMs)) return '时间未知';
  const hours = Math.max(0, Math.round((generatedAtMs - signalMs) / 36e5));
  if (hours === 0) return '本小时变化';
  if (hours < 24) return `${hours}小时前变化`;
  const days = Math.round(hours / 24);
  return `${days}天前变化`;
};
const directionLabel: Record<Direction, string> = { BUY: '买入', SELL: '卖出', UNKNOWN: '等待', CONFLICT: '冲突' };
const directionClass: Record<Direction, string> = { BUY: 'buy', SELL: 'sell', UNKNOWN: 'unknown', CONFLICT: 'conflict' };
const filterCounts = { all: signals.length, buy: buyCount, sell: sellCount, latest: latestTimeframes.length };
const pageTitle = `A股滚动策略｜九周期决策终端 | ${SITE_TITLE}`;
const pageDescription = 'A股滚动策略九周期决策终端，展示短中长周期方向、加权倾向、最近变化、持续时间与数据状态。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
  </head>
  <body>
    <Header />
    <main id="main-content" tabindex="-1">
      <AStockSubnav active="rolling" />

      <section class="strategy-terminal" aria-labelledby="rolling-title">
        <div class="terminal-top">
          <div class="title-block">
            <div class="context-line">
              <span class="live-dot" aria-hidden="true"></span>
              <span>A股 · 九周期监控</span>
              <span class="environment">{payload.mode === 'demo' ? '演示数据' : '实时数据'}</span>
            </div>
            <h1 id="rolling-title">滚动策略</h1>
            <div class="instrument"><strong>{primary?.instrument_name || '暂无标的'}</strong><code>{primary?.symbol || '—'}</code><span>{primary?.exchange || '—'}</span></div>
          </div>
          <div class="clock-slot">
            {payload.mode === 'demo' ? (
              <div class="snapshot-panel" role="status">
                <span>历史演示快照</span>
                <strong>{formatTime(payload.generated_at, true)}</strong>
                <small>脱敏数据 · 信号新鲜度均以此快照时间计算</small>
              </div>
            ) : <MarketClock market="a-share" />}
          </div>
        </div>

        <div class="decision-band">
          <article class="decision-cell primary-decision">
            <span>策略阶段</span>
            <strong>{primary?.phase_label || '等待状态数据'}</strong>
            <small>阶段由公开数据字段直接呈现</small>
          </article>
          <article class:list={['decision-cell', 'weighted', weightedTone]}>
            <span>周期加权倾向</span>
            <strong>{weightedLabel} <b>{weightedPct > 0 ? '+' : ''}{weightedPct}</b></strong>
            <small>高周期权重更高 · 范围 -100 至 +100</small>
          </article>
          <article class:list={['decision-cell', longState.tone]}>
            <span>高周期约束</span>
            <strong>{longState.label}</strong>
            <small>6小时 / 日线 · {longState.summary}</small>
          </article>
          <article class="decision-cell latest">
            <span>最近变化</span>
            <strong>{latestSignal ? `${timeframeLabels[latestSignal.timeframe]} ${directionLabel[latestSignal.direction]}` : '等待信号'}</strong>
            <small>{formatTime(latestSignal?.latest_signal_at || null)} · {freshness(latestSignal?.latest_signal_at || null)}</small>
          </article>
        </div>

        <div class="terminal-meta">
          <div><span>数据时间</span><strong>{formatTime(payload.generated_at, true)}</strong></div>
          <div><span>周期覆盖</span><strong>{signals.length}/9</strong></div>
          <div><span>方向计数</span><strong class="buy-text">{buyCount} 买</strong><i>·</i><strong class="sell-text">{sellCount} 卖</strong></div>
          <div><span>待确认</span><strong>{unresolvedCount}</strong></div>
        </div>
      </section>

      <section class="cycle-board" aria-labelledby="cycle-title">
        <div class="section-heading">
          <div><span>结构判断</span><h2 id="cycle-title">短、中、长周期</h2></div>
          <p>长周期负责约束，短周期负责执行节奏</p>
        </div>
        <div class="cycle-grid">
          {cycleGroups.map((group) => {
            const rows = rowsFor(group);
            const state = groupState(rows);
            return (
              <article class:list={['cycle-group', state.tone]}>
                <header><div><span>{group.note}</span><h3>{group.label}</h3></div><strong>{state.label}</strong></header>
                <div class="cycle-rail" aria-label={`${group.label}${state.summary}`}>
                  {rows.map((signal) => (
                    <div class:list={['rail-node', directionClass[signal.direction]]} title={`${timeframeLabels[signal.timeframe]} ${directionLabel[signal.direction]}`}>
                      <span>{timeframeLabels[signal.timeframe]}</span>
                      <b aria-hidden="true"></b>
                    </div>
                  ))}
                </div>
                <footer><span>{state.summary}</span><small>{group.timeframes.map((item) => timeframeLabels[item]).join(' · ')}</small></footer>
              </article>
            );
          })}
        </div>
      </section>

      <section class="signal-workbench" aria-labelledby="matrix-title">
        <div class="workbench-head">
          <div><span>信号工作台</span><h2 id="matrix-title">九周期矩阵</h2></div>
          <div class="filter-control" role="group" aria-label="筛选九周期信号">
            <button type="button" class="active" data-filter="all" aria-pressed="true">全部 <b>{filterCounts.all}</b></button>
            <button type="button" data-filter="buy" aria-pressed="false">买入 <b>{filterCounts.buy}</b></button>
            <button type="button" data-filter="sell" aria-pressed="false">卖出 <b>{filterCounts.sell}</b></button>
            <button type="button" data-filter="latest" aria-pressed="false">快照6h <b>{filterCounts.latest}</b></button>
          </div>
        </div>

        <div class="matrix-legend" aria-label="方向图例">
          <span><i class="buy"></i>买入</span><span><i class="sell"></i>卖出</span><span><i class="unknown"></i>等待</span>
          <em id="filter-status" role="status" aria-live="polite">显示全部 {signals.length} 个周期</em>
        </div>

        <div class="signal-list" data-signal-list>
          {cycleGroups.map((group) => (
            <section class="signal-group" data-signal-group aria-labelledby={`group-${group.key}`}>
              <div class="group-label"><span>{group.note}</span><strong id={`group-${group.key}`}>{group.label}</strong></div>
              <div class="group-rows">
                {rowsFor(group).map((signal) => (
                  <details
                    class:list={['signal-row', directionClass[signal.direction]]}
                    data-direction={directionClass[signal.direction]}
                    data-latest={latestTimeframes.includes(signal.timeframe) ? 'true' : 'false'}
                  >
                    <summary>
                      <span class="timeframe">{timeframeLabels[signal.timeframe] || signal.timeframe}<small>权重 {timeframeWeights[signal.timeframe] || 1}</small></span>
                      <span class:list={['direction', directionClass[signal.direction]]}><i aria-hidden="true"></i>{directionLabel[signal.direction]}</span>
                      <span class="signal-time"><small>最近变化</small><strong>{formatTime(signal.latest_signal_at)}</strong><em>{freshness(signal.latest_signal_at)}</em></span>
                      <span class="row-state">{latestTimeframes.includes(signal.timeframe) && <b>6h内</b>}<i aria-hidden="true">⌄</i></span>
                    </summary>
                    <div class="signal-facts">
                      <dl><div><dt>策略阶段</dt><dd>{signal.phase_label}</dd></div><div><dt>数据状态</dt><dd>{payload.mode === 'demo' ? '脱敏演示' : '实时接入'}</dd></div><div><dt>预警配置</dt><dd>{signal.alert_configured_count}</dd></div><div><dt>实时核验</dt><dd>{signal.live_verified_count}</dd></div></dl>
                    </div>
                  </details>
                ))}
              </div>
            </section>
          ))}
          <div class="empty-filter" hidden>当前筛选没有匹配周期</div>
        </div>
      </section>

      <aside class="data-boundary" aria-label="数据边界">
        <div class="boundary-icon" aria-hidden="true">i</div>
        <div><strong>{payload.mode === 'demo' ? '演示隔离模式' : '数据运行状态'}</strong><p>{payload.notice} 当前页面呈现方向监控与周期结构，不生成仓位、价格或交易指令。</p></div>
        <details><summary>查看数据边界</summary><p>页面读取公开静态快照；“周期加权倾向”仅用于避免九个周期机械等权，高周期拥有更高展示权重。它属于结构观察指标。</p></details>
      </aside>
    </main>
    <Footer />

    <script is:inline>
      (() => {
        const buttons = [...document.querySelectorAll('[data-filter]')];
        const rows = [...document.querySelectorAll('.signal-row')];
        const groups = [...document.querySelectorAll('[data-signal-group]')];
        const status = document.getElementById('filter-status');
        const empty = document.querySelector('.empty-filter');
        const labels = { all: '全部', buy: '买入', sell: '卖出', latest: '快照前6小时' };

        const applyFilter = (filter) => {
          let visible = 0;
          for (const row of rows) {
            const matches = filter === 'all' || row.dataset.direction === filter || (filter === 'latest' && row.dataset.latest === 'true');
            row.hidden = !matches;
            if (matches) visible += 1;
          }
          for (const group of groups) {
            group.hidden = !group.querySelector('.signal-row:not([hidden])');
          }
          for (const button of buttons) {
            const active = button.dataset.filter === filter;
            button.classList.toggle('active', active);
            button.setAttribute('aria-pressed', String(active));
          }
          if (status) status.textContent = `显示${labels[filter]} ${visible} 个周期`;
          if (empty) empty.hidden = visible > 0;
        };

        for (const button of buttons) button.addEventListener('click', () => applyFilter(button.dataset.filter));
      })();
    </script>
  </body>
</html>

<style>
  main { width: min(1180px, calc(100% - 1.5rem)); padding: 1rem 0 3rem; }
  .strategy-terminal { overflow: hidden; border: 1px solid #dce2e8; border-radius: 8px; background: #fff; box-shadow: 0 10px 32px rgba(28,38,48,.06); }
  .terminal-top { display: grid; grid-template-columns: minmax(300px,.82fr) minmax(520px,1.18fr); gap: 1rem; align-items: center; padding: 1rem 1.15rem; border-bottom: 1px solid #e5e9ed; background: #fbfcfd; }
  .context-line { display: flex; align-items: center; flex-wrap: wrap; gap: .4rem; color: #59636e; font-size: .7rem; font-weight: 850; }
  .live-dot { width: .48rem; height: .48rem; border-radius: 50%; background: var(--amber); box-shadow: 0 0 0 4px var(--amber-soft); }
  .environment { padding: .15rem .45rem; border: 1px solid #e8c57a; border-radius: 4px; background: #fff8e9; color: #8d5b00; }
  .title-block h1 { margin: .18rem 0 .12rem; font-size: 2rem; letter-spacing: 0; }
  .instrument { display: flex; align-items: center; flex-wrap: wrap; gap: .45rem; color: #6b747d; font-size: .76rem; }
  .instrument strong { font-size: .88rem; }
  .instrument code { padding: .08rem .3rem; background: #f1f3f5; }
  .clock-slot { min-width: 0; }
  .clock-slot :global(.market-clock) { width: 100%; box-shadow: none; border-radius: 6px; }
  .snapshot-panel { display: grid; align-content: center; min-height: 76px; padding: .7rem .85rem; border: 1px solid #e3c67d; border-radius: 6px; background: #fff9ec; }
  .snapshot-panel span { color: #805a12; font-size: .68rem; font-weight: 900; }
  .snapshot-panel strong { margin-top: .1rem; font-size: 1rem; }
  .snapshot-panel small { margin-top: .08rem; color: #755f35; font-size: .68rem; }
  .decision-band { display: grid; grid-template-columns: 1.35fr repeat(3,minmax(0,1fr)); border-bottom: 1px solid #e5e9ed; }
  .decision-cell { min-width: 0; min-height: 110px; padding: .85rem 1rem; border-right: 1px solid #e5e9ed; background: #fff; }
  .decision-cell:last-child { border-right: 0; }
  .decision-cell > span, .terminal-meta span { display: block; color: #747d86; font-size: .68rem; font-weight: 800; }
  .decision-cell > strong { display: block; margin-top: .28rem; font-size: .98rem; line-height: 1.4; letter-spacing: 0; }
  .decision-cell small { display: block; margin-top: .3rem; color: #7b838b; font-size: .68rem; line-height: 1.4; }
  .primary-decision { border-top: 3px solid #24364b; background: #f7f9fb; }
  .primary-decision > strong { font-size: 1.04rem; }
  .decision-cell.buy { border-top: 3px solid var(--action-buy); background: linear-gradient(180deg,#fff5f2,#fff); }
  .decision-cell.sell { border-top: 3px solid var(--action-sell); background: linear-gradient(180deg,#f1faf4,#fff); }
  .decision-cell.mixed, .decision-cell.latest { border-top: 3px solid #9aa4ae; }
  .weighted strong b { margin-left: .2rem; font-size: 1.3rem; }
  .weighted.buy strong b { color: var(--action-buy); }
  .weighted.sell strong b { color: var(--action-sell); }
  .weighted.mixed strong b { color: #56616c; }
  .terminal-meta { display: grid; grid-template-columns: 1.5fr .75fr 1fr .75fr; background: #f7f8fa; }
  .terminal-meta > div { min-height: 52px; padding: .5rem 1rem; border-right: 1px solid #e5e9ed; }
  .terminal-meta > div:last-child { border-right: 0; }
  .terminal-meta strong { font-size: .76rem; }
  .terminal-meta i { margin: 0 .3rem; color: #a2a8ae; font-style: normal; }
  .buy-text { color: var(--action-buy); }
  .sell-text { color: var(--action-sell); }
  .section-heading, .workbench-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; }
  .section-heading { margin: 1.45rem 0 .65rem; }
  .section-heading > div > span, .workbench-head > div > span { color: #6f7881; font-size: .68rem; font-weight: 900; }
  .section-heading h2, .workbench-head h2 { margin: .08rem 0 0; font-size: 1.25rem; letter-spacing: 0; }
  .section-heading p { margin: 0; color: #737c85; font-size: .74rem; }
  .cycle-grid { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: .65rem; }
  .cycle-group { padding: .75rem .8rem; border: 1px solid #dfe4e8; border-top: 3px solid #9da6af; border-radius: 7px; background: #fff; }
  .cycle-group.buy { border-top-color: var(--action-buy); }
  .cycle-group.sell { border-top-color: var(--action-sell); }
  .cycle-group header { display: flex; align-items: flex-start; justify-content: space-between; gap: .5rem; }
  .cycle-group header span { color: #7a838b; font-size: .65rem; font-weight: 800; }
  .cycle-group h3 { margin: .04rem 0 0; font-size: .9rem; letter-spacing: 0; }
  .cycle-group header > strong { font-size: .75rem; }
  .cycle-group.buy header > strong { color: var(--action-buy); }
  .cycle-group.sell header > strong { color: var(--action-sell); }
  .cycle-rail { display: flex; align-items: flex-start; margin: .65rem 0 .5rem; }
  .rail-node { position: relative; flex: 1; min-width: 0; text-align: center; }
  .rail-node::after { content: ''; position: absolute; z-index: 0; top: 1.68rem; left: 50%; width: 100%; height: 2px; background: #dfe3e7; }
  .rail-node:last-child::after { display: none; }
  .rail-node span { display: block; overflow: hidden; color: #69737d; font-size: .62rem; text-overflow: ellipsis; white-space: nowrap; }
  .rail-node b { position: relative; z-index: 1; display: block; width: .75rem; height: .75rem; margin: .32rem auto 0; border: 2px solid #fff; border-radius: 50%; background: #aeb6bd; box-shadow: 0 0 0 1px #aeb6bd; }
  .rail-node.buy b { background: var(--action-buy); box-shadow: 0 0 0 1px var(--action-buy); }
  .rail-node.sell b { background: var(--action-sell); box-shadow: 0 0 0 1px var(--action-sell); }
  .rail-node.conflict b { background: var(--amber); box-shadow: 0 0 0 1px var(--amber); }
  .cycle-group footer { display: flex; align-items: flex-end; justify-content: space-between; gap: .5rem; }
  .cycle-group footer span { font-size: .7rem; font-weight: 850; }
  .cycle-group footer small { overflow: hidden; max-width: 68%; color: #858d95; font-size: .6rem; text-align: right; text-overflow: ellipsis; white-space: nowrap; }
  .signal-workbench { margin-top: 1.4rem; overflow: hidden; border: 1px solid #d9dfe4; border-radius: 8px; background: #fff; }
  .workbench-head { padding: .8rem .9rem; border-bottom: 1px solid #e1e6ea; background: #f8fafb; }
  .filter-control { display: inline-flex; padding: .2rem; border: 1px solid #d8dee3; border-radius: 6px; background: #fff; }
  .filter-control button { min-height: 34px; padding: .35rem .65rem; border: 0; border-radius: 4px; background: transparent; color: #58636d; font: inherit; font-size: .7rem; font-weight: 850; cursor: pointer; }
  .filter-control button b { margin-left: .15rem; color: inherit; font-size: .65rem; }
  .filter-control button.active { background: #24364b; color: #fff; }
  .matrix-legend { display: flex; align-items: center; gap: .75rem; min-height: 38px; padding: .4rem .9rem; border-bottom: 1px solid #e8ebee; color: #6d7680; font-size: .65rem; }
  .matrix-legend span { display: inline-flex; align-items: center; gap: .25rem; }
  .matrix-legend i { width: .45rem; height: .45rem; border-radius: 50%; background: #aeb6bd; }
  .matrix-legend i.buy { background: var(--action-buy); }
