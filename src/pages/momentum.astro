---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'ETF动量雷达｜双动量轮动策略';
const description = 'ETF双动量策略看板：读取夜间轮动池JSON，盘中刷新实时行情、折溢价、核心候选和推荐持仓。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      .hero { padding: clamp(2.2rem, 6vw, 4.5rem) 0 1.4rem; }
      .hero h1 { margin: 0.7rem 0 0.85rem; letter-spacing: -0.045em; }
      .hero p { max-width: 860px; color: rgb(var(--gray)); font-size: 1.08rem; line-height: 1.75; }
      .toolbar { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 0.75rem; align-items: end; margin: 1.4rem 0; padding: 1rem; }
      .field { display: grid; gap: 0.35rem; }
      .field label { color: rgb(var(--gray)); font-size: 0.86rem; font-weight: 800; }
      select, button { width: 100%; min-height: 2.65rem; border-radius: 14px; border: 1px solid var(--border); background: white; color: rgb(var(--black)); font-weight: 800; padding: 0.55rem 0.75rem; font: inherit; }
      button.primary { background: rgb(var(--black)); color: white; cursor: pointer; }
      button.primary:disabled { opacity: 0.65; cursor: wait; }
      .checkline { display: flex; gap: 0.55rem; align-items: center; min-height: 2.65rem; padding: 0.55rem 0.75rem; border: 1px solid var(--border); border-radius: 14px; background: white; font-weight: 800; }
      .checkline input { width: 1.05rem; height: 1.05rem; accent-color: var(--accent-dark); }
      .dashboard-grid { display: grid; grid-template-columns: 1fr 340px; gap: 1rem; align-items: start; }
      .panel { padding: 1rem; }
      .panel-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 0.85rem; }
      .panel-head h2, .panel-head h3 { margin: 0; }
      .muted { color: rgb(var(--gray)); }
      .summary-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 0.75rem; margin: 1rem 0; }
      .metric { padding: 0.95rem; border: 1px solid var(--border); border-radius: 18px; background: var(--warm-2); }
      .metric strong { display: block; font-size: 1.35rem; margin-top: 0.28rem; }
      .rec-list { display: grid; gap: 0.75rem; }
      .rec-card { padding: 1rem; border: 1px solid var(--border); border-radius: 20px; background: linear-gradient(135deg, white, var(--accent-soft)); }
      .rec-top { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.55rem; }
      .rec-top h3 { margin: 0; }
      .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.6rem; }
      .tag { display: inline-flex; align-items: center; border-radius: 999px; padding: 0.22rem 0.55rem; font-size: 0.78rem; font-weight: 800; border: 1px solid var(--border); background: white; }
      .tag.pass { color: #137333; background: #eefaf1; border-color: #ccefd5; }
      .tag.fail { color: #b42318; background: #fff1ef; border-color: #ffd6cf; }
      .tag.watch { color: #9a6700; background: #fff7d6; border-color: #ffe7a3; }
      .table-wrap { overflow-x: auto; border: 1px solid var(--border); border-radius: 20px; background: white; }
      table { width: 100%; border-collapse: collapse; font-variant-numeric: lining-nums tabular-nums; min-width: 980px; }
      th, td { padding: 0.72rem 0.65rem; border-bottom: 1px solid var(--border); text-align: right; white-space: nowrap; }
      th { position: sticky; top: 0; z-index: 1; background: rgb(var(--black)); color: white; font-size: 0.82rem; }
      td:first-child, th:first-child { text-align: left; position: sticky; left: 0; z-index: 2; background: white; }
      th:first-child { background: rgb(var(--black)); z-index: 3; }
      tbody tr.recommended td { background: #fff8dc; }
      tbody tr.recommended td:first-child { background: #fff8dc; }
      .up { color: #c01616; font-weight: 900; }
      .down { color: #188038; font-weight: 900; }
      .side-stack { display: grid; gap: 1rem; }
      .explain-list { display: grid; gap: 0.75rem; padding: 0; margin: 0; list-style: none; }
      .explain-list li { padding: 0.8rem; border: 1px solid var(--border); border-radius: 16px; background: var(--warm-2); }
      .status-line { font-size: 0.9rem; color: rgb(var(--gray)); }
      .error { color: #b42318; font-weight: 800; }
      @media (max-width: 980px) { .dashboard-grid, .summary-grid { grid-template-columns: 1fr; } .toolbar { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
      @media (max-width: 560px) { .toolbar { grid-template-columns: 1fr; } .hero { padding-top: 1.6rem; } .panel { padding: 0.8rem; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <span class="pill pill-red">🔴 ETF动量雷达</span>
        <span class="pill">夜间JSON + 实时行情</span>
        <h1>双动量ETF轮动看板</h1>
        <p>晚上生成全市场ETF轮动池，按双动量、流动性、折溢价、过热回撤和量能过滤；盘中读取夜间池并刷新实时价格，辅助次日持仓和调仓判断。</p>
      </section>

      <section class="toolbar card" aria-label="策略筛选">
        <div class="field"><label for="type-filter">资产类型</label><select id="type-filter"><option value="全部">全部</option><option value="海外">海外</option><option value="宽基">宽基</option><option value="行业">行业</option><option value="商品">商品</option><option value="货币">货币</option></select></div>
        <div class="field"><label for="sort-key">排序方式</label><select id="sort-key"><option value="ret20">20日收益</option><option value="ret10">10日收益</option><option value="ret3">3日收益</option></select></div>
        <div class="field"><label for="ma-period">均线周期</label><select id="ma-period"><option value="10">10日均线</option><option value="20" selected>20日均线</option></select></div>
        <label class="checkline"><input type="checkbox" id="absolute-only" />仅看动量通过</label>
        <button class="primary" id="refresh-btn">刷新数据</button>
      </section>

      <section class="summary-grid" aria-label="今日策略摘要">
        <div class="metric"><span class="muted">ETF池</span><strong id="metric-total">—</strong></div>
        <div class="metric"><span class="muted">核心通过</span><strong id="metric-pass">—</strong></div>
        <div class="metric"><span class="muted">推荐持仓</span><strong id="metric-rec">—</strong></div>
        <div class="metric"><span class="muted">最后更新</span><strong id="metric-time">—</strong></div>
      </section>

      <section class="dashboard-grid">
        <div class="panel card">
          <div class="panel-head">
            <div><h2>ETF池数据</h2><p class="status-line" id="status-line">准备加载数据…</p></div>
            <span class="pill" id="date-pill">评估日期 —</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead><tr><th>名称</th><th>代码</th><th>类型</th><th>10日%</th><th>20日%</th><th>3日%</th><th>当前价</th><th id="ma-head">MA20</th><th id="ma-prev-head">折溢价</th><th>价>均线</th><th>均线上升</th><th>3日>-5%</th><th>核心条件</th></tr></thead>
              <tbody id="etf-body"><tr><td colspan="13">加载中…</td></tr></tbody>
            </table>
          </div>
        </div>

        <aside class="side-stack">
          <div class="panel card">
            <div class="panel-head"><h3>推荐持仓</h3><span class="pill pill-red">Top 2</span></div>
            <div class="rec-list" id="recommendations"></div>
          </div>
          <div class="panel card">
            <div class="panel-head"><h3>今日结论</h3><span class="pill">右侧雷达</span></div>
            <ul class="explain-list" id="today-notes"></ul>
          </div>
          <div class="panel card">
            <div class="panel-head"><h3>策略参数</h3></div>
            <ul class="explain-list">
              <li><strong>双动量：</strong>价格站上均线、均线向上、短期回撤受控，再按综合分排序。</li>
              <li><strong>短期阈值：</strong>3日收益大于 -5%。</li>
              <li><strong>仓位：</strong>推荐2只，默认50%/30%，保留20%现金或货币ETF。</li>
              <li><strong>用途：</strong>作为右侧趋势确认，和研测冰点信号交叉验证。</li>
            </ul>
          </div>
        </aside>
      </section>
    </main>
    <Footer />

    <script>
      const DATA_URL = '/data/etf-momentum-latest.json';
      const $ = (id) => document.getElementById(id);
      let payload = null;
      let rawRows = [];
      const fmt = (v, digits = 2) => Number.isFinite(Number(v)) ? Number(v).toFixed(digits) : '—';
      const cls = (v) => Number(v) >= 0 ? 'up' : 'down';
      const passTag = (ok) => `<span class="tag ${ok ? 'pass' : 'fail'}">${ok ? '🟢' : '🔴'}</span>`;
      const symbolOf = (row) => `${row.market || (row.code.startsWith('5') ? 'sh' : 'sz')}${row.code}`;
      function quoteByScript(row) {
        const symbol = symbolOf(row);
        return new Promise((resolve) => {
          const script = document.createElement('script');
          const done = () => { script.remove(); };
          script.src = `https://qt.gtimg.cn/q=${symbol}&_=${Date.now()}`;
          script.onload = () => {
            try {
              const text = window[`v_${symbol}`] || '';
              const p = text.split('~');
              if (p.length > 35) {
                resolve({ price: Number(p[3]), changePct: Number(p[32]), high: Number(p[33]), low: Number(p[34]), quoteTime: p[30] });
              } else resolve(null);
            } catch { resolve(null); }
            done();
          };
          script.onerror = () => { resolve(null); done(); };
          document.body.appendChild(script);
          setTimeout(() => { resolve(null); done(); }, 4500);
        });
      }
      async function refreshRealtime(rows) {
        const targets = rows.slice(0, 80);
        const quotes = await Promise.all(targets.map(quoteByScript));
        quotes.forEach((q, i) => {
          if (!q || !Number.isFinite(q.price)) return;
          const r = targets[i];
          const oldPrice = Number(r.price);
          r.price = q.price;
          r.change_pct = q.changePct;
          r.quote_time = q.quoteTime;
          if (Number.isFinite(oldPrice)) {
            r.ma20 = Number(r.ma20) + (q.price - oldPrice) / 20;
          }
          if (r.ret3_ref_close) r.ret3 = (q.price / Number(r.ret3_ref_close) - 1) * 100;
          if (r.ret10_ref_close) r.ret10 = (q.price / Number(r.ret10_ref_close) - 1) * 100;
          if (r.ret20_ref_close) r.ret20 = (q.price / Number(r.ret20_ref_close) - 1) * 100;
          const premium = r.premium || {};
          if (premium.available && premium.est_nav) premium.premium = (q.price / Number(premium.est_nav) - 1) * 100;
          r.checks = r.checks || {};
          r.checks.momentum = q.price > Number(r.ma20) && Number(r.ma20) > Number(r.ma20_prev) && Number(r.ret3) > -5;
          r.checks.premium = !premium.available || Math.abs(Number(premium.premium)) <= 1.5;
        });
      }
      function premiumText(r) {
        const p = r.premium || {};
        return p.available ? `${fmt(p.premium)}%` : '—';
      }
      function render() {
        const type = $('type-filter').value;
        const sortKey = $('sort-key').value === 'ret20' ? 'score' : $('sort-key').value;
        $('ma-head').textContent = 'MA20';
        $('ma-prev-head').textContent = '折溢价';
        let rows = [...rawRows];
        rows.sort((a, b) => (Number(b[sortKey]) || -Infinity) - (Number(a[sortKey]) || -Infinity));
        const recommendations = payload?.recommendations || rows.slice(0, 2);
        if (type !== '全部') rows = rows.filter(r => r.type === type);
        if ($('absolute-only').checked) rows = rows.filter(r => r.status === 'core');
        const recCodes = new Set(recommendations.map(r => r.code));
        const summary = payload?.summary || {};
        $('metric-total').textContent = `${summary.universe_count || rows.length}只`;
        $('metric-pass').textContent = `${summary.core_count || rows.length}只`;
        $('metric-rec').textContent = recommendations.map(r => r.code).join(' / ') || '空仓';
        $('metric-time').textContent = new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
        $('date-pill').textContent = `夜间池 ${payload?.run_date || '—'}｜实时 ${$('metric-time').textContent}`;
        $('status-line').textContent = `当前显示 ${rows.length} 只，核心池 ${summary.core_count || 0} 只，观察池 ${summary.watch_count || 0} 只，数据源：夜间JSON + 腾讯实时行情`;
        $('etf-body').innerHTML = rows.map(r => {
          const checks = r.checks || {};
          return `<tr class="${recCodes.has(r.code) ? 'recommended' : ''}"><td><strong>${r.name}</strong>${recCodes.has(r.code) ? ' <span class="tag pass">推荐</span>' : ''}</td><td>${r.code}</td><td>${r.type}</td><td class="${cls(r.ret10)}">${fmt(r.ret10)}</td><td class="${cls(r.ret20)}">${fmt(r.ret20)}</td><td class="${cls(r.ret3)}">${fmt(r.ret3)}</td><td>${fmt(r.price, 4)}</td><td>${fmt(r.ma20, 4)}</td><td>${premiumText(r)}</td><td>${passTag(Number(r.price) > Number(r.ma20))}</td><td>${passTag(Number(r.ma20) > Number(r.ma20_prev))}</td><td>${passTag(Number(r.ret3) > -5)}</td><td>${passTag(checks.momentum && checks.premium)}</td></tr>`;
        }).join('') || '<tr><td colspan="13">当前筛选下无ETF。</td></tr>';
        $('recommendations').innerHTML = recommendations.map((r, i) => `<div class="rec-card"><div class="rec-top"><h3>${i + 1}. ${r.name}</h3><span class="pill pill-red">${r.code}</span></div><p><strong>综合分：</strong>${fmt(r.score)}；<strong>20日：</strong><span class="${cls(r.ret20)}">${fmt(r.ret20)}%</span>；<strong>仓位：</strong>${r.recommended_weight || (i === 0 ? 50 : 30)}%</p><div class="tags"><span class="tag">${r.type}</span><span class="tag pass">MA20向上</span><span class="tag pass">折溢价${premiumText(r)}</span><span class="tag pass">量能${fmt(r.volume_heat)}x</span></div></div>`).join('') || '<p class="muted">当前无ETF满足核心条件，按空仓策略看货币ETF。</p>';
        const weak = [...(payload?.excluded_sample || [])].slice(0, 3);
        $('today-notes').innerHTML = [
          `<li><strong>夜间筛选：</strong>Universe ${summary.universe_count || 0}只，有效K线 ${summary.valid_count || 0}只，核心 ${summary.core_count || 0}只。</li>`,
          recommendations.length ? `<li><strong>推荐组合：</strong>${recommendations.map(r => `${r.name} ${r.code}`).join(' + ')}，建议50%/30%，保留20%现金或货币ETF。</li>` : '<li><strong>空仓策略：</strong>核心池为空时看银华日利ETF 511880。</li>',
          weak.length ? `<li><strong>排除样本：</strong>${weak.map(r => `${r.name}（${r.exclude_reason || '条件未过'}）`).join('，')}。</li>` : '',
          '<li><strong>策略口径：</strong>双动量 + 流动性 + 折溢价 + 过热/回撤/量能过滤，盘中仅刷新夜间候选池实时价。</li>'
        ].join('');
      }
      async function load() {
        $('refresh-btn').disabled = true;
        $('refresh-btn').textContent = '刷新中…';
        $('status-line').textContent = '正在读取夜间ETF轮动池…';
        try {
          payload = await fetch(`${DATA_URL}?t=${Date.now()}`).then(r => r.json());
          rawRows = [...(payload.core_pool || []), ...(payload.watch_pool || [])];
          await refreshRealtime(rawRows);
          render();
        } catch (err) {
          $('status-line').innerHTML = `<span class="error">加载失败：${err.message}</span>`;
          $('etf-body').innerHTML = `<tr><td colspan="13">轮动池加载失败，请稍后刷新。</td></tr>`;
        } finally {
          $('refresh-btn').disabled = false;
          $('refresh-btn').textContent = '刷新数据';
        }
      }
      ['type-filter', 'sort-key', 'absolute-only'].forEach(id => $(id).addEventListener('change', render));
      $('ma-period').disabled = true;
      $('refresh-btn').addEventListener('click', load);
      load();
      setInterval(load, 60000);
    </script>
  </body>
</html>
