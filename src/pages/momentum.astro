---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'A股ETF趋势雷达｜ETF花园 71 池';
const description = 'A股ETF花园71池趋势确认工具：趋势强度、交易风险、交易状态与行情快照分开呈现。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      .hero { padding: clamp(1.1rem, 3vw, 2rem) 0 0.85rem; }
      .hero h1 { margin: 0.55rem 0 0.5rem; letter-spacing: -0.045em; }
      .hero p { max-width: 880px; color: rgb(var(--gray)); font-size: 1rem; line-height: 1.65; margin-bottom: 0; }
      .toolbar { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 0.75rem; align-items: end; margin: 0.95rem 0; padding: 0.9rem; }
      .field { display: grid; gap: 0.35rem; }
      .field label { color: rgb(var(--gray)); font-size: 0.86rem; font-weight: 800; }
      select, button { width: 100%; min-height: 2.65rem; border-radius: 14px; border: 1px solid var(--border); background: white; color: rgb(var(--black)); font-weight: 800; padding: 0.55rem 0.75rem; font: inherit; }
      button.primary { background: rgb(var(--black)); color: white; cursor: pointer; }
      button.primary:disabled { opacity: 0.65; cursor: wait; }
      .checkline { display: flex; gap: 0.55rem; align-items: center; min-height: 2.65rem; padding: 0.55rem 0.75rem; border: 1px solid var(--border); border-radius: 14px; background: white; font-weight: 800; }
      .checkline input { width: 1.05rem; height: 1.05rem; accent-color: var(--accent-dark); }
      .dashboard-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; align-items: start; }
      .panel { padding: 1rem; }
      .panel-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 0.85rem; }
      .panel-head h2, .panel-head h3 { margin: 0; }
      .muted { color: rgb(var(--gray)); }
      .summary-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 0.65rem; margin: 0.85rem 0; }
      .metric { padding: 0.8rem; border: 1px solid var(--border); border-radius: 16px; background: var(--warm-2); }
      .metric strong { display: block; font-size: 1.12rem; margin-top: 0.22rem; line-height: 1.3; overflow-wrap: anywhere; }
      .metric.danger { background: #fff1ef; border-color: #ffd6cf; }
      .metric.danger strong { color: #b42318; }
      .decision-board { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(260px, 0.75fr); gap: 1rem; padding: 1rem; margin: 0.8rem 0 0.9rem; background: linear-gradient(135deg, white, #fff8f0); }
      .decision-main h2 { margin: 0 0 0.35rem; font-size: clamp(1.25rem, 2.6vw, 1.75rem); }
      .decision-main p { color: rgb(var(--gray)); margin: 0; }
      .decision-badges { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.75rem; }
      .badge-state { border-radius: 999px; padding: 0.28rem 0.65rem; font-weight: 900; font-size: 0.82rem; border: 1px solid var(--border); background: white; }
      .badge-state.danger { color: #b42318; background: #fff1ef; border-color: #ffd6cf; }
      .badge-state.warn { color: #9a6700; background: #fff7d6; border-color: #ffe7a3; }
      .badge-state.good { color: #137333; background: #eefaf1; border-color: #ccefd5; }
      .decision-side { display: grid; gap: 0.45rem; align-content: center; }
      .decision-side div { padding: 0.55rem 0.7rem; border-radius: 14px; background: rgba(255,255,255,0.78); border: 1px solid var(--border); font-weight: 800; }
      .decision-side div:first-child { color: #b42318; background: #fff1ef; border-color: #ffd6cf; font-size: 1rem; }
      .top-panel { padding: 1rem; margin: 0.8rem 0 1rem; }
      .rec-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 0.65rem; }
      .rec-card { padding: 0.82rem; border: 1px solid var(--border); border-radius: 18px; background: linear-gradient(135deg, white, var(--accent-soft)); min-height: 100%; }
      :global(.rec-top) { display: grid; gap: 0.25rem; margin-bottom: 0.65rem; }
      :global(.rec-top h3) { margin: 0; }
      :global(.rec-code) { color: rgb(var(--gray)); font-weight: 900; }
      :global(.rec-metrics) { display: grid; gap: 0.35rem; line-height: 1.45; margin: 0; }
      :global(.rec-metrics > span) { display: block; }
      :global(.rec-tags) { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.65rem; }
      .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.6rem; }
      .tag { display: inline-flex; align-items: center; border-radius: 999px; padding: 0.22rem 0.55rem; font-size: 0.78rem; font-weight: 800; border: 1px solid var(--border); background: white; }
      .tag.pass { color: #137333; background: #eefaf1; border-color: #ccefd5; }
      .tag.fail { color: #b42318; background: #fff1ef; border-color: #ffd6cf; }
      .tag.watch { color: #9a6700; background: #fff7d6; border-color: #ffe7a3; }
      .agent-grid { display: grid; gap: 0.3rem; margin-top: 0.45rem; }
      .agent-box { border: 1px solid var(--border); border-radius: 12px; padding: 0.38rem 0.5rem; background: rgba(255,255,255,0.72); font-size: 0.74rem; line-height: 1.32; }
      .verdict { display: inline-flex; width: fit-content; margin-top: 0.5rem; border-radius: 999px; padding: 0.24rem 0.58rem; background: rgb(var(--black)); color: white; font-weight: 900; font-size: 0.76rem; }
      .table-wrap { overflow: auto; max-height: 531px; border: 1px solid var(--border); border-radius: 20px; background: white; }
      table { width: 100%; border-collapse: separate; border-spacing: 0; font-variant-numeric: lining-nums tabular-nums; min-width: 900px; display: table; }
      th, td { padding: 0.72rem 0.65rem; border-bottom: 1px solid var(--border); text-align: right; white-space: nowrap; }
      thead { position: relative; z-index: 10; will-change: transform; }
      thead th { position: relative; z-index: 5; background: rgb(var(--black)); color: white; font-size: 0.82rem; }
      td:first-child, th:first-child { text-align: left; position: sticky; left: 0; z-index: 2; background: white; }
      thead th:first-child { background: rgb(var(--black)); z-index: 6; }
      tbody tr.recommended td { background: #fff8dc; }
      tbody tr.recommended td:first-child { background: #fff8dc; }
      .up { color: #c01616; font-weight: 900; }
      .down { color: #188038; font-weight: 900; }
      .side-stack { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 1rem; }
      .explain-list { display: grid; gap: 0.75rem; padding: 0; margin: 0; list-style: none; }
      .explain-list li { padding: 0.8rem; border: 1px solid var(--border); border-radius: 16px; background: var(--warm-2); }
      .status-line { font-size: 0.9rem; color: rgb(var(--gray)); }
      .scope-note { margin: 0.75rem 0 0; padding: 0.75rem 0.85rem; border-left: 4px solid #9a6700; background: #fff7d6; border-radius: 12px; color: #604400; font-size: 0.9rem; }
      .error { color: #b42318; font-weight: 800; }
      .data-details { border-radius: 20px; }
      .data-details > summary { cursor: pointer; list-style: none; padding: 1rem; font-weight: 900; }
      .data-details > summary::-webkit-details-marker { display: none; }
      .data-details > summary::after { content: '展开完整数据 ↓'; float: right; color: rgb(var(--gray)); font-size: 0.82rem; }
      .data-details[open] > summary::after { content: '收起数据 ↑'; }
      .data-details .panel { border: 0; box-shadow: none; padding-top: 0; }
      @media (max-width: 1100px) { .rec-list { grid-template-columns: repeat(2, minmax(0, 1fr)); } .summary-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
      @media (max-width: 980px) { .dashboard-grid, .summary-grid, .decision-board, .side-stack { grid-template-columns: 1fr; } .toolbar { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
      @media (max-width: 560px) { .toolbar, .rec-list { grid-template-columns: 1fr; } .hero { padding-top: 1rem; } .panel { padding: 0.8rem; } .summary-grid { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <span class="pill pill-red">🔴 A股ETF花园 71 池</span>
        <span class="pill">Trend Radar v3</span>
        <h1>A股ETF趋势雷达</h1>
        <p>这是趋势确认工具，不是买入推荐榜。趋势强度、交易风险和当前状态分别展示，先判断能否持有，再判断是否值得追。</p>
      </section>

      <section class="decision-board card" aria-label="今日决策看板">
        <div class="decision-main">
          <h2 id="decision-title">读取今日轮动结论…</h2>
          <p id="decision-subtitle">市场状态、推荐观察池与风险提示会随实时行情自动刷新。</p>
          <div class="decision-badges" id="decision-badges"></div>
        </div>
        <div class="decision-side">
          <div id="decision-action">操作：等待数据</div>
          <div id="decision-risk">风险：等待数据</div>
          <div id="decision-source">数据：加载中</div>
        </div>
        <p class="scope-note" id="scope-note">模型分数、风险和仓位来自基准快照；盘中只更新价格、收益估算和MA20状态。</p>
      </section>

      <section class="toolbar card" aria-label="策略筛选">
        <div class="field"><label for="type-filter">资产类型</label><select id="type-filter"><option value="全部">全部</option><option value="海外">海外</option><option value="宽基">宽基</option><option value="行业">行业</option><option value="商品">商品</option><option value="货币">货币</option></select></div>
        <div class="field"><label for="state-filter">交易状态</label><select id="state-filter"><option value="全部">全部</option><option value="可持有">可持有</option><option value="回踩候选">回踩候选</option><option value="禁止追高">禁止追高</option><option value="观察">观察</option><option value="退出">退出</option></select></div>
        <div class="field"><label for="sort-key">排序方式</label><select id="sort-key"><option value="signal_score">综合评分</option><option value="ret20">20日收益</option><option value="ret10">10日收益</option><option value="ret3">3日收益</option><option value="trading_risk_score">交易风险</option></select></div>
        <label class="checkline"><input type="checkbox" id="absolute-only" />仅看动量通过</label>
        <button class="primary" id="refresh-btn">刷新数据</button>
      </section>

      <section class="summary-grid" aria-label="今日策略摘要">
        <div class="metric"><span class="muted">ETF池</span><strong id="metric-total">—</strong></div>
        <div class="metric"><span class="muted">动量通过</span><strong id="metric-pass">—</strong></div>
        <div class="metric"><span class="muted">代表观察</span><strong id="metric-rec">—</strong></div>
        <div class="metric"><span class="muted">市场状态</span><strong id="metric-regime">—</strong></div>
        <div class="metric"><span class="muted">实时刷新</span><strong id="metric-time">—</strong></div>
      </section>

      <section class="top-panel card" aria-label="组合经理Top5">
        <div class="panel-head"><h2>主题代表观察池</h2><span class="pill pill-red">同主题最多一只</span></div>
        <div class="rec-list" id="recommendations"></div>
      </section>

      <section class="dashboard-grid">
        <details class="data-details card">
          <summary>ETF花园 71 池完整数据</summary>
          <div class="panel">
            <div class="panel-head">
              <div><h2>ETF池数据</h2><p class="status-line" id="status-line">准备加载数据…</p></div>
              <span class="pill" id="date-pill">评估日期 —</span>
            </div>
            <div class="table-wrap">
              <table>
                <thead><tr><th>名称</th><th>代码</th><th>类型</th><th>趋势</th><th>状态</th><th>5日%</th><th>20日%</th><th>位置</th><th>交易风险</th><th>风险提示</th></tr></thead>
                <tbody id="etf-body"><tr><td colspan="10">加载中…</td></tr></tbody>
              </table>
            </div>
          </div>
        </details>

        <aside class="side-stack">
          <div class="panel card">
            <div class="panel-head"><h3>今日结论</h3><span class="pill">右侧雷达</span></div>
            <ul class="explain-list" id="today-notes"></ul>
          </div>
          <div class="panel card">
            <div class="panel-head"><h3>策略参数</h3></div>
            <ul class="explain-list">
              <li><strong>动量Agent：</strong>近5日强度 + 20/60日斜率R²，过滤弱反抽。</li>
              <li><strong>量能Agent：</strong>用成交量比衡量参与度；当前不等同于主力净流入。</li>
              <li><strong>风险Agent：</strong>高位过热、缩量冲高、跌破20日线进入冷却/降权。</li>
              <li><strong>组合经理：</strong>输出加仓/持有/观察/减仓/退出与建议仓位。</li>
            </ul>
          </div>
        </aside>
      </section>
    </main>
    <Footer />

    <script>
      const DATA_URL = '/data/etf-garden-pool.json';
      const LIVE_URL = 'https://etf-live.peekabo.cc/api/etf-garden/live';
      const $ = (id) => document.getElementById(id);
      let payload = null;
      let rawRows = [];
      let livePayload = null;
      let liveTimer = null;
      const fmt = (v, digits = 2) => Number.isFinite(Number(v)) ? Number(v).toFixed(digits) : '—';
      const cls = (v) => Number(v) >= 0 ? 'up' : 'down';
      const stateClass = (state) => state === '极弱' || state === '防御' ? 'danger' : (state === '震荡' ? 'warn' : 'good');
      const actionHint = (state) => state === '极弱' ? '控制仓位：Top5仅作观察，不代表立即加仓' : (state === '防御' ? '轻仓试探：先看承接，再分批' : (state === '震荡' ? '低吸高抛：只做强弱切换' : '趋势跟随：优先强势持有'));
      const passTag = (ok) => `<span class="tag ${ok ? 'pass' : 'fail'}">${ok ? '🟢' : '🔴'}</span>`;
      function applyLiveRows(rows) {
        const liveMap = new Map((livePayload?.items || []).map(x => [x.code, x]));
        return rows.map(row => {
          const live = liveMap.get(row.code);
          if (!live || !Number.isFinite(Number(live.price))) return row;
          const price = Number(live.price);
          const base3 = Number(row.ret3);
          const base10 = Number(row.ret10);
          const base20 = Number(row.ret20);
          const oldPrice = Number(row.price);
          const adjustReturn = (base) => Number.isFinite(base) && Number.isFinite(oldPrice) && oldPrice > 0
            ? (((1 + base / 100) * price / oldPrice) - 1) * 100
            : base;
          const ret3 = adjustReturn(base3);
          const ret10 = adjustReturn(base10);
          const ret20 = adjustReturn(base20);
          const ma20 = Number(row.ma20);
          const ma20Prev = Number(row.ma20_prev);
          const priceAboveMa = Number.isFinite(ma20) ? price > ma20 : row.checks?.price_above_ma;
          const maRising = Number.isFinite(ma20) && Number.isFinite(ma20Prev) ? ma20 > ma20Prev : row.checks?.ma_rising;
          const shortOk = Number.isFinite(ret3) ? ret3 > -5 : row.checks?.short_ok;
          const momentum = Boolean(priceAboveMa && maRising && shortOk);
          return {
            ...row,
            price,
            prev_close: live.prev_close ?? row.prev_close,
            change_pct: live.change_pct ?? row.change_pct,
            high: live.high ?? row.high,
            low: live.low ?? row.low,
            quote_source: live.source || row.quote_source,
            ret3: Number.isFinite(ret3) ? Number(ret3.toFixed(2)) : row.ret3,
            ret10: Number.isFinite(ret10) ? Number(ret10.toFixed(2)) : row.ret10,
            ret20: Number.isFinite(ret20) ? Number(ret20.toFixed(2)) : row.ret20,
            status: momentum ? 'core' : (row.status === 'cash' ? 'cash' : 'watch'),
            checks: {
              ...(row.checks || {}),
              price_above_ma: priceAboveMa,
              ma_rising: maRising,
              short_ok: shortOk,
              momentum,
            },
            live: true,
          };
        });
      }
      function buildLiveSummary(rows) {
        const core = rows.filter(r => r.status === 'core' && r.cooldown_state !== '止损观察');
        return {
          ...(payload?.summary || {}),
          universe_count: rows.length,
          valid_count: rows.filter(r => Number.isFinite(Number(r.price))).length,
          core_count: core.length,
          watch_count: rows.filter(r => r.status === 'watch').length,
          momentum_pass_count: core.length,
        };
      }
      const themeOf = (row) => {
        const name = String(row.name || '');
        const groups = [
          ['科技', ['半导体', '科技', '科创', '信息技术', '计算机', '软件', '人工智能', '电子', '数字经济', '通信', '机器人']],
          ['医药', ['医药', '医疗', '创新药', '生物']],
          ['防御', ['银行', '煤炭', '红利', '电力', '黄金']],
          ['消费', ['消费', '酒ETF', '家电', '旅游']],
          ['海外', ['恒生', '纳指', '标普', '道琼斯', '德国', '法国', '日经', '沙特', '印度', '东南亚']],
          ['新能源制造', ['电池', '光伏', '汽车', '电网', '工业母机', '军工', '航空航天']],
        ];
        return groups.find(([, keys]) => keys.some(key => name.includes(key)))?.[0] || row.type || '其他';
      };
      function buildLiveRecommendations(rows) {
        const candidates = [...rows]
          .filter(r => r.status === 'core' && Number(r.signal_score) >= 52 && ['可持有', '回踩候选', '观察'].includes(r.trade_state || r.action))
          .sort((a, b) => (Number(b.signal_score) || -Infinity) - (Number(a.signal_score) || -Infinity));
        const selected = [];
        const themes = new Set();
        for (const row of candidates) {
          const theme = themeOf(row);
          if (themes.has(theme)) continue;
          selected.push({ ...row, theme });
          themes.add(theme);
          if (selected.length >= 5) break;
        }
        return selected;
      }
      function render() {
        const type = $('type-filter').value;
        const stateFilter = $('state-filter').value;
        const sortKey = $('sort-key').value;
        let rows = applyLiveRows(rawRows);
        rows.sort((a, b) => (Number(b[sortKey]) || -Infinity) - (Number(a[sortKey]) || -Infinity));
        const summary = buildLiveSummary(rows);
        const recommendations = buildLiveRecommendations(rows);
        if (type !== '全部') rows = rows.filter(r => r.type === type);
        if (stateFilter !== '全部') rows = rows.filter(r => (r.trade_state || r.action) === stateFilter);
        if ($('absolute-only').checked) rows = rows.filter(r => r.status === 'core' && r.cooldown_state !== '止损观察');
        const recCodes = new Set(recommendations.map(r => r.code));
        const totalAfterFilter = rows.length;
        const liveTime = livePayload?.generated_at ? livePayload.generated_at.replace(' UTC+08:00', '').slice(11, 16) : null;
        const generatedDate = livePayload?.generated_at?.slice(0, 10);
        const tradeDate = payload?.latest_trade_date;
        const isSnapshot = Boolean(generatedDate && tradeDate && generatedDate !== tradeDate);
        const quoteState = isSnapshot ? '休市快照' : (livePayload ? '盘中行情' : '基准快照');
        const weak = [...rawRows].sort((a, b) => (Number(a.ret20) || Infinity) - (Number(b.ret20) || Infinity)).slice(0, 3);
        $('metric-total').textContent = `${summary.universe_count || rows.length}只`;
        $('metric-pass').textContent = `${summary.core_count || rows.filter(r => r.status === 'core' && r.cooldown_state !== '止损观察').length}只`;
        $('metric-rec').textContent = recommendations.map(r => r.code).join(' / ') || '空仓';
        $('metric-regime').textContent = payload?.market_regime?.state || '—';
        $('metric-time').textContent = `${quoteState}${liveTime ? ` ${liveTime}` : ''}`;
        const regime = payload?.market_regime || {};
        const state = regime.state || '—';
        const recNames = recommendations.slice(0, 3).map(r => `${r.code} ${r.name.replace(/ETF.*/, 'ETF')}`).join(' / ') || '空仓观察';
        $('decision-title').textContent = `${state}市场｜${recommendations.length ? '主题代表观察' : '空仓防御'}｜趋势通过 ${summary.core_count || 0}/${summary.universe_count || rows.length}`;
        $('decision-subtitle').textContent = `Top候选：${recNames}。${actionHint(state)}。`;
        $('decision-badges').innerHTML = [`<span class="badge-state ${stateClass(state)}">市场 ${state}</span>`, `<span class="badge-state">权益 ${regime.equity_allocation || '—'}</span>`, `<span class="badge-state">防御 ${regime.defense_allocation || '—'}</span>`, `<span class="badge-state">${quoteState} ${liveTime || '—'}</span>`].join('');
        $('decision-action').textContent = `操作：${actionHint(state)}`;
        $('decision-risk').textContent = `风险：${weak.length ? weak.map(r => r.code).join(' / ') : '暂无尾部数据'}`;
        $('decision-source').textContent = `模型评估：${payload?.evaluation_date || '—'}｜行情交易日：${tradeDate || '—'}｜接口检查：${generatedDate || '—'} ${liveTime || ''}`;
        $('date-pill').textContent = `模型 ${payload?.evaluation_date || payload?.run_date || '—'}｜行情 ${tradeDate || '—'}｜${quoteState}${liveTime ? ` ${liveTime}` : ''}`;
        $('scope-note').textContent = `实时重算：${(payload?.realtime_scope || ['当前价', '收益估算', 'MA20状态']).join('、')}。快照字段：${(payload?.snapshot_scope || ['综合分', '交易风险', '交易状态', '市场状态']).join('、')}。`;
        $('status-line').textContent = `当前显示 ${rows.length}/${totalAfterFilter} 只，趋势通过 ${summary.core_count || 0} 只，${quoteState}：${livePayload?.source || payload?.quote_source || 'stock-api'}${livePayload?.latency_ms ? `，接口延迟 ${livePayload.latency_ms}ms` : ''}`;
        $('etf-body').innerHTML = rows.map(r => {
          const risks = (r.risk_flags || []).slice(0, 2).join(' / ') || '—';
          const tradeState = r.trade_state || r.action || '观察';
          return `<tr class="${recCodes.has(r.code) ? 'recommended' : ''}"><td><strong>${r.name}</strong>${recCodes.has(r.code) ? ' <span class="tag pass">代表</span>' : ''}</td><td>${r.code}</td><td>${r.type}</td><td><strong>${r.strength_level || '—'} / ${fmt(r.signal_score)}</strong></td><td><span class="tag ${tradeState === '禁止追高' || tradeState === '退出' ? 'fail' : (tradeState === '可持有' ? 'pass' : 'watch')}">${tradeState}</span></td><td class="${cls(r.ret5)}">${fmt(r.ret5)}%</td><td class="${cls(r.ret20)}">${fmt(r.ret20)}%</td><td>${fmt(Number(r.close_position) * 100, 0)}%</td><td><strong>${r.risk_level || '—'}</strong> / ${fmt(r.trading_risk_score, 0)}</td><td>${risks}</td></tr>`;
        }).join('') || '<tr><td colspan="13">当前筛选下无ETF。</td></tr>';
        $('recommendations').innerHTML = recommendations.map((r, i) => {
          const scores = r.agent_scores || {};
          const bull = (r.agent_bull || []).slice(0, 2).join('；');
          const bear = (r.agent_bear || []).slice(0, 2).join('；');
          const tradeState = r.trade_state || r.action || '观察';
          return `<div class="rec-card"><div class="rec-top"><h3>${i + 1}. ${r.code} ${r.name}</h3><div class="rec-code">趋势 ${r.strength_level || '—'} / ${fmt(r.signal_score)}｜交易风险 ${r.risk_level || '中'} / ${fmt(r.trading_risk_score, 0)}</div></div><p class="rec-metrics"><span><strong>5日：</strong><span class="${cls(r.ret5)}">${fmt(r.ret5)}%</span>　<strong>20日：</strong><span class="${cls(r.ret20)}">${fmt(r.ret20)}%</span></span><span><strong>状态：</strong>${tradeState}　<strong>位置：</strong>${fmt(Number(r.close_position) * 100, 0)}%</span></p><div class="agent-box"><strong>看点：</strong>${bull || '相对强势观察'}；<strong>风险：</strong>${bear || '暂无'}</div><div class="rec-tags"><span class="tag ${tradeState === '禁止追高' || tradeState === '退出' ? 'fail' : (tradeState === '可持有' ? 'pass' : 'watch')}">${tradeState}</span><span class="tag ${r.risk_level === '高' ? 'fail' : 'watch'}">${r.risk_level || '中'}风险</span><span class="tag">${r.theme || themeOf(r)}</span></div></div>`;
        }).join('') || '<p class="muted">当前无ETF满足趋势强度与交易风险双重准入，按空仓/防御策略处理。</p>';
        $('today-notes').innerHTML = [
          `<li><strong>ETF花园 71 池：</strong>覆盖宽基/海外/行业/商品/LOF 五大类，评估日期 ${payload?.evaluation_date || '—'}。</li>`,
          recommendations.length ? `<li><strong>操作结论：</strong>${state}市场，${actionHint(state)}。</li><li><strong>Top观察：</strong>${recommendations.map(r => `${r.code} ${r.name}(${r.action || '观察'})`).join(' / ')}。</li>` : '<li><strong>空仓策略：</strong>绝对动量为空时看银华日利ETF 511880。</li>',
          weak.length ? `<li><strong>弱势尾部：</strong>${weak.map(r => `${r.name} ${fmt(r.ret20)}%`).join('，')}。</li>` : '',
          `<li><strong>市场状态：</strong>${payload?.market_regime?.state || '—'}，权益仓 ${payload?.market_regime?.equity_allocation || '—'}，防御仓 ${payload?.market_regime?.defense_allocation || '—'}。</li>`,
          '<li><strong>本站口径：</strong>Trend Radar v3 将趋势强度、交易风险和交易状态分开；K线/价格由 stock-api v2.7.2 更新。</li>'
        ].join('');
        pinTableHeader();
      }
      function pinTableHeader() {
        const wrap = document.querySelector('.table-wrap');
        const head = document.querySelector('thead');
        if (!wrap || !head) return;
        head.style.transform = `translateY(${wrap.scrollTop}px)`;
      }
      async function loadLive() {
        if (!payload) return;
        try {
          livePayload = await fetch(`${LIVE_URL}?t=${Date.now()}`, { cache: 'no-store' }).then(r => {
            if (!r.ok) throw new Error(`HTTP ${r.status}`);
            return r.json();
          });
          render();
        } catch (err) {
          $('status-line').innerHTML = `<span class="error">实时行情暂时不可用：${err.message}；已保留最新静态快照。</span>`;
        }
      }
      async function load() {
        $('refresh-btn').disabled = true;
        $('refresh-btn').textContent = '刷新中…';
        $('status-line').textContent = '正在读取 ETF花园 71 池基准快照…';
        try {
          payload = await fetch(`${DATA_URL}?t=${Date.now()}`).then(r => r.json());
          rawRows = payload.all_rows || [...(payload.core_pool || []), ...(payload.watch_pool || [])];
          render();
          await loadLive();
          if (!liveTimer) liveTimer = setInterval(loadLive, 3000);
        } catch (err) {
          $('status-line').innerHTML = `<span class="error">加载失败：${err.message}</span>`;
          $('etf-body').innerHTML = `<tr><td colspan="10">轮动池加载失败，请稍后刷新。</td></tr>`;
        } finally {
          $('refresh-btn').disabled = false;
          $('refresh-btn').textContent = '刷新数据';
        }
      }
      ['type-filter', 'state-filter', 'sort-key', 'absolute-only'].forEach(id => $(id).addEventListener('change', render));
      $('refresh-btn').addEventListener('click', loadLive);
      document.querySelector('.table-wrap').addEventListener('scroll', pinTableHeader, { passive: true });
      load();
    </script>
  </body>
</html>
