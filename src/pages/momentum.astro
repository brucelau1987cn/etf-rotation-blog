---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const title = 'ETF TradingAgents v2｜ETF花园 71 池';
const description = 'ETF TradingAgents v2 多智能体轮动看板：动量、资金、风控、多空辩论与组合经理裁决。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      .hero { padding: clamp(2.2rem, 6vw, 4.5rem) 0 1.4rem; }
      .hero h1 { margin: 0.7rem 0 0.85rem; letter-spacing: -0.045em; }
      .hero p { max-width: 860px; color: rgb(var(--gray)); font-size: 1.08rem; line-height: 1.75; }
      .toolbar { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 0.75rem; align-items: end; margin: 1.4rem 0; padding: 1rem; }
      .field { display: grid; gap: 0.35rem; }
      .field label { color: rgb(var(--gray)); font-size: 0.86rem; font-weight: 800; }
      select, button { width: 100%; min-height: 2.65rem; border-radius: 14px; border: 1px solid var(--border); background: white; color: rgb(var(--black)); font-weight: 800; padding: 0.55rem 0.75rem; font: inherit; }
      button.primary { background: rgb(var(--black)); color: white; cursor: pointer; }
      button.primary:disabled { opacity: 0.65; cursor: wait; }
      .checkline { display: flex; gap: 0.55rem; align-items: center; min-height: 2.65rem; padding: 0.55rem 0.75rem; border: 1px solid var(--border); border-radius: 14px; background: white; font-weight: 800; }
      .checkline input { width: 1.05rem; height: 1.05rem; accent-color: var(--accent-dark); }
      .dashboard-grid { display: grid; grid-template-columns: 1fr 340px; gap: 1rem; align-items: start; }
      .panel { padding: 1rem; }
      .panel-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 0.85rem; }
      .panel-head h2, .panel-head h3 { margin: 0; }
      .muted { color: rgb(var(--gray)); }
      .summary-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 0.75rem; margin: 1rem 0; }
      .metric { padding: 0.95rem; border: 1px solid var(--border); border-radius: 18px; background: var(--warm-2); }
      .metric strong { display: block; font-size: 1.35rem; margin-top: 0.28rem; }
      .rec-list { display: grid; gap: 0.75rem; }
      .rec-card { padding: 1rem; border: 1px solid var(--border); border-radius: 20px; background: linear-gradient(135deg, white, var(--accent-soft)); }
      :global(.rec-top) { display: grid; gap: 0.25rem; margin-bottom: 0.65rem; }
      :global(.rec-top h3) { margin: 0; }
      :global(.rec-code) { color: rgb(var(--gray)); font-weight: 900; }
      :global(.rec-metrics) { display: grid; gap: 0.35rem; line-height: 1.45; margin: 0; }
      :global(.rec-metrics > span) { display: block; }
      :global(.rec-tags) { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.65rem; }
      .tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.6rem; }
      .tag { display: inline-flex; align-items: center; border-radius: 999px; padding: 0.22rem 0.55rem; font-size: 0.78rem; font-weight: 800; border: 1px solid var(--border); background: white; }
      .tag.pass { color: #137333; background: #eefaf1; border-color: #ccefd5; }
      .tag.fail { color: #b42318; background: #fff1ef; border-color: #ffd6cf; }
      .tag.watch { color: #9a6700; background: #fff7d6; border-color: #ffe7a3; }
      .agent-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.35rem; margin-top: 0.65rem; }
      .agent-box { border: 1px solid var(--border); border-radius: 12px; padding: 0.45rem 0.55rem; background: rgba(255,255,255,0.72); font-size: 0.78rem; line-height: 1.35; }
      .verdict { display: inline-flex; width: fit-content; margin-top: 0.55rem; border-radius: 999px; padding: 0.25rem 0.6rem; background: rgb(var(--black)); color: white; font-weight: 900; font-size: 0.78rem; }
      .table-wrap { overflow: auto; max-height: 531px; border: 1px solid var(--border); border-radius: 20px; background: white; }
      table { width: 100%; border-collapse: separate; border-spacing: 0; font-variant-numeric: lining-nums tabular-nums; min-width: 980px; }
      th, td { padding: 0.72rem 0.65rem; border-bottom: 1px solid var(--border); text-align: right; white-space: nowrap; }
      thead { position: relative; z-index: 10; will-change: transform; }
      thead th { position: relative; z-index: 5; background: rgb(var(--black)); color: white; font-size: 0.82rem; }
      td:first-child, th:first-child { text-align: left; position: sticky; left: 0; z-index: 2; background: white; }
      thead th:first-child { background: rgb(var(--black)); z-index: 6; }
      tbody tr.recommended td { background: #fff8dc; }
      tbody tr.recommended td:first-child { background: #fff8dc; }
      .up { color: #c01616; font-weight: 900; }
      .down { color: #188038; font-weight: 900; }
      .side-stack { display: grid; gap: 1rem; }
      .explain-list { display: grid; gap: 0.75rem; padding: 0; margin: 0; list-style: none; }
      .explain-list li { padding: 0.8rem; border: 1px solid var(--border); border-radius: 16px; background: var(--warm-2); }
      .status-line { font-size: 0.9rem; color: rgb(var(--gray)); }
      .error { color: #b42318; font-weight: 800; }
      @media (max-width: 980px) { .dashboard-grid, .summary-grid { grid-template-columns: 1fr; } .toolbar { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
      @media (max-width: 560px) { .toolbar { grid-template-columns: 1fr; } .hero { padding-top: 1.6rem; } .panel { padding: 0.8rem; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <span class="pill pill-red">🔴 TradingAgents v2</span>
        <span class="pill">ETF花园 71 池 + 多Agent轮动裁决</span>
        <h1>ETF多智能体轮动池</h1>
        <p>轮动池来自 ETF花园 71 池，新增动量Agent、资金Agent、风险Agent、多头/空头研究员和组合经理裁决；用于把右侧动量、资金质量、位置风险和仓位动作合并成可执行队列。</p>
      </section>

      <section class="toolbar card" aria-label="策略筛选">
        <div class="field"><label for="type-filter">资产类型</label><select id="type-filter"><option value="全部">全部</option><option value="海外">海外</option><option value="宽基">宽基</option><option value="行业">行业</option><option value="商品">商品</option><option value="货币">货币</option></select></div>
        <div class="field"><label for="sort-key">排序方式</label><select id="sort-key"><option value="ret20">20日收益</option><option value="ret10">10日收益</option><option value="ret3">3日收益</option></select></div>
        <div class="field"><label for="ma-period">均线周期</label><select id="ma-period"><option value="10">10日均线</option><option value="20" selected>20日均线</option></select></div>
        <label class="checkline"><input type="checkbox" id="absolute-only" />仅看动量通过</label>
        <button class="primary" id="refresh-btn">刷新数据</button>
      </section>

      <section class="summary-grid" aria-label="今日策略摘要">
        <div class="metric"><span class="muted">ETF池</span><strong id="metric-total">—</strong></div>
        <div class="metric"><span class="muted">动量通过</span><strong id="metric-pass">—</strong></div>
        <div class="metric"><span class="muted">推荐持仓</span><strong id="metric-rec">—</strong></div>
        <div class="metric"><span class="muted">市场状态</span><strong id="metric-regime">—</strong></div>
        <div class="metric"><span class="muted">实时刷新</span><strong id="metric-time">—</strong></div>
      </section>

      <section class="dashboard-grid">
        <div class="panel card">
          <div class="panel-head">
            <div><h2>ETF池数据</h2><p class="status-line" id="status-line">准备加载数据…</p></div>
            <span class="pill" id="date-pill">评估日期 —</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead><tr><th>名称</th><th>代码</th><th>类型</th><th>得分</th><th>动作</th><th>裁决</th><th>5日%</th><th>20日%</th><th>斜率R²</th><th>量比</th><th>位置</th><th>冷却</th><th>风险</th></tr></thead>
              <tbody id="etf-body"><tr><td colspan="13">加载中…</td></tr></tbody>
            </table>
          </div>
        </div>

        <aside class="side-stack">
          <div class="panel card">
            <div class="panel-head"><h3>组合经理裁决</h3><span class="pill pill-red">Top 5</span></div>
            <div class="rec-list" id="recommendations"></div>
          </div>
          <div class="panel card">
            <div class="panel-head"><h3>今日结论</h3><span class="pill">右侧雷达</span></div>
            <ul class="explain-list" id="today-notes"></ul>
          </div>
          <div class="panel card">
            <div class="panel-head"><h3>策略参数</h3></div>
            <ul class="explain-list">
              <li><strong>动量Agent：</strong>近5日强度 + 20/60日斜率R²，过滤弱反抽。</li>
              <li><strong>资金Agent：</strong>用成交量比代理资金质量，后续叠加MX主力净流入。</li>
              <li><strong>风险Agent：</strong>高位过热、缩量冲高、跌破20日线进入冷却/降权。</li>
              <li><strong>组合经理：</strong>输出加仓/持有/观察/减仓/退出与建议仓位。</li>
            </ul>
          </div>
        </aside>
      </section>
    </main>
    <Footer />

    <script>
      const DATA_URL = '/data/etf-garden-pool.json';
      const LIVE_URL = 'https://etf-live.peekabo.cc/api/etf-garden/live';
      const $ = (id) => document.getElementById(id);
      let payload = null;
      let rawRows = [];
      let livePayload = null;
      let liveTimer = null;
      const fmt = (v, digits = 2) => Number.isFinite(Number(v)) ? Number(v).toFixed(digits) : '—';
      const cls = (v) => Number(v) >= 0 ? 'up' : 'down';
      const passTag = (ok) => `<span class="tag ${ok ? 'pass' : 'fail'}">${ok ? '🟢' : '🔴'}</span>`;
      function applyLiveRows(rows) {
        const liveMap = new Map((livePayload?.items || []).map(x => [x.code, x]));
        return rows.map(row => {
          const live = liveMap.get(row.code);
          if (!live || !Number.isFinite(Number(live.price))) return row;
          const price = Number(live.price);
          const base3 = Number(row.ret3);
          const base10 = Number(row.ret10);
          const base20 = Number(row.ret20);
          const oldPrice = Number(row.price);
          const adjustReturn = (base) => Number.isFinite(base) && Number.isFinite(oldPrice) && oldPrice > 0
            ? (((1 + base / 100) * price / oldPrice) - 1) * 100
            : base;
          const ret3 = adjustReturn(base3);
          const ret10 = adjustReturn(base10);
          const ret20 = adjustReturn(base20);
          const ma20 = Number(row.ma20);
          const ma20Prev = Number(row.ma20_prev);
          const priceAboveMa = Number.isFinite(ma20) ? price > ma20 : row.checks?.price_above_ma;
          const maRising = Number.isFinite(ma20) && Number.isFinite(ma20Prev) ? ma20 > ma20Prev : row.checks?.ma_rising;
          const shortOk = Number.isFinite(ret3) ? ret3 > -5 : row.checks?.short_ok;
          const momentum = Boolean(priceAboveMa && maRising && shortOk);
          return {
            ...row,
            price,
            prev_close: live.prev_close ?? row.prev_close,
            change_pct: live.change_pct ?? row.change_pct,
            high: live.high ?? row.high,
            low: live.low ?? row.low,
            quote_source: live.source || row.quote_source,
            ret3: Number.isFinite(ret3) ? Number(ret3.toFixed(2)) : row.ret3,
            ret10: Number.isFinite(ret10) ? Number(ret10.toFixed(2)) : row.ret10,
            ret20: Number.isFinite(ret20) ? Number(ret20.toFixed(2)) : row.ret20,
            status: momentum ? 'core' : (row.status === 'cash' ? 'cash' : 'watch'),
            checks: {
              ...(row.checks || {}),
              price_above_ma: priceAboveMa,
              ma_rising: maRising,
              short_ok: shortOk,
              momentum,
            },
            live: true,
          };
        });
      }
      function buildLiveSummary(rows) {
        const core = rows.filter(r => r.status === 'core' && r.cooldown_state !== '止损观察');
        return {
          ...(payload?.summary || {}),
          universe_count: rows.length,
          valid_count: rows.filter(r => Number.isFinite(Number(r.price))).length,
          core_count: core.length,
          watch_count: rows.filter(r => r.status === 'watch').length,
          momentum_pass_count: core.length,
        };
      }
      function buildLiveRecommendations(rows) {
        const weights = [25, 20, 15, 15, 10];
        return [...rows]
          .filter(r => r.status === 'core' && r.cooldown_state !== '止损观察')
          .sort((a, b) => (Number(b.signal_score) || -Infinity) - (Number(a.signal_score) || -Infinity))
          .slice(0, 5)
          .map((r, i) => ({ ...r, recommended_weight: r.recommended_weight || r.suggested_weight || weights[i] || 10 }));
      }
      function render() {
        const type = $('type-filter').value;
        const sortKey = $('sort-key').value;
        $('ma-head').textContent = 'MA20';
        $('ma-prev-head').textContent = 'MA20(5日前)';
        let rows = applyLiveRows(rawRows);
        rows.sort((a, b) => (Number(b[sortKey === 'ret20' ? 'signal_score' : sortKey]) || -Infinity) - (Number(a[sortKey === 'ret20' ? 'signal_score' : sortKey]) || -Infinity));
        const summary = buildLiveSummary(rows);
        const recommendations = buildLiveRecommendations(rows);
        if (type !== '全部') rows = rows.filter(r => r.type === type);
        if ($('absolute-only').checked) rows = rows.filter(r => r.status === 'core' && r.cooldown_state !== '止损观察');
        const recCodes = new Set(recommendations.map(r => r.code));
        const totalAfterFilter = rows.length;
        const liveTime = livePayload?.generated_at ? livePayload.generated_at.replace(' UTC+08:00', '').slice(11, 16) : null;
        $('metric-total').textContent = `${summary.universe_count || rows.length}只`;
        $('metric-pass').textContent = `${summary.core_count || rows.filter(r => r.status === 'core' && r.cooldown_state !== '止损观察').length}只`;
        $('metric-rec').textContent = recommendations.map(r => r.code).join(' / ') || '空仓';
        $('metric-regime').textContent = payload?.market_regime?.state || '—';
        $('metric-time').textContent = liveTime || new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
        $('date-pill').textContent = `评估 ${payload?.evaluation_date || payload?.run_date || '—'}｜行情 ${payload?.latest_trade_date || '—'}${liveTime ? `｜实时 ${liveTime}` : ''}`;
        $('status-line').textContent = `当前显示 ${rows.length}/${totalAfterFilter} 只，动量通过 ${summary.core_count || 0} 只，实时行情：${livePayload?.source || payload?.quote_source || 'stock-api'}${livePayload?.latency_ms ? `，延迟 ${livePayload.latency_ms}ms` : ''}`;
        $('etf-body').innerHTML = rows.map(r => {
          const risks = (r.risk_flags || []).slice(0, 2).join(' / ') || '—';
          return `<tr class="${recCodes.has(r.code) ? 'recommended' : ''}"><td><strong>${r.name}</strong>${recCodes.has(r.code) ? ' <span class="tag pass">🟢</span>' : ''}</td><td>${r.code}</td><td>${r.type}</td><td>${fmt(r.signal_score)}</td><td>${r.action || '观察'}</td><td>${r.portfolio_verdict || '—'}</td><td class="${cls(r.ret5)}">${fmt(r.ret5)}</td><td class="${cls(r.ret20)}">${fmt(r.ret20)}</td><td>${fmt(r.slope20_score, 3)}</td><td>${fmt(r.volume_ratio)}</td><td>${fmt(Number(r.close_position) * 100, 0)}%</td><td>${r.cooldown_state || '正常'}</td><td>${risks}</td></tr>`;
        }).join('') || '<tr><td colspan="13">当前筛选下无ETF。</td></tr>';
        $('recommendations').innerHTML = recommendations.map((r, i) => {
          const scores = r.agent_scores || {};
          const bull = (r.agent_bull || []).slice(0, 2).join('；');
          const bear = (r.agent_bear || []).slice(0, 2).join('；');
          return `<div class="rec-card"><div class="rec-top"><h3>${i + 1}. ${r.name}</h3><div class="rec-code">${r.code}｜得分 ${fmt(r.signal_score)}｜${r.action || '观察'}</div></div><p class="rec-metrics"><span><strong>5日：</strong><span class="${cls(r.ret5)}">${fmt(r.ret5)}%</span>；<strong>20日：</strong><span class="${cls(r.ret20)}">${fmt(r.ret20)}%</span></span><span><strong>仓位：</strong>${r.recommended_weight || r.suggested_weight || 0}%；<strong>冷却：</strong>${r.cooldown_state || '正常'}</span></p><div class="agent-grid"><div class="agent-box"><strong>多头：</strong>${bull}</div><div class="agent-box"><strong>空头：</strong>${bear}</div><div class="agent-box"><strong>动量/资金：</strong>${fmt(scores['动量Agent'])}/${fmt(scores['资金Agent'])}</div><div class="agent-box"><strong>风控/组合：</strong>${fmt(scores['风险Agent'])}/${fmt(scores['组合经理'])}</div></div><span class="verdict">${r.portfolio_verdict || '组合经理待确认'}</span><div class="rec-tags"><span class="tag">${r.type}</span><span class="tag pass">${r.quote_source || 'stock-api'}</span><span class="tag watch">${r.risk_level || '中'}风险</span></div></div>`;
        }).join('') || '<p class="muted">当前无ETF满足TradingAgents v2准入，按空仓/防御策略处理。</p>';
        const weak = [...rawRows].sort((a, b) => (Number(a.ret20) || Infinity) - (Number(b.ret20) || Infinity)).slice(0, 3);
        $('today-notes').innerHTML = [
          `<li><strong>ETF花园 71 池：</strong>覆盖宽基/海外/行业/商品/LOF 五大类，评估日期 ${payload?.evaluation_date || '—'}。</li>`,
          recommendations.length ? `<li><strong>组合经理：</strong>${recommendations.map(r => `${r.name} ${r.code}(${r.action || '观察'})`).join(' + ')}，按多Agent综合得分选前 ${recommendations.length} 名。</li>` : '<li><strong>空仓策略：</strong>绝对动量为空时看银华日利ETF 511880。</li>',
          weak.length ? `<li><strong>弱势尾部：</strong>${weak.map(r => `${r.name} ${fmt(r.ret20)}%`).join('，')}。</li>` : '',
          `<li><strong>市场状态：</strong>${payload?.market_regime?.state || '—'}，权益仓 ${payload?.market_regime?.equity_allocation || '—'}，防御仓 ${payload?.market_regime?.defense_allocation || '—'}。</li>`,
          '<li><strong>本站口径：</strong>TradingAgents v2 多Agent评分；K线/价格由 stock-api v2.7.2 更新。</li>'
        ].join('');
        pinTableHeader();
      }
      function pinTableHeader() {
        const wrap = document.querySelector('.table-wrap');
        const head = document.querySelector('thead');
        if (!wrap || !head) return;
        head.style.transform = `translateY(${wrap.scrollTop}px)`;
      }
      async function loadLive() {
        if (!payload) return;
        try {
          livePayload = await fetch(`${LIVE_URL}?t=${Date.now()}`, { cache: 'no-store' }).then(r => {
            if (!r.ok) throw new Error(`HTTP ${r.status}`);
            return r.json();
          });
          render();
        } catch (err) {
          $('status-line').innerHTML = `<span class="error">实时行情暂时不可用：${err.message}；已保留最新静态快照。</span>`;
        }
      }
      async function load() {
        $('refresh-btn').disabled = true;
        $('refresh-btn').textContent = '刷新中…';
        $('status-line').textContent = '正在读取 ETF花园 71 池基准快照…';
        try {
          payload = await fetch(`${DATA_URL}?t=${Date.now()}`).then(r => r.json());
          rawRows = payload.all_rows || [...(payload.core_pool || []), ...(payload.watch_pool || [])];
          render();
          await loadLive();
          if (!liveTimer) liveTimer = setInterval(loadLive, 3000);
        } catch (err) {
          $('status-line').innerHTML = `<span class="error">加载失败：${err.message}</span>`;
          $('etf-body').innerHTML = `<tr><td colspan="13">轮动池加载失败，请稍后刷新。</td></tr>`;
        } finally {
          $('refresh-btn').disabled = false;
          $('refresh-btn').textContent = '刷新数据';
        }
      }
      ['type-filter', 'sort-key', 'absolute-only'].forEach(id => $(id).addEventListener('change', render));
      $('ma-period').disabled = true;
      $('refresh-btn').addEventListener('click', loadLive);
      document.querySelector('.table-wrap').addEventListener('scroll', pinTableHeader, { passive: true });
      load();
    </script>
  </body>
</html>
