---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { isDailyReviewPost, sortByPubDateDesc } from '../../lib/posts';

const posts = (await getCollection('blog')).filter(isDailyReviewPost).sort(sortByPubDateDesc);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`每日复盘 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.archive-head { padding: 3rem 0 1.5rem; max-width: 860px; }
			.archive-head p { color: rgb(var(--gray)); font-size: 1.12rem; }
			.kicker { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-bottom: 0.75rem; }
			ul { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; list-style-type: none; margin: 0; padding: 0; }
			ul li:first-child { grid-column: 1 / -1; }
			.post-card { display: grid; grid-template-columns: 1fr; gap: 0.8rem; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; min-height: 13rem; }
			ul li:first-child .post-card { min-height: 15rem; background: linear-gradient(135deg, #fff, var(--accent-soft)); }
			.post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
			.post-card img { width: 100%; margin-bottom: 0.5rem; }
			.title { margin: 0; color: rgb(var(--black)); }
			.date { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
			.description { margin: 0; color: rgb(var(--gray)); }
			.notice { margin: 1.25rem 0 1.5rem; padding: 1rem 1.15rem; }
			@media (max-width: 820px) { ul { grid-template-columns: 1fr; } }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="archive-head">
				<div class="kicker"><span class="pill pill-red">每日复盘</span><span class="pill">ETF轮动并入花园解释层</span></div>
				<h1>ETF花园每日预测、盘中修正与收盘复盘</h1>
				<p>这里只保留ETF轮动相关日报。个股文章已从主归档中过滤，旧链接继续作为历史资料访问。</p>
			</section>
			<section class="notice card">
				<strong>归档口径</strong>
				<p>每日复盘解释花园信号为什么进库、为什么出库、明天怎么验证；ETF花园页负责承载准备种花、种花、准备摘花、摘花的状态库。</p>
			</section>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a class="post-card" href={`/blog/${post.id}/`}>
									{post.data.heroImage && <Image width={720} height={360} src={post.data.heroImage} alt="" />}
									<div><span class="pill pill-red">{post.data.category ?? 'ETF复盘'}</span><h2 class="title">{post.data.title}</h2></div>
									<p class="description">{post.data.description}</p>
									<p class="date"><FormattedDate date={post.data.pubDate} /></p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
