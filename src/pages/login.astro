---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title="登录回测实验室｜ETF罗盘" description="登录ETF罗盘回测实验室，上传有操作ETF名单并查看验证结果。" />
  <style>
    main { width: min(520px, calc(100% - 1.5rem)); margin: auto; padding: clamp(2rem, 8vw, 5rem) 0; }
    .card { padding: clamp(1.25rem, 4vw, 2rem); border: 1px solid var(--border); border-radius: 20px; background: var(--paper); box-shadow: var(--box-shadow); }
    .kicker { color: var(--accent-dark); font-size: .72rem; font-weight: 900; letter-spacing: .12em; }
    h1 { margin: .45rem 0 .6rem; font-size: clamp(1.8rem, 5vw, 2.7rem); letter-spacing: -.04em; }
    p { color: rgb(var(--gray)); line-height: 1.7; }
    label { display: grid; gap: .35rem; margin-top: 1rem; color: rgb(var(--gray-dark)); font-size: .86rem; font-weight: 800; }
    input { width: 100%; box-sizing: border-box; padding: .75rem .8rem; border: 1px solid var(--border); border-radius: 10px; background: #fff; color: rgb(var(--black)); font: inherit; }
    button { width: 100%; margin-top: 1.1rem; padding: .75rem .9rem; border: 0; border-radius: 10px; background: #14243b; color: #fff; font: inherit; font-weight: 850; cursor: pointer; }
    button:disabled { opacity: .6; cursor: wait; }
    .status { min-height: 1.3rem; margin-top: .85rem; color: #a33b32; font-size: .88rem; }
    .hidden { display: none; }
  </style>
</head>
<body>
  <Header />
  <main>
    <section class="card" aria-labelledby="title">
      <span class="kicker">ETF COMPASS LAB</span>
      <h1 id="title">登录回测实验室</h1>
      <p>上传“有操作ETF名单”，自动验证触价、收盘站回和T+1表现。</p>
      <form id="login-form">
        <label>用户名<input name="username" autocomplete="username" required /></label>
        <label>密码<input name="password" type="password" autocomplete="current-password" required /></label>
        <button type="submit">登录</button>
      </form>
      <form id="change-form" class="hidden">
        <p>这是初始密码，请先设置个人密码。</p>
        <label>当前密码<input name="old_password" type="password" autocomplete="current-password" required /></label>
        <label>新密码<input name="new_password" type="password" autocomplete="new-password" minlength="10" required /></label>
        <button type="submit">修改密码并进入</button>
      </form>
      <div id="status" class="status" role="status" aria-live="polite"></div>
    </section>
  </main>
  <Footer />
  <script>
    const loginForm = document.querySelector('#login-form');
    const changeForm = document.querySelector('#change-form');
    const status = document.querySelector('#status');
    const setStatus = (message = '') => { status.textContent = message; };
    loginForm.addEventListener('submit', async (event) => {
      event.preventDefault(); setStatus('登录中…');
      const body = Object.fromEntries(new FormData(loginForm));
      const response = await fetch('/api/auth/login', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body) });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) { setStatus(data.error || '登录失败'); return; }
      if (data.user.must_change_password) {
        loginForm.classList.add('hidden'); changeForm.classList.remove('hidden');
        changeForm.elements.old_password.value = body.password; setStatus('请先修改初始密码'); return;
      }
      location.href = '/lab/';
    });
    changeForm.addEventListener('submit', async (event) => {
      event.preventDefault(); setStatus('保存中…');
      const body = Object.fromEntries(new FormData(changeForm));
      const response = await fetch('/api/auth/change-password', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body) });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) { setStatus(data.error || '修改失败'); return; }
      location.href = '/lab/';
    });
  </script>
</body>
</html>
