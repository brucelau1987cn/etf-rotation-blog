---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import UsSubnav from '../components/UsSubnav.astro';

const data = JSON.parse(readFileSync(join(process.cwd(), 'public/data/us-macro-dashboard.json'), 'utf8'));
const toneIcon = (tone: string) => tone === 'danger' ? '🔴' : tone === 'warning' ? '🟠' : tone === 'positive' ? '🟢' : tone === 'missing' ? '⚪' : '🟡';
const riskIcon = data.risk.key === 'danger' ? '🔴' : data.risk.key === 'tight' ? '🟠' : data.risk.key === 'slightly-tight' ? '🟡' : '🟢';
const dateTime = (raw: string) => raw ? raw.replace('T', ' ').replace(/\.\d+/, '').replace(/-\d\d:\d\d$/, ' ET') : '—';
const calendarDate = (raw: string) => raw ? new Intl.DateTimeFormat('zh-CN', { month: 'short', day: 'numeric', timeZone: 'America/New_York' }).format(new Date(`${raw}T12:00:00-04:00`)) : '—';
const marketCards = [
  { key:'dollar', label:'美元指数', symbol:'DXY', impact:'全球流动性' },
  { key:'oil', label:'原油代理', symbol:'USO', impact:'能源与通胀' },
  { key:'gold', label:'黄金', symbol:'GLD', impact:'避险与实际利率' },
  { key:'copper', label:'铜矿代理', symbol:'COPX', impact:'工业周期' },
].map((item) => ({...item, ...(data.market[item.key] || {})}));
---
<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title="美股宏观雷达｜风险与事件终端" description="美股宏观风险雷达：波动率、利率曲线、流动性、信用广度、事件日历及ETF影响映射。" />
  <style>
    :root{--terminal:#122033;--terminal-2:#1b304a;--ink:#142033;--muted:#64748b;--line:#dce4ee;--blue:#2563eb;--green:#137547;--orange:#c96a13;--red:#c5221f}
    main{width:min(1180px,calc(100% - 1.5rem));padding:1rem 0 3.5rem}.macro-hero{position:relative;overflow:hidden;padding:clamp(1.05rem,3vw,1.7rem);color:#fff;background:linear-gradient(135deg,var(--terminal),var(--terminal-2) 65%,#244666)}.macro-hero:after{content:"";position:absolute;width:340px;height:340px;right:-130px;top:-180px;border:1px solid rgba(255,255,255,.12);border-radius:50%;box-shadow:0 0 0 55px rgba(255,255,255,.025),0 0 0 110px rgba(255,255,255,.02)}.hero-top,.risk-command{position:relative;z-index:1}.hero-top{display:flex;justify-content:space-between;gap:1rem;align-items:flex-start}.eyebrow{font-size:.72rem;font-weight:900;letter-spacing:.14em;color:#a8c7f5}.hero-top h1{margin:.35rem 0 .3rem;color:#fff;font-size:clamp(2rem,5vw,3.35rem);letter-spacing:-.04em}.hero-top p{margin:0;max-width:62ch;color:#cad7e7;line-height:1.6}.hero-meta{display:grid;gap:.25rem;text-align:right;color:#b8c7da;font-size:.75rem}.risk-command{display:grid;grid-template-columns:auto 1fr auto;gap:1rem;align-items:center;margin-top:1.3rem;padding:1rem;border:1px solid rgba(255,255,255,.15);border-radius:18px;background:rgba(255,255,255,.07);backdrop-filter:blur(8px)}.risk-icon{font-size:2rem}.risk-command span{display:block;color:#aebfd3;font-size:.7rem;font-weight:850;letter-spacing:.08em}.risk-command strong{display:block;color:#fff;font-size:1.3rem}.risk-command p{margin:.2rem 0 0;color:#cad7e7;font-size:.82rem}.allocation{padding:.6rem .8rem;border-radius:12px;background:#fff;color:var(--ink);text-align:right}.allocation small{display:block;color:var(--muted);font-size:.68rem}.allocation b{font-size:.88rem}.section-head{display:flex;justify-content:space-between;align-items:end;gap:1rem;margin:1.6rem 0 .7rem}.section-head h2{margin:.2rem 0 0;font-size:1.45rem}.section-head p{margin:0;color:var(--muted);font-size:.78rem}.section-kicker{color:var(--blue);font-size:.68rem;font-weight:950;letter-spacing:.12em}.dimension-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.7rem}.dimension{padding:1rem;border-top:4px solid #94a3b8}.dimension.positive{border-top-color:var(--green)}.dimension.warning{border-top-color:var(--orange)}.dimension.danger{border-top-color:var(--red)}.dimension.missing{border-top-color:#94a3b8;background:#fafbfc}.dim-top{display:flex;justify-content:space-between;gap:.5rem}.dim-top span{color:var(--muted);font-size:.72rem;font-weight:850}.dim-state{padding:.16rem .42rem;border-radius:999px;background:#f1f5f9;color:var(--ink)!important}.dimension h3{margin:.75rem 0 .22rem;font-size:1.35rem}.dimension>p{min-height:2.5em;margin:.2rem 0;color:var(--muted);font-size:.78rem;line-height:1.55}.dim-impact{margin-top:.7rem;padding:.55rem .6rem;border-radius:9px;background:#f6f8fb;font-size:.75rem}.symbols{display:flex;flex-wrap:wrap;gap:.25rem;margin-top:.6rem}.symbols b{padding:.18rem .38rem;border-radius:6px;background:#eaf1fb;color:#31557d;font-size:.65rem}.asof{display:block;margin-top:.6rem;color:#94a3b8;font-size:.64rem}.fund-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.7rem}.fund{padding:.9rem}.fund.missing{background:#f8fafc}.fund-top{display:flex;justify-content:space-between;gap:.5rem;color:var(--muted);font-size:.72rem;font-weight:850}.fund h3{margin:.5rem 0 .35rem;font-size:1.25rem}.fund p{margin:0;color:var(--muted);font-size:.75rem;line-height:1.5}.fund small{display:block;margin-top:.55rem;color:#94a3b8;font-size:.66rem}.event-layout{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(0,.85fr);gap:.75rem;align-items:start}.events,.impact-map{padding:1rem}.event{display:grid;grid-template-columns:70px 1fr auto;gap:.7rem;align-items:center;padding:.75rem 0;border-bottom:1px solid var(--line)}.event:last-child{border:0}.event-date b{display:block;font-size:1rem}.event-date small{color:var(--muted)}.event h3{margin:0;font-size:.95rem}.event p{margin:.18rem 0 0;color:var(--muted);font-size:.75rem}.event-tag{padding:.25rem .5rem;border-radius:999px;background:#fff4e8;color:var(--orange);font-size:.68rem;font-weight:900}.impact{padding:.7rem 0;border-bottom:1px solid var(--line)}.impact:last-child{border:0}.impact strong{display:block;font-size:.88rem}.impact-row{display:flex;flex-wrap:wrap;gap:.35rem;margin:.35rem 0;color:var(--muted);font-size:.72rem}.impact-row b{color:var(--ink)}.impact p{margin:.3rem 0 0;font-size:.75rem}.pulse-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.6rem}.pulse{padding:.8rem}.pulse span{display:block;color:var(--muted);font-size:.68rem}.pulse strong{display:block;margin:.25rem 0;font-size:1.15rem}.pulse small{color:var(--muted)}.quality{margin-top:1.3rem;padding:.85rem 1rem}.quality summary{cursor:pointer;font-weight:900}.quality-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem;margin-top:.7rem}.quality-grid div{padding:.65rem;background:#f6f8fb;border-radius:10px}.quality-grid span{display:block;color:var(--muted);font-size:.67rem}.quality-grid b{font-size:.78rem}.links{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.8rem}.links a{padding:.4rem .65rem;border:1px solid var(--line);border-radius:999px;text-decoration:none;font-size:.74rem;font-weight:850}
    @media(max-width:900px){.dimension-grid,.pulse-grid,.fund-grid{grid-template-columns:repeat(2,1fr)}.event-layout{grid-template-columns:1fr}.hero-top{display:grid}.hero-meta{text-align:left}.risk-command{grid-template-columns:auto 1fr}.allocation{grid-column:1/-1;text-align:left}}
    @media(max-width:620px){main{width:min(100% - 1rem,1180px);padding-top:1rem}.macro-hero{padding:1rem}.hero-top h1{font-size:2rem}.hero-meta span:nth-child(2){display:none}.risk-command{gap:.65rem;padding:.75rem}.risk-icon{font-size:1.45rem}.risk-command strong{font-size:1.05rem}.dimension-grid,.fund-grid{grid-template-columns:1fr}.pulse-grid{grid-template-columns:repeat(2,1fr)}.event{grid-template-columns:58px 1fr}.event-tag{display:none}.section-head{align-items:flex-start}.quality-grid{grid-template-columns:1fr}}
  </style>
</head>
<body><Header /><main class="site-shell"><UsSubnav active="macro" />
  <section class="macro-hero card">
    <div class="hero-top"><div><span class="eyebrow">US MACRO RISK TERMINAL</span><h1>美股宏观雷达</h1><p>先决定风险预算，再选择ETF，最后等待关键价位。宏观只约束仓位，不替代交易触发。</p></div><div class="hero-meta"><span>数据截止 {dateTime(data.generated_at)}</span><span>时区 America/New_York</span><span>免费公开数据 · 无券商权限</span></div></div>
    <div class="risk-command"><div class="risk-icon">{riskIcon}</div><div><span>MACRO RISK GATE</span><strong>{data.risk.label} · {data.risk.headline}</strong><p>{data.risk.equity_constraint}</p></div><div class="allocation"><small>风险评分 · 越高风险越大</small><b>{data.risk.score} / 10</b></div></div>
  </section>

  <section><div class="section-head"><div><span class="section-kicker">FOUR-DIMENSION GATE</span><h2>四维风险矩阵</h2></div><p>每张卡使用自己的观察日期，避免把低频数据伪装成实时。</p></div><div class="dimension-grid">{data.dimensions.map((item: any) => <article class={`dimension card ${item.tone}`}><div class="dim-top"><span>{item.title}</span><span class="dim-state">{toneIcon(item.tone)} {item.state}</span></div><h3>{item.headline}</h3><p>{item.detail}</p><div class="dim-impact">{item.impact}</div><div class="symbols">{item.symbols.map((symbol: string) => <b>{symbol}</b>)}</div><small class="asof">观察日 {item.as_of || 'N/A'}</small></article>)}</div></section>

  <section><div class="section-head"><div><span class="section-kicker">LIQUIDITY LEDGER</span><h2>利率与流动性底表</h2></div><p>SOFR与ON RRP来自纽约联储，Fed资产来自H.4.1，TGA来自财政部；频率不同，不伪装成盘中实时流量。</p></div><div class="fund-grid">{(data.liquidity_components || []).map((item:any) => <article class={`fund card ${item.tone}`}><div class="fund-top"><span>{item.title}</span><span>{item.stale ? '旧快照' : item.frequency}</span></div><h3>{item.value}</h3><p>{item.detail}</p><small>观察日 {item.as_of || 'N/A'} · {item.source_url ? <a href={item.source_url} target="_blank" rel="noreferrer">{item.source} ↗</a> : item.source}</small></article>)}</div></section>

  <section><div class="section-head"><div><span class="section-kicker">ECONOMIC FUNDAMENTALS</span><h2>就业、通胀与增长景气</h2></div><p>月度与季度数据只调整风险预算，不替代ETF价格触发。</p></div><div class="fund-grid">{(data.fundamentals || []).map((item:any) => <article class={`fund card ${item.tone}`}><div class="fund-top"><span>{item.title}</span><span>{item.stale ? '旧快照' : item.frequency}</span></div><h3>{item.value}</h3><p>{item.detail}</p><small>观察日 {item.as_of || 'N/A'} · {item.source_url ? <a href={item.source_url} target="_blank" rel="noreferrer">{item.source} ↗</a> : item.source}</small></article>)}</div></section>

  <section><div class="section-head"><div><span class="section-kicker">EVENT & ETF IMPACT</span><h2>事件与ETF影响</h2></div><p>只有会改变执行的事件才升级为告警。</p></div><div class="event-layout"><div class="events card"><h3>未来核心事件</h3>{data.events.length ? data.events.map((event:any) => <article class="event"><div class="event-date"><b>{calendarDate(event.date)}</b><small>{event.time_et} ET</small></div><div><h3>{event.title}</h3><p>{event.discipline} · 影响 {event.symbols.join(' / ')}</p></div><span class="event-tag">{event.importance}影响</span></article>) : <p>官方事件日历暂未获得可靠数据，不猜测日期。</p>}</div><div class="impact-map card"><h3>当前冲击映射</h3>{data.impacts.map((item:any) => <article class="impact"><strong>{item.driver}</strong><div class="impact-row">受益 <b>{item.benefit.length ? item.benefit.join(' / ') : '—'}</b> · 承压 <b>{item.pressure.length ? item.pressure.join(' / ') : '—'}</b></div><p>{item.discipline}</p></article>)}</div></div></section>

  <section><div class="section-head"><div><span class="section-kicker">CROSS-ASSET PULSE</span><h2>跨资产脉搏</h2></div><p>只作方向验证，不冒充资金净流入。</p></div><div class="pulse-grid">{marketCards.map((item:any) => <article class="pulse card"><span>{item.label} · {item.symbol}</span><strong>{typeof item.value === 'number' ? item.value.toFixed(2) : 'N/A'}</strong><small>{item.stale ? '旧快照 · ' : ''}{typeof item.change_5d_pct === 'number' ? `5日 ${item.change_5d_pct >= 0 ? '+' : ''}${item.change_5d_pct.toFixed(2)}%` : '数据暂缺'} · {item.impact}</small></article>)}</div></section>

  <details class="quality card"><summary>数据质量、来源与口径</summary><div class="quality-grid"><div><span>免费来源</span><b>{data.sources.join(' · ')}</b></div><div><span>本轮缺失</span><b>{data.data_quality.failed}项</b></div><div><span>风险口径</span><b>波动＋利率＋信用，不机械数灯</b></div></div><p>{data.data_quality.note} 缺失值显示N/A，不使用模型猜测补值。</p><div class="links"><a href="/us-compass/">返回今日动作</a><a href="/us-momentum/">查看趋势风控</a><a href="/us-compass/history/">历史成绩</a></div></details>
</main><Footer /></body></html>
