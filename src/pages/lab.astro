---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title="回测实验室｜ETF罗盘" description="上传ETF名单并查看回测任务。" />
  <style>
    main { width: min(980px, calc(100% - 1.5rem)); margin: auto; padding: 2rem 0 5rem; }
    .hero, .panel { padding: clamp(1.1rem, 3vw, 1.7rem); border: 1px solid var(--border); border-radius: 18px; background: var(--paper); box-shadow: var(--box-shadow); }
    .hero { background: linear-gradient(135deg, #122033, #244666); color: white; }
    .kicker { color: #b9dfdc; font-size: .72rem; font-weight: 900; letter-spacing: .12em; }
    h1 { margin: .45rem 0 .5rem; font-size: clamp(1.8rem, 5vw, 2.8rem); letter-spacing: -.04em; }
    .hero p { margin: 0; color: #dceaf1; }
    .grid { display: grid; grid-template-columns: minmax(260px, .8fr) minmax(0, 1.2fr); gap: 1rem; margin-top: 1rem; }
    h2 { margin: 0 0 .8rem; font-size: 1.05rem; }
    input[type=file] { width: 100%; box-sizing: border-box; padding: .8rem; border: 1px dashed var(--border); border-radius: 12px; background: #fff; }
    button { margin-top: .9rem; padding: .68rem .9rem; border: 0; border-radius: 10px; background: #14243b; color: #fff; font: inherit; font-weight: 850; cursor: pointer; }
    .secondary { margin-left: .45rem; background: #e9eef1; color: #23384b; }
    .status { min-height: 1.35rem; margin-top: .7rem; color: rgb(var(--gray)); font-size: .9rem; }
    .jobs { display: grid; gap: .6rem; }
    .job { display: grid; grid-template-columns: 1fr auto; gap: .3rem 1rem; padding: .75rem; border: 1px solid var(--border); border-radius: 12px; }
    .job strong { overflow-wrap: anywhere; }
    .meta { color: rgb(var(--gray)); font-size: .8rem; }
    .summary { grid-column: 1 / -1; display: flex; flex-wrap: wrap; gap: .4rem .8rem; margin-top: .25rem; color: rgb(var(--gray-dark)); font-size: .8rem; }
    .summary span { padding: .2rem .45rem; border-radius: 6px; background: #eef3f4; }
    .job-status { align-self: start; padding: .18rem .45rem; border-radius: 999px; background: #eef3f4; color: #43586a; font-size: .72rem; font-weight: 850; }
    .quality { grid-column: 1 / -1; display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .15rem; }
    .quality span { padding: .18rem .42rem; border-radius: 999px; background: #edf7f1; color: #247047; font-size: .72rem; font-weight: 800; }
    .quality .warning { background: #fff4dc; color: #8a5a00; }
    .method { grid-column: 1 / -1; color: rgb(var(--gray)); font-size: .75rem; }
    .method summary { width: fit-content; cursor: pointer; font-weight: 800; }
    .method p { margin: .35rem 0 0; line-height: 1.55; }
    .empty { color: rgb(var(--gray)); }
    .research-panel { margin-top: 1rem; }
    .audit-panel { margin-top: 1rem; }
    .kronos-panel { margin-top: 1rem; }
    .research-head { display: flex; align-items: end; justify-content: space-between; gap: 1rem; margin-bottom: .8rem; }
    .research-head h2 { margin: 0; }
    .research-head p { margin: 0; color: rgb(var(--gray)); font-size: .8rem; }
    @media (max-width: 720px) { .grid { grid-template-columns: 1fr; } }
  </style>
  <style is:global>
    #audit-content .audit-grid { display: grid; grid-template-columns: repeat(4,minmax(0,1fr)); gap: .65rem; }
    #audit-content .audit-card { padding: .78rem; border: 1px solid var(--border); border-top: 3px solid #66839a; border-radius: 12px; background: #fbfcfd; }
    #audit-content .audit-card.warning { border-top-color: #b7801f; background: #fffaf0; }
    #audit-content .audit-card.buy { border-top-color: var(--action-buy); background: #fff8f6; }
    #audit-content .audit-card.sell { border-top-color: var(--action-sell); background: #f3fbf6; }
    #audit-content .audit-card span { display: block; color: rgb(var(--gray)); font-size: .72rem; }
    #audit-content .audit-card strong { display: block; margin-top: .15rem; font-size: 1.15rem; overflow-wrap: anywhere; }
    #audit-content .audit-card small { display: block; margin-top: .2rem; color: rgb(var(--gray)); line-height: 1.4; }
    #audit-content .audit-details { margin-top: .7rem; border: 1px solid var(--border); border-radius: 11px; background: #fbfcfd; }
    #audit-content .audit-details summary { padding: .65rem .75rem; cursor: pointer; font-size: .8rem; font-weight: 850; }
    #audit-content .audit-detail-body { display: grid; gap: .45rem; padding: 0 .75rem .75rem; }
    #audit-content .audit-row { display: grid; grid-template-columns: minmax(170px,.8fr) 1.4fr; gap: .65rem; padding-top: .45rem; border-top: 1px solid var(--border); font-size: .76rem; }
    #audit-content .audit-row span { color: rgb(var(--gray)); }
    #audit-content code { font-size: .72rem; overflow-wrap: anywhere; }
    #audit-content .audit-note { margin: .6rem 0 0; color: rgb(var(--gray)); font-size: .72rem; line-height: 1.55; }
    #research-content .research-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: .65rem; }
    #research-content .research-card { padding: .78rem; border: 1px solid var(--border); border-top: 3px solid #66839a; border-radius: 12px; background: #fbfcfd; }
    #research-content .research-card.buy { border-top-color: var(--action-buy); background: #fff8f6; }
    #research-content .research-card.sell { border-top-color: var(--action-sell); background: #f3fbf6; }
    #research-content .research-card span { display: block; color: rgb(var(--gray)); font-size: .72rem; }
    #research-content .research-card strong { display: block; margin-top: .15rem; font-size: 1.2rem; }
    #research-content .research-card small { display: block; margin-top: .2rem; color: rgb(var(--gray)); line-height: 1.4; }
    #research-content .validation { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: .55rem; margin-top: .7rem; }
    #research-content .validation div { padding: .62rem .7rem; border-radius: 10px; background: #eef3f4; font-size: .78rem; }
    #research-content .validation b { display: block; margin-top: .12rem; }
    #research-content .research-note { margin: .5rem 0 0; color: rgb(var(--gray)); font-size: .72rem; }
    #research-content .watch-list { display: grid; gap: .4rem; margin-top: .75rem; }
    #research-content .watch-row { display: grid; grid-template-columns: minmax(150px,1fr) 2fr; gap: .55rem; align-items: center; padding: .5rem .65rem; border: 1px solid var(--border); border-radius: 9px; font-size: .78rem; }
    #research-content .tags { display: flex; flex-wrap: wrap; gap: .28rem; }
    #research-content .tag { padding: .12rem .38rem; border-radius: 999px; background: #edf2f4; color: #445867; font-weight: 800; }
    #research-content .tag.buy { background: #fff0ef; color: var(--action-buy); }
    #research-content .tag.sell { background: #e9f7ef; color: var(--action-sell); }
    #kronos-content .kronos-grid { display: grid; grid-template-columns: repeat(4,minmax(0,1fr)); gap: .65rem; }
    #kronos-content .kronos-card { padding: .78rem; border: 1px solid var(--border); border-top: 3px solid #6c62a7; border-radius: 12px; background: #faf9ff; }
    #kronos-content .kronos-card span { display: block; color: rgb(var(--gray)); font-size: .72rem; }
    #kronos-content .kronos-card strong { display: block; margin-top: .15rem; font-size: 1.2rem; }
    #kronos-content .kronos-card strong span { display: inline; color: inherit; font-size: inherit; }
    #kronos-content .kronos-card small { display: block; margin-top: .2rem; color: rgb(var(--gray)); line-height: 1.4; }
    #kronos-content .kronos-list { display: grid; gap: .4rem; margin-top: .75rem; }
    #kronos-content .kronos-row { display: grid; grid-template-columns: minmax(170px,1fr) auto minmax(210px,1fr); gap: .65rem; align-items: center; padding: .52rem .65rem; border: 1px solid var(--border); border-radius: 9px; font-size: .78rem; }
    #kronos-content .kronos-return { font-size: .9rem; font-weight: 900; }
    #kronos-content .kronos-range { color: rgb(var(--gray)); text-align: right; }
    #kronos-content .quality-warning { color: #9a6500; font-weight: 800; }
    #kronos-content .kronos-note { margin: .6rem 0 0; color: rgb(var(--gray)); font-size: .72rem; line-height: 1.55; }
    @media (max-width: 720px) { #audit-content .audit-grid, #research-content .research-grid, #kronos-content .kronos-grid { grid-template-columns: repeat(2,1fr); } #audit-content .audit-row { grid-template-columns: 1fr; gap: .2rem; } #research-content .validation { grid-template-columns: 1fr; } #kronos-content .kronos-row { grid-template-columns: 1fr auto; } #kronos-content .kronos-range { grid-column: 1/-1; text-align: left; } }
    @media (max-width: 480px) { #audit-content .audit-grid, #research-content .research-grid, #kronos-content .kronos-grid { grid-template-columns: 1fr; } #research-content .watch-row { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <Header />
  <main>
    <section class="hero"><span class="kicker">ETF COMPASS LAB</span><h1>回测实验室</h1><p id="welcome">正在读取登录状态…</p></section>
    <section class="panel audit-panel" aria-labelledby="audit-title">
      <div class="research-head"><div><h2 id="audit-title">研究审计台</h2><p>数据指纹 · 样本外分折 · 执行阻断 · 筹码POC门禁</p></div><p>旁路研究 · 生产规则未改变</p></div>
      <div id="audit-content"><div class="empty">正在读取研究审计快照…</div></div>
    </section>
    <section class="panel research-panel" aria-labelledby="research-title">
      <div class="research-head"><div><h2 id="research-title">旁路信号增强</h2><p>多周期一致性 · ATR动态防守 · RSI Z-score止盈 · 突破回踩审计</p></div><p>研究层 · 正式信号保持原规则</p></div>
      <div id="research-content"><div class="empty">正在读取研究快照…</div></div>
    </section>
    <section class="panel kronos-panel" aria-labelledby="kronos-title">
      <div class="research-head"><div><h2 id="kronos-title">未来5日影子预测</h2><p>K线基础模型 · 前复权已收盘日线 · 固定参数路径</p></div><p>研究展示与模型审计</p></div>
      <div id="kronos-content"><div class="empty">正在读取未来路径快照…</div></div>
    </section>
    <div class="grid">
      <section class="panel"><h2>上传名单</h2><form id="upload-form"><input name="file" type="file" accept=".csv,text/csv" required /><button type="submit">上传并排队</button><button class="secondary" type="button" id="logout">退出登录</button></form><div class="status" id="status" role="status" aria-live="polite"></div></section>
      <section class="panel"><h2>我的任务</h2><div class="jobs" id="jobs"><div class="empty">正在读取…</div></div></section>
    </div>
  </main>
  <Footer />
  <script>
    const welcome = document.querySelector('#welcome'); const status = document.querySelector('#status'); const jobs = document.querySelector('#jobs');
    const escapeHtml = (value) => String(value ?? '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[ch]));
    const signed = (value, suffix) => { if (value === null || value === undefined || value === '') return '—'; const number = Number(value); if (!Number.isFinite(number)) return '—'; const clean = Math.abs(number) < 0.005 ? 0 : number; return `${clean > 0 ? '+' : ''}${clean.toFixed(2)}${suffix}`; };
    const pct = value => signed(value, '%');
    const pp = value => signed(value, '个百分点');
    const whole = value => { if (value === null || value === undefined || value === '') return '—'; const number = Number(value); return Number.isInteger(number) && number >= 0 ? String(number) : '—'; };
    async function loadAudit() {
      const box = document.querySelector('#audit-content');
      try {
        const response = await fetch(`/data/model-lab/a-share-research-audit.json?cb=${Date.now()}`, { cache: 'no-store' });
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        const data = await response.json(), dataset = data.dataset || {}, provenance = dataset.provenance || {}, walk = data.walk_forward || {}, aggregate = walk.aggregate || {}, execution = data.execution_audit || {}, blockers = execution.blockers || {}, chip = data.chip_poc || {};
        const blockerValue = item => item?.status === 'known' ? whole(item.count) : '未知';
        const avg = Number(aggregate.oos_average_directional_return_pct), oosTone = Number.isFinite(avg) && avg > 0 ? 'buy' : Number.isFinite(avg) && avg < 0 ? 'sell' : '';
        const foldRows = (walk.folds || []).map(fold => `<div class="audit-row"><strong>${escapeHtml(fold.test_start)}—${escapeHtml(fold.test_end)}</strong><span>样本 ${escapeHtml(whole(fold.test?.count))} · 命中 ${escapeHtml(pct(fold.test?.hit_rate_pct))} · 方向收益 ${escapeHtml(pct(fold.test?.average_directional_return_pct))} · 相对训练退化 ${escapeHtml(pp(fold.hit_rate_degradation_pp))}</span></div>`).join('');
        const chipMain = chip.status === 'evaluated' ? `${whole(chip.eligible_symbols)}只已评估` : '数据质量阻断';
        box.innerHTML = `<div class="audit-grid">
          <article class="audit-card"><span>冻结数据指纹</span><strong><code>${escapeHtml(String(dataset.value || '').slice(0,16))}</code></strong><small>${escapeHtml(whole(dataset.record_count))}条方向记录＋${escapeHtml(whole(dataset.pool_row_count))}条当前池｜截至 ${escapeHtml(dataset.as_of || '—')}</small></article>
          <article class="audit-card ${oosTone}"><span>样本外T+1方向</span><strong>${escapeHtml(pct(aggregate.oos_hit_rate_pct))}</strong><small>${escapeHtml(whole(aggregate.fold_count))}折 · ${escapeHtml(whole(aggregate.oos_count))}条 · 平均方向收益 ${escapeHtml(pct(aggregate.oos_average_directional_return_pct))} · 正收益折 ${escapeHtml(pct(aggregate.positive_fold_consistency_pct))}</small></article>
          <article class="audit-card warning"><span>执行数据审计</span><strong>${escapeHtml(blockerValue(blockers.invalid_levels))}条关键位异常</strong><small>陈旧 ${escapeHtml(blockerValue(blockers.stale_rows))} · 数据未知 ${escapeHtml(blockerValue(blockers.unknown_market_data))} · 收盘确认 ${escapeHtml(blockerValue(blockers.pending_close_confirmation))}</small></article>
          <article class="audit-card warning"><span>换手衰减筹码POC</span><strong>${escapeHtml(chipMain)}</strong><small>${escapeHtml(chip.reason || chip.caveat || '仅作研究旁路')}</small></article>
        </div><details class="audit-details"><summary>查看分折、阻断与复现口径</summary><div class="audit-detail-body">
          ${foldRows || '<div class="audit-row"><strong>样本外分折</strong><span>历史样本仍在积累。</span></div>'}
          <div class="audit-row"><strong>盘中严格数据</strong><span>等待收盘确认：${escapeHtml(blockerValue(blockers.pending_close_confirmation))}；缺少严格5分钟：${escapeHtml(blockerValue(blockers.missing_strict_5m_bars))}。运行时数据未进入静态快照时保持“未知”。</span></div>
          <div class="audit-row"><strong>复现口径</strong><span>${escapeHtml(provenance.adjustment || '—')}；${escapeHtml(provenance.execution_basis || '—')}；账户级成本尚未计入方向标签评价。</span></div>
          <div class="audit-row"><strong>推广门禁</strong><span>${(data.promotion_gate?.requirements || []).map(escapeHtml).join('；')}</span></div>
        </div></details><p class="audit-note">该区只做数据质量、样本外稳定性和研究旁路审计。正式动作、权重、关键位、仓位及模拟盘规则保持原状态。</p>`;
      } catch (error) { box.innerHTML = `<div class="empty">研究审计快照读取失败：${escapeHtml(error?.message || error)}</div>`; }
    }
    async function loadResearch() {
      const box = document.querySelector('#research-content');
      try {
        const response = await fetch(`/data/model-lab/a-share-shadow.json?cb=${Date.now()}`, { cache: 'no-store' });
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        const data = await response.json(); const feature = data.signal_enhancement;
        if (!feature) { box.innerHTML = '<div class="empty">研究增强快照尚未生成。</div>'; return; }
        const s = feature.summary, v = feature.historical_validation, br = s.break_retest;
        const priority = item => { const x = item.signal_enhancement; return x.atr_defense.state === 'breached' ? 0 : x.rsi_take_profit.state === 'cooling_trigger' ? 1 : x.break_retest.state === 'armed' ? 2 : x.atr_defense.state === 'near' ? 3 : 4; };
        const selected = (data.items || []).filter(item => { const x = item.signal_enhancement; return x && (x.break_retest.state === 'armed' || x.atr_defense.state !== 'above' || ['overheated','cooling_trigger'].includes(x.rsi_take_profit.state)); }).sort((a,b) => priority(a) - priority(b)).slice(0, 12);
        const rows = selected.map(item => { const x = item.signal_enhancement, tags = [];
          if (x.break_retest.state === 'armed') tags.push('<span class="tag buy">回踩候场</span>');
          if (x.atr_defense.state === 'breached') tags.push('<span class="tag sell">ATR跌破</span>'); else if (x.atr_defense.state === 'near') tags.push('<span class="tag sell">接近ATR防守</span>');
          if (x.rsi_take_profit.state === 'overheated') tags.push('<span class="tag sell">Z-score过热</span>'); else if (x.rsi_take_profit.state === 'cooling_trigger') tags.push('<span class="tag sell">Z-score回落</span>');
          tags.push(`<span class="tag">多周期 ${escapeHtml(x.multi_timeframe.score ?? '—')}</span>`);
          return `<div class="watch-row"><strong>${escapeHtml(item.symbol)} · ${escapeHtml(item.name)}</strong><div class="tags">${tags.join('')}</div></div>`;
        }).join('');
        box.innerHTML = `<div class="research-grid">
          <article class="research-card buy"><span>多周期强一致</span><strong>${escapeHtml(whole(s.multi_timeframe.strong_bullish))}只</strong><small>日/周/60日已收盘信号投票</small></article>
          <article class="research-card sell"><span>ATR动态防守</span><strong>${escapeHtml(whole(s.atr_defense.breached))}跌破 · ${escapeHtml(whole(s.atr_defense.near))}接近</strong><small>2×ATR单向跟踪，当前角色：旁路观察</small></article>
          <article class="research-card sell"><span>RSI Z-score止盈</span><strong>${escapeHtml(whole(s.rsi_take_profit.overheated))}过热 · ${escapeHtml(whole(s.rsi_take_profit.cooling_trigger))}回落</strong><small>RSI14相对20期分布，阈值 +2</small></article>
          <article class="research-card buy"><span>突破回踩状态机</span><strong>${escapeHtml(whole(br.armed))}候场 · 已决胜率${escapeHtml(pct(br.win_rate))}</strong><small>确认 ${escapeHtml(whole(br.historical_confirmed))}；已决 ${escapeHtml(whole(br.decided_count))}；到期 ${escapeHtml(whole(br.outcome_expired))}；开放 ${escapeHtml(whole(br.outcome_open))}</small></article>
        </div><div class="validation">
          <div>强一致组未来5日<b>${escapeHtml(pct(v.multi_timeframe.strong_alignment.average_pct))} · 相对提升 ${escapeHtml(pp(v.multi_timeframe.average_return_lift_pct))}</b></div>
          <div>RSI过热回落后5日<b>${escapeHtml(pct(v.rsi_cooling.average_pct))} · 样本 ${escapeHtml(whole(v.rsi_cooling.count))}</b></div>
          <div>ATR跌破后5日<b>${escapeHtml(pct(v.atr_breach.average_pct))} · 样本 ${escapeHtml(whole(v.atr_breach.count))}</b></div>
        </div><p class="research-note">历史覆盖 ${escapeHtml(whole(feature.coverage?.symbols_at_least_260))}/${escapeHtml(whole(feature.coverage?.symbols))}只达到260根；统计使用ETF×日期重叠观察值，交易成本将在推广闸门阶段纳入。</p>${rows ? `<div class="watch-list">${rows}</div>` : '<div class="empty">当前没有旁路关注项。</div>'}`;
      } catch (error) { box.innerHTML = `<div class="empty">研究快照读取失败：${escapeHtml(error?.message || error)}</div>`; }
    }
    async function loadFuturePath() {
      const box = document.querySelector('#kronos-content');
      try {
        const response = await fetch(`/data/model-lab/a-share-kronos-shadow.json?cb=${Date.now()}`, { cache: 'no-store' });
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        const data = await response.json(), coverage = data.coverage || {}, summary = data.summary || {};
        const ranked = [...(data.items || [])].sort((a,b) => Number(b.five_day?.predicted_return_pct) - Number(a.five_day?.predicted_return_pct));
        const selected = [...ranked.slice(0,5), ...ranked.slice(-5)].filter((item,index,list) => list.findIndex(other => other.symbol === item.symbol) === index);
        const rows = selected.map(item => { const value = Number(item.five_day?.predicted_return_pct), tone = value > 0 ? 'market-up-text' : value < 0 ? 'market-down-text' : '', quality = item.quality?.raw_ohlc_valid ? '' : '<span class="quality-warning">OHLC校验提醒</span>';
          return `<div class="kronos-row"><strong>${escapeHtml(item.symbol)} · ${escapeHtml(item.name)}</strong><span class="kronos-return ${tone}">${pct(value)}</span><span class="kronos-range">路径低/高 ${pct(item.five_day?.path_low_pct)} / ${pct(item.five_day?.path_high_pct)} ${quality}</span></div>`;
        }).join('');
        box.innerHTML = `<div class="kronos-grid">
          <article class="kronos-card"><span>预测覆盖</span><strong>${escapeHtml(whole(coverage.predicted_symbols))}/${escapeHtml(whole(coverage.expected_symbols))}</strong><small>正式轮动ETF · 数据日 ${escapeHtml(data.latest_trade_date)}</small></article>
          <article class="kronos-card"><span>未来5日方向</span><strong><span class="market-up-text">${escapeHtml(whole(summary.bullish_symbols))}正</span> · <span class="market-down-text">${escapeHtml(whole(summary.bearish_symbols))}负</span></strong><small>只统计模型路径终点方向</small></article>
          <article class="kronos-card"><span>中位预测收益</span><strong class="${Number(summary.median_predicted_return_pct) >= 0 ? 'market-up-text' : 'market-down-text'}">${escapeHtml(pct(summary.median_predicted_return_pct))}</strong><small>截面中位数 · horizon 5个交易日</small></article>
          <article class="kronos-card"><span>原始OHLC质量</span><strong>${escapeHtml(whole(coverage.raw_ohlc_valid_symbols))}/${escapeHtml(whole(coverage.predicted_symbols))}</strong><small>异常路径保留原值并提示，未用于正式信号</small></article>
        </div><div class="kronos-list">${rows}</div><p class="kronos-note">输入最近${escapeHtml(whole(data.model?.parameters?.lookback))}根OHLC；未来交易日：${(data.forecast_definition?.future_sessions || []).map(escapeHtml).join('、')}。当前输出是一条固定参数的研究路径，用于旁路观察、历史积累和后续样本外验证；正式动作、权重、关键位与模拟盘规则保持原状态。</p>`;
      } catch (error) { box.innerHTML = `<div class="empty">未来路径快照读取失败：${escapeHtml(error?.message || error)}</div>`; }
    }
    async function load() {
      const me = await fetch('/api/auth/me'); if (!me.ok) { location.href = '/login/'; return; }
      const user = await me.json(); welcome.textContent = `已登录：${user.user.username} · ${user.user.role === 'admin' ? '管理员' : '用户'}`;
      loadAudit();
      loadResearch();
      loadFuturePath();
      const response = await fetch('/api/jobs'); const data = await response.json(); if (!response.ok) { jobs.textContent = data.error || '任务读取失败'; return; }
      const statusLabel = value => ({queued:'排队中',processing:'处理中',completed:'已完成',failed:'失败',waiting_close:'等待收盘'})[value] || value;
      jobs.innerHTML = data.jobs.length ? data.jobs.map(job => {
        const result = job.result || {}, summary = result.by_category || {}, quality = result.data_quality || {};
        const labels = [['candidate','候场'],['伏击','伏击'],['止盈观察','止盈观察'],['兑现','兑现']].map(([key,label]) => {
          const item = summary[key]; if (!item || !Number(item.count)) return '';
          const target = `触价 ${whole(item.target_hit)}/${whole(item.target_samples ?? item.count)}`;
          const confirmed = key === '伏击' ? ` · 收盘确认 ${Number(item.confirmation_samples) ? `${whole(item.confirmed)}/${whole(item.confirmation_samples)}` : '待定'}` : '';
          return `<span>${escapeHtml(label)} ${escapeHtml(whole(item.count))}只 · ${escapeHtml(target)}${escapeHtml(confirmed)} · T+1 ${escapeHtml(pct(item.t1_hit_rate))}</span>`;
        }).join('');
        const qualityLabels = result.version === 'strict_intraday_v2' ? `<div class="quality"><span>严格5分钟 ${escapeHtml(whole(quality.m5_final ?? 0))}</span>${Number(quality.m5_partial) ? `<span class="warning">盘中待收盘 ${escapeHtml(whole(quality.m5_partial))}</span>` : ''}${Number(quality.pending_intraday) ? `<span class="warning">等待下午行情 ${escapeHtml(whole(quality.pending_intraday))}</span>` : ''}${Number(quality.daily_fallback) ? `<span class="warning">日线粗略回退 ${escapeHtml(whole(quality.daily_fallback))}</span>` : ''}</div>` : (result.version ? '<div class="quality"><span class="warning">旧版日线预回测</span></div>' : '');
        const method = result.methodology ? `<details class="method"><summary>查看回测口径</summary><p>${escapeHtml(result.methodology)}</p></details>` : '';
        return `<div class="job"><strong>${escapeHtml(job.filename)}</strong><span class="job-status">${escapeHtml(statusLabel(job.status))}</span><span class="meta">日期：${escapeHtml(job.trade_date || result.trade_date || '待识别')}</span><span class="meta">提交：${escapeHtml(job.created_at)}</span>${labels ? `<div class="summary">${labels}</div>` : ''}${qualityLabels}${method}${job.error_message ? `<div class="summary"><span>错误：${escapeHtml(job.error_message)}</span></div>` : ''}</div>`;
      }).join('') : '<div class="empty">还没有上传任务。</div>';
    }
    document.querySelector('#upload-form').addEventListener('submit', async event => { event.preventDefault(); status.textContent = '上传中…'; const response = await fetch('/api/upload', { method: 'POST', body: new FormData(event.currentTarget) }); const data = await response.json().catch(() => ({})); status.textContent = response.ok ? `已排队：${data.filename}（${data.count}行）` : (data.error || '上传失败'); if (response.ok) { event.currentTarget.reset(); load(); } });
    document.querySelector('#logout').addEventListener('click', async () => { await fetch('/api/auth/logout', { method: 'POST' }); location.href = '/login/'; });
    load();
  </script>
</body>
</html>
