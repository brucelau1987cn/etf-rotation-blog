---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latest = posts.slice(0, 6);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero { padding: clamp(3rem, 9vw, 6.5rem) 0 2.5rem; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2rem; align-items: center; }
      .eyebrow { margin-bottom: 0.9rem; }
      .hero h1 { max-width: 820px; margin-bottom: 1rem; letter-spacing: -0.055em; }
      .hero p { max-width: 680px; color: rgb(var(--gray)); font-size: clamp(1.05rem, 2vw, 1.24rem); line-height: 1.75; }
      .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
      .button { display: inline-flex; align-items: center; justify-content: center; min-height: 2.6rem; padding: 0.62rem 1rem; border-radius: 999px; font-weight: 800; text-decoration: none; }
      .button.primary { background: rgb(var(--black)); color: white; }
      .button.secondary { background: white; color: rgb(var(--black)); border: 1px solid var(--border); }
      .dashboard { padding: 1.1rem; }
      .dashboard-title { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
      .dashboard-title strong { font-size: 1rem; }
      .dashboard-note { margin: -0.35rem 0 0.85rem; color: rgb(var(--gray)); font-size: 0.9rem; line-height: 1.55; }
      .rank-list { display: grid; gap: 0.7rem; }
      .rank-row { display: grid; grid-template-columns: auto 1fr; align-items: start; gap: 0.75rem; padding: 0.85rem; border: 1px solid var(--border); border-radius: 16px; background: var(--warm-2); }
      .rank-row .num { display: inline-flex; align-items: center; justify-content: center; width: 1.9rem; height: 1.9rem; border-radius: 999px; background: rgb(var(--black)); color: white; font-weight: 800; font-size: 0.85rem; }
      .rank-main { min-width: 0; }
      .rank-head { display: flex; align-items: center; justify-content: space-between; gap: 0.65rem; margin-bottom: 0.4rem; }
      .rank-head strong { font-size: 1.02rem; }
      .rank-details { display: grid; grid-template-columns: 1fr 1fr; gap: 0.35rem 0.65rem; margin-top: 0.55rem; color: rgb(var(--gray)); font-size: 0.82rem; line-height: 1.45; }
      .rank-details span { display: block; }
      .rank-action { color: rgb(var(--black)); font-weight: 800; }
      .section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; margin: 2.5rem 0 1rem; }
      .section-head h2 { margin: 0; }
      .cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; margin: 1rem 0 2rem; }
      .card { padding: 1.15rem; }
      .card strong { display: block; margin-bottom: 0.45rem; }
      .post-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; padding: 0; list-style: none; margin: 0; }
      .post-card { display: block; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; min-height: 13rem; }
      .post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
      .post-card h3 { margin-top: 0.65rem; }
      .date { color: rgb(var(--gray)); margin: 0.35rem 0 0; font-size: 0.92rem; }
      @media (max-width: 860px) { .hero, .post-list, .cards { grid-template-columns: 1fr; } .hero { padding-top: 2.5rem; } }
      @media (max-width: 520px) { .rank-details { grid-template-columns: 1fr; } .rank-head { align-items: flex-start; flex-direction: column; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div>
          <div class="eyebrow"><span class="pill pill-red">🔴 A股ETF轮动</span> <span class="pill">作者 {SITE_AUTHOR}</span></div>
          <h1>每日预测，次日复盘，持续修正权重。</h1>
          <p>{SITE_DESCRIPTION} 核心看近3/5日强度、资金流向、收盘位置、成交放量、新闻催化和监管风险。</p>
          <div class="hero-actions">
            <a class="button primary" href="/blog">查看最新文章</a>
            <a class="button secondary" href="/research">查看研测</a>
            <a class="button secondary" href="/picks">查看研推</a>
            <a class="button secondary" href="/stocks">查看个股</a>
            <a class="button secondary" href="/momentum">动量雷达</a>
            <a class="button secondary" href="/about">了解策略框架</a>
          </div>
        </div>
        <aside class="dashboard card" aria-label="当前轮动观察">
          <div class="dashboard-title"><strong>当前观察队列</strong><span class="pill pill-red">收盘复盘</span></div>
          <p class="dashboard-note">按15:46收盘后腾讯快照、成交额和日内位置展示，优先看“动作”和“失效条件”。</p>
          <div class="rank-list">
            <div class="rank-row"><span class="num">1</span><div class="rank-main"><div class="rank-head"><strong>煤炭</strong><span class="pill pill-red">🔴 轮动补涨升权</span></div><span class="etf-codes"><span class="code-pill">515220</span></span><div class="rank-details"><span><b>关键位</b> 1.38–1.40</span><span class="rank-action">动作：站稳持有，回踩承接低吸</span><span><b>失效</b> 跌回 1.35 附近</span><span><b>风险</b> 补涨一日游</span></div></div></div>
            <div class="rank-row"><span class="num">2</span><div class="rank-main"><div class="rank-head"><strong>通信 / AI算力</strong><span class="pill pill-red">🔴 趋势延续有兑现</span></div><span class="etf-codes"><span class="code-pill">515880</span><span class="code-pill">159819</span></span><div class="rank-details"><span><b>关键位</b> 1.70 / 2.03</span><span class="rank-action">动作：趋势仓持有，回踩确认再加</span><span><b>失效</b> 跌回 1.67 / 2.00 下方</span><span><b>风险</b> 连续急涨后兑现</span></div></div></div>
            <div class="rank-row"><span class="num">3</span><div class="rank-main"><div class="rank-head"><strong>芯片 / 半导体</strong><span class="pill pill-red">🔴 趋势延续</span></div><span class="etf-codes"><span class="code-pill">159995</span><span class="code-pill">512760</span><span class="code-pill">512480</span></span><div class="rank-details"><span><b>关键位</b> 2.45–2.48 / 2.10–2.15</span><span class="rank-action">动作：守强弱线持有，回踩低吸</span><span><b>失效</b> 跌破 2.43 / 2.10</span><span><b>风险</b> 溢价与高波动</span></div></div></div>
            <div class="rank-row"><span class="num">4</span><div class="rank-main"><div class="rank-head"><strong>科创50 / 创业板</strong><span class="pill pill-red">🔴 放量修复</span></div><span class="etf-codes"><span class="code-pill">588000</span><span class="code-pill">159915</span><span class="code-pill">159949</span></span><div class="rank-details"><span><b>关键位</b> 1.80–1.83</span><span class="rank-action">动作：科技底座观察，站稳持有</span><span><b>失效</b> 588000 跌破 1.80</span><span><b>风险</b> 科技线共振回落</span></div></div></div>
            <div class="rank-row"><span class="num">5</span><div class="rank-main"><div class="rank-head"><strong>电力 / 红利防守修复</strong><span class="pill pill-amber">⚠️ 观察位</span></div><span class="etf-codes"><span class="code-pill">159611</span><span class="code-pill">512890</span><span class="code-pill">512800</span></span><div class="rank-details"><span><b>关键位</b> 1.18 / 0.785</span><span class="rank-action">动作：科技分歧时防守备选</span><span><b>失效</b> 再度跌回日内低位</span><span><b>风险</b> 强度弱于煤炭科技</span></div></div></div>
          </div>
        </aside>
      </section>

      <section class="cards">
        <div class="card"><span class="pill">01</span><strong>每日预测</strong><p>收盘后给出次日ETF板块Top 5、关键条件和操作优先级。</p></div>
        <div class="card"><span class="pill">02</span><strong>研测</strong><p>把筹码冰点、持仓弹性、候选池筛选单独沉淀成可回测文章。</p></div>
        <div class="card"><span class="pill">03</span><strong>研推</strong><p>从研测ETF继续下钻持仓龙头，形成值得验证的个股候选。</p></div>
        <div class="card"><span class="pill">04</span><strong>个股</strong><p>把单票筹码、基本面、新闻和交易计划沉淀成深度报告。</p></div>
        <div class="card"><span class="pill">05</span><strong>动量雷达</strong><p>用ETF日线接口做右侧趋势确认，和冰点研测交叉验证。</p></div>
        <div class="card"><span class="pill">06</span><strong>策略框架</strong><p>把资金背离、监管风险、新闻催化纳入下一轮权重。</p></div>
      </section>

      <section>
        <div class="section-head">
          <h2>最新文章</h2>
          <a href="/blog">全部文章 →</a>
        </div>
        <ul class="post-list">
          {latest.map((post) => (
            <li>
              <a class="post-card" href={`/blog/${post.id}/`}>
                <span class="pill pill-red">{post.data.category ?? 'ETF研究'}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <p class="date"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
