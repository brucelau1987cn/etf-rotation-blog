---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type AAction = { code:string; name:string; status:string; action:string; price?:number; support?:number; target?:number; stop?:number; action_level?:number; action_level_label?:string; distance_pct?:number; risk_level?:string; price_date?:string };
type GardenData = { date:string; updated_at:string; level_data_as_of?:string; market_state:string; position:string; mainline:string; summary:string; harvest:AAction[]; plant:AAction[] };
type UsAction = { symbol:string; name:string; price:number; support:number; target:number; stop:number; trade_state:string; signal:string; trigger_level:number; support_gap?:number; target_gap?:number; risk_level:string; trade_date:string };
type UsData = { date:string; updated_at:string; summary:string; market_regime:{state:string;equity_allocation:string}; flower_signals:Record<string,UsAction[]>; flower_counts:Record<string,number> };

const rename = (raw:string) => raw.replaceAll('准备种花','候场').replaceAll('准备摘花','止盈观察').replaceAll('种花','伏击').replaceAll('摘花','兑现').replaceAll('失效退出','破位撤退').replaceAll('回踩位','伏击位').replaceAll('目标位','兑现位').replaceAll('失效线','防守线').replaceAll('ETF花园','ETF罗盘').replaceAll('US ETF Garden','US ETF Compass').replaceAll('Flower Signals','Compass Signals');
const dataPath = (name:string) => join(process.cwd(),`public/data/${name}`);
const garden = JSON.parse(rename(readFileSync(dataPath('garden-recommendations.json'),'utf8'))) as GardenData;
const aPool = JSON.parse(readFileSync(dataPath('etf-garden-pool.json'),'utf8'));
const us = JSON.parse(rename(readFileSync(dataPath('us-etf-garden.json'),'utf8'))) as UsData;
const usPool = JSON.parse(readFileSync(dataPath('us-etf-pool.json'),'utf8'));
const macro = JSON.parse(readFileSync(dataPath('us-macro-dashboard.json'),'utf8'));
const aActions = [...garden.harvest.slice(0,2),...garden.plant.slice(0,2)].slice(0,4);
const usPriority = ['exit','harvest','plant','ready_harvest','ready_plant'];
const usActions = usPriority.flatMap(key => us.flower_signals[key] || []).slice(0,4);
const usFormalCount = ['exit','harvest','plant'].reduce((n,key)=>n+(us.flower_signals[key]?.length||0),0);
const usReadyCount = ['ready_harvest','ready_plant'].reduce((n,key)=>n+(us.flower_signals[key]?.length||0),0);
const macroIcon = macro.risk.key === 'danger' ? '🔴' : macro.risk.key === 'tight' ? '🟠' : macro.risk.key === 'slightly-tight' ? '🟡' : '🟢';
const number = (v?:number) => typeof v === 'number' && Number.isFinite(v) ? v.toFixed(v >= 100 ? 2 : 3).replace(/0+$/,'').replace(/\.$/,'') : 'N/A';
const distance = (v?:number) => typeof v === 'number' && Number.isFinite(v) ? `${v>0?'+':''}${v.toFixed(1)}%` : 'N/A';
const aTone = (status:string) => status.includes('兑现') ? 'sell' : status.includes('撤退') ? 'exit' : 'buy';
const usLabel = (item:UsAction) => item.signal || item.trade_state;
const usTone = (item:UsAction) => item.signal?.includes('兑现') ? 'sell' : item.signal?.includes('撤退') ? 'exit' : 'buy';
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description="ETF罗盘双市场今日仪表盘：集中展示A股与美股市场结论、仓位建议、趋势风控、宏观风险和优先动作。" />
    <style>
      main{width:min(1180px,calc(100% - 1.5rem));padding:1rem 0 3rem}.dashboard-head{display:flex;justify-content:space-between;align-items:flex-end;gap:1rem;padding:.7rem 0 1rem;border-bottom:1px solid var(--border)}
      .dashboard-head h1{margin:.25rem 0;font-size:clamp(1.8rem,4.5vw,2.75rem)}.dashboard-head p{margin:0;color:rgb(var(--gray));max-width:700px}.dates{display:grid;grid-template-columns:repeat(2,auto);gap:.32rem}.dates span{padding:.34rem .55rem;border:1px solid var(--border);border-radius:9px;background:#fff;font-size:.7rem;white-space:nowrap;color:rgb(var(--gray))}
      .markets{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.9rem;margin-top:.9rem}.market{padding:1rem;overflow:hidden}.market.a{border-top:5px solid var(--accent)}.market.us{border-top:5px solid #1b67b2;background:linear-gradient(180deg,#f7fbff 0,#fff 20%)}
      .market-top{display:flex;justify-content:space-between;align-items:flex-start;gap:.75rem}.market-title{display:flex;gap:.55rem;align-items:center}.market-title h2{margin:0;font-size:1.35rem}.market-date{text-align:right;color:rgb(var(--gray));font-size:.7rem}.market-date strong{display:block;font-size:.8rem}
      .verdict{margin:.75rem 0;padding:.8rem;border-radius:13px;background:var(--warm-2);border:1px solid var(--border)}.verdict-head{display:flex;justify-content:space-between;gap:.7rem;align-items:center}.verdict h3{margin:0;font-size:1.12rem}.verdict p{margin:.42rem 0 0;color:rgb(var(--gray));font-size:.82rem;line-height:1.55}.allocation{font-weight:850;font-size:.76rem;padding:.25rem .55rem;border-radius:999px;background:#fff;border:1px solid var(--border)}
      .metrics{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.42rem;margin:.7rem 0}.metric{padding:.58rem;background:#fff;border:1px solid var(--border);border-radius:10px;min-width:0}.metric span{display:block;font-size:.65rem;color:rgb(var(--gray));font-weight:750}.metric strong{display:block;margin-top:.1rem;font-size:.82rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.metric.wide{grid-column:span 2}
      .actions-head{display:flex;justify-content:space-between;align-items:center;margin:.9rem 0 .48rem}.actions-head h3{margin:0;font-size:1rem}.actions-head small{color:rgb(var(--gray))}.action-list{display:grid;gap:.5rem}.action{padding:.7rem;border:1px solid var(--border);border-radius:12px;background:#fff}.action.sell{border-left:4px solid var(--green)}.action.buy{border-left:4px solid var(--accent)}.action.exit{border-left:4px solid #991b1b}.action-top{display:flex;justify-content:space-between;gap:.55rem;align-items:flex-start}.identity{min-width:0}.identity strong{display:block;font-size:.88rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.identity small{display:block;color:rgb(var(--gray));font-size:.68rem}.state{padding:.18rem .46rem;border-radius:999px;font-size:.66rem;font-weight:850;white-space:nowrap}.sell .state{background:var(--green-soft);color:var(--green)}.buy .state{background:var(--accent-soft);color:var(--accent-dark)}.exit .state{background:#fee2e2;color:#991b1b}
      .levels{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:.3rem;margin-top:.55rem}.level{padding:.42rem .3rem;text-align:center;background:var(--warm-2);border-radius:8px;min-width:0}.level span{display:block;color:rgb(var(--gray));font-size:.59rem;white-space:nowrap}.level strong{display:block;font-size:.72rem;overflow:hidden;text-overflow:ellipsis}.action-copy{margin:.46rem 0 0;color:rgb(var(--gray));font-size:.72rem;line-height:1.45}
      .market-links{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.85rem;padding-top:.75rem;border-top:1px solid var(--border)}.market-links a{flex:1;text-align:center;padding:.46rem .55rem;border:1px solid var(--border);border-radius:9px;background:var(--warm-2);font-size:.72rem;font-weight:850;text-decoration:none;white-space:nowrap}
      @media(max-width:960px){.markets{grid-template-columns:1fr}.dashboard-head{align-items:flex-start}.dates{grid-template-columns:1fr}}
      @media(max-width:620px){main{width:min(100% - 1rem,1180px);padding-top:.55rem}.dashboard-head{display:block}.dashboard-head p{font-size:.82rem}.dates{grid-template-columns:repeat(2,minmax(0,1fr));margin-top:.65rem}.dates span{white-space:normal}.market{padding:.8rem}.metrics{grid-template-columns:repeat(2,minmax(0,1fr))}.metric.wide{grid-column:span 2}.levels{grid-template-columns:repeat(4,minmax(0,1fr))}.level:last-child{grid-column:span 4}.market-links a{flex:1 1 42%}}
    </style>
  </head>
  <body>
    <Header />
    <main>
      <header class="dashboard-head">
        <div><span class="pill">DAILY ETF COMPASS</span><h1>双市场今日仪表盘</h1><p>A股与美股的市场状态、仓位建议、风险闸门和优先动作。风险动作优先；候场不等于买入，正式触发才进入执行。</p></div>
        <div class="dates"><span>A股计划 {garden.date}</span><span>A股行情 {garden.level_data_as_of||'待更新'}</span><span>美股行情 {us.date}</span><span>美股更新 {us.updated_at.replace('T',' ').slice(0,16)}</span></div>
      </header>

      <section class="markets" aria-label="双市场今日仪表盘">
        <article class="market a card">
          <div class="market-top"><div class="market-title"><span class="pill pill-red">🇨🇳 A股</span><h2>今日决策</h2></div><div class="market-date"><strong>行情 {garden.level_data_as_of||'待更新'}</strong>计划 {garden.date}</div></div>
          <div class="verdict"><div class="verdict-head"><h3>{garden.market_state}</h3><span class="allocation">仓位 {garden.position}</span></div><p>{garden.summary}</p></div>
          <div class="metrics"><div class="metric"><span>兑现侧</span><strong>{garden.harvest.length}只</strong></div><div class="metric"><span>伏击侧</span><strong>{garden.plant.length}只</strong></div><div class="metric"><span>趋势通过</span><strong>{aPool.summary.momentum_pass_count}/{aPool.summary.universe_count}</strong></div><div class="metric"><span>风险状态</span><strong>{garden.market_state}</strong></div><div class="metric wide"><span>当前主线</span><strong>{garden.mainline}</strong></div><div class="metric wide"><span>数据截止</span><strong>{garden.updated_at}</strong></div></div>
          <div class="actions-head"><h3>优先动作</h3><small>现价与关键位均为行情日快照</small></div>
          <div class="action-list">{aActions.map(item=><div class={`action ${aTone(item.status)}`}><div class="action-top"><div class="identity"><strong>{item.code} · {item.name}</strong><small>风险 {item.risk_level||'N/A'} · 行情 {item.price_date||garden.level_data_as_of||'待更新'}</small></div><span class="state">{item.status}</span></div><div class="levels"><div class="level"><span>现价</span><strong>{number(item.price)}</strong></div><div class="level"><span>伏击位</span><strong>{number(item.support)}</strong></div><div class="level"><span>兑现位</span><strong>{number(item.target)}</strong></div><div class="level"><span>防守线</span><strong>{number(item.stop)}</strong></div><div class="level"><span>距动作位</span><strong>{distance(item.distance_pct)}</strong></div></div><p class="action-copy">{item.action}</p></div>)}</div>
          <nav class="market-links" aria-label="A股功能"><a href="/garden/">今日动作</a><a href="/momentum/">趋势风控</a><a href="/blog/">盘后复盘</a></nav>
        </article>

        <article class="market us card">
          <div class="market-top"><div class="market-title"><span class="pill" style="background:#eaf3ff;color:#174ea6">🇺🇸 美股</span><h2>今日决策</h2></div><div class="market-date"><strong>行情 {us.date}</strong>{macroIcon} {macro.risk.label}</div></div>
          <div class="verdict"><div class="verdict-head"><h3>{us.market_regime.state}</h3><span class="allocation">权益 {us.market_regime.equity_allocation}</span></div><p>{us.summary}</p></div>
          <div class="metrics"><div class="metric"><span>正式动作</span><strong>{usFormalCount}项</strong></div><div class="metric"><span>候场观察</span><strong>{usReadyCount}项</strong></div><div class="metric"><span>趋势通过</span><strong>{usPool.summary.momentum_pass}/{usPool.summary.universe}</strong></div><div class="metric"><span>宏观闸门</span><strong>{macro.risk.label}</strong></div><div class="metric wide"><span>风险预算</span><strong>{macro.risk.equity_constraint}</strong></div><div class="metric wide"><span>宏观信号</span><strong>{macro.risk.headline}</strong></div></div>
          <div class="actions-head"><h3>优先动作</h3><small>正式动作优先，其次候场观察</small></div>
          <div class="action-list">{usActions.map(item=><div class={`action ${usTone(item)}`}><div class="action-top"><div class="identity"><strong>{item.symbol} · {item.name}</strong><small>风险 {item.risk_level} · 行情 {item.trade_date}</small></div><span class="state">{usLabel(item)}</span></div><div class="levels"><div class="level"><span>现价</span><strong>${number(item.price)}</strong></div><div class="level"><span>伏击位</span><strong>${number(item.support)}</strong></div><div class="level"><span>兑现位</span><strong>${number(item.target)}</strong></div><div class="level"><span>防守线</span><strong>${number(item.stop)}</strong></div><div class="level"><span>距动作位</span><strong>{distance(item.signal?.includes('兑现') ? item.target_gap : item.support_gap)}</strong></div></div><p class="action-copy">{item.trade_state}</p></div>)}</div>
          <nav class="market-links" aria-label="美股功能"><a href="/us-garden/">今日动作</a><a href="/us-momentum/">趋势风控</a><a href="/us-macro/">宏观雷达</a><a href="/us-garden/history/">历史成绩</a></nav>
        </article>
      </section>
    </main>
    <Footer />
  </body>
</html>
