---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latest = posts.slice(0, 6);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero { padding: clamp(3rem, 9vw, 6.5rem) 0 2.5rem; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2rem; align-items: center; }
      .eyebrow { margin-bottom: 0.9rem; }
      .hero h1 { max-width: 820px; margin-bottom: 1rem; letter-spacing: -0.055em; }
      .hero p { max-width: 680px; color: rgb(var(--gray)); font-size: clamp(1.05rem, 2vw, 1.24rem); line-height: 1.75; }
      .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
      .button { display: inline-flex; align-items: center; justify-content: center; min-height: 2.6rem; padding: 0.62rem 1rem; border-radius: 999px; font-weight: 800; text-decoration: none; }
      .button.primary { background: rgb(var(--black)); color: white; }
      .button.secondary { background: white; color: rgb(var(--black)); border: 1px solid var(--border); }
      .dashboard { padding: 1.1rem; }
      .dashboard-title { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
      .dashboard-title strong { font-size: 1rem; }
      .dashboard-note { margin: -0.35rem 0 0.85rem; color: rgb(var(--gray)); font-size: 0.9rem; line-height: 1.55; }
      .rank-list { display: grid; gap: 0.7rem; }
      .rank-row { display: grid; grid-template-columns: auto 1fr; align-items: start; gap: 0.75rem; padding: 0.85rem; border: 1px solid var(--border); border-radius: 16px; background: var(--warm-2); }
      .rank-row .num { display: inline-flex; align-items: center; justify-content: center; width: 1.9rem; height: 1.9rem; border-radius: 999px; background: rgb(var(--black)); color: white; font-weight: 800; font-size: 0.85rem; }
      .rank-main { min-width: 0; }
      .rank-head { display: flex; align-items: center; justify-content: space-between; gap: 0.65rem; margin-bottom: 0.4rem; }
      .rank-head strong { font-size: 1.02rem; }
      .rank-details { display: grid; grid-template-columns: 1fr 1fr; gap: 0.35rem 0.65rem; margin-top: 0.55rem; color: rgb(var(--gray)); font-size: 0.82rem; line-height: 1.45; }
      .rank-details span { display: block; }
      .rank-action { color: rgb(var(--black)); font-weight: 800; }
      .section-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; margin: 2.5rem 0 1rem; }
      .section-head h2 { margin: 0; }
      .cards { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); grid-auto-rows: 1fr; gap: 1rem; margin: 1rem 0 2rem; }
      .card { padding: 1.15rem; }
      .card strong { display: block; margin-bottom: 0.45rem; }
      .post-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); grid-auto-rows: 1fr; gap: 1rem; padding: 0; list-style: none; margin: 0; }
      .post-card { display: flex; flex-direction: column; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; min-height: 13rem; }
      .post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
      .post-card h3 { margin-top: 0.65rem; }
      .date { color: rgb(var(--gray)); margin: 0.35rem 0 0; font-size: 0.92rem; }
      @media (max-width: 860px) { .hero, .post-list, .cards { grid-template-columns: 1fr; } .hero { padding-top: 2.5rem; } }
      @media (max-width: 520px) { .rank-details { grid-template-columns: 1fr; } .rank-head { align-items: flex-start; flex-direction: column; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div>
          <div class="eyebrow"><span class="pill pill-red">🔴 A股ETF轮动</span> <span class="pill">作者 {SITE_AUTHOR}</span></div>
          <h1>每日预测，次日复盘，持续修正权重。</h1>
          <p>{SITE_DESCRIPTION} 核心看近3/5日强度、资金流向、收盘位置、成交放量、新闻催化和监管风险。</p>
          <div class="hero-actions">
            <a class="button primary" href="/blog">查看最新文章</a>
            <a class="button secondary" href="/research">查看研测</a>
            <a class="button secondary" href="/picks">查看研推</a>
            <a class="button secondary" href="/garden">ETF花园</a>
            <a class="button secondary" href="/stocks">查看个股</a>
            <a class="button secondary" href="/momentum">动量雷达</a>
            <a class="button secondary" href="/about">了解策略框架</a>
          </div>
        </div>
        <aside class="dashboard card" aria-label="当前轮动观察">
          <div class="dashboard-title"><strong>当前观察队列</strong><span class="pill pill-red">上午盘中修正</span></div>
          <p class="dashboard-note">按 2026-06-08 10:46–10:48 腾讯ETF快照复核：周一开盘市场普跌（上证 -0.68% / 深成指 -1.65% / 创业板 -1.95%），机器人 562500/159770 早盘🔴收涨（+1.38%/+1.58%），是上午唯一延续的趋势主线；银行 512800、红利低波 512890 防守承接；煤炭 515220 仍🔴但日内位置 87% 已透支，降为反抽观察；芯片/半导体/科创50/通信AI/军工/有色/黄金/酒/中概/创新药全面退潮，全部降权。</p>
          <div class="rank-list">
            <div class="rank-row"><span class="num">1</span><div class="rank-main"><div class="rank-head"><strong>机器人 / 自动化</strong><span class="pill pill-red">🔴 趋势延续（高位）</span></div><span class="etf-codes"><span class="code-pill">562500</span><span class="code-pill">159770</span></span><div class="rank-details"><span><b>10:48</b> 562500 +1.38%，成交额10.33亿</span><span class="rank-action">动作：趋势第一观察</span><span><b>关键</b> 562500守1.15–1.16</span><span><b>降速</b> 跌破1.13</span></div></div></div>
            <div class="rank-row"><span class="num">2</span><div class="rank-main"><div class="rank-head"><strong>银行 / 红利低波</strong><span class="pill pill-red">🔴 防守承接</span></div><span class="etf-codes"><span class="code-pill">512800</span><span class="code-pill">512890</span></span><div class="rank-details"><span><b>10:48</b> 512800 +0.77%，日内位置67%</span><span class="rank-action">动作：进攻线分歧时防守</span><span><b>关键</b> 512800守0.780–0.784</span><span><b>风险</b> 跌回0.774降权</span></div></div></div>
            <div class="rank-row"><span class="num">3</span><div class="rank-main"><div class="rank-head"><strong>煤炭反抽观察</strong><span class="pill pill-amber">⚠️ 高位透支</span></div><span class="etf-codes"><span class="code-pill">515220</span></span><div class="rank-details"><span><b>10:48</b> +0.50%，日内位置87%</span><span class="rank-action">动作：只看反抽，不追</span><span><b>反抽</b> 1.40–1.42</span><span><b>出队</b> 跌破1.40</span></div></div></div>
            <div class="rank-row"><span class="num">4</span><div class="rank-main"><div class="rank-head"><strong>游戏 / 传媒AI应用</strong><span class="pill pill-amber">⚠️ 回踩观察</span></div><span class="etf-codes"><span class="code-pill">159869</span><span class="code-pill">516010</span></span><div class="rank-details"><span><b>10:48</b> 159869 -0.89%，516010 -1.07%</span><span class="rank-action">动作：守1.10才观察</span><span><b>升权</b> 159869站1.14</span><span><b>失败</b> 跌回1.10下方</span></div></div></div>
            <div class="rank-row"><span class="num">5</span><div class="rank-main"><div class="rank-head"><strong>医药 / 创新药修复</strong><span class="pill pill-amber">⚠️ 回踩观察</span></div><span class="etf-codes"><span class="code-pill">512010</span><span class="code-pill">159992</span><span class="code-pill">159570</span></span><div class="rank-details"><span><b>10:48</b> 512010 -1.22%，159570 -1.20%</span><span class="rank-action">动作：不追高，等确认</span><span><b>关键</b> 512010站0.328–0.330</span><span><b>确认</b> 159570收回1.27</span></div></div></div>
          </div>
        </aside>
      </section>

      <section class="cards">
        <div class="card"><span class="pill">01</span><strong>每日预测</strong><p>收盘后给出次日ETF板块Top 5、关键条件和操作优先级。</p></div>
        <div class="card"><span class="pill">02</span><strong>研测</strong><p>把筹码冰点、持仓弹性、候选池筛选单独沉淀成可回测文章。</p></div>
        <div class="card"><span class="pill">03</span><strong>研推</strong><p>从研测ETF继续下钻持仓龙头，形成值得验证的个股候选。</p></div>
        <div class="card"><span class="pill">04</span><strong>ETF花园</strong><p>记录71只ETF/LOF的准备种花、种花、准备摘花与摘花信号。</p></div>
        <div class="card"><span class="pill">05</span><strong>个股</strong><p>把单票筹码、基本面、新闻和交易计划沉淀成深度报告。</p></div>
        <div class="card"><span class="pill">06</span><strong>动量雷达</strong><p>用ETF日线接口做右侧趋势确认，和冰点研测交叉验证。</p></div>
        <div class="card"><span class="pill">07</span><strong>策略框架</strong><p>把资金背离、监管风险、新闻催化纳入下一轮权重。</p></div>
      </section>

      <section>
        <div class="section-head">
          <h2>最新文章</h2>
          <a href="/blog">全部文章 →</a>
        </div>
        <ul class="post-list">
          {latest.map((post) => (
            <li>
              <a class="post-card" href={`/blog/${post.id}/`}>
                <span class="pill pill-red">{post.data.category ?? 'ETF研究'}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <p class="date"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
