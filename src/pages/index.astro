---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { isDailyReviewPost, isEtfResearchPost, isPublicEtfPost, sortByPubDateDesc, summarizeDescription } from '../lib/posts';

interface RecommendationItem {
  code: string;
  name: string;
  status: string;
  priority: string;
  reason: string;
  action: string;
  level?: string;
}
interface GardenData {
  date: string;
  updated_at: string;
  market_state: string;
  position: string;
  mainline: string;
  summary: string;
  harvest: RecommendationItem[];
  plant: RecommendationItem[];
}
const garden = JSON.parse(readFileSync(join(process.cwd(), 'public/data/garden-recommendations.json'), 'utf8')) as GardenData;
const allPosts = (await getCollection('blog')).filter(isPublicEtfPost).sort(sortByPubDateDesc);
const latestDaily = allPosts.filter(isDailyReviewPost).slice(0, 3);
const latestResearch = allPosts.filter(isEtfResearchPost).slice(0, 1);
const harvest = garden.harvest.slice(0, 3);
const plant = garden.plant.slice(0, 3);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero { padding: clamp(1.6rem, 4vw, 3rem) 0 1.1rem; display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr); gap: 1.25rem; align-items: stretch; }
      .hero-copy { padding: clamp(0.4rem, 2vw, 1.2rem) 0; }
      .eyebrow, .hero-actions, .meta-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
      .hero h1 { max-width: 740px; margin: 0.8rem 0 0.8rem; font-size: clamp(2.1rem, 4.8vw, 3.55rem); letter-spacing: -0.05em; text-wrap: balance; }
      .hero-copy > p { max-width: 690px; color: rgb(var(--gray)); font-size: clamp(1rem, 2vw, 1.15rem); line-height: 1.75; }
      .hero-actions { margin-top: 1.35rem; }
      .market-card { padding: 1.25rem; background: linear-gradient(145deg, #fff, var(--accent-soft)); }
      .market-card h2 { margin: 0.7rem 0 0.45rem; font-size: clamp(1.45rem, 3vw, 2rem); }
      .market-card p { color: rgb(var(--gray)); }
      .market-facts { display: grid; gap: 0.55rem; margin-top: 1rem; }
      .fact { display: grid; grid-template-columns: 5.2rem 1fr; gap: 0.65rem; padding: 0.7rem 0.8rem; border-radius: 13px; background: rgba(255,255,255,0.78); border: 1px solid var(--border); }
      .fact span { color: rgb(var(--gray)); font-size: 0.82rem; font-weight: 800; }
      .fact strong { font-size: 0.92rem; }
      .signal-columns { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
      .signal-panel { padding: 1rem; }
      .signal-panel-head { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.7rem; }
      .signal-panel-head h3 { margin: 0; font-size: 1.08rem; }
      .mini-list { display: grid; gap: 0.55rem; }
      .mini-signal { display: grid; grid-template-columns: 1fr auto; gap: 0.7rem; align-items: start; padding: 0.78rem; border: 1px solid var(--border); border-radius: 14px; background: var(--warm-2); color: rgb(var(--gray-dark)); text-decoration: none; }
      .mini-signal:hover { color: rgb(var(--gray-dark)); border-color: rgba(214,61,46,.25); }
      .mini-signal strong { display: block; }
      .mini-signal p { margin: 0.18rem 0 0; color: rgb(var(--gray)); font-size: 0.82rem; line-height: 1.45; }
      .read-path { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.75rem; }
      .path-card { padding: 1rem; }
      .path-card strong { display: block; margin: 0.45rem 0 0.25rem; }
      .path-card p { margin: 0; color: rgb(var(--gray)); font-size: 0.88rem; }
      .research-row { display: grid; grid-template-columns: 1fr; gap: 1rem; }
      @media (max-width: 900px) { .hero, .signal-columns { grid-template-columns: 1fr; } .hero { padding-top: 2rem; } }
      @media (max-width: 720px) { .read-path, .research-row { grid-template-columns: 1fr; } .hero h1 { font-size: clamp(2rem, 11vw, 3rem); } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div class="hero-copy">
          <div class="eyebrow"><span class="pill pill-red">🔴 低吸种花</span><span class="pill pill-green">🟢 高抛摘花</span></div>
          <h1>先看今日动作，再读复盘逻辑。</h1>
          <p>ETF花园把盘前预测、盘中修正、收盘验证收敛成一张可执行清单。首页给结论，花园给动作，每日复盘解释胜负。</p>
          <div class="hero-actions">
            <a class="button primary" href="/garden">查看今日推荐</a>
            <a class="button" href="/blog">阅读最新复盘</a>
            <a class="button" href="/momentum">打开动量雷达</a>
          </div>
        </div>
        <aside class="market-card card" aria-label="今日市场摘要">
          <div class="meta-row"><span class="pill pill-amber">适用交易日：{garden.date}</span><span class="pill">数据截止：{garden.updated_at}</span></div>
          <h2>{garden.market_state}</h2>
          <p>{garden.summary}</p>
          <div class="market-facts">
            <div class="fact"><span>仓位建议</span><strong>{garden.position}</strong></div>
            <div class="fact"><span>当前主线</span><strong>{garden.mainline}</strong></div>
          </div>
        </aside>
      </section>

      <section>
        <div class="section-heading"><h2>今日动作</h2><a href="/garden">完整清单与关键位 →</a></div>
        <div class="signal-columns">
          <div class="signal-panel card">
            <div class="signal-panel-head"><h3>🟢 摘花 / 准备摘花</h3><span class="pill pill-green">高抛</span></div>
            <div class="mini-list">
              {harvest.map((item) => <a class="mini-signal" href={`/garden/#etf-${item.code}`}><div><strong>{item.code} {item.name}</strong><p>{item.action}</p></div><span class="pill pill-green">{item.status}</span></a>)}
            </div>
          </div>
          <div class="signal-panel card">
            <div class="signal-panel-head"><h3>🔴 种花 / 准备种花</h3><span class="pill pill-red">低吸</span></div>
            <div class="mini-list">
              {plant.map((item) => <a class="mini-signal" href={`/garden/#etf-${item.code}`}><div><strong>{item.code} {item.name}</strong><p>{item.action}</p></div><span class="pill pill-red">{item.status}</span></a>)}
            </div>
          </div>
        </div>
      </section>

      <section>
        <div class="section-heading"><h2>三步阅读</h2></div>
        <div class="read-path">
          <a class="path-card card" href="/garden"><span class="pill pill-red">01</span><strong>今日推荐</strong><p>先确认摘花、种花和执行关键位。</p></a>
          <a class="path-card card" href="/blog"><span class="pill">02</span><strong>每日复盘</strong><p>再看资金、量价、错因和次日验证。</p></a>
          <a class="path-card card" href="/momentum"><span class="pill pill-amber">03</span><strong>动量雷达</strong><p>最后用71池确认相对强弱与风险。</p></a>
        </div>
      </section>

      <section>
        <div class="section-heading"><h2>最新每日复盘</h2><a href="/blog">全部复盘 →</a></div>
        <ul class="archive-grid">
          {latestDaily.map((post) => <li><a class="archive-card card" href={`/blog/${post.id}/`}><div class="kicker"><span class="pill pill-red">{post.data.category ?? 'ETF复盘'}</span>{post.data.stage && <span class="pill pill-amber">{post.data.stage}</span>}</div><h3>{post.data.title}</h3><p class="description">{summarizeDescription(post.data.description)}</p><p class="date"><FormattedDate date={post.data.pubDate} /></p></a></li>)}
        </ul>
      </section>

      <section>
        <div class="section-heading"><h2>历史策略验证</h2><a href="/research">查看档案 →</a></div>
        <div class="research-row">
          {latestResearch.map((post) => <a class="archive-card card" href={`/blog/${post.id}/`}><span class="pill">历史研测</span><h3>{post.data.title}</h3><p class="description">{summarizeDescription(post.data.description)}</p><p class="date"><FormattedDate date={post.data.pubDate} /></p></a>)}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
