---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

const title = 'C09 竞价狙击 · 板块脉冲';
const description = 'C09 实验室信号：当日 S/A 级 A 股相关新闻 + 6 维板块冲击星图。原始数据来自 nasa-drain-arthritis-figured.trycloudflare.com trycloudflare 隧道。';

// Locate c09-signal.json at build time. Astro 6's prerender container runs
// with `process.cwd()` at the Astro project root on every host we know:
//   - local `astro build`           → cwd = repo root
//   - local `astro preview`         → cwd = repo root
//   - Cloudflare Pages build        → cwd = /opt/buildhome/repo (repo root)
// We try multiple candidate paths so a future layout change still resolves.
const CANDIDATE_DATA_PATHS = [
  join(process.cwd(), 'public', 'data', 'c09-signal.json'),
  join(process.cwd(), 'src', 'data', 'c09-signal.json'),
];
let signal: any = null;
let readError = '';
let resolvedPath = '';
for (const p of CANDIDATE_DATA_PATHS) {
  try {
    signal = JSON.parse(readFileSync(p, 'utf-8'));
    resolvedPath = p;
    break;
  } catch (e) {
    readError = String(e);
  }
}

// Verdict pill styling
const verdictCls: Record<string, string> = {
  '主升': 'pill-red',
  '观察': 'pill-amber',
  '谨慎观察': 'pill-amber',
  '回避': '',
};

// Derived views from the loaded signal
const important = signal?.important_news || [];
const sectors = signal?.sector_stars || [];
const top3 = signal?.top3 || [];
const meta = signal?.meta || {};
const status = signal?.status || 'unknown';
const tradeDate = signal?.trade_date || '—';
const generatedAt = signal?.generated_at || '—';
const fetchedAt = signal?.fetched_at || '—';

function fmtScore(v: number | null | undefined) {
  return Number.isFinite(Number(v)) ? Number(v).toFixed(1) : '—';
}
function fmtPct(v: number | null | undefined) {
  if (!Number.isFinite(Number(v))) return '—';
  const n = Number(v);
  return (n * 100).toFixed(0) + '%';
}
function relativeTime(iso: string) {
  if (!iso) return '—';
  try {
    const t = new Date(iso.replace(' ', 'T'));
    if (Number.isNaN(t.getTime())) return iso;
    return t.toLocaleString('zh-CN', { hour12: false, month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' });
  } catch { return iso; }
}
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      .hero { padding: clamp(2.2rem, 6vw, 4.5rem) 0 1.2rem; }
      .hero h1 { margin: 0.7rem 0 0.6rem; letter-spacing: -0.04em; }
      .hero p { max-width: 860px; color: rgb(var(--gray)); font-size: 1.05rem; line-height: 1.7; }
      .meta-bar { display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; margin: 1rem 0 0.5rem; }
      .meta-bar .muted { color: rgb(var(--gray)); font-size: 0.92rem; }
      .summary-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 0.7rem; margin: 1rem 0; }
      .metric { padding: 0.85rem; border: 1px solid var(--border); border-radius: 16px; background: var(--warm-2); }
      .metric strong { display: block; font-size: 1.4rem; margin-top: 0.2rem; font-variant-numeric: lining-nums tabular-nums; }
      .panel { padding: 1rem; }
      .panel-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.6rem; margin-bottom: 0.7rem; }
      .panel-head h2, .panel-head h3 { margin: 0; }
      .muted { color: rgb(var(--gray)); }
      .news-list { display: grid; gap: 0.75rem; }
      .news-card { padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 16px; background: white; }
      .news-card.is-s { border-color: #c4231c; background: #fff7f5; }
      .news-card.is-a { border-color: #f0a13a; background: #fffaef; }
      .news-head { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.35rem; }
      .news-title { font-weight: 800; font-size: 1.02rem; line-height: 1.45; color: rgb(var(--black)); }
      .news-meta { font-size: 0.82rem; color: rgb(var(--gray)); margin-top: 0.25rem; }
      .news-sectors { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.55rem; }
      .chip { display: inline-flex; align-items: center; border-radius: 999px; padding: 0.18rem 0.55rem; font-size: 0.78rem; font-weight: 700; background: var(--warm-2); border: 1px solid var(--border); }
      .sector-table { width: 100%; border-collapse: separate; border-spacing: 0; font-variant-numeric: lining-nums tabular-nums; }
      .sector-table th, .sector-table td { padding: 0.55rem 0.5rem; border-bottom: 1px solid var(--border); text-align: right; }
      .sector-table th { background: rgb(var(--black)); color: white; font-size: 0.82rem; text-align: center; }
      .sector-table th:first-child, .sector-table td:first-child, .sector-table th:nth-child(2), .sector-table td:nth-child(2) { text-align: left; }
      .score-bar { display: inline-block; min-width: 60px; padding: 0 0.4rem; height: 0.55rem; border-radius: 4px; background: var(--warm-2); position: relative; overflow: hidden; }
      .score-bar::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; background: linear-gradient(90deg, #c4231c 0%, #f0a13a 60%, #188038 100%); width: var(--w, 0%); }
      .score-num { display: inline-block; min-width: 40px; text-align: right; font-weight: 900; }
      .top3-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0.7rem; }
      .top3-card { padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 18px; background: linear-gradient(135deg, white, var(--accent-soft)); }
      .status-line { font-size: 0.92rem; color: rgb(var(--gray)); }
      .empty { padding: 1.2rem; text-align: center; color: rgb(var(--gray)); border: 1px dashed var(--border); border-radius: 16px; }
      .notice { background: var(--warm-2); border: 1px solid var(--border); padding: 0.8rem 1rem; border-radius: 14px; font-size: 0.92rem; line-height: 1.6; }
      .notice strong { color: #b42318; }
      @media (max-width: 980px) { .summary-grid, .top3-grid { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 560px) { .summary-grid, .top3-grid { grid-template-columns: 1fr; } .sector-table { font-size: 0.88rem; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <span class="pill pill-red">C09 竞价狙击实验室</span>
        <span class="pill">板块脉冲看板</span>
        <h1>S/A 级新闻 × 6 维板块打分</h1>
        <p>C09 五席 Agent（ORION 决策中枢 / NOVA 新闻雷达 / ATLAS 题材图谱 / VECTOR 竞价技师 / AEGIS 风控闸门）输出的当日信号。原始数据来自 <code>nasa-drain-arthritis-figured.trycloudflare.com</code> trycloudflare 隧道，由 <code>scripts/fetch_c09_signal.py</code> 定时拉取并落盘到 <code>public/data/c09-signal.json</code>。</p>
        <div class="meta-bar">
          <span class="pill">{status === 'ok' ? '🟢 正常' : status === 'no_signal' ? '🟡 非交易日' : '🔴 异常'}</span>
          <span class="muted">交易日期：{tradeDate}</span>
          <span class="muted">实验室生成：{relativeTime(generatedAt)}</span>
          <span class="muted">本站拉取：{relativeTime(fetchedAt)}</span>
          {meta.next_refresh_at && <span class="muted">下次刷新：{relativeTime(meta.next_refresh_at)}</span>}
        </div>
      </section>

      <section class="summary-grid" aria-label="C09 当日摘要">
        <div class="metric"><span class="muted">S/A 级 A 股相关新闻</span><strong>{important.length}</strong></div>
        <div class="metric"><span class="muted">板块冲击星图</span><strong>{sectors.length}</strong></div>
        <div class="metric"><span class="muted">ORION TOP3</span><strong>{top3.length || '—'}</strong></div>
        <div class="metric"><span class="muted">信号状态</span><strong style="font-size: 1.05rem;">{status}</strong></div>
      </section>

      {readError ? (
        <div class="notice">
          <strong>读取本地快照失败：</strong>{readError}<br />
          请先跑一次 <code>python3 scripts/fetch_c09_signal.py</code> 生成 <code>public/data/c09-signal.json</code>。
        </div>
      ) : (
        <div class="dashboard-grid" style="display: grid; grid-template-columns: 1.6fr 1fr; gap: 1rem; align-items: start;">
          <section class="panel card">
            <div class="panel-head">
              <div>
                <h2>S/A 级 A 股相关新闻</h2>
                <p class="status-line">仅保留 <code>rating ∈ &#123;S, A&#125;</code> 且 <code>a_share_relevance=true</code>，按 rating_rank 倒序排列</p>
              </div>
              <span class="pill pill-red">S/A · A股相关</span>
            </div>
            {important.length === 0 ? (
              <div class="empty">当前无 S/A 级 A 股相关新闻（窗口 4 天）。</div>
            ) : (
              <div class="news-list">
                {important.slice(0, 12).map((n: any) => (
                  <article class={`news-card ${n.rating === 'S' ? 'is-s' : 'is-a'}`}>
                    <div class="news-head">
                      <span class="pill pill-red">{n.rating || '?'}</span>
                      {n.rating_rank && <span class="pill">rank {n.rating_rank}</span>}
                      <span class="muted" style="font-size: 0.85rem;">{n.src}</span>
                      <span class="muted" style="font-size: 0.85rem;">{relativeTime(n.datetime)}</span>
                    </div>
                    <div class="news-title">{n.title}</div>
                    {(n.sectors || []).length > 0 && (
                      <div class="news-sectors">
                        {(n.sectors || []).slice(0, 6).map((s: string) => (
                          <span class="chip">{s}</span>
                        ))}
                      </div>
                    )}
                  </article>
                ))}
              </div>
            )}
          </section>

          <aside style="display: grid; gap: 1rem;">
            <section class="panel card">
              <div class="panel-head">
                <div>
                  <h2>板块冲击星图</h2>
                  <p class="status-line">6 维打分：技术 / 资金 / 新闻 / 热度 / 成交 / 政策</p>
                </div>
                <span class="pill">TOP {sectors.length}</span>
              </div>
              {sectors.length === 0 ? (
                <div class="empty">暂无板块打分。</div>
              ) : (
                <div style="overflow-x: auto;">
                  <table class="sector-table">
                    <thead>
                      <tr>
                        <th>板块</th>
                        <th>状态</th>
                        <th>总分</th>
                        <th>技</th>
                        <th>资</th>
                        <th>闻</th>
                        <th>热</th>
                        <th>额</th>
                        <th>策</th>
                      </tr>
                    </thead>
                    <tbody>
                      {sectors.map((s: any) => (
                        <tr>
                          <td><strong>{s.name}</strong></td>
                          <td><span class={`pill ${verdictCls[s.verdict] || ''}`}>{s.verdict || '—'}</span></td>
                          <td>
                            <div class="score-bar" style={`--w: ${Math.max(0, Math.min(100, Number(s.score) || 0))}%`}></div>
                            <div class="score-num">{fmtScore(s.score)}</div>
                          </td>
                          {['technical','funds','news','heat','amount','policy'].map((k: string) => (
                            <td>{fmtScore((s.dimensions || {})[k])}</td>
                          ))}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </section>

            <section class="panel card">
              <div class="panel-head">
                <div>
                  <h2>ORION 当日 TOP3</h2>
                  <p class="status-line">融合打分排序 / {meta.mode || 'own_logic_no_teacher'}</p>
                </div>
                <span class="pill">{top3.length}/3</span>
              </div>
              {top3.length === 0 ? (
                <div class="empty">
                  当前无 TOP3（{status === 'no_signal' ? '非交易日 / 09:28:59 截尾前' : '暂无信号'}）。
                </div>
              ) : (
                <div class="top3-grid">
                  {top3.map((t: any, i: number) => (
                    <div class="top3-card">
                      <strong>#{i + 1} {t.name || t.code || '—'}</strong>
                      <div class="muted" style="font-size: 0.9rem; margin-top: 0.3rem;">{t.code || ''}</div>
                    </div>
                  ))}
                </div>
              )}
            </section>

            <section class="panel card">
              <div class="panel-head">
                <div>
                  <h2>关于这条数据</h2>
                </div>
                <span class="pill">read-only</span>
              </div>
              <ul style="line-height: 1.7; padding-left: 1.2rem; margin: 0;">
                <li>原始数据：<code>nasa-drain-arthritis-figured.trycloudflare.com/api/live-news</code> + <code>/api/current-signal</code></li>
                <li>本地快照：<code>public/data/c09-signal.json</code>（每次 git push 前需刷新）</li>
                <li>采集脚本：<code>scripts/fetch_c09_signal.py</code>（失败保留上次快照，ttl=900s）</li>
                <li>窗口：<code>{meta.news_window_start || '—'} ~ {meta.news_window_end || '—'}</code></li>
                <li>漏斗：input → 竞价 → 基础 → 风控，{meta.pool_size || 80} 票池</li>
                <li><strong>非交易建议</strong>，仅供研测链路交叉验证。</li>
              </ul>
            </section>
          </aside>
        </div>
      )}
    </main>
    <Footer />
  </body>
</html>
