---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { cleanDescription, isEtfResearchPost, isStockPost, sortByPubDateDesc } from '../lib/posts';
const posts = (await getCollection('blog')).filter((post) => isEtfResearchPost(post) && !isStockPost(post)).sort(sortByPubDateDesc);
---
<!doctype html><html lang="zh-CN"><head><BaseHead title={`研测 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} /></head><body><Header /><main>
<section class="page-intro"><div class="kicker"><span class="pill pill-red">研测</span><span class="pill">策略实验</span></div><h1>把临盘发现沉淀成可验证规则</h1><p>这里收录筹码冰点、候选池筛选、持仓弹性与回测实验。每篇文章都围绕假设、证据、结论和后续验证展开。</p></section>
<section><div class="section-heading"><h2>研究归档</h2><span class="pill">共 {posts.length} 篇</span></div><ul class="archive-grid">{posts.map((post) => <li><a class="archive-card card" href={`/blog/${post.id}/`}><div><span class="pill pill-red">{post.data.category ?? '研测'}</span></div><h2>{post.data.title}</h2><p class="description">{cleanDescription(post.data.description)}</p><p class="date"><FormattedDate date={post.data.pubDate} /></p></a></li>)}</ul></section>
</main><Footer /></body></html>
