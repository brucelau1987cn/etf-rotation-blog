---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { isEtfResearchPost, isStockPost, sortByPubDateDesc } from '../lib/posts';

const posts = (await getCollection('blog'))
  .filter((post) => isEtfResearchPost(post) && !isStockPost(post))
  .sort(sortByPubDateDesc);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`研测 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .archive-head { padding: 3rem 0 1.5rem; max-width: 860px; }
      .archive-head p { color: rgb(var(--gray)); font-size: 1.12rem; }
      .research-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; list-style: none; margin: 0; padding: 0; }
      .research-grid li:first-child { grid-column: 1 / -1; }
      .post-card { display: grid; grid-template-columns: 1fr; gap: 0.8rem; padding: 1.2rem; color: rgb(var(--gray-dark)); text-decoration: none; min-height: 13rem; }
      .research-grid li:first-child .post-card { min-height: 15rem; background: linear-gradient(135deg, #fff, var(--accent-soft)); }
      .post-card:hover { transform: translateY(-2px); transition: transform 0.18s ease; color: rgb(var(--gray-dark)); }
      .title { margin: 0; color: rgb(var(--black)); }
      .date { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
      .description { margin: 0; color: rgb(var(--gray)); }
      @media (max-width: 820px) { .research-grid { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="archive-head">
        <span class="pill pill-red">研测</span>
        <h1>ETF信号实验与候选池</h1>
        <p>这里单独记录预测型研测：筹码冰点、ETF持仓弹性、候选池筛选和后续验证，用于把临盘发现沉淀成可回测框架。</p>
      </section>
      <section>
        <ul class="research-grid">
          {posts.map((post) => (
            <li>
              <a class="post-card" href={`/blog/${post.id}/`}>
                {post.data.heroImage && <Image width={720} height={360} src={post.data.heroImage} alt="" />}
                <div><span class="pill pill-red">{post.data.category ?? '研测'}</span><h2 class="title">{post.data.title}</h2></div>
                <p class="description">{post.data.description}</p>
                <p class="date"><FormattedDate date={post.data.pubDate} /></p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
