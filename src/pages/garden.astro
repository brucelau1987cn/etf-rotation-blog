---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type Recommendation = {
  status: string;
  code: string;
  name: string;
  priority: string;
  trigger: string;
  action: string;
};

type WatchItem = { label: string; text: string };

type GardenRecommendations = {
  date: string;
  updated_at: string;
  market_state: string;
  position: string;
  mainline: string;
  summary: string;
  harvest: Recommendation[];
  plant: Recommendation[];
  watch: WatchItem[];
};

const dataPath = join(process.cwd(), 'public', 'data', 'garden-recommendations.json');
const data = JSON.parse(readFileSync(dataPath, 'utf-8')) as GardenRecommendations;

const pageTitle = `ETF花园｜今日推荐 | ${SITE_TITLE}`;
const pageDescription = 'ETF花园今日推荐仪表盘：只展示摘花、准备摘花、种花、准备种花的高优先级名单，历史复盘移入独立页面。';

const updatedAt = data.updated_at || data.date;
const harvest = data.harvest || [];
const plant = data.plant || [];
const watch = data.watch || [];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <style>
      .garden-shell { max-width: 1180px; }
      .hero { padding: 2.5rem 0 1.25rem; display: grid; grid-template-columns: minmax(0, 1.1fr) 360px; gap: 1rem; align-items: stretch; }
      .hero h1 { margin: 0.45rem 0 0.6rem; }
      .hero p { color: rgb(var(--gray)); font-size: 1.08rem; max-width: 60ch; }
      .strategy-card { padding: 1rem; display: grid; gap: 0.75rem; }
      .metric { padding: 0.85rem 0.95rem; border-radius: 14px; background: var(--warm-2); border: 1px solid var(--border); }
      .metric span { display: block; color: rgb(var(--gray)); font-size: 0.78rem; font-weight: 800; letter-spacing: 0.04em; }
      .metric strong { font-size: 1.2rem; }
      .section-head { display: flex; align-items: end; justify-content: space-between; gap: 1rem; margin: 1.25rem 0 0.8rem; }
      .section-head h2 { margin: 0; }
      .section-head p { margin: 0; color: rgb(var(--gray)); font-size: 0.92rem; }
      .recommend-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.9rem; }
      .recommend-card { position: relative; overflow: hidden; padding: 1rem; border-radius: 18px; background: var(--paper); border: 1px solid var(--border); box-shadow: var(--box-shadow); }
      .recommend-card::before { content: ''; position: absolute; inset: 0 auto 0 0; width: 5px; background: var(--accent); }
      .recommend-card.green::before { background: var(--green); }
      .recommend-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.75rem; margin-bottom: 0.8rem; }
      .ticker { display: grid; gap: 0.1rem; }
      .ticker code { width: fit-content; font-size: 1rem; font-weight: 900; background: #fff; }
      .ticker strong { font-size: 1.05rem; }
      .priority { font-size: 0.76rem; font-weight: 900; padding: 0.22rem 0.55rem; border-radius: 999px; background: var(--warm); color: rgb(var(--gray-dark)); border: 1px solid var(--border); white-space: nowrap; }
      .recommend-card p { margin: 0.45rem 0; color: rgb(var(--gray-dark)); }
      .recommend-card .label { color: rgb(var(--gray)); font-size: 0.78rem; font-weight: 900; margin-right: 0.25rem; }
      .watch-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 0.8rem; }
      .watch { padding: 0.95rem; border-radius: 16px; background: var(--paper); border: 1px solid var(--border); box-shadow: var(--box-shadow); }
      .watch strong { display: block; margin-bottom: 0.35rem; }
      .links-panel { margin-top: 1.5rem; padding: 1rem; display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; justify-content: space-between; }
      .links-panel p { margin: 0; color: rgb(var(--gray)); }
      .button-row { display: flex; flex-wrap: wrap; gap: 0.6rem; }
      .button { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; padding: 0.68rem 0.95rem; text-decoration: none; font-weight: 900; background: rgb(var(--black)); color: #fff; }
      .button.secondary { background: var(--warm); color: rgb(var(--black)); border: 1px solid var(--border); }
      .button:hover { color: #fff; transform: translateY(-1px); }
      .button.secondary:hover { color: rgb(var(--black)); }
      .risk-note { margin: 1.2rem 0 0; padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 14px; background: var(--amber-soft); color: rgb(var(--gray-dark)); font-size: 0.85rem; line-height: 1.6; }
      @media (max-width: 900px) {
        .hero, .recommend-grid, .watch-grid { grid-template-columns: 1fr; }
        main { width: min(100% - 1rem, 1180px); }
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="garden-shell">
      <section class="hero">
        <div>
          <span class="pill pill-red">ETF花园主入口</span>
          <h1>今日推荐仪表盘</h1>
          <p>{data.summary || '主入口只保留可操作推荐：摘花 / 准备摘花、种花 / 准备种花。四窗口复盘和历史记录移到独立页面。'}</p>
          <div class="decision-tags">
            <span class="pill pill-red">🔴 种花 = 低吸 / 持有观察</span>
            <span class="pill pill-green">🟢 摘花 = 止盈 / 减仓观察</span>
            <span class="pill pill-amber">适用交易日：{data.date}</span>
            <span class="pill">数据截止：{updatedAt}</span>
          </div>
        </div>
        <aside class="strategy-card card">
          <div class="metric"><span>市场状态</span><strong>{data.market_state}</strong></div>
          <div class="metric"><span>仓位建议</span><strong>{data.position}</strong></div>
          <div class="metric"><span>今日主线</span><strong>{data.mainline}</strong></div>
        </aside>
      </section>

      <section>
        <div class="section-head">
          <div>
            <span class="pill pill-green">🟢 高抛区</span>
            <h2>摘花 / 准备摘花</h2>
          </div>
          <p>只保留需要优先减仓或兑现观察的方向</p>
        </div>
        <div class="recommend-grid">
          {harvest.map((item) => (
            <article class="recommend-card green" id={`etf-${item.code}`}>
              <div class="recommend-top">
                <div class="ticker"><code>{item.code}</code><strong>{item.name}</strong></div>
                <span class="priority">{item.status}｜{item.priority}</span>
              </div>
              <p><span class="label">理由</span>{item.trigger}</p>
              <p><span class="label">动作</span>{item.action}</p>
            </article>
          ))}
        </div>
      </section>

      <section>
        <div class="section-head">
          <div>
            <span class="pill pill-red">🔴 低吸区</span>
            <h2>种花 / 准备种花</h2>
          </div>
          <p>优先看主线弹性和目标价触发，弱分支降权</p>
        </div>
        <div class="recommend-grid">
          {plant.map((item) => (
            <article class="recommend-card red" id={`etf-${item.code}`}>
              <div class="recommend-top">
                <div class="ticker"><code>{item.code}</code><strong>{item.name}</strong></div>
                <span class="priority">{item.status}｜{item.priority}</span>
              </div>
              <p><span class="label">理由</span>{item.trigger}</p>
              <p><span class="label">动作</span>{item.action}</p>
            </article>
          ))}
        </div>
      </section>

      <section>
        <div class="section-head">
          <div>
            <span class="pill pill-amber">明日验证</span>
            <h2>只看 4 个条件</h2>
          </div>
        </div>
        <div class="watch-grid">
          {watch.map((item) => (
            <div class="watch"><strong>{item.label}</strong><span>{item.text}</span></div>
          ))}
        </div>
      </section>

      <p class="risk-note"><strong>风险提示：</strong>页面动作仅用于个人研究和策略复盘。行情与资金数据可能延迟、缺失或错误；历史表现不代表未来收益。种花、摘花均需结合个人仓位和触发条件独立决策。</p>

      <section class="links-panel card">
        <p>四窗口过程、历史命中和完整归档已移入历史页。</p>
        <div class="button-row">
          <a class="button" href="/garden/history/">查看历史复盘</a>
          <a class="button secondary" href="/momentum/">动量雷达</a>
          <a class="button secondary" href="/blog/">每日复盘</a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
