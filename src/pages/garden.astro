---
import { getEntry, render } from 'astro:content';
import BlogPost from '../layouts/BlogPost.astro';

const post = await getEntry('blog', 'garden/etf-garden');

if (!post) {
  throw new Error('Missing ETF garden post: garden/etf-garden');
}

const { Content } = await render(post);
---

<BlogPost {...post.data}>
  <Content />
</BlogPost>
