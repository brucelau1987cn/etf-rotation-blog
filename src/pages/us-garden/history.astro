---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
const data = JSON.parse(readFileSync(join(process.cwd(), 'public/data/us-etf-backtest.json'), 'utf8'));
---
<!doctype html><html lang="zh-CN"><head><BaseHead title="美股ETF花园｜历史成绩" description="美股ETF花园历史方向验证、统计口径及回测限制。" /></head><body><Header /><main class="site-shell"><section class="hero"><span class="pill">🇺🇸 US ETF HISTORY</span><h1>美股ETF花园历史成绩</h1><p>公开样本、口径和限制。方向命中不等于实际交易收益。</p></section><section class="score"><article><span>验证样本</span><strong>{data.sample_count.toLocaleString()}条</strong></article><article><span>次日方向命中</span><strong>{data.next_day_direction_rate}%</strong></article><article><span>收益口径</span><strong>Adjusted Close</strong></article><article><span>对照基准</span><strong>{data.benchmark}</strong></article></section><section class="card"><h2>当前验证定义</h2><p>当ETF收盘价站上MA20，且MA20高于五个交易日前的MA20时，记录一次“趋势通过”；检查下一交易日复权收盘是否不低于信号日。</p><div class="notice">{data.note} 该统计尚未计入交易成本、买卖价差、盘中可执行窗口、止损、止盈以及相对SPY超额收益。</div></section><section class="grid"><article class="card"><h2>四层成绩体系</h2><ol><li><strong>目标触发率：</strong>原始OHLC是否触达预设价位。</li><li><strong>方向命中率：</strong>次日、三日、五日方向。</li><li><strong>可执行命中率：</strong>是否出现实际入场窗口。</li><li><strong>收益验证：</strong>复权收益、最大回撤、相对SPY收益。</li></ol></article><article class="card"><h2>后续扩展</h2><ul><li>滚动一年与三年窗口</li><li>牛市、熊市、高VIX分组</li><li>相对SPY超额收益</li><li>按交易状态统计胜率</li><li>交易成本与滑点敏感度</li></ul></article></section><div class="links"><a href="/us-garden/">返回美股花园</a><a href="/us-momentum/">进入趋势雷达</a><a href="/garden/history/">查看A股成绩</a></div></main><Footer /><style>main{padding-block:1.5rem 3rem}.hero{padding:1rem 0}.hero h1{font-size:clamp(2rem,5vw,3.4rem);margin:.5rem 0}.hero p{color:rgb(var(--gray-dark))}.pill{background:#e8f2ff;color:#174ea6}.score{display:grid;grid-template-columns:repeat(4,1fr);gap:.8rem;margin:1rem 0}.score article,.card{padding:1rem;border:1px solid var(--border);border-radius:20px;background:#fff}.score article{display:grid;gap:.35rem}.score span{font-size:.8rem;color:rgb(var(--gray))}.score strong{font-size:1.25rem}.notice{padding:1rem;background:#fff8e6;border-left:4px solid #d99a00}.grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem}.grid li{margin:.55rem 0}.links{display:flex;gap:1rem;flex-wrap:wrap;margin-top:1.5rem}.links a{color:#174ea6;font-weight:850}@media(max-width:720px){.score,.grid{grid-template-columns:repeat(2,1fr)}.grid{grid-template-columns:1fr}}</style></body></html>
