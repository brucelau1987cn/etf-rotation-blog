---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import UsSubnav from '../../components/UsSubnav.astro';
const backtest = JSON.parse(readFileSync(join(process.cwd(), 'public/data/us-etf-backtest.json'), 'utf8'));
const flowerHistory = JSON.parse(readFileSync(join(process.cwd(), 'public/data/us-etf-flower-history.json'), 'utf8'));
const records = flowerHistory.records || [];
const total = (key: string) => records.reduce((sum: number, r: any) => sum + (r.counts?.[key] || 0), 0);
const labels: Record<string,string> = { ready_plant:'候场', plant:'伏击', ready_harvest:'止盈观察', harvest:'兑现', exit:'破位撤退' };
---
<!doctype html><html lang="zh-CN"><head><BaseHead title="美股ETF罗盘｜信号历史与成绩" description="美股ETF伏击兑现信号历史、方向验证及统计口径。" /></head><body><Header /><main class="site-shell"><UsSubnav active="history" />
<section class="hero"><span class="pill">🇺🇸 US ETF COMPASS HISTORY</span><h1>美股ETF罗盘历史成绩</h1><p>伏击、兑现与失效信号按交易日留档；准备信号和实际触发分开统计。</p></section>
<section class="score"><article><span>记录交易日</span><strong>{records.length}天</strong></article><article><span>伏击触发</span><strong>{total('plant')}次</strong></article><article><span>兑现触发</span><strong>{total('harvest')}次</strong></article><article><span>破位撤退</span><strong>{total('exit')}次</strong></article></section>
<section class="card"><h2>罗盘信号时间线</h2>{records.length ? <div class="timeline">{records.map((record:any) => <article><div class="date"><strong>{record.date}</strong><small>{record.market_regime?.state} · 权益参考{record.market_regime?.equity_allocation}</small></div><div class="counts">{Object.entries(record.counts || {}).map(([key,value]:any) => <span>{labels[key]} <b>{value}</b></span>)}</div><div class="symbols">{Object.entries(record.signals || {}).flatMap(([key,items]:any) => items.map((x:any) => <span><b>{labels[key]}</b> {x.symbol} · ${x.trigger_level}</span>))}</div></article>)}</div> : <p>尚未生成首个交易日记录。</p>}</section>
<section class="score secondary"><article><span>趋势验证样本</span><strong>{backtest.sample_count.toLocaleString()}条</strong></article><article><span>次日方向命中</span><strong>{backtest.next_day_direction_rate}%</strong></article><article><span>收益口径</span><strong>Adjusted Close</strong></article><article><span>对照基准</span><strong>{backtest.benchmark}</strong></article></section>
<section class="grid"><article class="card"><h2>触发规则</h2><ol><li><strong>伏击：</strong>当日最低价触达前一快照伏击位，收盘未跌破防守线。</li><li><strong>兑现：</strong>当日最高价触达前一快照兑现位。</li><li><strong>失效：</strong>当日最低价触达前一快照防守线。</li><li><strong>准备：</strong>距当前关键位3%以内，仅作次日计划。</li></ol></article><article class="card"><h2>审计口径</h2><ul><li>触发使用未复权原始OHLC</li><li>收益使用Adjusted Close</li><li>同一交易日重复运行覆盖、不重复累计</li><li>最多保留260个交易日</li><li>准备信号不计作实际成交</li></ul></article></section>
<section class="card notice"><strong>限制：</strong>方向验证不等同实际收益。罗盘记录尚未计入交易成本、点差、滑点、税务与盘中成交顺序；没有实际持仓时，“兑现”表示目标触发，不代表账户完成卖出。</section>
<div class="links"><a href="/us-garden/">返回美股罗盘</a><a href="/us-momentum/">进入美股雷达</a><a href="/garden/history/">查看A股成绩</a></div>
</main><Footer /><style>
main{width:min(1180px,calc(100% - 1.5rem));margin:auto;padding:1rem 0 3rem}.hero{padding:1rem 0}.hero h1{font-size:clamp(2rem,5vw,3.4rem);margin:.5rem 0}.hero p{color:rgb(var(--gray-dark))}.pill{background:#e8f2ff;color:#174ea6}.score{display:grid;grid-template-columns:repeat(4,1fr);gap:.8rem;margin:1rem 0}.score article,.card{padding:1rem;border:1px solid var(--border);border-radius:20px;background:#fff}.score article{display:grid;gap:.35rem}.score span{font-size:.8rem;color:rgb(var(--gray))}.score strong{font-size:1.2rem}.secondary{margin-top:1.5rem}.timeline>article{padding:1rem 0;border-top:1px solid var(--border)}.date{display:flex;justify-content:space-between;gap:.8rem}.date small{color:rgb(var(--gray))}.counts,.symbols{display:flex;flex-wrap:wrap;gap:.45rem;margin-top:.7rem}.counts span,.symbols span{padding:.35rem .55rem;border-radius:999px;background:#f1f5f9;font-size:.78rem}.symbols span{background:#f8fafc}.grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.card li{margin:.55rem 0}.notice{margin-top:1rem;background:#fff8e6;border-left:4px solid #d99a00}.links{display:flex;gap:1rem;margin-top:1.5rem;flex-wrap:wrap}.links a{color:#174ea6;font-weight:800}@media(max-width:720px){.score{grid-template-columns:1fr 1fr}.grid{grid-template-columns:1fr}.date{display:grid}}
</style></body></html>