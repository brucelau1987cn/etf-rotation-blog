---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const watchlist = [
  { code: 'LC0', name: '碳酸锂', exchange: '广期所', focus: '新能源链库存与现货贴水', state: '重点跟踪', bias: '低位波段' },
  { code: 'PS0', name: '多晶硅', exchange: '广期所', focus: '产能出清与现金成本线', state: '重点跟踪', bias: '周期修复' },
  { code: 'SI0', name: '工业硅', exchange: '广期所', focus: '光伏链补库与仓单变化', state: '观察', bias: '供需验证' },
  { code: 'AU0', name: '黄金', exchange: '上期所', focus: '美元利率、避险与实际利率', state: '观察', bias: '趋势防守' },
  { code: 'SC0', name: '原油', exchange: '能源中心', focus: '地缘风险与库存周期', state: '观察', bias: '事件驱动' },
  { code: 'M0', name: '豆粕', exchange: '大商所', focus: '美豆天气、压榨利润与基差', state: '观察', bias: '商品独立alpha' },
];

const modules = [
  { title: '结构', body: 'BOS / CHoCH 判断趋势切换，区分主升、反抽、破位和箱体震荡。' },
  { title: '资金', body: '成交量、持仓量和席位多空变化合并判断，过滤单日情绪噪声。' },
  { title: '缺口', body: '跟踪 FVG 与夜盘跳空，确认回补、延续和失效位置。' },
  { title: '供需', body: '仓单、库存、现货升贴水和产业链利润决定胜率边界。' },
];
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title="期货罗盘 | ETF罗盘" description="期货罗盘用于跟踪中国商品期货趋势、资金、缺口和供需变化，重点覆盖碳酸锂、多晶硅、工业硅、黄金、原油和豆粕。" />
    <style>
      main{width:min(1120px,calc(100% - 2rem));padding:1.15rem 0 3rem}
      .hero{display:grid;grid-template-columns:1.1fr .9fr;gap:1rem;align-items:stretch;margin-top:.65rem}
      .hero-main,.hero-side{padding:1.2rem;border:1px solid var(--border);border-radius:16px;background:#fff;box-shadow:var(--box-shadow)}
      .hero-main{border-top:5px solid var(--amber)}
      .hero h1{margin:.35rem 0 .5rem;font-size:clamp(1.9rem,4.2vw,2.7rem)}
      .hero p{margin:0;color:rgb(var(--gray));line-height:1.6;max-width:680px}
      .hero-tags{display:flex;flex-wrap:wrap;gap:.45rem;margin-top:.9rem}
      .status-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.55rem;margin-top:.75rem}
      .status{padding:.7rem;border:1px solid var(--border);border-radius:11px;background:var(--warm-2)}
      .status span{display:block;font-size:.68rem;color:rgb(var(--gray));font-weight:780}
      .status strong{display:block;margin-top:.18rem;font-size:.92rem;line-height:1.35}
      .section-head{display:flex;justify-content:space-between;gap:1rem;align-items:flex-end;margin:1.35rem 0 .65rem}
      .section-head h2{margin:0;font-size:1.35rem}
      .section-head p{margin:0;color:rgb(var(--gray));font-size:.82rem}
      .watch-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:.75rem}
      .future-card{padding:.9rem;border:1px solid var(--border);border-radius:13px;background:#fff;box-shadow:var(--box-shadow);min-width:0}
      .future-top{display:flex;justify-content:space-between;gap:.6rem;align-items:flex-start}
      .future-top strong{display:block;font-size:1rem}
      .future-top small{display:block;color:rgb(var(--gray));font-size:.68rem}
      .tag{padding:.18rem .45rem;border-radius:999px;background:var(--amber-soft);color:var(--amber);font-size:.66rem;font-weight:850;white-space:nowrap}
      .future-card p{margin:.65rem 0 .75rem;color:rgb(var(--gray));font-size:.78rem;line-height:1.5}
      .bias{display:flex;justify-content:space-between;gap:.5rem;padding-top:.65rem;border-top:1px solid var(--border);font-size:.75rem;color:rgb(var(--gray))}
      .bias strong{font-size:.78rem;color:rgb(var(--gray-dark))}
      .module-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.75rem}
      .module{padding:.9rem;border:1px solid var(--border);border-radius:13px;background:var(--warm-2)}
      .module h3{margin:0 0 .38rem;font-size:1rem}
      .module p{margin:0;color:rgb(var(--gray));font-size:.78rem;line-height:1.55}
      .roadmap{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:.75rem;margin-top:.8rem}
      .step{padding:.9rem;border:1px solid var(--border);border-radius:13px;background:#fff}
      .step span{display:inline-flex;align-items:center;justify-content:center;width:1.8rem;height:1.8rem;border-radius:999px;background:rgb(var(--black));color:#fff;font-weight:900;font-size:.8rem}
      .step h3{margin:.55rem 0 .35rem;font-size:1rem}
      .step p{margin:0;color:rgb(var(--gray));font-size:.78rem;line-height:1.55}
      @media(max-width:900px){.hero{grid-template-columns:1fr}.watch-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.module-grid,.roadmap{grid-template-columns:repeat(2,minmax(0,1fr))}}
      @media(max-width:620px){main{width:min(100% - 1rem,1120px);padding-top:.75rem}.hero-main,.hero-side{padding:.95rem}.watch-grid,.module-grid,.roadmap{grid-template-columns:1fr}.section-head{display:block}.section-head p{margin-top:.2rem}.status-grid{grid-template-columns:1fr}}
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="hero" aria-label="期货罗盘首页">
        <div class="hero-main">
          <span class="pill pill-amber">期货罗盘</span>
          <h1>商品期货趋势与供需雷达</h1>
          <p>先跟踪结构和资金，再用仓单、库存、现货升贴水确认胜率。首版聚焦新能源链和高流动性商品，后续接入自动行情、仓单和席位数据。</p>
          <div class="hero-tags">
            <span class="pill">BOS / CHoCH</span>
            <span class="pill">资金流五档</span>
            <span class="pill">FVG缺口</span>
            <span class="pill">仓单供需</span>
          </div>
        </div>
        <aside class="hero-side" aria-label="期货罗盘状态">
          <span class="pill">首版状态</span>
          <div class="status-grid">
            <div class="status"><span>覆盖品种</span><strong>{watchlist.length}个</strong></div>
            <div class="status"><span>核心市场</span><strong>中国商品期货</strong></div>
            <div class="status"><span>重点链条</span><strong>锂电 / 光伏 / 资源</strong></div>
            <div class="status"><span>更新节奏</span><strong>手动研究 -> 自动化</strong></div>
          </div>
        </aside>
      </section>

      <section aria-label="期货观察池">
        <div class="section-head">
          <h2>观察池</h2>
          <p>代码采用连续主力合约口径，正式信号接入后展示实时价、关键位和动作状态。</p>
        </div>
        <div class="watch-grid">
          {watchlist.map((item) => (
            <article class="future-card">
              <div class="future-top">
                <div>
                  <strong>{item.code} · {item.name}</strong>
                  <small>{item.exchange}</small>
                </div>
                <span class="tag">{item.state}</span>
              </div>
              <p>{item.focus}</p>
              <div class="bias"><span>当前任务</span><strong>{item.bias}</strong></div>
            </article>
          ))}
        </div>
      </section>

      <section aria-label="分析框架">
        <div class="section-head">
          <h2>分析框架</h2>
          <p>期货罗盘采用结构、资金、缺口、供需四层交叉验证。</p>
        </div>
        <div class="module-grid">
          {modules.map((item) => (
            <article class="module">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section aria-label="接入路线">
        <div class="section-head">
          <h2>接入路线</h2>
          <p>页面入口先上线，数据闭环分三步补齐。</p>
        </div>
        <div class="roadmap">
          <article class="step"><span>1</span><h3>行情快照</h3><p>接入连续合约日线和实时价，输出趋势、波动和关键位。</p></article>
          <article class="step"><span>2</span><h3>供需因子</h3><p>合并仓单、库存、现货价格和产业利润，标注供应压力和补库强度。</p></article>
          <article class="step"><span>3</span><h3>信号复盘</h3><p>冻结每日判断，回填 T+1 / T+5 表现，持续校准胜率和盈亏比。</p></article>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
