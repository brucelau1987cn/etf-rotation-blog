---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html><html lang="zh-CN"><head><BaseHead title="美股ETF趋势雷达｜45池" description="美股ETF趋势雷达：相对SPY强度、交易风险、交易状态和主题代表观察池。" /></head><body><Header /><main class="site-shell">
<section class="hero"><span class="pill">🇺🇸 US ETF · 45 POOL</span><h1>美股ETF趋势雷达</h1><p>趋势确认工具，不是买入推荐榜。收益和趋势使用Adjusted Close；目标触发使用原始OHLC。</p></section>
<section class="board card"><div><span>市场状态</span><strong id="regime">—</strong></div><div><span>趋势通过</span><strong id="pass">—</strong></div><div><span>有效数据</span><strong id="valid">—</strong></div><div><span>模型日期</span><strong id="model-date">—</strong></div><p id="source">正在加载数据…</p></section>
<section class="toolbar card"><label>资产类型<select id="type"><option value="全部">全部</option><option>宽基</option><option>行业</option><option>主题</option><option>海外</option><option>债券</option><option>商品</option><option>现金</option><option>宏观</option></select></label><label>交易状态<select id="state"><option value="全部">全部</option><option>可持有</option><option>回踩候选</option><option>禁止追高</option><option>观察</option><option>退出</option></select></label><label>排序<select id="sort"><option value="trend_score">趋势评分</option><option value="relative_spy20">相对SPY</option><option value="ret20">20日收益</option><option value="trading_risk_score">交易风险</option></select></label><label class="check"><input id="pass-only" type="checkbox"/>仅看趋势通过</label></section>
<section><div class="heading"><div><span>THEME REPRESENTATIVES</span><h2>主题代表观察池</h2></div><a href="/us-garden/">查看今日动作 →</a></div><div id="top" class="top-grid"><p>加载中…</p></div></section>
<section class="table-card card"><div class="heading"><div><span>FULL UNIVERSE</span><h2>完整45池</h2></div><b id="count">—</b></div><div class="table-wrap"><table><thead><tr><th>ETF</th><th>类型/主题</th><th>趋势</th><th>状态</th><th>价格</th><th>20日</th><th>相对SPY</th><th>风险</th><th>关键位</th></tr></thead><tbody id="rows"><tr><td colspan="9">加载中…</td></tr></tbody></table></div></section>
<section class="note card"><strong>时间与数据范围</strong><p id="scope">模型快照与行情检查时间分开显示。页面不会把接口刷新时间伪装成交易时间。</p><a href="/us-garden/history/">查看历史成绩与统计口径</a></section>
</main><Footer />
<script>
const $=(id)=>document.getElementById(id); let data; const up=n=>Number(n)>=0?'up':'down'; const fmt=n=>Number.isFinite(Number(n))?Number(n).toFixed(2):'—';
function render(){if(!data)return; const type=$('type').value,state=$('state').value,key=$('sort').value; let rows=[...data.rows]; if(type!=='全部')rows=rows.filter(r=>r.asset_type===type); if(state!=='全部')rows=rows.filter(r=>r.trade_state===state); if($('pass-only').checked)rows=rows.filter(r=>r.momentum_pass); rows.sort((a,b)=>(Number(b[key])||-999)-(Number(a[key])||-999)); $('count').textContent=`${rows.length}只`; $('rows').innerHTML=rows.map(r=>`<tr><td><strong>${r.symbol}</strong><small>${r.name}</small></td><td>${r.asset_type}<small>${r.theme}</small></td><td><b>${r.strength_level} / ${fmt(r.trend_score)}</b></td><td><span class="state ${r.trade_state==='禁止追高'?'danger':r.trade_state==='可持有'?'hold':'watch'}">${r.trade_state}</span></td><td>$${fmt(r.price)}</td><td class="${up(r.ret20)}">${r.ret20>=0?'+':''}${fmt(r.ret20)}%</td><td class="${up(r.relative_spy20)}">${r.relative_spy20>=0?'+':''}${fmt(r.relative_spy20)}pp</td><td><b>${r.risk_level} / ${fmt(r.trading_risk_score)}</b><small>${(r.risk_flags||[]).slice(0,2).join('、')||'—'}</small></td><td><small>回踩 $${r.support}<br/>失效 $${r.stop}</small></td></tr>`).join('')||'<tr><td colspan="9">当前筛选无结果</td></tr>'}
async function load(){try{const res=await fetch(`/data/us-etf-pool.json?cb=${Date.now()}`,{cache:'no-store'});data=await res.json();$('regime').textContent=`${data.market_regime.state}｜权益${data.market_regime.equity_allocation}`;$('pass').textContent=`${data.summary.momentum_pass}/${data.summary.universe}`;$('valid').textContent=`${data.summary.valid}/${data.summary.universe}`;$('model-date').textContent=data.model_date;$('source').textContent=`行情交易日 ${data.quote_trade_date}｜模型生成 ${new Date(data.generated_at).toLocaleString('zh-CN',{timeZone:'America/New_York',hour12:false})} ET｜${data.data_source}`;$('scope').textContent=`实时字段：${data.realtime_scope.join('、')}。快照字段：${data.snapshot_scope.join('、')}。上涨为绿色，下跌为红色。`; $('top').innerHTML=data.recommendations.map(r=>`<article class="top-card card"><div><span>${r.theme}</span><h3>${r.symbol} · ${r.name}</h3></div><p><b>趋势 ${r.strength_level}/${r.trend_score}</b><b>风险 ${r.risk_level}/${r.trading_risk_score}</b><b>${r.trade_state}</b></p><p>20日 <i class="${up(r.ret20)}">${r.ret20>=0?'+':''}${r.ret20}%</i>｜相对SPY <i class="${up(r.relative_spy20)}">${r.relative_spy20>=0?'+':''}${r.relative_spy20}pp</i></p><small>回踩 $${r.support}｜失效 $${r.stop}</small></article>`).join('');render()}catch(e){$('source').textContent=`数据加载失败：${e.message}`}}
['type','state','sort','pass-only'].forEach(id=>$(id).addEventListener('change',render));load();
</script>
<style>
main{padding-block:1.5rem 3rem}.hero{padding:1rem 0 1.5rem}.hero h1{font-size:clamp(2.1rem,5vw,3.5rem);margin:.5rem 0}.hero p{color:rgb(var(--gray-dark))}.pill{background:#e8f2ff;color:#174ea6}.card{background:#fff;border:1px solid var(--border);border-radius:20px;box-shadow:0 10px 30px rgba(15,23,42,.05)}.board{display:grid;grid-template-columns:repeat(4,1fr);padding:1rem}.board div{display:grid;gap:.2rem;padding:.35rem 1rem;border-right:1px solid var(--border)}.board div:nth-child(4){border:0}.board span,.heading span{font-size:.75rem;color:rgb(var(--gray));letter-spacing:.08em}.board strong{font-size:1.1rem}.board p{grid-column:1/-1;margin:.75rem 1rem 0;color:rgb(var(--gray));font-size:.85rem}.toolbar{display:flex;align-items:end;gap:.8rem;padding:1rem;margin:1rem 0}.toolbar label{display:grid;gap:.3rem;font-size:.8rem;font-weight:800}.toolbar select{min-width:145px;border:1px solid var(--border);border-radius:10px;padding:.55rem;background:#fff}.toolbar .check{display:flex;align-items:center;padding:.55rem}.heading{display:flex;justify-content:space-between;align-items:end;margin:1.8rem 0 .8rem}.heading h2{margin:.2rem 0}.heading a,.note a{color:#174ea6;font-weight:800}.top-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.8rem}.top-card{padding:1rem}.top-card h3{margin:.25rem 0}.top-card span{font-size:.75rem;color:#174ea6;font-weight:900}.top-card p{display:flex;gap:.8rem;flex-wrap:wrap}.top-card i{font-style:normal;font-weight:800}.table-card{padding:1rem;margin-top:2rem}.table-card .heading{margin:0 0 .8rem}.table-wrap{overflow:auto}table{border-collapse:collapse;width:100%;min-width:960px}th,td{text-align:left;padding:.7rem;border-bottom:1px solid var(--border);font-size:.86rem}th{position:sticky;top:0;background:#f7f9fc}td small{display:block;color:rgb(var(--gray));margin-top:.2rem}.state{padding:.25rem .5rem;border-radius:999px;font-size:.75rem;font-weight:900}.hold{background:#e8f7ee;color:#176b3a}.watch{background:#fff3d6;color:#8a5a00}.danger{background:#fff0f0;color:#b42318}.up{color:#16803c}.down{color:#c5221f}.note{padding:1rem;margin-top:1rem}.note p{color:rgb(var(--gray-dark))}@media(max-width:720px){.board{grid-template-columns:repeat(2,1fr)}.board div:nth-child(2){border:0}.toolbar{overflow:auto}.top-grid{grid-template-columns:1fr}}
</style></body></html>
