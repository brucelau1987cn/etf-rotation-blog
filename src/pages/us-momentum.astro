---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import UsSubnav from '../components/UsSubnav.astro';
---
<!doctype html>
<html lang="zh-CN">
<head>
  <BaseHead title="美股趋势风控雷达｜ETF池市场结构与风险过滤" description="美股趋势风控雷达：通过市场广度、相对SPY强度、趋势质量和交易风险，为左侧轮动与右侧动量提供确认和过滤。" />
  <style>
    :root{--terminal:#122033;--terminal-2:#1c3950;--ink:#142033;--muted:#64748b;--line:#dce4ee;--teal:#0f8b83;--green:#137547;--orange:#c96a13;--red:#c5221f;--blue:#2563eb}
    main{width:min(1180px,calc(100% - 1.5rem));margin:auto;padding:1rem 0 3rem}.card{background:#fff;border:1px solid var(--border);border-radius:20px;box-shadow:0 10px 30px rgba(15,23,42,.05)}
    .terminal-hero{position:relative;overflow:hidden;padding:clamp(1.1rem,3vw,1.7rem);color:#fff;background:linear-gradient(135deg,var(--terminal),var(--terminal-2) 68%,#17615e)}.terminal-hero:after{content:"";position:absolute;width:360px;height:360px;right:-150px;top:-185px;border:1px solid rgba(255,255,255,.12);border-radius:50%;box-shadow:0 0 0 55px rgba(255,255,255,.025),0 0 0 110px rgba(255,255,255,.02)}
    .hero-top,.command{position:relative;z-index:1}.hero-top{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem}.eyebrow,.kicker{font-size:.7rem;font-weight:950;letter-spacing:.13em;color:#83d6cd}.hero-top h1{margin:.35rem 0;color:#fff;font-size:clamp(2rem,5vw,3.35rem);letter-spacing:-.04em}.hero-top p{max-width:64ch;margin:0;color:#cbd8e5;line-height:1.6}.hero-meta{display:grid;gap:.25rem;text-align:right;color:#b7c8d8;font-size:.73rem}.command{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:1rem;margin-top:1.25rem;padding:1rem;border:1px solid rgba(255,255,255,.15);border-radius:18px;background:rgba(255,255,255,.07)}.command-icon{font-size:1.9rem}.command span{display:block;color:#9fb7ca;font-size:.68rem;font-weight:900;letter-spacing:.09em}.command strong{display:block;color:#fff;font-size:1.2rem}.command p{margin:.2rem 0 0;color:#cbd8e5;font-size:.8rem}.macro-chip{padding:.62rem .8rem;border-radius:12px;background:#fff;color:var(--ink);text-decoration:none}.macro-chip small{display:block;color:var(--muted);font-size:.65rem}.macro-chip b{font-size:.82rem}
    .section-head{display:flex;justify-content:space-between;align-items:end;gap:1rem;margin:1.6rem 0 .7rem}.section-head h2{margin:.2rem 0 0;font-size:1.45rem}.section-head p,.section-head>a{margin:0;color:var(--muted);font-size:.78rem}.section-head>a{color:var(--blue);font-weight:850}.matrix{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:.7rem}.metric{padding:1rem;border-top:4px solid var(--teal)}.metric.warning{border-top-color:var(--orange)}.metric.danger{border-top-color:var(--red)}.metric-top{display:flex;justify-content:space-between;gap:.5rem}.metric-top span{color:var(--muted);font-size:.72rem;font-weight:850}.metric-top b{padding:.16rem .42rem;border-radius:999px;background:#edf7f6;color:var(--teal);font-size:.68rem}.metric h3{margin:.75rem 0 .2rem;font-size:1.35rem}.metric p{min-height:2.5em;margin:.2rem 0;color:var(--muted);font-size:.77rem;line-height:1.5}.metric small{display:block;margin-top:.6rem;color:#78909f;font-size:.67rem}
    .line-tabs{display:none;grid-template-columns:1fr 1fr;gap:.45rem;margin:.75rem 0}.line-tabs button{min-height:44px;border:1px solid var(--line);border-radius:12px;background:#fff;color:var(--muted);font-weight:900}.line-tabs button.active{border-color:var(--terminal);background:var(--terminal);color:#fff}.split{display:grid;grid-template-columns:1fr 1fr;gap:1rem;align-items:start}.line-panel{overflow:hidden;border-top:5px solid var(--teal)}.line-panel.risk-line{border-top-color:var(--orange);background:linear-gradient(180deg,#fffaf4 0,#fff 180px)}.line-panel.main-line{background:linear-gradient(180deg,#f4fbfa 0,#fff 180px)}.panel-head{display:flex;justify-content:space-between;gap:1rem;padding:1rem 1rem .8rem;border-bottom:1px solid var(--line)}.panel-head h3{margin:0;font-size:1.08rem}.panel-head p{margin:.28rem 0 0;color:var(--muted);font-size:.72rem}.panel-count{display:grid;place-items:center;min-width:42px;height:32px;border-radius:999px;background:#dff4f1;color:var(--teal);font-weight:950}.risk-line .panel-count{background:#fff0df;color:var(--orange)}.panel-list{display:grid;gap:.55rem;padding:.75rem}.rank-item{overflow:hidden;border:1px solid var(--line);border-radius:14px;background:#fff;transition:border-color .2s,box-shadow .2s}.rank-item[open]{border-color:#9ccfc9;box-shadow:0 8px 22px rgba(15,139,131,.09)}.risk-line .rank-item[open]{border-color:#efb77f;box-shadow:0 8px 22px rgba(201,106,19,.09)}.rank-item summary{display:grid;grid-template-columns:48px 1fr auto;gap:.65rem;align-items:center;padding:.78rem;cursor:pointer;list-style:none}.rank-item summary::-webkit-details-marker{display:none}.rank-symbol{font-size:1rem}.rank-main b{display:block}.rank-main p{margin:.15rem 0;color:var(--muted);font-size:.72rem}.rank-item .right{text-align:right}.rank-item .right b{display:block}.rank-item .right small{color:var(--muted)}.rank-item .open-label{display:none}.rank-item[open] .closed-label{display:none}.rank-item[open] .open-label{display:inline}.rank-detail{display:grid;grid-template-columns:repeat(3,1fr);gap:.45rem;padding:.7rem .78rem .8rem;border-top:1px solid var(--line);border-left:3px solid var(--teal);background:#eef8f6}.risk-line .rank-detail{border-left-color:var(--orange);background:#fff6eb}.rank-detail div{min-width:0}.rank-detail span{display:block;color:var(--muted);font-size:.65rem}.rank-detail b{display:block;margin-top:.12rem;font-size:.76rem}.rank-detail .discipline{grid-column:1/-1;padding-top:.45rem;border-top:1px dashed var(--line);color:var(--ink);line-height:1.45}.panel-foot{display:flex;justify-content:space-between;align-items:center;gap:.6rem;padding:.8rem 1rem;border-top:1px solid var(--line);color:var(--muted);font-size:.7rem}.panel-foot button{border:0;background:transparent;color:var(--blue);font-weight:900;cursor:pointer}.tag{display:inline-flex;padding:.18rem .4rem;border-radius:999px;background:#edf7f6;color:var(--teal);font-size:.65rem;font-weight:900}.tag.warn{background:#fff4e8;color:var(--orange)}.tag.danger{background:#fff0ef;color:var(--red)}
    .macro-map{padding:1rem}.macro-row{display:grid;grid-template-columns:120px 1fr 1fr 1.25fr;gap:.6rem;align-items:center;padding:.65rem 0;border-top:1px solid var(--line);font-size:.76rem}.macro-row:first-of-type{border-top:0}.macro-row span{color:var(--muted)}.macro-row b{font-size:.8rem}.macro-row em{font-style:normal;color:var(--orange);font-weight:850}
    .toolbar{display:flex;align-items:end;gap:.7rem;padding:.9rem;margin:.8rem 0}.toolbar label{display:grid;gap:.28rem;color:var(--muted);font-size:.75rem;font-weight:850}.toolbar select{min-width:138px;padding:.52rem;border:1px solid var(--line);border-radius:10px;background:#fff}.toolbar .check{display:flex;align-items:center;color:var(--ink);padding:.52rem}.table-card{padding:1rem}.table-wrap{overflow:auto}table{width:100%;min-width:960px;border-collapse:collapse}th,td{text-align:left;padding:.68rem;border-bottom:1px solid var(--line);font-size:.82rem}th{position:sticky;top:0;background:#f6f8fb}td small{display:block;color:var(--muted);margin-top:.18rem}.state{padding:.22rem .46rem;border-radius:999px;font-size:.7rem;font-weight:900}.hold{background:#e8f7ee;color:#176b3a}.watch{background:#fff3d6;color:#8a5a00}.danger{background:#fff0f0;color:#b42318}.up{color:var(--market-up)}.down{color:var(--market-down)}.mobile-cards{display:none}.pager{display:flex;justify-content:space-between;align-items:center;gap:1rem;padding-top:.9rem;color:var(--muted);font-size:.78rem}.pager>div{display:flex;align-items:center;gap:.35rem}.pager button{min-width:38px;padding:.45rem .62rem;border:1px solid var(--line);border-radius:9px;background:#fff;color:var(--ink);font-weight:850;cursor:pointer}.pager button:hover:not(:disabled),.pager button.active{background:var(--terminal);color:#fff;border-color:var(--terminal)}.pager button:disabled{opacity:.4;cursor:not-allowed}.page-numbers{display:flex;gap:.25rem}.mobile-etf{padding:.85rem 0;border-top:1px solid var(--line)}.mobile-etf:first-child{border-top:0}.mobile-etf-head{display:flex;justify-content:space-between;gap:.6rem}.mobile-etf-head h3{margin:0;font-size:1rem}.mobile-etf-head p{margin:.15rem 0;color:var(--muted);font-size:.7rem}.mobile-etf-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.4rem;margin-top:.65rem}.mobile-etf-grid div{padding:.5rem;border-radius:10px;background:#f6f8fb}.mobile-etf-grid span{display:block;color:var(--muted);font-size:.65rem}.mobile-etf-grid b{font-size:.8rem}.quality{margin-top:1rem;padding:.9rem}.quality summary{cursor:pointer;font-weight:900}.quality p{color:var(--muted);font-size:.8rem}.quality a{color:var(--blue);font-weight:850}
    @media(max-width:900px){.matrix{grid-template-columns:repeat(2,1fr)}.line-tabs{display:grid}.split{grid-template-columns:1fr}.line-panel[hidden]{display:none}.hero-top{display:grid}.hero-meta{text-align:left}.command{grid-template-columns:auto 1fr}.macro-chip{grid-column:1/-1}.macro-row{grid-template-columns:100px 1fr 1fr}.macro-row em{grid-column:2/-1}}
    @media(max-width:620px){main{width:min(100% - 1rem,1180px);padding-top:1rem}.terminal-hero{padding:1rem}.hero-top h1{font-size:2rem}.hero-meta span:nth-child(2){display:none}.command{gap:.65rem;padding:.75rem}.command-icon{font-size:1.45rem}.command strong{font-size:1.04rem}.matrix{grid-template-columns:1fr}.toolbar{overflow:auto}.macro-row{grid-template-columns:80px 1fr}.macro-row span:nth-child(3){grid-column:2}.rank-item summary{grid-template-columns:42px 1fr;padding:.7rem}.rank-item .right{grid-column:2;text-align:left;display:flex;gap:.45rem}.rank-detail{grid-template-columns:repeat(3,1fr)}.section-head{align-items:flex-start}.table-wrap{display:none}.mobile-cards{display:block}.pager{display:grid;justify-content:stretch;text-align:center}.pager>div{justify-content:space-between}.page-numbers{display:none}.pager button{flex:1}.toolbar{padding:.7rem}.toolbar select{min-width:112px}}
  </style>
  <style is:global>
    .panel-list .rank-item{overflow:hidden;border:1px solid #dce4ee;border-radius:14px;background:#fff;transition:border-color .2s,box-shadow .2s}
    .panel-list .rank-item[open]{border-color:#9ccfc9;box-shadow:0 8px 22px rgba(15,139,131,.09)}
    .risk-line .rank-item[open]{border-color:#efb77f;box-shadow:0 8px 22px rgba(201,106,19,.09)}
    .panel-list .rank-item summary{display:grid;grid-template-columns:48px 1fr auto;gap:.65rem;align-items:center;padding:.78rem;cursor:pointer;list-style:none}
    .panel-list .rank-item summary::-webkit-details-marker{display:none}
    .panel-list .rank-symbol{font-size:1rem}.panel-list .rank-main b{display:block}.panel-list .rank-main p{margin:.15rem 0;color:#64748b;font-size:.72rem}
    .panel-list .rank-item .right{text-align:right}.panel-list .rank-item .right b{display:block}.panel-list .rank-item .right small{color:#64748b}
    .panel-list .rank-item .open-label{display:none}.panel-list .rank-item[open] .closed-label{display:none}.panel-list .rank-item[open] .open-label{display:inline}
    .panel-list .rank-detail{display:grid;grid-template-columns:repeat(3,1fr);gap:.45rem;padding:.7rem .78rem .8rem;border-top:1px solid #dce4ee;border-left:3px solid #0f8b83;background:#eef8f6}
    .risk-line .rank-detail{border-left-color:#c96a13;background:#fff6eb}.panel-list .rank-detail div{min-width:0}.panel-list .rank-detail span{display:block;color:#64748b;font-size:.65rem}.panel-list .rank-detail b{display:block;margin-top:.12rem;font-size:.76rem}.panel-list .rank-detail .discipline{grid-column:1/-1;padding-top:.45rem;border-top:1px dashed #dce4ee;color:#142033;line-height:1.45}
    .panel-list .tag{display:inline-flex;padding:.18rem .4rem;border-radius:999px;background:#edf7f6;color:#0f8b83;font-size:.65rem;font-weight:900}.panel-list .tag.warn{background:#fff4e8;color:#c96a13}.panel-list .up{color:var(--market-up)}.panel-list .down{color:var(--market-down)}
    .table-card .up,.mobile-cards .up,.macro-map .up{color:var(--market-up);font-weight:900}.table-card .down,.mobile-cards .down,.macro-map .down{color:var(--market-down);font-weight:900}
    @media(max-width:620px){.panel-list .rank-item summary{grid-template-columns:42px 1fr;padding:.7rem}.panel-list .rank-item .right{grid-column:2;text-align:left;display:flex;gap:.45rem}.panel-list .rank-detail{grid-template-columns:repeat(3,1fr)}}
  </style>
</head>
<body><Header /><main><UsSubnav active="trend" />
  <section class="terminal-hero card">
    <div class="hero-top"><div><span class="eyebrow">🇺🇸 US ETF TREND &amp; RISK TERMINAL · <span id="hero-pool-size">—</span> POOL</span><h1>美股趋势风控雷达</h1><p>两套策略共用的市场确认与风险过滤层；负责识别结构、强弱和过热，不直接构成买入指令。</p></div><div class="hero-meta"><span id="model-date">模型日期 —</span><span id="source-date">行情日期 —</span><span>行情：🔴上涨 / 🟢下跌</span></div></div>
    <div class="command" role="status" aria-live="polite"><span class="command-icon" id="command-icon">◉</span><div><span>TREND COMMAND</span><strong id="command-title">正在载入趋势结论</strong><p id="command-text">计算ETF池趋势结构、扩散度与风险约束…</p><button id="retry-load" type="button" hidden>重试加载</button></div><a class="macro-chip" href="/us-macro/"><small>宏观约束</small><b id="macro-status">读取中 →</b></a></div>
  </section>

  <div class="section-head"><div><span class="kicker">FOUR-DIMENSION TREND GATE</span><h2>四维趋势矩阵</h2></div><p>同一份<span id="matrix-pool-size">ETF</span>池快照 · 不重复计算相关指标</p></div>
  <section class="matrix">
    <article class="metric card" id="m-breadth"><div class="metric-top"><span>市场广度</span><b id="breadth-state">—</b></div><h3 id="breadth-value">—</h3><p id="breadth-detail">趋势通过率与扩散方向</p><small id="breadth-impact">等待数据</small></article>
    <article class="metric card" id="m-relative"><div class="metric-top"><span>相对强度</span><b id="relative-state">—</b></div><h3 id="relative-value">—</h3><p id="relative-detail">跑赢SPY的ETF数量</p><small id="relative-impact">等待数据</small></article>
    <article class="metric card" id="m-quality"><div class="metric-top"><span>趋势质量</span><b id="quality-state">—</b></div><h3 id="quality-value">—</h3><p id="quality-detail">A级趋势与量价确认</p><small id="quality-impact">等待数据</small></article>
    <article class="metric card" id="m-risk"><div class="metric-top"><span>交易风险</span><b id="risk-state">—</b></div><h3 id="risk-value">—</h3><p id="risk-detail">过热、破位与禁止追高</p><small id="risk-impact">等待数据</small></article>
  </section>

  <div class="section-head"><div><span class="kicker">LEADERS & RISK</span><h2>主线与风险线</h2></div><a href="/us-garden/">进入今日动作 →</a></div>
  <div class="line-tabs" role="tablist" aria-label="主线与风险线切换"><button class="active" type="button" role="tab" aria-selected="true" data-panel="main">🟢 趋势主线 <span id="main-tab-count">—</span></button><button type="button" role="tab" aria-selected="false" data-panel="risk">🟠 弱线与风险 <span id="risk-tab-count">—</span></button></div>
  <section class="split" id="line-panels">
    <article class="line-panel main-line card" id="main-panel"><header class="panel-head"><div><h3>🟢 趋势主线</h3><p>按相对SPY强度排序，主题去重</p></div><b class="panel-count" id="main-count">—</b></header><div class="panel-list" id="leaders">加载中…</div><footer class="panel-foot"><span>点击ETF展开关键位与执行纪律</span><button class="jump-universe" type="button">查看完整池 ↓</button></footer></article>
    <article class="line-panel risk-line card" id="risk-panel"><header class="panel-head"><div><h3>🟠 弱线与风险</h3><p>按交易风险排序，退出信号优先</p></div><b class="panel-count" id="risk-count">—</b></header><div class="panel-list" id="risks">加载中…</div><footer class="panel-foot"><span>点击ETF查看风险理由与防守线</span><button class="jump-universe" type="button">查看完整池 ↓</button></footer></article>
  </section>

  <div class="section-head"><div><span class="kicker">TREND × MACRO</span><h2>趋势与宏观联动</h2></div><p>强趋势遇到宏观约束时，降级为等待回踩</p></div>
  <section class="macro-map card" id="macro-map"><p>正在读取宏观雷达…</p></section>

  <div class="section-head" id="universe-section"><div><span class="kicker">FULL UNIVERSE</span><h2>完整<span id="universe-pool-size">ETF</span>池</h2></div><b id="count">—</b></div>
  <section class="toolbar card"><label>资产类型<select id="type"><option value="全部">全部</option><option>宽基</option><option>行业</option><option>主题</option><option>因子</option><option>海外</option><option>债券</option><option>商品</option><option>加密资产</option><option>现金</option><option>宏观</option></select></label><label>交易状态<select id="state"><option value="全部">全部</option><option>可持有</option><option>回踩候选</option><option>禁止追高</option><option>观察</option><option>退出</option></select></label><label>排序<select id="sort"><option value="trend_score">趋势评分</option><option value="relative_spy20">相对SPY</option><option value="ret20">20日收益</option><option value="trading_risk_score">交易风险</option></select></label><label>每页<select id="page-size"><option value="10">10只</option><option value="20">20只</option><option value="all">全部</option></select></label><label class="check"><input id="pass-only" type="checkbox"/>仅看趋势通过</label></section>
  <section class="table-card card"><div class="table-wrap"><table><thead><tr><th>ETF</th><th>类型/主题</th><th>趋势</th><th>状态</th><th>价格</th><th>20日</th><th>相对SPY</th><th>风险</th><th>关键位</th></tr></thead><tbody id="rows"><tr><td colspan="9">加载中…</td></tr></tbody></table></div><div id="mobile-cards" class="mobile-cards"></div><nav class="pager" aria-label="完整ETF池分页"><span id="page-info">—</span><div><button id="prev-page" type="button">‹ 上一页</button><span id="page-numbers"></span><button id="next-page" type="button">下一页 ›</button></div></nav></section>
  <details class="quality card"><summary>数据时间、口径与限制</summary><p id="scope">模型快照与行情检查时间分开显示。趋势风控用于确认和过滤，不构成买入建议。</p><a href="/us-garden/history/">查看历史成绩与审计口径</a></details>
</main><Footer />
<script>
const $=id=>document.getElementById(id);let data,macro,currentPage=1;const num=n=>Number(n)||0,fmt=n=>Number.isFinite(Number(n))?Number(n).toFixed(2):'—',up=n=>num(n)>=0?'up':'down';
const rankItem=(r,risk=false)=>{const flags=(r.risk_flags||[]).join('、')||'暂无额外风险标记';const discipline=risk?`${r.trade_state}优先；防守线 $${r.stop}，${flags}。`:`趋势未破坏时持有观察；回踩 $${r.support} 附近再评估，跌破 $${r.stop} 失效。`;const relative=`${num(r.relative_spy20)>=0?'+':''}${fmt(r.relative_spy20)}pp`;return `<details class="rank-item ${risk?'risk-item':'leader-item'}"><summary><strong class="rank-symbol">${r.symbol}</strong><div class="rank-main"><b>${r.theme||r.asset_type} · ${r.name}</b><p>趋势 ${r.strength_level}/${fmt(r.trend_score)} · 20日 <span class="${up(r.ret20)}">${num(r.ret20)>=0?'+':''}${fmt(r.ret20)}%</span></p><span class="tag ${risk?'warn':''}">${risk?r.trade_state:`相对SPY <span class="${up(r.relative_spy20)}">${relative}</span>`}</span></div><div class="right"><b>${risk?'风险 '+r.risk_level:r.strength_level+'级'}</b><small><span class="closed-label">展开详情 ▸</span><span class="open-label">收起详情 ▾</span></small></div></summary><div class="rank-detail"><div><span>现价</span><b>$${fmt(r.price)}</b></div><div><span>回踩位</span><b>$${fmt(r.support)}</b></div><div><span>防守线</span><b>$${fmt(r.stop)}</b></div><b class="discipline">${discipline}</b></div></details>`};
function setMetric(key,state,value,detail,impact,tone=''){const box=$('m-'+key);box.classList.toggle('warning',tone==='warning');box.classList.toggle('danger',tone==='danger');$(key+'-state').textContent=state;$(key+'-value').textContent=value;$(key+'-detail').textContent=detail;$(key+'-impact').textContent=impact}
function renderMatrix(){const rows=data.rows||[],valid=rows.filter(r=>Number.isFinite(Number(r.trend_score))),pass=valid.filter(r=>r.momentum_pass),relative=valid.filter(r=>num(r.relative_spy20)>0),a=valid.filter(r=>r.strength_level==='A'),risk=valid.filter(r=>r.trade_state==='禁止追高'||r.trade_state==='退出'||num(r.trading_risk_score)>=65);const passRate=Math.round(pass.length/Math.max(valid.length,1)*100),relRate=Math.round(relative.length/Math.max(valid.length,1)*100);setMetric('breadth',passRate>=55?'健康':passRate>=40?'分化':'偏弱',`${pass.length} / ${valid.length}`,`趋势通过率 ${passRate}%`,passRate>=55?'上涨具有扩散基础':'指数与内部结构可能背离',passRate<40?'danger':passRate<55?'warning':'');setMetric('relative',relRate>=50?'扩散':relRate>=35?'集中':'落后',`${relative.length}只`,`跑赢SPY，占有效池 ${relRate}%`,relRate>=50?'主线不只依赖权重股':'优先龙头，降低边缘方向仓位',relRate<35?'warning':'');setMetric('quality',a.length>=10?'强':a.length>=5?'中性':'不足',`${a.length}只 A级`,`A级趋势占 ${Math.round(a.length/Math.max(valid.length,1)*100)}%`,`确认后仍只在动作位执行`,a.length<5?'warning':'');setMetric('risk',risk.length>=12?'升温':risk.length>=6?'警惕':'可控',`${risk.length}只`,`退出、高风险或禁止追高方向`,risk.length>=6?'强势不追，优先兑现/回踩':'允许按罗盘关键位正常执行',risk.length>=12?'danger':risk.length>=6?'warning':'');const regime=data.market_regime?.state||'未知';$('command-icon').textContent=passRate>=55?'🟢':passRate>=40?'🟡':'🟠';$('command-title').textContent=`${regime} · ${passRate>=55?'趋势扩散健康':passRate>=40?'趋势分化':'趋势承压'}`;$('command-text').textContent=`${pass.length}/${valid.length}只通过趋势，${relative.length}只跑赢SPY，${risk.length}只进入退出、高风险或禁止追高区。${risk.length>=6?'强势方向只等回踩。':'按今日罗盘关键位执行。'}`}
function renderLists(){const valid=(data.rows||[]).filter(r=>Number.isFinite(Number(r.trend_score)));const ranked=[...valid].filter(r=>r.momentum_pass&&r.trade_state!=='禁止追高').sort((a,b)=>num(b.relative_spy20)-num(a.relative_spy20)),seen=new Set(),leaders=[];for(const r of ranked){const key=r.theme||r.asset_type;if(seen.has(key))continue;seen.add(key);leaders.push(r);if(leaders.length===5)break}const risks=[...valid].filter(r=>r.trade_state==='禁止追高'||r.trade_state==='退出'||num(r.trading_risk_score)>=55).sort((a,b)=>num(b.trading_risk_score)-num(a.trading_risk_score)).slice(0,5);$('leaders').innerHTML=leaders.map(r=>rankItem(r)).join('')||'<p>暂无确认主线</p>';$('risks').innerHTML=risks.map(r=>rankItem(r,true)).join('')||'<p>暂无高风险方向</p>';$('main-count').textContent=`${leaders.length}只`;$('risk-count').textContent=`${risks.length}只`;$('main-tab-count').textContent=String(leaders.length);$('risk-tab-count').textContent=String(risks.length)}
function renderTable(){const type=$('type').value,state=$('state').value,key=$('sort').value;let rows=[...(data.rows||[])];if(type!=='全部')rows=rows.filter(r=>r.asset_type===type);if(state!=='全部')rows=rows.filter(r=>r.trade_state===state);if($('pass-only').checked)rows=rows.filter(r=>r.momentum_pass);rows.sort((a,b)=>(num(b[key])||-999)-(num(a[key])||-999));const sizeValue=$('page-size').value,pageSize=sizeValue==='all'?Math.max(rows.length,1):Number(sizeValue),totalPages=Math.max(1,Math.ceil(rows.length/pageSize));currentPage=Math.min(Math.max(1,currentPage),totalPages);const start=(currentPage-1)*pageSize,shown=rows.slice(start,start+pageSize);$('count').textContent=`${rows.length}只`;$('rows').innerHTML=shown.map(r=>`<tr><td><strong>${r.symbol}</strong><small>${r.name}</small></td><td>${r.asset_type}<small>${r.theme}</small></td><td><b>${r.strength_level} / ${fmt(r.trend_score)}</b></td><td><span class="state ${r.trade_state==='禁止追高'?'danger':r.trade_state==='可持有'?'hold':'watch'}">${r.trade_state}</span></td><td>$${fmt(r.price)}</td><td class="${up(r.ret20)}">${num(r.ret20)>=0?'+':''}${fmt(r.ret20)}%</td><td class="${up(r.relative_spy20)}">${num(r.relative_spy20)>=0?'+':''}${fmt(r.relative_spy20)}pp</td><td><b>${r.risk_level} / ${fmt(r.trading_risk_score)}</b><small>${(r.risk_flags||[]).slice(0,2).join('、')||'—'}</small></td><td><small>回踩 $${r.support}<br/>失效 $${r.stop}</small></td></tr>`).join('')||'<tr><td colspan="9">当前筛选无结果</td></tr>';$('mobile-cards').innerHTML=shown.map(r=>`<article class="mobile-etf"><div class="mobile-etf-head"><div><h3>${r.symbol} · ${r.theme}</h3><p>${r.name}</p></div><span class="state ${r.trade_state==='禁止追高'?'danger':r.trade_state==='可持有'?'hold':'watch'}">${r.trade_state}</span></div><div class="mobile-etf-grid"><div><span>现价</span><b>$${fmt(r.price)}</b></div><div><span>趋势</span><b>${r.strength_level} / ${fmt(r.trend_score)}</b></div><div><span>20日</span><b class="${up(r.ret20)}">${num(r.ret20)>=0?'+':''}${fmt(r.ret20)}%</b></div><div><span>相对SPY</span><b class="${up(r.relative_spy20)}">${num(r.relative_spy20)>=0?'+':''}${fmt(r.relative_spy20)}pp</b></div><div><span>风险</span><b>${r.risk_level} / ${fmt(r.trading_risk_score)}</b></div><div><span>回踩 / 失效</span><b>$${r.support} / $${r.stop}</b></div></div></article>`).join('')||'<p>当前筛选无结果</p>';const first=rows.length?start+1:0,last=Math.min(start+shown.length,rows.length);$('page-info').textContent=sizeValue==='all'?`显示全部 ${rows.length}只`:`显示 ${first}–${last} / 共${rows.length}只 · 第${currentPage}/${totalPages}页`;$('prev-page').disabled=currentPage<=1;$('next-page').disabled=currentPage>=totalPages;$('page-numbers').innerHTML=sizeValue==='all'?'':Array.from({length:totalPages},(_,i)=>i+1).map(p=>`<button type="button" data-page="${p}" class="${p===currentPage?'active':''}" aria-label="第${p}页">${p}</button>`).join('');$('page-numbers').querySelectorAll('button').forEach(b=>b.addEventListener('click',()=>goPage(Number(b.dataset.page))))}
function goPage(page){currentPage=page;renderTable();$('universe-section').scrollIntoView({behavior:'smooth',block:'start'})}
function renderMacro(){if(!macro){$('macro-status').textContent='数据待更新 →';$('macro-map').innerHTML='<p>宏观雷达暂不可用；趋势判断不代替宏观风险检查。</p>';return}$('macro-status').textContent=`${macro.risk.label} · ${macro.risk.score}/10 →`;const selected=['QQQ','SMH','XLF','TLT','IWM'];const rows=data.rows||[];$('macro-map').innerHTML=selected.map(s=>{const r=rows.find(x=>x.symbol===s);if(!r)return'';const impacted=(macro.impacts||[]).find(i=>(i.benefit||[]).includes(s)||(i.pressure||[]).includes(s));const pressure=impacted&&(impacted.pressure||[]).includes(s);const benefit=impacted&&(impacted.benefit||[]).includes(s);const weak=r.trade_state==='退出'||r.strength_level==='D';const discipline=weak?'趋势偏弱，暂不参与':pressure?'强势不追高，等待回踩':benefit?'受益方向，确认后按关键位执行':impacted?.discipline||'按趋势与关键位执行';return `<div class="macro-row"><b>${s} · ${r.strength_level}</b><span>相对SPY <b class="${up(r.relative_spy20)}">${num(r.relative_spy20)>=0?'+':''}${fmt(r.relative_spy20)}pp</b></span><span>${impacted?impacted.driver:'宏观中性'}</span><em>${discipline}</em></div>`}).join('')}
async function load(){try{$('retry-load').hidden=true;const [poolRes,macroRes]=await Promise.all([fetch(`/data/us-etf-pool.json?cb=${Date.now()}`,{cache:'no-store'}),fetch(`/data/us-macro-dashboard.json?cb=${Date.now()}`,{cache:'no-store'})]);if(!poolRes.ok)throw new Error(`ETF池请求失败（HTTP ${poolRes.status}）`);data=await poolRes.json();macro=macroRes.ok?await macroRes.json():null;const poolSize=data.summary?.universe||(data.rows||[]).length;$('hero-pool-size').textContent=String(poolSize);$('matrix-pool-size').textContent=String(poolSize);$('universe-pool-size').textContent=String(poolSize);$('model-date').textContent=`模型 ${data.model_date}`;$('source-date').textContent=`行情 ${data.quote_trade_date}`;$('scope').textContent=`行情源：${data.data_source}。实时字段：${data.realtime_scope.join('、')}；快照字段：${data.snapshot_scope.join('、')}。行情颜色为红涨绿跌。趋势风控用于两套策略的确认和过滤，不构成买入建议。`;renderMatrix();renderLists();renderTable();renderMacro()}catch(e){$('command-title').textContent='数据加载失败';$('command-text').textContent=e instanceof Error?e.message:'未知错误';$('retry-load').hidden=false;['breadth-value','relative-value','quality-value','risk-value'].forEach(id=>$(id).textContent='数据不可用');$('leaders').innerHTML='<p>主线数据暂不可用</p>';$('risks').innerHTML='<p>风险数据暂不可用</p>';$('rows').innerHTML='<tr><td colspan="9">ETF池加载失败，请点击重试。</td></tr>';$('mobile-cards').innerHTML='<p>ETF池加载失败，请点击重试。</p>';$('page-info').textContent='数据不可用';renderMacro()}}
function setLinePanel(name){const mobile=window.matchMedia('(max-width:900px)').matches;document.querySelectorAll('.line-tabs button').forEach(b=>{const active=b.dataset.panel===name;b.classList.toggle('active',active);b.setAttribute('aria-selected',String(active))});$('main-panel').hidden=mobile&&name!=='main';$('risk-panel').hidden=mobile&&name!=='risk'}
document.querySelectorAll('.line-tabs button').forEach(b=>b.addEventListener('click',()=>setLinePanel(b.dataset.panel||'main')));document.querySelectorAll('.jump-universe').forEach(b=>b.addEventListener('click',()=>$('universe-section').scrollIntoView({behavior:'smooth',block:'start'})));const panelMedia=window.matchMedia('(max-width:900px)');panelMedia.addEventListener('change',()=>setLinePanel(document.querySelector('.line-tabs button.active')?.dataset.panel||'main'));setLinePanel('main');
['type','state','sort','pass-only','page-size'].forEach(id=>$(id).addEventListener('change',()=>{currentPage=1;renderTable()}));$('prev-page').addEventListener('click',()=>{if(currentPage>1)goPage(currentPage-1)});$('next-page').addEventListener('click',()=>goPage(currentPage+1));$('retry-load').addEventListener('click',load);load();
</script>
</body></html>
