---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

type UsSignal = {
  symbol: string; name: string; theme: string; price: number; support: number; target: number; stop: number;
  trigger_level: number; trigger_basis: string; strength_level: string; trend_score: number; risk_level: string;
  trade_state: string; ret20: number; support_gap?: number; target_gap?: number;
};
type Breadth = { group: string; state: string; passed: number; total: number; ratio: number; members: string[] };
type GardenData = {
  date: string; updated_at: string; stage: string; model_version?: string; data_source?: string; summary: string;
  market_regime: { state: string; equity_allocation: string; benchmark: string };
  recommendations: UsSignal[];
  flower_signals: Record<string, UsSignal[]>;
  flower_counts: Record<string, number>;
  breadth_groups: Breadth[];
  disclaimer: string;
};
const renameStrategyTerms = (raw: string) => raw
  .replaceAll('准备种花', '候场').replaceAll('准备摘花', '止盈观察')
  .replaceAll('种花', '伏击').replaceAll('摘花', '兑现')
  .replaceAll('失效退出', '破位撤退').replaceAll('回踩位', '伏击位')
  .replaceAll('目标位', '兑现位').replaceAll('失效线', '防守线')
  .replaceAll('ETF花园', 'ETF罗盘');
const data = JSON.parse(renameStrategyTerms(readFileSync(join(process.cwd(), 'public/data/us-etf-garden.json'), 'utf8'))) as GardenData;
const sections = [
  { key: 'exit', icon: '🛑', title: '破位撤退', note: '触及前一快照防守线，风险动作最高优先', tone: 'exit' },
  { key: 'harvest', icon: '✂️', title: '兑现触发', note: '盘中触及前一快照兑现位', tone: 'harvest' },
  { key: 'plant', icon: '🪴', title: '伏击触发', note: '触及伏击位且趋势未失效', tone: 'plant' },
  { key: 'ready_harvest', icon: '🌼', title: '止盈观察', note: '距目标3%以内或短期过热', tone: 'ready' },
  { key: 'ready_plant', icon: '🌱', title: '候场', note: '距伏击位3%以内，等待分批进入', tone: 'ready' },
];
const activeSections = sections.map((section) => ({ ...section, items: data.flower_signals[section.key] || [] })).filter((section) => section.items.length > 0);
const firstAction = activeSections[0]?.items[0];
const signalSymbols = new Set(Object.values(data.flower_signals).flat().map((item) => item.symbol));
const secondaryRecommendations = (data.recommendations || []).filter((item) => !signalSymbols.has(item.symbol)).slice(0, 3);
const topBreadth = (data.breadth_groups || []).slice(0, 3);
const formatPrice = (value?: number | null) => typeof value === 'number' && Number.isFinite(value) ? `$${value.toFixed(2)}` : '—';
const formatTime = (value: string) => value ? value.replace('T', ' ').replace(/\.\d+/, '').replace(/([+-]\d\d:\d\d|Z)$/, '') : '—';
const activeLabel = (key: string) => key === 'exit' ? '防守线' : key.includes('harvest') ? '兑现位' : '伏击位';
const actionCopy = (key: string) => ({
  exit: '立即退出并复核失效条件',
  harvest: '分批兑现，不等回落确认',
  plant: '触发后分批伏击，不一次打满',
  ready_harvest: '不追高，进入分批兑现观察',
  ready_plant: '只挂条件，不提前追价',
}[key] || '按触发条件执行');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title="美股ETF罗盘｜今日动作" description="美股ETF交易仪表盘：优先展示退出、兑现、伏击动作及现价、伏击位、兑现位和防守线。" />
    <style>
      main { width: min(1180px, calc(100% - 1.5rem)); padding: 1.25rem 0 3rem; }
      .dashboard-hero { padding: clamp(1rem, 3vw, 1.45rem); background: linear-gradient(135deg, #f3f8ff, #fff); }
      .hero-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; }
      .hero-copy h1 { margin: .35rem 0; font-size: clamp(1.85rem, 5vw, 2.8rem); }
      .hero-copy p { margin: 0; max-width: 72ch; line-height: 1.6; }
      .us-pill { background: #e8f2ff; color: #174ea6; }
      .meta-line { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: .35rem; max-width: 620px; }
      .count-strip { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: .45rem; margin-top: 1rem; }
      .count { padding: .65rem .7rem; border: 1px solid var(--border); border-radius: 13px; background: #fff; }
      .count span { display: block; color: rgb(var(--gray)); font-size: .72rem; font-weight: 800; }
      .count strong { font-size: 1.25rem; }
      .market-strip { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: .55rem; margin-top: .65rem; }
      .market-strip div { padding: .7rem .8rem; background: var(--warm-2); border: 1px solid var(--border); border-radius: 12px; }
      .market-strip span { display: block; font-size: .72rem; color: rgb(var(--gray)); font-weight: 850; }
      .market-strip strong { display: block; font-size: .9rem; white-space: nowrap; }
      .secondary-card { padding: .8rem; display: grid; grid-template-columns: 1fr auto; gap: .45rem .8rem; align-items: center; opacity: .8; }
      .secondary-card h3 { margin: .1rem 0; font-size: .9rem; min-width: 0; }
      .secondary-card .secondary-price { grid-row: span 2; text-align: right; }
      .secondary-card .secondary-price span { display: block; color: rgb(var(--gray)); font-size: .65rem; }
      .secondary-card .secondary-distance { color: rgb(var(--gray)); font-size: .73rem; }
      .top-action { margin-top: .65rem; padding: .8rem .9rem; display: grid; grid-template-columns: auto 1fr; align-items: center; gap: .7rem; background: #152238; color: #fff; border-radius: 14px; }
      .top-action strong, .top-action span { color: #fff; }
      .top-action small { display: block; opacity: .72; }
      .section-head { display: flex; justify-content: space-between; align-items: end; gap: .7rem; margin: 1.45rem 0 .7rem; }
      .section-head h2 { margin: .2rem 0 0; }
      .section-head a { font-size: .82rem; font-weight: 850; }
      .signal-section { margin-bottom: .95rem; }
      .signal-section.ready { opacity: .88; }
      .signal-heading { display: flex; justify-content: space-between; gap: .7rem; align-items: center; margin-bottom: .55rem; }
      .signal-heading > div { display: flex; gap: .55rem; align-items: center; }
      .signal-heading .icon { font-size: 1.35rem; }
      .signal-heading h2 { margin: 0; font-size: 1.12rem; }
      .signal-heading small { display: block; color: rgb(var(--gray)); }
      .signal-heading b { padding: .2rem .55rem; border-radius: 999px; background: var(--warm); font-size: .75rem; }
      .signal-grid { display: grid; grid-template-columns: repeat(6, minmax(0,1fr)); gap: .7rem; }
      .signal-card { grid-column: span 2; padding: .85rem; border-left: 5px solid #d99a00; }
      .signal-card:only-child { grid-column: 1 / -1; }
      .signal-grid > .signal-card:nth-last-child(2):nth-child(3n+1),
      .signal-grid > .signal-card:last-child:nth-child(3n+2) { grid-column: span 3; }
      .signal-card.exit { border-left-color: #c5221f; }
      .signal-card.harvest { border-left-color: #ed7d00; }
      .signal-card.plant { border-left-color: #137547; }
      .card-top { display: flex; justify-content: space-between; gap: .5rem; align-items: flex-start; }
      .identity h3 { margin: 0; font-size: 1rem; }
      .identity small { display: block; color: rgb(var(--gray)); margin-top: .1rem; }
      .state { padding: .17rem .42rem; border-radius: 999px; background: var(--warm); font-size: .68rem; font-weight: 900; white-space: nowrap; }
      .level-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); margin: .65rem 0; border: 1px solid var(--border); border-radius: 11px; overflow: hidden; }
      .level { padding: .5rem .25rem; text-align: center; background: var(--warm-2); border-right: 1px solid var(--border); }
      .level:last-child { border: 0; }
      .level.active { background: #fff4df; }
      .exit .level.active { background: #fff0ef; }
      .plant .level.active { background: #edf9f1; }
      .level span { display: block; color: rgb(var(--gray)); font-size: .64rem; white-space: nowrap; }
      .level b { font-size: .85rem; }
      .signal-meta { display: flex; justify-content: space-between; gap: .5rem; font-size: .72rem; color: rgb(var(--gray)); }
      .basis { margin: .55rem 0 0; padding: .55rem .6rem; border-radius: 9px; background: var(--warm); font-size: .8rem; line-height: 1.5; }
      .zero-strip { display: flex; flex-wrap: wrap; gap: .4rem; margin: .8rem 0 1.2rem; padding: .65rem; }
      .zero-strip strong { margin-right: .2rem; }
      .zero-strip span { padding: .18rem .48rem; border-radius: 999px; background: var(--warm); color: rgb(var(--gray)); font-size: .74rem; }
      .secondary-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: .65rem; }
      .breadth-strip { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: .55rem; }
      .breadth-item { padding: .75rem; display: flex; justify-content: space-between; gap: .6rem; align-items: center; }
      .breadth-item small { display: block; color: rgb(var(--gray)); }
      details.method { margin-top: 1.2rem; padding: .8rem .9rem; }
      details summary { cursor: pointer; font-weight: 900; }
      .rules { display: grid; grid-template-columns: repeat(4,1fr); gap: .6rem; margin-top: .8rem; }
      .rules p { margin: 0; padding: .65rem; background: var(--warm-2); border-radius: 10px; font-size: .8rem; }
      .links { display: flex; flex-wrap: wrap; gap: .45rem; margin-top: .8rem; }
      .links a { padding: .45rem .65rem; border: 1px solid var(--border); border-radius: 999px; text-decoration: none; font-size: .78rem; font-weight: 850; }
      .us-up { color: #137547; } .us-down { color: #c5221f; }
      @media (max-width: 940px) {
        .hero-top { display: grid; }
        .meta-line { justify-content: flex-start; max-width: none; }
        .signal-grid, .secondary-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
        .signal-card,
        .signal-card:only-child,
        .signal-grid > .signal-card:nth-last-child(2):nth-child(3n+1),
        .signal-grid > .signal-card:last-child:nth-child(3n+2) { grid-column: span 1; }
      }
      @media (max-width: 620px) {
        main { width: min(100% - 1rem, 1180px); padding-top: .7rem; }
        .dashboard-hero { padding: .85rem; }
        .hero-copy h1 { font-size: 1.8rem; }
        .hero-copy p { font-size: .88rem; }
        .count-strip { grid-template-columns: repeat(5, minmax(70px,1fr)); overflow-x: auto; gap: .3rem; }
        .count { padding: .5rem .4rem; }
        .market-strip, .signal-grid, .secondary-grid, .breadth-strip, .rules { grid-template-columns: 1fr; }
        .market-strip { gap: .35rem; }
        .market-strip div { padding: .55rem .65rem; }
        .signal-heading small { display: none; }
        .level-grid { grid-template-columns: repeat(2,1fr); }
        .level:nth-child(2) { border-right: 0; }
        .level:nth-child(-n+2) { border-bottom: 1px solid var(--border); }
        .section-head { align-items: flex-start; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="dashboard-hero card" aria-labelledby="us-page-title">
        <div class="hero-top"><div class="hero-copy"><span class="pill us-pill">🇺🇸 美股ETF交易仪表盘</span><h1 id="us-page-title">美股ETF今日动作</h1><p>{data.summary}</p></div><div class="meta-line"><span class="pill us-pill">{data.stage}</span><span class="pill">交易日 {data.date}</span><span class="pill">截止 {formatTime(data.updated_at)}</span><span class="pill">{data.model_version || 'US ETF Garden v3'}</span></div></div>
        <div class="count-strip" aria-label="今日五类动作数量">{sections.map((section) => <div class="count"><span>{section.icon} {section.title}</span><strong>{data.flower_counts[section.key] || 0}</strong></div>)}</div>
        <div class="market-strip"><div><span>市场状态</span><strong>{data.market_regime.state}</strong></div><div><span>权益参考</span><strong>{data.market_regime.equity_allocation}</strong></div><div><span>颜色口径</span><strong><span class="us-up">绿涨</span> · <span class="us-down">红跌</span></strong></div></div>
        {firstAction ? <div class="top-action"><span>⚡</span><div><small>第一优先级｜{activeSections[0].title}</small><strong>{firstAction.symbol} · {actionCopy(activeSections[0].key)}</strong></div></div> : <div class="top-action"><span>✓</span><div><small>今日动作</small><strong>没有触发类信号，保持观察，不机械凑数。</strong></div></div>}
      </section>

      <section aria-label="美股ETF战术信号">
        <div class="section-head"><div><span class="pill us-pill">ACTION QUEUE</span><h2>今日待办</h2></div><a href="/us-momentum/">进入完整美股雷达 →</a></div>
        {activeSections.map((section) => <section class={`signal-section ${section.tone}`} aria-labelledby={`signal-${section.key}`}><div class="signal-heading"><div><span class="icon">{section.icon}</span><div><h2 id={`signal-${section.key}`}>{section.title}</h2><small>{section.note}</small></div></div><b>{section.items.length}只</b></div><div class="signal-grid">{section.items.map((item) => <article class={`signal-card card ${section.tone}`}><div class="card-top"><div class="identity"><h3>{item.symbol} · {item.name}</h3><small>{item.theme}</small></div><span class="state">{item.trade_state}</span></div><div class="level-grid" aria-label={`${item.symbol}关键价位`}><div class="level"><span>现价</span><b>{formatPrice(item.price)}</b></div><div class={`level ${activeLabel(section.key) === '伏击位' ? 'active' : ''}`}><span>伏击位</span><b>{formatPrice(item.support)}</b></div><div class={`level ${activeLabel(section.key) === '兑现位' ? 'active' : ''}`}><span>兑现位</span><b>{formatPrice(item.target)}</b></div><div class={`level ${activeLabel(section.key) === '防守线' ? 'active' : ''}`}><span>防守线</span><b>{formatPrice(item.stop)}</b></div></div><div class="signal-meta"><span>趋势 {item.strength_level} / {item.trend_score}</span><span>交易风险 {item.risk_level}</span></div><p class="basis"><strong>{activeLabel(section.key)}触发：</strong>{item.trigger_basis}</p></article>)}</div></section>)}
      </section>

      {secondaryRecommendations.length > 0 && <section aria-labelledby="secondary-title"><div class="section-head"><div><span class="pill">SECONDARY WATCH</span><h2 id="secondary-title">未触发主题代表</h2></div><a href="/us-momentum/">查看完整观察池 →</a></div><div class="secondary-grid">{secondaryRecommendations.map((item) => <article class="secondary-card card"><div><span class="pill">{item.theme}</span><h3>{item.symbol} · {item.name}</h3><span class="secondary-distance">距伏击位 {typeof item.support_gap === 'number' ? `${Math.abs(item.support_gap).toFixed(1)}%` : '—'} · 完整关键位进入雷达查看</span></div><div class="secondary-price"><span>现价</span><b>{formatPrice(item.price)}</b></div></article>)}</div></section>}

      <section aria-labelledby="breadth-title"><div class="section-head"><div><span class="pill">SECTOR BREADTH</span><h2 id="breadth-title">行业广度 Top 3</h2></div><a href="/us-momentum/">查看全部行业 →</a></div><div class="breadth-strip">{topBreadth.map((group) => <article class="breadth-item card"><div><strong>{group.group}</strong><small>{group.state}</small></div><b>{group.passed}/{group.total} · {group.ratio}%</b></article>)}</div></section>

      <details class="method card"><summary>如何理解趋势、风险与战术信号</summary><div class="rules"><p><strong>趋势强度</strong><br/>回答过去一段时间是否强势。</p><p><strong>交易风险</strong><br/>回答当前位置是否值得追入。</p><p><strong>行业广度</strong><br/>同类ETF共同走强才算扩散。</p><p><strong>执行纪律</strong><br/>退出与兑现优先于新增伏击。</p></div><p>{data.disclaimer} 历史表现不代表未来收益。</p><div class="links"><a href="/paper/">模拟交易</a><a href="/us-momentum/">美股雷达</a><a href="/us-garden/history/">历史成绩</a><a href="/garden/">A股ETF罗盘</a></div></details>
    </main>
    <Footer />
  </body>
</html>
