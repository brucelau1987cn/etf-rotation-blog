---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const data = JSON.parse(readFileSync(join(process.cwd(), 'public/data/us-etf-garden.json'), 'utf8'));
const stateClass = (s: string) => s === '可持有' ? 'hold' : s === '禁止追高' ? 'danger' : 'watch';
const pctClass = (n: number) => n >= 0 ? 'us-up' : 'us-down';
---
<!doctype html><html lang="zh-CN"><head><BaseHead title="美股ETF花园｜今日动作" description="美股ETF花园收盘研究：趋势强度、交易风险、关键价位和主题代表观察池。" /></head><body><Header /><main class="site-shell">
<section class="hero card"><div><span class="pill us-pill">🇺🇸 美股ETF花园</span><h1>美股ETF今日动作</h1><p>{data.summary}</p></div><div class="meta"><strong>{data.stage}</strong><span>交易日 {data.date}</span><span>美东时间 · Adjusted Close</span></div></section>
<section class="market card"><div><span>市场状态</span><strong>{data.market_regime.state}</strong></div><div><span>权益参考</span><strong>{data.market_regime.equity_allocation}</strong></div><div><span>基准</span><strong>{data.market_regime.benchmark}</strong></div><div><span>观察数</span><strong>{data.recommendations.length}只</strong></div></section>
<section><div class="section-head"><div><span class="eyebrow">CURRENT ACTIONS</span><h2>主题代表观察池</h2></div><a href="/us-momentum/">进入完整趋势雷达 →</a></div><div class="cards">{data.recommendations.map((r: any) => <article class="etf-card card"><div class="card-top"><div><span class="theme">{r.theme}</span><h3>{r.symbol} · {r.name}</h3></div><span class={`state ${stateClass(r.trade_state)}`}>{r.trade_state}</span></div><div class="score-row"><div><span>趋势</span><strong>{r.strength_level} / {r.trend_score}</strong></div><div><span>交易风险</span><strong>{r.risk_level} / {r.trading_risk_score}</strong></div><div><span>20日</span><strong class={pctClass(r.ret20)}>{r.ret20 >= 0 ? '+' : ''}{r.ret20}%</strong></div></div><div class="levels"><div><span>现价</span><b>${r.price}</b></div><div><span>回踩位</span><b>${r.support}</b></div><div><span>观察目标</span><b>${r.target}</b></div><div><span>失效线</span><b>${r.stop}</b></div></div><p class="risk">{r.risk_flags.length ? `风险：${r.risk_flags.join('、')}` : '当前没有主要风险标记，仍须执行失效线。'}</p></article>)}</div></section>
<section class="method card"><h2>使用规则</h2><div class="rules"><p><strong>趋势强度</strong><br/>回答过去一段时间是否强势。</p><p><strong>交易风险</strong><br/>回答当前位置是否值得追入。</p><p><strong>关键位</strong><br/>目标触发使用原始OHLC；趋势和收益使用复权收盘。</p><p><strong>颜色</strong><br/><span class="us-up">绿色代表上涨</span>，<span class="us-down">红色代表下跌</span>。</p></div><p class="disclaimer">{data.disclaimer} 历史表现不代表未来收益。</p><div class="links"><a href="/us-momentum/">趋势雷达</a><a href="/us-garden/history/">历史成绩</a><a href="/garden/">A股ETF花园</a></div></section>
</main><Footer />
<style>
main{padding-block:1.4rem 3rem}.card{border:1px solid var(--border);border-radius:22px;background:#fff;box-shadow:0 12px 36px rgba(15,23,42,.05)}.hero{display:flex;justify-content:space-between;gap:2rem;padding:1.5rem;background:linear-gradient(135deg,#f7fbff,#fff)}.hero h1{margin:.45rem 0;font-size:clamp(2rem,5vw,3.4rem)}.hero p{max-width:720px;color:rgb(var(--gray-dark));margin:0}.us-pill{background:#e8f2ff;color:#174ea6}.meta{display:grid;align-content:center;gap:.35rem;min-width:220px;color:rgb(var(--gray));text-align:right}.meta strong{color:#174ea6}.market{display:grid;grid-template-columns:repeat(4,1fr);margin:1rem 0;padding:1rem}.market div{display:grid;gap:.25rem;padding:.35rem 1rem;border-right:1px solid var(--border)}.market div:last-child{border:0}.market span,.score-row span,.levels span{font-size:.8rem;color:rgb(var(--gray))}.market strong{font-size:1.15rem}.section-head{display:flex;justify-content:space-between;align-items:end;margin:2rem 0 .9rem}.section-head h2{margin:.25rem 0 0}.section-head a,.links a{color:#174ea6;font-weight:800}.eyebrow{font-size:.74rem;letter-spacing:.14em;color:#174ea6;font-weight:900}.cards{display:grid;gap:1rem}.etf-card{padding:1.15rem}.card-top{display:flex;justify-content:space-between;gap:1rem}.card-top h3{margin:.35rem 0}.theme{font-size:.75rem;font-weight:800;color:#174ea6}.state{padding:.35rem .65rem;border-radius:999px;height:max-content;font-size:.8rem;font-weight:900}.hold{background:#e8f7ee;color:#176b3a}.watch{background:#fff3d6;color:#8a5a00}.danger{background:#fff0f0;color:#b42318}.score-row,.levels{display:grid;grid-template-columns:repeat(3,1fr);gap:.65rem;margin-top:.9rem}.score-row div,.levels div{padding:.65rem;background:#f7f9fc;border-radius:12px;display:grid;gap:.2rem}.levels{grid-template-columns:repeat(4,1fr)}.risk{margin:.85rem 0 0;color:rgb(var(--gray-dark));font-size:.9rem}.us-up{color:#16803c}.us-down{color:#c5221f}.method{padding:1.25rem;margin-top:2rem}.rules{display:grid;grid-template-columns:repeat(4,1fr);gap:.8rem}.rules p{margin:0;padding:.9rem;background:#f7f9fc;border-radius:14px}.disclaimer{padding:.85rem;background:#fff8e6;border-left:4px solid #d99a00}.links{display:flex;gap:1rem;flex-wrap:wrap}@media(max-width:720px){.hero{display:grid}.meta{text-align:left;min-width:0}.market{grid-template-columns:repeat(2,1fr)}.market div:nth-child(2){border-right:0}.score-row{grid-template-columns:1fr 1fr}.levels,.rules{grid-template-columns:repeat(2,1fr)}.section-head{align-items:start;gap:.5rem}}
</style></body></html>
