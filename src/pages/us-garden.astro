---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import UsSubnav from '../components/UsSubnav.astro';
import MarketClock from '../components/MarketClock.astro';

type UsSignal = {
  symbol: string; name: string; theme: string; price: number; support: number; target: number; stop: number;
  trigger_level: number; trigger_basis: string; strength_level: string; trend_score: number; risk_level: string;
  trade_state: string; ret20: number; support_gap?: number; target_gap?: number;
};
type Breadth = { group: string; state: string; passed: number; total: number; ratio: number; members: string[] };
type GardenData = {
  date: string; updated_at: string; stage: string; model_version?: string; data_source?: string; summary: string;
  market_regime: { state: string; equity_allocation: string; benchmark: string };
  recommendations: UsSignal[];
  flower_signals: Record<string, UsSignal[]>;
  flower_counts: Record<string, number>;
  breadth_groups: Breadth[];
  disclaimer: string;
};
const renameStrategyTerms = (raw: string) => raw
  .replaceAll('准备种花', '候场').replaceAll('准备摘花', '止盈观察')
  .replaceAll('种花', '伏击').replaceAll('摘花', '兑现')
  .replaceAll('失效退出', '破位撤退').replaceAll('回踩位', '伏击位')
  .replaceAll('目标位', '兑现位').replaceAll('失效线', '防守线')
  .replaceAll('ETF花园', 'ETF罗盘')
  .replaceAll('US ETF Garden', 'US ETF Compass').replaceAll('Flower Signals', 'Compass Signals');
const data = JSON.parse(renameStrategyTerms(readFileSync(join(process.cwd(), 'public/data/us-etf-garden.json'), 'utf8'))) as GardenData;
const macro = JSON.parse(readFileSync(join(process.cwd(), 'public/data/us-macro-dashboard.json'), 'utf8'));
const macroIcon = macro.risk.key === 'danger' ? '🔴' : macro.risk.key === 'tight' ? '🟠' : macro.risk.key === 'slightly-tight' ? '🟡' : '🟢';
const sections = [
  { key: 'exit', status: 'exit', title: '破位撤退', note: '触及前一快照防守线，风险动作最高优先', tone: 'exit' },
  { key: 'harvest', status: 'harvest', title: '兑现触发', note: '盘中触及前一快照兑现位', tone: 'harvest' },
  { key: 'plant', status: 'plant', title: '正式伏击', note: '触及伏击位且收盘站回，可执行', tone: 'plant' },
  { key: 'ready_harvest', status: 'take-profit', title: '止盈观察', note: '距兑现位3%以内或短期过热', tone: 'ready' },
  { key: 'ready_plant', status: 'watch', title: '候场', note: '距伏击位3%以内，仅观察不提前追', tone: 'watch' },
];
const displaySections = sections.map((section) => ({ ...section, items: data.flower_signals[section.key] || [] }));
const activeSections = displaySections.filter((section) => section.items.length > 0);
const firstAction = activeSections[0]?.items[0];
const signalSymbols = new Set(Object.values(data.flower_signals).flat().map((item) => item.symbol));
const secondaryRecommendations = (data.recommendations || []).filter((item) => !signalSymbols.has(item.symbol)).slice(0, 3);
const topBreadth = (data.breadth_groups || []).slice(0, 3);
const formatPrice = (value?: number | null) => typeof value === 'number' && Number.isFinite(value) ? `$${value.toFixed(2)}` : '—';
const formatTime = (value: string) => value ? value.replace('T', ' ').replace(/\.\d+/, '').replace(/([+-]\d\d:\d\d|Z)$/, '') : '—';
const activeLabel = (key: string) => key === 'exit' ? '防守线' : key.includes('harvest') ? '兑现位' : '伏击位';
const actionCopy = (key: string) => ({
  exit: '立即退出并复核失效条件',
  harvest: '分批兑现，不等回落确认',
  plant: '正式伏击触发，分批低吸不打满',
  ready_harvest: '不追高，进入分批兑现观察',
  ready_plant: '候场观察，只挂条件不提前追',
}[key] || '按触发条件执行');
const countNote = (key: string) => ({
  exit: '最高优先',
  harvest: '正式兑现',
  plant: '可执行低吸',
  ready_harvest: '接近兑现位',
  ready_plant: '仅观察',
}[key] || '观察');
const countTone = (section: { key: string; tone: string }) => {
  if (section.key === 'ready_plant') return 'watch';
  if (section.key === 'ready_harvest') return 'ready';
  return section.tone;
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title="美股ETF罗盘｜今日动作" description="美股ETF交易仪表盘：优先展示退出、兑现、伏击动作及现价、伏击位、兑现位和防守线。" />
    <style>
      main { width: min(1180px, calc(100% - 1.5rem)); padding: 1rem 0 3rem; }
      .dashboard-hero { padding: clamp(1rem, 3vw, 1.45rem); background: linear-gradient(135deg, #f3f8ff, #fff); }
      .hero-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; }
      .hero-copy h1 { margin: .35rem 0; font-size: clamp(1.85rem, 5vw, 2.8rem); }
      .hero-copy p { margin: 0; max-width: 72ch; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
      .hero-copy details { margin-top: .35rem; }
      .hero-copy summary { cursor: pointer; color: rgb(var(--gray-dark)); font-size: .75rem; font-weight: 850; list-style: none; }
      .hero-copy summary::-webkit-details-marker { display: none; }
      .hero-copy details[open] p { -webkit-line-clamp: unset; display: block; }
      .us-pill { background: #e8f2ff; color: #174ea6; }
      .meta-line { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: .35rem; max-width: 620px; }
      .count-strip { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: .45rem; margin-top: 1rem; }
      .count { padding: .7rem .65rem; border: 1px solid var(--border); border-radius: 14px; background: #fff; min-height: 4.5rem; display: flex; flex-direction: column; justify-content: space-between; }
      .count.exit, .count.harvest, .count.ready { background: linear-gradient(180deg, #f3fbf6, #fff); border-color: rgba(31,122,78,.16); }
      .count.plant, .count.watch { background: linear-gradient(180deg, #fff7f5, #fff); border-color: rgba(214,61,46,.14); }
      .count span { display: block; color: rgb(var(--gray)); font-size: .7rem; font-weight: 800; }
      .count strong { font-size: 1.4rem; line-height: 1; margin-top: .28rem; }
      .count.exit strong, .count.harvest strong, .count.ready strong { color: #159447; }
      .count.plant strong, .count.watch strong { color: #d63d2e; }
      .count .count-note { margin-top: .28rem; font-size: .64rem; color: rgb(var(--gray)); font-weight: 700; font-style: normal; }
      .status-label { display: inline-flex !important; align-items: center; gap: .38rem; }
      .status-dot { display: inline-block; width: .62rem; height: .62rem; border-radius: 50%; flex: 0 0 auto; background: #2774c8; box-shadow: 0 0 0 3px rgb(39 116 200 / 12%); }
      .status-dot.exit, .status-dot.harvest, .status-dot.take-profit { background: #159447; box-shadow: 0 0 0 3px rgb(21 148 71 / 12%); }
      .status-dot.plant, .status-dot.watch { background: #d63d2e; box-shadow: 0 0 0 3px rgb(214 61 46 / 12%); }
      .market-strip { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: .55rem; margin-top: .65rem; }
      .market-strip div { padding: .7rem .8rem; background: var(--warm-2); border: 1px solid var(--border); border-radius: 12px; min-height: 4rem; }
      .market-strip span { display: block; font-size: .72rem; color: rgb(var(--gray)); font-weight: 850; }
      .market-strip strong { display: block; margin-top: .18rem; font-size: .92rem; line-height: 1.35; }
      .market-strip strong.color-legend { display: inline-flex; margin-top: .28rem; }
      .market-strip .mainline { grid-column: 1 / -1; background: #fff; min-height: auto; }
      .market-strip .mainline strong { font-size: .86rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; white-space: normal; }
      .top-action strong { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; }
      .macro-gate small { display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
      .secondary-card { padding: .8rem; display: grid; grid-template-columns: 1fr auto; gap: .45rem .8rem; align-items: center; opacity: .8; }
      .secondary-card h3 { margin: .1rem 0; font-size: .9rem; min-width: 0; }
      .secondary-card .secondary-price { grid-row: span 2; text-align: right; min-width: 7rem; }
      .secondary-card .secondary-price span { display: block; color: rgb(var(--gray)); font-size: .65rem; }
      .secondary-card .secondary-price .live-quote-meta { display: block; margin-top: .12rem; font-size: .61rem; white-space: nowrap; }
      .secondary-card .secondary-distance { color: rgb(var(--gray)); font-size: .73rem; }
      .top-action { margin-top: .65rem; padding: .8rem .9rem; display: grid; grid-template-columns: auto 1fr; align-items: center; gap: .7rem; background: #152238; color: #fff; border-radius: 14px; }
      .top-action strong, .top-action span { color: #fff; }
      .top-action small { display: block; opacity: .72; }
      .macro-gate { margin-top: .65rem; padding: .7rem .85rem; display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: .65rem; border: 1px solid #cddbed; border-radius: 13px; background: #f6f9fd; }
      .macro-gate > span { font-size: 1.15rem; }
      .macro-gate strong { display: block; font-size: .84rem; }
      .macro-gate small { display: block; color: rgb(var(--gray)); margin-top: .08rem; }
      .macro-gate a { padding: .35rem .55rem; border-radius: 9px; background: #14243b; color: #fff; text-decoration: none; font-size: .72rem; font-weight: 850; white-space: nowrap; }
      .section-head { display: flex; justify-content: space-between; align-items: end; gap: .7rem; margin: 1.45rem 0 .7rem; }
      .section-head h2 { margin: .2rem 0 0; }
      .section-head a { font-size: .82rem; font-weight: 850; }
      .signal-section { margin-bottom: .95rem; }
      .signal-section.ready { opacity: .88; }
      .signal-heading { display: flex; justify-content: space-between; gap: .7rem; align-items: center; margin-bottom: .55rem; }
      .signal-heading > div { display: flex; gap: .55rem; align-items: center; }
      .signal-heading .status-dot { width: .8rem; height: .8rem; }
      .signal-heading h2 { margin: 0; font-size: 1.12rem; }
      .signal-heading small { display: block; color: rgb(var(--gray)); }
      .signal-heading b { padding: .2rem .55rem; border-radius: 999px; background: var(--warm); font-size: .75rem; }
      .signal-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: .7rem; }
      .signal-card { padding: .85rem; border-left: 5px solid #d99a00; min-width: 0; }
      .signal-card.exit, .signal-card.harvest, .signal-card.ready { border-left-color: #159447; }
      .signal-card.plant, .signal-card.watch { border-left-color: #d63d2e; }
      .signal-section.collapsible .signal-grid { display: none; }
      .signal-section.collapsible[open] .signal-grid { display: grid; }
      .signal-section.collapsible > summary.signal-heading { list-style: none; cursor: pointer; }
      .signal-section.collapsible > summary.signal-heading::-webkit-details-marker { display: none; }
      .signal-section.collapsible > summary.signal-heading::after { content: '展开'; font-size: .72rem; color: rgb(var(--gray)); font-weight: 800; }
      .signal-section.collapsible[open] > summary.signal-heading::after { content: '收起'; }
      .card-top { display: flex; justify-content: space-between; gap: .5rem; align-items: flex-start; }
      .identity h3 { margin: 0; font-size: 1rem; }
      .identity small { display: block; color: rgb(var(--gray)); margin-top: .1rem; }
      .state { padding: .17rem .42rem; border-radius: 999px; background: var(--warm); font-size: .68rem; font-weight: 900; white-space: nowrap; }
      .level-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); margin: .65rem 0; border: 1px solid var(--border); border-radius: 11px; overflow: hidden; }
      .level { padding: .5rem .25rem; text-align: center; background: var(--warm-2); border-right: 1px solid var(--border); }
      .level:last-child { border: 0; }
      .level.active { background: #f3fbf6; }
      .exit .level.active, .harvest .level.active, .ready .level.active { background: #f3fbf6; }
      .plant .level.active, .watch .level.active { background: #fff7f5; }
      .level span { display: block; color: rgb(var(--gray)); font-size: .64rem; white-space: nowrap; }
      .level b { font-size: .85rem; }
      .signal-meta { display: flex; justify-content: space-between; gap: .5rem; font-size: .72rem; color: rgb(var(--gray)); }
      .basis { margin: .55rem 0 0; padding: .55rem .6rem; border-radius: 9px; background: var(--warm); font-size: .8rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
      .zero-strip { display: flex; flex-wrap: wrap; gap: .4rem; margin: .8rem 0 1.2rem; padding: .65rem; }
      .zero-strip strong { margin-right: .2rem; }
      .zero-strip span { padding: .18rem .48rem; border-radius: 999px; background: var(--warm); color: rgb(var(--gray)); font-size: .74rem; }
      .secondary-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: .65rem; }
      .breadth-strip { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: .55rem; }
      .breadth-item { padding: .75rem; display: flex; justify-content: space-between; gap: .6rem; align-items: center; }
      .breadth-item small { display: block; color: rgb(var(--gray)); }
      details.method { margin-top: 1.2rem; padding: .8rem .9rem; }
      details summary { cursor: pointer; font-weight: 900; }
      .rules { display: grid; grid-template-columns: repeat(4,1fr); gap: .6rem; margin-top: .8rem; }
      .rules p { margin: 0; padding: .65rem; background: var(--warm-2); border-radius: 10px; font-size: .8rem; }
      .links { display: flex; flex-wrap: wrap; gap: .45rem; margin-top: .8rem; }
      .links a { padding: .45rem .65rem; border: 1px solid var(--border); border-radius: 999px; text-decoration: none; font-size: .78rem; font-weight: 850; }
      .us-up { color: #c5221f; font-weight: 900; }
      .us-down { color: #137547; font-weight: 900; }
      .color-legend { display: inline-flex; align-items: center; gap: .45rem; flex-wrap: nowrap; white-space: nowrap; }
      .color-legend .legend-item { display: inline-flex; align-items: center; gap: .28rem; }
      .color-legend .dot { width: .62rem; height: .62rem; border-radius: 50%; flex: 0 0 auto; }
      .color-legend .dot.up { background: #c5221f; box-shadow: 0 0 0 3px rgb(197 34 31 / 12%); }
      .color-legend .dot.down { background: #137547; box-shadow: 0 0 0 3px rgb(19 117 71 / 12%); }
      .color-legend .sep { color: rgb(var(--gray)); font-weight: 800; }
      .live-status { display: inline-flex; align-items: center; gap: .38rem; background: #fff7df; color: #8a5a00; }
      .live-status::before { content: ''; width: .48rem; height: .48rem; border-radius: 50%; background: #d99a00; box-shadow: 0 0 0 3px rgb(217 154 0 / 12%); }
      .live-status.online { background: #edf9f1; color: #137547; }
      .live-status.online::before { background: #137547; }
      .live-status.error { background: #fff0ef; color: #a3201d; }
      .live-status.error::before { background: #c5221f; }
      .live-price.updated { color: #174ea6; }
      .live-refresh-button { font: inherit; color: inherit; cursor: pointer; appearance: none; }
      .level.live-refresh-button { border: 0; border-right: 1px solid var(--border); }
      .secondary-price.live-refresh-button { border: 0; padding: .2rem; background: transparent; border-radius: 9px; }
      .live-refresh-button:hover, .live-refresh-button:focus-visible { background: #eaf3ff; outline: 2px solid #78a7dc; outline-offset: -2px; }
      .live-refresh-button.loading { opacity: .58; cursor: wait; }
      .live-refresh-button.loading .live-price::after { content: ' ↻'; }
      .live-quote-meta { margin-top: .45rem; color: rgb(var(--gray)); font-size: .7rem; }
      .live-quote-meta .up { color: #c5221f; font-weight: 850; }
      .live-quote-meta .down { color: #137547; font-weight: 850; }
      @media (max-width: 940px) {
        .hero-top { display: grid; }
        .meta-line { justify-content: flex-start; max-width: none; }
        .signal-grid, .secondary-grid { grid-template-columns: repeat(auto-fit, minmax(240px,1fr)); }
      }
      @media (max-width: 620px) {
        main { width: min(100% - 1rem, 1180px); padding-top: 1rem; }
        .dashboard-hero { padding: .85rem; }
        .hero-copy h1 { font-size: 1.8rem; }
        .hero-copy p { font-size: .88rem; }
        .count-strip { grid-template-columns: repeat(2, minmax(0,1fr)); gap: .4rem; }
        .count { padding: .55rem .5rem; min-height: 3.9rem; }
        .count strong { font-size: 1.2rem; }
        .market-strip, .signal-grid, .secondary-grid, .breadth-strip, .rules { grid-template-columns: 1fr; }
        .market-strip .mainline strong { -webkit-line-clamp: 3; }
        .market-strip { gap: .35rem; }
        .market-strip div { padding: .55rem .65rem; }
        .signal-heading small { display: none; }
        .level-grid { grid-template-columns: repeat(2,1fr); }
        .level:nth-child(2) { border-right: 0; }
        .level:nth-child(-n+2) { border-bottom: 1px solid var(--border); }
        .section-head { align-items: flex-start; }
        .macro-gate { grid-template-columns: auto 1fr; }
        .macro-gate a { grid-column: 1/-1; text-align: center; }
      }
    </style>
    <style is:global>
      main .live-quote-meta .up { color: #c5221f; font-weight: 850; }
      main .live-quote-meta .down { color: #137547; font-weight: 850; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <UsSubnav active="garden" />
      <section class="dashboard-hero card" aria-labelledby="us-page-title">
              <div class="hero-top">
                <div class="hero-copy">
                  <span class="pill us-pill">🇺🇸 美股ETF交易仪表盘</span>
                  <h1 id="us-page-title">美股ETF今日动作</h1>
                  <details>
                    <p>{data.summary}</p>
                    <summary>展开完整结论</summary>
                  </details>
                </div>
                <div class="meta-line">
                  <span class="pill us-pill">{data.stage}</span>
                  <span class="pill">信号交易日 {data.date}</span>
                  <span class="pill">数据截止 {formatTime(data.updated_at)}</span>
                  <span class="pill">{data.model_version || 'US ETF Compass v3'}</span>
                  <span id="us-live-status" class="pill live-status" aria-live="polite">实时行情连接中…</span>
                  <MarketClock market="us" />
                </div>
              </div>
              <div class="count-strip" aria-label="今日五类动作数量">
                {sections.map((section) => (
                  <div class={`count ${countTone(section)}`}>
                    <span class="status-label"><i class={`status-dot ${section.status}`} aria-hidden="true"></i>{section.title}</span>
                    <strong id={`us-count-${section.key}`} data-base-count={data.flower_counts[section.key] || 0}>{data.flower_counts[section.key] || 0}</strong>
                    <em class="count-note">{countNote(section.key)}</em>
                  </div>
                ))}
              </div>
              <div class="market-strip">
                <div><span>市场状态</span><strong>{data.market_regime.state}</strong></div>
                <div><span>权益参考</span><strong>{data.market_regime.equity_allocation}</strong></div>
                <div><span>颜色口径</span><strong class="color-legend" aria-label="涨跌颜色：红涨绿跌"><span class="legend-item"><i class="dot up" aria-hidden="true"></i><span class="us-up">红涨</span></span><span class="sep">·</span><span class="legend-item"><i class="dot down" aria-hidden="true"></i><span class="us-down">绿跌</span></span></strong></div>
                <div class="mainline"><span>今日主线</span><strong title={data.summary}>{data.summary}</strong></div>
              </div>
              <div class="macro-gate"><span>{macroIcon}</span><div><strong>宏观风险：{macro.risk.label} · {macro.risk.headline}</strong><small>{macro.risk.equity_constraint}</small></div><a href="/us-macro/">查看宏观雷达 →</a></div>
              <div class="top-action" id="us-top-action"><span>⚡</span><div><small id="us-top-action-label">{firstAction ? `第一优先级｜${activeSections[0].title}` : '今日动作'}</small><strong id="us-top-action-text">{firstAction ? `${firstAction.symbol} · ${actionCopy(activeSections[0].key)}` : '没有触发类信号，保持观察，不机械凑数。'}</strong></div></div>
            </section>

            <section aria-label="美股ETF战术信号">
              <div class="section-head"><div><span class="pill us-pill">今日队列</span><h2>今日待办</h2></div><a href="/us-momentum/">进入趋势风控 →</a></div>
              {displaySections.map((section) => {
                const collapse = section.key === 'ready_harvest' && section.items.length > 3;
                const HeadingTag = collapse ? 'summary' : 'div';
                const SectionTag = collapse ? 'details' : 'section';
                return (
                  <SectionTag
                    id={`us-section-${section.key}`}
                    class={`signal-section ${section.tone}${collapse ? ' collapsible' : ''}`}
                    aria-labelledby={`signal-${section.key}`}
                    hidden={section.items.length === 0 && section.key !== 'plant'}
                    data-section-key={section.key}
                    data-section-title={section.title}
                  >
                    <HeadingTag class="signal-heading">
                      <div>
                        <i class={`status-dot ${section.status}`} aria-hidden="true"></i>
                        <div>
                          <h2 id={`signal-${section.key}`}>{section.title} {section.items.length}</h2>
                          <small>{section.key === 'plant' && section.items.length === 0 ? '今日无正式伏击；下方候场仅观察' : section.note}</small>
                        </div>
                      </div>
                      <b id={`us-section-count-${section.key}`}>{section.items.length}只</b>
                    </HeadingTag>
                    {section.key === 'plant' && section.items.length === 0 ? (
                      <div class="zero-strip card"><strong>正式伏击 0</strong><span>今日无收盘站回确认的可执行伏击；候场名单见下方</span></div>
                    ) : (
                    <div class="signal-grid" id={`us-grid-${section.key}`}>
                      {section.items.map((item) => (
                        <article
                          class={`signal-card card ${section.tone}`}
                          data-us-live-card
                          data-symbol={item.symbol}
                          data-side={section.key}
                          data-origin-section={section.key}
                          data-current-section={section.key}
                          data-support={item.support}
                          data-target={item.target}
                          data-stop={item.stop}
                        >
                          <div class="card-top">
                            <div class="identity">
                              <h3>{item.symbol} · {item.name}</h3>
                              <small>{item.theme}</small>
                            </div>
                            <span class="state" id={`us-live-trigger-${item.symbol}`}>{item.trade_state}</span>
                          </div>
                          <div class="level-grid" aria-label={`${item.symbol}关键价位`}>
                            <button type="button" class="level live-refresh-button" data-live-refresh={item.symbol} aria-label={`刷新 ${item.symbol} 实时价格`}>
                              <span>实时现价 · 点击更新</span>
                              <b class="live-price" id={`us-live-price-${item.symbol}`}>{formatPrice(item.price)}</b>
                            </button>
                            <div class={`level ${activeLabel(section.key) === '伏击位' ? 'active' : ''}`}><span>伏击位</span><b>{formatPrice(item.support)}</b></div>
                            <div class={`level ${activeLabel(section.key) === '兑现位' ? 'active' : ''}`}><span>兑现位</span><b>{formatPrice(item.target)}</b></div>
                            <div class={`level ${activeLabel(section.key) === '防守线' ? 'active' : ''}`}><span>防守线</span><b>{formatPrice(item.stop)}</b></div>
                          </div>
                          <div class="signal-meta"><span>趋势 {item.strength_level} / {item.trend_score}</span><span>交易风险 {item.risk_level}</span></div>
                          <div class="live-quote-meta" id={`us-live-meta-${item.symbol}`}>收盘快照 · 等待实时行情</div>
                          <p class="basis" id={`us-live-basis-${item.symbol}`}><strong>动作：</strong>{actionCopy(section.key)} · {item.trigger_basis}</p>
                        </article>
                      ))}
                    </div>
                    )}
                  </SectionTag>
                );
              })}
            </section>

            {secondaryRecommendations.length > 0 && <section aria-labelledby="secondary-title"><div class="section-head"><div><span class="pill">次级观察</span><h2 id="secondary-title">未触发主题代表</h2></div><a href="/us-momentum/">查看完整观察池 →</a></div><div class="secondary-grid">{secondaryRecommendations.map((item) => <article class="secondary-card card" data-us-live-card data-symbol={item.symbol}><div><span class="pill">{item.theme}</span><h3>{item.symbol} · {item.name}</h3><span class="secondary-distance">距伏击位 {typeof item.support_gap === 'number' ? `${Math.abs(item.support_gap).toFixed(1)}%` : '—'} · 完整关键位进入雷达查看</span></div><button type="button" class="secondary-price live-refresh-button" data-live-refresh={item.symbol} aria-label={`刷新 ${item.symbol} 实时价格`}><span>实时现价 · 点击更新</span><b class="live-price" id={`us-live-price-${item.symbol}`}>{formatPrice(item.price)}</b><small class="live-quote-meta" id={`us-live-meta-${item.symbol}`}>等待实时行情</small></button></article>)}</div></section>}

            <section aria-labelledby="breadth-title"><div class="section-head"><div><span class="pill">行业广度</span><h2 id="breadth-title">行业广度 Top 3</h2></div><a href="/us-momentum/">查看全部行业 →</a></div><div class="breadth-strip">{topBreadth.map((group) => <article class="breadth-item card"><div><strong>{group.group}</strong><small>{group.state}</small></div><b>{group.passed}/{group.total} · {group.ratio}%</b></article>)}</div></section>

      <details class="method card"><summary>如何理解趋势、风险与战术信号</summary><div class="rules"><p><strong>趋势强度</strong><br/>回答过去一段时间是否强势。</p><p><strong>交易风险</strong><br/>回答当前位置是否值得追入。</p><p><strong>行业广度</strong><br/>同类ETF共同走强才算扩散。</p><p><strong>执行纪律</strong><br/>退出与兑现优先于新增伏击。</p></div><p>{data.disclaimer} 历史表现不代表未来收益。</p><div class="links"><a href="/paper/">模拟盘</a><a href="/us-momentum/">趋势风控</a><a href="/us-garden/history/">历史成绩</a><a href="/garden/">A股ETF罗盘</a></div></details>
    </main>
    <Footer />
    <script is:inline>
      const US_LIVE_URL = 'https://etf-live.peekabo.cc/api/us-etf-garden/live';
      const usLiveStatus = document.getElementById('us-live-status');
      const usLiveCards = [...document.querySelectorAll('[data-us-live-card]')];
      let usLiveLoading = false;
      const num = (value) => {
        if (value === null || value === undefined || value === '') return null;
        const parsed = Number(value);
        return Number.isFinite(parsed) ? parsed : null;
      };
      const nyClock = () => {
        const parts = Object.fromEntries(new Intl.DateTimeFormat('en-CA', {
          timeZone: 'America/New_York', weekday: 'short', hour: '2-digit', minute: '2-digit', hourCycle: 'h23'
        }).formatToParts(new Date()).filter(part => part.type !== 'literal').map(part => [part.type, part.value]));
        return { weekday: parts.weekday, minutes: Number(parts.hour) * 60 + Number(parts.minute) };
      };
      const isUsTradingWindow = () => {
        const { weekday, minutes } = nyClock();
        return !['Sat', 'Sun'].includes(weekday) && minutes >= 9 * 60 + 30 && minutes <= 16 * 60 + 5;
      };
      const nyTime = (value) => {
        const date = value ? new Date(value) : new Date();
        if (Number.isNaN(date.getTime())) return '刚刚';
        return new Intl.DateTimeFormat('zh-CN', {
          timeZone: 'America/New_York', hour: '2-digit', minute: '2-digit', second: '2-digit', hourCycle: 'h23'
        }).format(date);
      };
      const setUsLiveStatus = (text, state = '') => {
        if (!usLiveStatus) return;
        usLiveStatus.textContent = text;
        usLiveStatus.classList.toggle('online', state === 'online');
        usLiveStatus.classList.toggle('error', state === 'error');
      };
      const sectionPriority = ['exit', 'harvest', 'plant', 'ready_harvest', 'ready_plant'];
      const sectionTone = { exit: 'exit', harvest: 'harvest', plant: 'plant', ready_harvest: 'ready', ready_plant: 'watch' };
      const realtimeActionCopy = {
        exit: '实时跌破防守线，优先撤退并复核',
        harvest: '实时达到兑现位，进入分批兑现',
        plant: '实时进入伏击区，按计划分批确认',
        ready_harvest: '接近兑现位，保持止盈观察',
        ready_plant: '等待价格进入伏击区',
      };
      const realtimeBasisCopy = {
        exit: '实时价≤防守线',
        harvest: '实时价≥兑现位',
        plant: '实时价≤伏击位且高于防守线',
        ready_harvest: '距兑现位3%以内或短期过热',
        ready_plant: '距伏击位3%以内，等待分批进入',
      };
      const sectionLabel = {
        exit: '防守线',
        harvest: '兑现位',
        plant: '伏击位',
        ready_harvest: '兑现位',
        ready_plant: '伏击位',
      };
      function moveUsCard(card, nextSection) {
        if (!card.dataset.originSection || card.dataset.currentSection === nextSection) return;
        const grid = document.getElementById(`us-grid-${nextSection}`);
        if (!grid) return;
        grid.appendChild(card);
        card.dataset.currentSection = nextSection;
        card.classList.remove('exit', 'harvest', 'plant', 'ready');
        card.classList.add(sectionTone[nextSection] || 'ready');
        const basisNode = card.querySelector('.basis');
        if (basisNode) {
          const label = sectionLabel[nextSection] || '关键位';
          basisNode.innerHTML = `<strong>${label}触发：</strong>${realtimeBasisCopy[nextSection] || '按实时价格重判'}`;
        }
      }
      function refreshUsSections() {
        for (const key of sectionPriority) {
          const grid = document.getElementById(`us-grid-${key}`);
          const section = document.getElementById(`us-section-${key}`);
          const count = grid ? grid.querySelectorAll(':scope > [data-us-live-card]').length : 0;
          if (section) section.hidden = count === 0;
          const sectionCount = document.getElementById(`us-section-count-${key}`);
          if (sectionCount) sectionCount.textContent = `${count}只`;
          const sectionHeading = document.getElementById(`signal-${key}`);
          if (sectionHeading) sectionHeading.textContent = `${section?.dataset.sectionTitle || ''} ${count}`;
          const topCount = document.getElementById(`us-count-${key}`);
          if (topCount) topCount.textContent = String(count);
        }
        const firstKey = sectionPriority.find((key) => document.querySelector(`#us-grid-${key} > [data-us-live-card]`));
        const firstCard = firstKey ? document.querySelector(`#us-grid-${firstKey} > [data-us-live-card]`) : null;
        const label = document.getElementById('us-top-action-label');
        const text = document.getElementById('us-top-action-text');
        if (label) label.textContent = firstKey ? `第一优先级｜${document.getElementById(`us-section-${firstKey}`)?.dataset.sectionTitle || ''}` : '今日动作';
        if (text) text.textContent = firstCard ? `${firstCard.dataset.symbol} · ${realtimeActionCopy[firstKey]}` : '没有触发类信号，保持观察。';
      }
      function applyUsLive(payload) {
        const liveMap = new Map((payload.items || []).map(item => [String(item.symbol), item]));
        const mode = isUsTradingWindow() ? '盘中实时' : '最新快照';
        const statusTime = nyTime(payload.generated_at);
        let updated = 0;
        for (const card of usLiveCards) {
          const symbol = card.dataset.symbol;
          const quote = liveMap.get(symbol);
          const price = num(quote?.price);
          if (price === null) continue;
          const priceNode = document.getElementById(`us-live-price-${symbol}`);
          const metaNode = document.getElementById(`us-live-meta-${symbol}`);
          const triggerNode = document.getElementById(`us-live-trigger-${symbol}`);
          if (priceNode) {
            priceNode.textContent = `$${price.toFixed(2)}`;
            priceNode.classList.add('updated');
          }
          const change = num(quote?.change_pct);
          if (metaNode) {
            const changeText = change === null ? '' : ` · <span class="${change >= 0 ? 'up' : 'down'}">${change >= 0 ? '+' : ''}${change.toFixed(2)}%</span>`;
            const quoteClock = nyTime(quote?.quote_time);
            metaNode.innerHTML = card.classList.contains('secondary-card')
              ? `${quoteClock.slice(0, 5)} ET${changeText}`
              : `${mode} ${quoteClock} ET${changeText}`;
          }
          if (triggerNode) {
            const origin = card.dataset.originSection || card.dataset.side || '';
            const support = num(card.dataset.support);
            const target = num(card.dataset.target);
            const stop = num(card.dataset.stop);
            let nextSection = origin;
            let triggerText = triggerNode.textContent || '观察';
            if (stop !== null && price <= stop) {
              nextSection = 'exit';
              triggerText = '破位撤退';
            } else if (origin.includes('harvest') && target !== null) {
              const gap = (price / target - 1) * 100;
              if (price >= target) nextSection = 'harvest';
              triggerText = price >= target ? '达到兑现位' : (Math.abs(gap) <= 3 ? '距兑现位≤3%' : '等待兑现');
            } else if (origin.includes('plant') && support !== null) {
              const gap = (price / support - 1) * 100;
              if (price <= support) nextSection = 'plant';
              triggerText = price <= support ? '进入伏击区' : (Math.abs(gap) <= 3 ? '距伏击位≤3%' : '等待伏击');
            }
            moveUsCard(card, nextSection);
            triggerNode.textContent = triggerText;
          }
          updated += 1;
        }
        refreshUsSections();
        setUsLiveStatus(`${mode} ${statusTime} ET · ${updated}/${usLiveCards.length}`, 'online');
      }
      async function loadUsLive() {
        if (usLiveLoading || document.hidden) return;
        usLiveLoading = true;
        try {
          const response = await fetch(`${US_LIVE_URL}?t=${Date.now()}`, { cache: 'no-store' });
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          const payload = await response.json();
          if (!payload.ok || !Array.isArray(payload.items)) throw new Error('行情格式异常');
          applyUsLive(payload);
        } catch (error) {
          setUsLiveStatus('实时行情暂不可用 · 保留收盘快照', 'error');
          console.warn('US ETF live quote overlay failed', error);
        } finally {
          usLiveLoading = false;
        }
      }
      async function refreshUsSymbol(symbol, button) {
        if (!symbol || button.classList.contains('loading')) return;
        button.classList.add('loading');
        button.disabled = true;
        button.setAttribute('aria-busy', 'true');
        setUsLiveStatus(`正在更新 ${symbol}…`);
        try {
          const response = await fetch(`${US_LIVE_URL}?symbol=${encodeURIComponent(symbol)}&t=${Date.now()}`, { cache: 'no-store' });
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          const payload = await response.json();
          if (!payload.ok || payload.count !== 1 || !Array.isArray(payload.items)) throw new Error('单股行情格式异常');
          applyUsLive(payload);
          const quote = payload.items[0];
          setUsLiveStatus(`${symbol} 已更新 ${nyTime(quote.quote_time)} ET`, 'online');
        } catch (error) {
          setUsLiveStatus(`${symbol} 更新失败 · 保留现有价格`, 'error');
          console.warn('US ETF single quote refresh failed', error);
        } finally {
          button.classList.remove('loading');
          button.disabled = false;
          button.removeAttribute('aria-busy');
        }
      }
      document.querySelectorAll('[data-live-refresh]').forEach((button) => {
        button.addEventListener('click', () => void refreshUsSymbol(button.dataset.liveRefresh, button));
      });
      document.addEventListener('visibilitychange', () => { if (!document.hidden) void loadUsLive(); });
      void loadUsLive();
      window.setInterval(loadUsLive, 30_000);
    </script>
  </body>
</html>
