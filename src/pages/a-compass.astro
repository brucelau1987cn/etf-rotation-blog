---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import AStockSubnav from '../components/AStockSubnav.astro';
import MarketClock from '../components/MarketClock.astro';
import { SITE_TITLE } from '../consts';

type Recommendation = {
  status: string;
  code: string;
  name: string;
  priority: string;
  trigger: string;
  action: string;
  price?: number | null;
  support?: number | null;
  target?: number | null;
  stop?: number | null;
  action_level?: number | null;
  action_level_label?: string | null;
  distance_pct?: number | null;
  trend_level?: string | null;
  risk_level?: string | null;
  price_date?: string | null;
  level_basis?: string | null;
  level_status?: string | null;
  eligibility?: string | null;
};
type WatchItem = { label?: string; text?: string; code?: string; name?: string; action?: string };
type GardenRecommendations = {
  date: string;
  updated_at: string;
  data_as_of?: string;
  market_state: string;
  position: string;
  mainline: string;
  summary: string;
  harvest: Recommendation[];
  plant: Recommendation[];
  watch: WatchItem[];
  level_model_version?: string;
  level_data_as_of?: string;
  mid_macro?: {
    generated_at?: string;
    headwind_level?: number;
    label?: string;
    equity_constraint?: string;
    allow_chase?: boolean;
    allow_new_offense?: boolean;
    base_position?: string;
    factors?: Array<{ key: string; label: string; state: string; score: number; headline: string }>;
  };
};

const renameStrategyTerms = (raw: string) => raw
  .replaceAll('准备种花', '候场').replaceAll('准备摘花', '止盈观察')
  .replaceAll('种花', '伏击').replaceAll('摘花', '兑现')
  .replaceAll('失效退出', '破位撤退').replaceAll('回踩位', '伏击位')
  .replaceAll('目标位', '兑现位').replaceAll('失效线', '防守线')
  .replaceAll('ETF花园', 'ETF罗盘');
const data = JSON.parse(renameStrategyTerms(readFileSync(join(process.cwd(), 'public/data/garden-recommendations.json'), 'utf-8'))) as GardenRecommendations;
let midMacro: any = data.mid_macro || null;
try {
  midMacro = midMacro || JSON.parse(readFileSync(join(process.cwd(), 'public/data/a-share-mid-macro.json'), 'utf-8'));
  if (midMacro?.constraint && !data.mid_macro) {
    midMacro = {
      generated_at: midMacro.generated_at,
      headwind_level: midMacro.constraint.headwind_level,
      label: midMacro.constraint.label,
      equity_constraint: midMacro.constraint.equity_constraint,
      allow_chase: midMacro.constraint.allow_chase,
      allow_new_offense: midMacro.constraint.allow_new_offense,
      base_position: midMacro.constraint.base_position,
      factors: (midMacro.factors || []).map((f: any) => ({
        key: f.key, label: f.label, state: f.state, score: f.score, headline: f.headline,
      })),
    };
  }
} catch {
  midMacro = data.mid_macro || null;
}
const midLevel = Number(midMacro?.headwind_level ?? midMacro?.constraint?.headwind_level ?? 0);
const midLabel = midMacro?.label || midMacro?.constraint?.label || '中性';
const midConstraint = midMacro?.equity_constraint || midMacro?.constraint?.equity_constraint || '按关键位正常执行';
const midFactors = (midMacro?.factors || []) as Array<{ label: string; state: string; headline: string; score?: number }>;
const midTone = midLevel >= 3 ? 'danger' : midLevel >= 2 ? 'warn' : midLevel >= 1 ? 'watch' : 'ok';
const midIcon = midLevel >= 3 ? '🔴' : midLevel >= 2 ? '🟠' : midLevel >= 1 ? '🟡' : '🟢';
const harvest = data.harvest || [];
const plant = data.plant || [];
const watch = data.watch || [];
const priorityRank: Record<string, number> = { 高: 4, 中高: 3, 中: 2, 观察: 1 };
const topAction = [...harvest, ...plant].sort((a, b) => (priorityRank[b.priority] || 0) - (priorityRank[a.priority] || 0))[0];
const counts = {
  harvest: harvest.filter((item) => item.status === '兑现').length,
  readyHarvest: harvest.filter((item) => item.status === '止盈观察').length,
  plant: plant.filter((item) => item.status === '伏击').length,
  readyPlant: plant.filter((item) => item.status === '候场').length,
};
const formatPrice = (value?: number | null) => typeof value === 'number' && Number.isFinite(value) ? value.toFixed(3) : '待更新';
const formatDistance = (value?: number | null) => typeof value === 'number' && Number.isFinite(value) ? `${Math.abs(value).toFixed(1)}%` : '待更新';
const actionLevelFor = (item: Recommendation, side: 'harvest' | 'plant') => item.action_level ?? (side === 'harvest' ? item.target : item.support);
const actionLabelFor = (item: Recommendation, side: 'harvest' | 'plant') => item.action_level_label ?? (side === 'harvest' ? '兑现位' : '伏击位');
const distanceFor = (item: Recommendation, side: 'harvest' | 'plant') => {
  if (typeof item.distance_pct === 'number' && Number.isFinite(item.distance_pct)) return item.distance_pct;
  const level = actionLevelFor(item, side);
  return typeof item.price === 'number' && typeof level === 'number' && level > 0 ? (item.price / level - 1) * 100 : null;
};
const pageTitle = `A股ETF罗盘｜今日动作 | ${SITE_TITLE}`;
const pageDescription = 'A股ETF今日交易仪表盘：移动端优先展示结论、伏击兑现动作、当前价、关键位、兑现位与防守线。';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <style>
      main { width: min(1180px, calc(100% - 1.5rem)); padding: 1rem 0 3rem; }
      .dashboard-hero { padding: clamp(1rem, 3vw, 1.45rem); background: linear-gradient(135deg, #fff8f5, #fff); }
      .hero-top { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .55rem; align-items: flex-start; }
      .hero-copy { grid-column: 1 / 3; }
      .hero-copy h1 { margin: .35rem 0 .35rem; font-size: clamp(1.85rem, 5vw, 2.8rem); }
      .hero-copy p { margin: 0; max-width: 72ch; color: rgb(var(--gray-dark)); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
      .hero-copy details { margin-top: .35rem; }
      .hero-copy summary { cursor: pointer; color: rgb(var(--gray-dark)); font-size: .75rem; font-weight: 850; list-style: none; }
      .hero-copy summary::-webkit-details-marker { display: none; }
      .hero-copy details[open] p { -webkit-line-clamp: unset; display: block; }
      .meta-line { grid-column: 3 / 5; display: flex; flex-wrap: wrap; justify-content: flex-end; gap: .35rem; max-width: none; }
      .meta-line :global(.market-clock) { width: 100%; flex-basis: 100%; }
      .count-strip { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: .55rem; margin-top: 1rem; }
      .count { padding: .75rem .8rem; border: 1px solid var(--border); border-radius: 14px; background: #fff; min-height: 4.4rem; display: flex; flex-direction: column; justify-content: space-between; }
      .count span { display: block; color: rgb(var(--gray)); font-size: .74rem; font-weight: 800; letter-spacing: .02em; }
      .count strong { font-size: 1.55rem; line-height: 1; margin-top: .35rem; }
      .count.harvest { background: linear-gradient(180deg, #f3fbf6, #fff); border-color: rgba(31,122,78,.16); }
      .count.plant { background: linear-gradient(180deg, #fff7f5, #fff); border-color: rgba(214,61,46,.14); }
      .count.harvest strong { color: var(--green); }
      .count.plant strong { color: var(--accent); }
      .count .count-note { margin-top: .28rem; font-size: .68rem; color: rgb(var(--gray)); font-weight: 700; }
      .decision-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .55rem; margin-top: .7rem; }
      .decision-box { padding: .72rem .8rem; border: 1px solid var(--border); border-radius: 13px; background: var(--warm-2); min-height: 4.1rem; }
      .decision-box span { display: block; color: rgb(var(--gray)); font-size: .72rem; font-weight: 850; letter-spacing: .03em; }
      .decision-box strong { display: block; margin-top: .22rem; font-size: .95rem; line-height: 1.35; }
      .decision-box small { display: block; margin-top: .12rem; color: rgb(var(--gray)); font-size: .67rem; }
      .decision-box.mainline { grid-column: 1 / -1; background: #fff; min-height: auto; }
      .decision-box.mainline strong { font-size: .88rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
      .top-action { margin-top: .7rem; padding: .85rem 1rem; border-radius: 14px; background: rgb(var(--black)); color: #fff; display: grid; grid-template-columns: auto minmax(0,1fr); gap: .75rem; align-items: center; }
      .top-action .rank { font-size: 1.25rem; }
      .top-action span, .top-action strong { color: #fff; }
      .top-action small { display: block; opacity: .7; }
      .top-action strong { display: block; line-height: 1.5; }
      .macro-gate { margin-top: .7rem; padding: .75rem .85rem; border: 1px solid var(--border); border-radius: 14px; background: #f7fafc; }
      .macro-gate.ok { border-color: #b7e0c8; background: #f3fbf6; }
      .macro-gate.watch { border-color: #f0d48a; background: #fffaf0; }
      .macro-gate.warn { border-color: #f0b27a; background: #fff6ef; }
      .macro-gate.danger { border-color: #f0b0a8; background: #fff5f3; }
      .macro-gate summary { list-style: none; cursor: pointer; display: grid; grid-template-columns: auto 1fr auto; gap: .65rem; align-items: center; }
      .macro-gate summary::-webkit-details-marker { display: none; }
      .macro-gate summary > span { font-size: 1.2rem; }
      .macro-gate summary strong { display: block; font-size: .9rem; }
      .macro-gate summary small { display: block; margin-top: .12rem; color: rgb(var(--gray)); font-size: .75rem; line-height: 1.45; }
      .macro-gate summary b { font-size: .78rem; padding: .28rem .5rem; border-radius: 999px; background: #fff; border: 1px solid var(--border); white-space: nowrap; }
      .macro-gate .macro-more { margin-top: .55rem; display: grid; gap: .45rem; }
      .macro-factors { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: .45rem; }
      .macro-factor { padding: .55rem .6rem; border-radius: 10px; background: rgba(255,255,255,.78); border: 1px solid rgba(0,0,0,.04); }
      .macro-factor span { display: block; color: rgb(var(--gray)); font-size: .68rem; font-weight: 850; }
      .macro-factor strong { display: block; margin-top: .12rem; font-size: .78rem; }
      .macro-factor em { display: block; margin-top: .18rem; font-style: normal; color: rgb(var(--gray-dark)); font-size: .72rem; line-height: 1.4; }
      .macro-hint { color: rgb(var(--gray)); font-size: .72rem; }
      .section-head { display: flex; justify-content: space-between; align-items: end; gap: .8rem; margin: 1.5rem 0 .7rem; }
      .section-head h2 { margin: .25rem 0 0; }
      .section-head p { margin: 0; color: rgb(var(--gray)); font-size: .84rem; }
      .signal-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: .75rem; }
      .signal-card { position: relative; overflow: hidden; padding: .9rem; border-left: 5px solid var(--accent); min-width: 0; }
      .signal-card.harvest { border-left-color: var(--green); }
      .card-top { display: flex; justify-content: space-between; align-items: flex-start; gap: .55rem; }
      .identity { min-width: 0; }
      .identity code { font-size: .9rem; font-weight: 900; background: transparent; border: 0; padding: 0; }
      .identity h3 { margin: .12rem 0 0; font-size: 1rem; }
      .badges { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: .25rem; }
      .status, .priority { white-space: nowrap; border-radius: 999px; padding: .18rem .45rem; font-size: .7rem; font-weight: 900; }
      .status { background: var(--accent-soft); color: var(--accent-dark); }
      .harvest .status { background: var(--green-soft); color: var(--green); }
      .priority { background: var(--warm); border: 1px solid var(--border); }
      .live-pill { display: inline-flex; align-items: center; gap: .35rem; }
      .live-pill::before { content: ''; width: .5rem; height: .5rem; border-radius: 50%; background: #b7791f; box-shadow: 0 0 0 3px rgba(183,121,31,.12); }
      .live-pill.online::before { background: var(--green); box-shadow: 0 0 0 3px rgba(31,122,78,.14); }
      .live-pill.error::before { background: var(--accent); box-shadow: 0 0 0 3px rgba(214,61,46,.14); }
      .live-trigger { background: #eef6ff; color: #1d4f91; border: 1px solid #cfe2fa; }
      .live-trigger.triggered { background: var(--accent-soft); color: var(--accent-dark); border-color: rgba(214,61,46,.22); }
      .harvest .live-trigger.triggered { background: var(--green-soft); color: var(--green); border-color: rgba(31,122,78,.22); }
      .live-price { transition: color .2s ease; }
      .live-price.updated { color: #1d4f91; }
      .level-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); margin: .72rem 0; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
      .level { padding: .55rem .38rem; text-align: center; background: var(--warm-2); border-right: 1px solid var(--border); }
      .level:last-child { border: 0; }
      .level.active { background: var(--accent-soft); }
      .harvest .level.active { background: var(--green-soft); }
      .level span { display: block; font-size: .66rem; color: rgb(var(--gray)); white-space: nowrap; }
      .level b { font-size: .9rem; }
      .distance { display: flex; justify-content: space-between; gap: .5rem; font-size: .73rem; color: rgb(var(--gray)); margin: -.25rem 0 .55rem; }
      .action-copy { margin: 0; padding: .62rem .7rem; border-radius: 10px; background: var(--accent-soft); font-size: .86rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
      .harvest .action-copy { background: var(--green-soft); }
      .reason { margin: .45rem 0 0; color: rgb(var(--gray-dark)); font-size: .8rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
      .signal-card.blocked { opacity: .94; border-style: dashed; }
      .signal-card.level-invalid { border-color: #f0c36d; }
      .empty-signal { padding: 1rem; color: rgb(var(--gray-dark)); font-size: .92rem; }
      .watch-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .65rem; }
      .watch { padding: .85rem; }
      .watch strong { display: block; margin-bottom: .2rem; }
      .watch span { font-size: .84rem; color: rgb(var(--gray-dark)); }
      .risk-note { margin: 1rem 0; padding: .75rem .9rem; border: 1px solid var(--border); border-radius: 12px; background: var(--amber-soft); font-size: .8rem; }
      .links-panel { padding: .9rem; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: .7rem; }
      .links-panel p { margin: 0; color: rgb(var(--gray)); font-size: .84rem; }
      .button-row { display: flex; flex-wrap: wrap; gap: .45rem; }
      .button { display: inline-flex; padding: .55rem .75rem; border-radius: 999px; background: var(--warm); border: 1px solid var(--border); text-decoration: none; font-size: .8rem; font-weight: 900; color: rgb(var(--black)); }
      .button.primary { background: rgb(var(--black)); color: #fff; }
      @media (max-width: 940px) {
        .hero-top { grid-template-columns: 1fr; gap: .8rem; }
        .hero-copy, .meta-line { grid-column: 1; }
        .meta-line { justify-content: flex-start; max-width: none; }
        .signal-grid { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
        .decision-grid { grid-template-columns: repeat(3, minmax(0,1fr)); }
        .macro-factors { grid-template-columns: 1fr; }
      }
      @media (max-width: 620px) {
        main { width: min(100% - 1rem, 1180px); padding-top: 1rem; }
        .dashboard-hero { padding: .85rem; }
        .hero-copy h1 { font-size: 1.8rem; }
        .hero-copy p { font-size: .88rem; }
        .count-strip { grid-template-columns: repeat(2, minmax(0,1fr)); gap: .4rem; }
        .count { padding: .55rem .55rem; min-height: 3.8rem; }
        .count strong { font-size: 1.25rem; }
        .decision-grid, .signal-grid, .watch-grid { grid-template-columns: 1fr; }
        .decision-box.mainline strong { -webkit-line-clamp: 3; }
        .top-action { grid-template-columns: auto 1fr; padding: .7rem .8rem; }
        .macro-gate summary { grid-template-columns: auto 1fr; }
        .macro-gate summary b { grid-column: 1/-1; justify-self: start; }
        .section-head { align-items: flex-start; margin-top: 1.15rem; }
        .section-head p { display: none; }
        .level-grid { grid-template-columns: repeat(2, 1fr); }
        .level:nth-child(2) { border-right: 0; }
        .level:nth-child(-n+2) { border-bottom: 1px solid var(--border); }
        .links-panel { display: grid; }
        .button-row { display: grid; grid-template-columns: repeat(2, 1fr); }
        .button { justify-content: center; }
      }
    </style>
    <style is:global>
      main .market-up { color: var(--market-up); font-weight: 850; }
      main .market-down { color: var(--market-down); font-weight: 850; }
    </style>
  </head>
  <body>
    <Header />
    <main id="main-content" tabindex="-1">
      <AStockSubnav active="compass" />
      <section class="dashboard-hero card" aria-labelledby="page-title">
        <div class="hero-top">
          <div class="hero-copy">
            <span class="pill pill-red">🇨🇳A股ETF交易仪表盘</span>
            <h1 id="page-title">A股ETF罗盘</h1>
            <details>
              <summary>查看完整结论</summary>
              <p>{data.summary}</p>
            </details>
          </div>
          <div class="meta-line" aria-label="数据元信息">
            <span class="pill pill-amber">适用：{data.date}</span>
            <span class="pill">截止：{data.updated_at}</span>
            <span class="pill">策略基线：{data.level_data_as_of || data.data_as_of || '待更新'}</span>
            <span class="pill">{data.level_model_version || '关键位静态冻结'}</span>
            <span class="pill live-pill" id="live-quote-status" role="status" aria-live="polite">实时行情连接中</span>
            <MarketClock market="a-share" />
          </div>
        </div>
        <div class="count-strip" aria-label="今日动作数量">
          <div class="count harvest"><span>🟢 兑现</span><strong>{counts.harvest}</strong><em class="count-note">正式减仓</em></div>
          <div class="count harvest"><span>🟢 止盈观察</span><strong>{counts.readyHarvest}</strong><em class="count-note">接近兑现位</em></div>
          <div class="count plant"><span>🔴 正式伏击</span><strong>{counts.plant}</strong><em class="count-note">可执行低吸</em></div>
          <div class="count plant"><span>🔴 候场</span><strong>{counts.readyPlant}</strong><em class="count-note">仅观察</em></div>
        </div>
        <div class="decision-grid">
          <div class="decision-box"><span>市场状态</span><strong>{data.market_state}</strong></div>
          <div class="decision-box"><span>仓位建议</span><strong>{data.position}</strong></div>
          <div class="decision-box"><span>颜色规则</span><strong>🔴低吸 / 🟢兑现</strong><small>行情：🔴上涨 / 🟢下跌</small></div>
          <div class="decision-box mainline"><span>今日主线</span><strong title={data.mainline}>{data.mainline}</strong></div>
        </div>
        {midMacro && (
          <details class={`macro-gate ${midTone}`} aria-label="中观三因子约束">
            <summary>
              <span>{midIcon}</span>
              <div>
                <strong>中观约束：{midLabel} · 逆风等级 {midLevel}/3</strong>
                <small>{midConstraint}{midMacro.base_position ? `｜微观原建议 ${midMacro.base_position}` : ''}</small>
              </div>
              <b>{midMacro.allow_chase ? '允许按位执行' : midMacro.allow_new_offense === false ? '停开进攻仓' : '禁止追高'}</b>
            </summary>
            <div class="macro-more">
              <div class="macro-hint">点击标题可收起。三因子只压缩权益上限与追高资格，不改关键位触发。</div>
              {midFactors.length > 0 && (
                <div class="macro-factors">
                  {midFactors.map((factor) => (
                    <article class="macro-factor">
                      <span>{factor.label}</span>
                      <strong>{factor.state}</strong>
                      <em>{factor.headline}</em>
                    </article>
                  ))}
                </div>
              )}
            </div>
          </details>
        )}
        {topAction && <div class="top-action" aria-label="最高优先级动作"><span class="rank">⚡</span><div><small>第一优先级｜{topAction.status} · {topAction.priority}</small><strong>{topAction.code} {topAction.name}：{topAction.action}</strong></div></div>}
      </section>

      <section aria-labelledby="harvest-title">
              <div class="section-head"><div><span class="pill pill-green">🟢 风险优先</span><h2 id="harvest-title">{counts.harvest > 0 ? `兑现 ${counts.harvest}` : '兑现 0'}{counts.readyHarvest > 0 ? ` · 止盈观察 ${counts.readyHarvest}` : ''}</h2></div><p>先处理兑现和失效风险；关键位无效仅观察</p></div>
              <div class="signal-grid">
                {harvest.map((item) => <article class={`signal-card harvest card${item.level_status === 'invalid' ? ' level-invalid' : ''}`} id={`etf-${item.code}`} data-live-card data-side="harvest" data-code={item.code} data-action-level={actionLevelFor(item, 'harvest')} data-stop={item.stop} data-snapshot-price={item.price}>
                  <div class="card-top"><div class="identity"><code>{item.code}</code><h3>{item.name}</h3></div><div class="badges"><span class="status">{item.status}</span><span class="priority">{item.priority}</span>{item.level_status === 'invalid' && <span class="status">关键位无效</span>}<span class="status live-trigger" id={`live-trigger-${item.code}`}>静态快照</span></div></div>
                  <div class="level-grid" aria-label={`${item.name}关键价位`}>
                    <div class="level"><span>实时现价</span><b class="live-price" id={`live-price-${item.code}`}>{formatPrice(item.price)}</b></div>
                    <div class="level active"><span>{actionLabelFor(item, 'harvest')}</span><b>{formatPrice(actionLevelFor(item, 'harvest'))}</b></div>
                    <div class="level"><span>观察目标</span><b>{formatPrice(item.target)}</b></div>
                    <div class="level"><span>防守线</span><b>{formatPrice(item.stop)}</b></div>
                  </div>
                  <div class="distance"><span id={`live-distance-${item.code}`}>距动作位 {formatDistance(distanceFor(item, 'harvest'))}</span><span id={`live-meta-${item.code}`}>快照{item.price_date || data.level_data_as_of || data.data_as_of || '待更新'} · 趋势{item.trend_level || '—'} · 风险{item.risk_level || '—'}</span></div>
                  <p class="action-copy"><strong>动作：</strong>{item.action}</p>
                  <p class="reason"><strong>依据：</strong>{item.trigger}</p>
                </article>)}
              </div>
            </section>

            <section aria-labelledby="plant-title">
              <div class="section-head"><div><span class="pill pill-red">🔴 低吸区</span><h2 id="plant-title">{counts.plant > 0 ? `正式伏击 ${counts.plant}` : '正式伏击 0'}{counts.readyPlant > 0 ? ` · 候场 ${counts.readyPlant}` : ''}</h2></div><p>{counts.plant > 0 ? '执行伏击位和防守线，不追高开' : '今日无正式伏击；下方仅候场观察，中观强逆风不新开'}</p></div>
              {plant.length === 0 ? (
                <div class="empty-signal card">今日无候场/伏击标的。中观约束下不机械凑数。</div>
              ) : (
              <div class="signal-grid">
                {plant.map((item) => <article class={`signal-card card${item.eligibility === 'blocked' ? ' blocked' : ''}`} id={`etf-${item.code}`} data-live-card data-side="plant" data-code={item.code} data-action-level={actionLevelFor(item, 'plant')} data-stop={item.stop} data-snapshot-price={item.price}>
                  <div class="card-top"><div class="identity"><code>{item.code}</code><h3>{item.name}</h3></div><div class="badges"><span class="status">{item.status}</span><span class="priority">{item.priority}</span>{item.eligibility === 'blocked' && <span class="status">不可执行</span>}<span class="status live-trigger" id={`live-trigger-${item.code}`}>静态快照</span></div></div>
                  <div class="level-grid" aria-label={`${item.name}关键价位`}>
                    <div class="level"><span>实时现价</span><b class="live-price" id={`live-price-${item.code}`}>{formatPrice(item.price)}</b></div>
                    <div class="level active"><span>{actionLabelFor(item, 'plant')}</span><b>{formatPrice(actionLevelFor(item, 'plant'))}</b></div>
                    <div class="level"><span>观察目标</span><b>{formatPrice(item.target)}</b></div>
                    <div class="level"><span>防守线</span><b>{formatPrice(item.stop)}</b></div>
                  </div>
                  <div class="distance"><span id={`live-distance-${item.code}`}>距动作位 {formatDistance(distanceFor(item, 'plant'))}</span><span id={`live-meta-${item.code}`}>快照{item.price_date || data.level_data_as_of || data.data_as_of || '待更新'} · 趋势{item.trend_level || '—'} · 风险{item.risk_level || '—'}</span></div>
                  <p class="action-copy"><strong>动作：</strong>{item.action}</p>
                  <p class="reason"><strong>依据：</strong>{item.trigger}</p>
                </article>)}
              </div>
              )}
            </section>

      <section aria-labelledby="watch-title">
        <div class="section-head"><div><span class="pill pill-amber">下一窗口验证</span><h2 id="watch-title">只看 {watch.length} 个条件</h2></div></div>
        <div class="watch-grid">{watch.map((item) => <div class="watch card"><strong>{item.label || [item.code, item.name].filter(Boolean).join(' · ') || '观察条件'}</strong><span>{item.text || item.action || '等待下一窗口确认'}</span></div>)}</div>
      </section>

      <p class="risk-note"><strong>风险提示：</strong>ATR关键位优先使用qfq日线；qfq缺失时使用明确标记的近90日未复权短窗备用。页面披露两类样本数量；关键位不替代盘中资金、成交和个人仓位判断，历史表现不代表未来收益。</p>
      <section class="links-panel card"><p>完整过程、历史命中与策略验证保留独立归档。</p><div class="button-row"><a class="button primary" href="/paper/">模拟盘</a><a class="button" href="/a-momentum/">A股趋势风控雷达</a><a class="button" href="/a-macro/">A股宏观雷达</a><a class="button" href="/blog/">A股盘后复盘</a><a class="button" href="/a-compass/history/">历史复盘</a><a class="button" href="/research/">策略档案</a></div></section>
    </main>
    <Footer />
    <script is:inline>
      const LIVE_URL = 'https://etf-live.peekabo.cc/api/etf-garden/live';
      const liveStatus = document.getElementById('live-quote-status');
      let liveLoading = false;
      const liveCards = [...document.querySelectorAll('[data-live-card]')];
      const liveCodes = [...new Set(liveCards.map(card => card.dataset.code).filter(Boolean))];
      const LIVE_QUERY_URL = liveCodes.length ? `${LIVE_URL}?codes=${encodeURIComponent(liveCodes.join(','))}` : LIVE_URL;
      const numberOf = (value) => {
        if (value === null || value === undefined || value === '') return null;
        const parsed = Number(value);
        return Number.isFinite(parsed) ? parsed : null;
      };
      const shanghaiClock = () => {
        const parts = Object.fromEntries(new Intl.DateTimeFormat('en-CA', {
          timeZone: 'Asia/Shanghai', weekday: 'short', hour: '2-digit', minute: '2-digit', hourCycle: 'h23'
        }).formatToParts(new Date()).filter(part => part.type !== 'literal').map(part => [part.type, part.value]));
        return { weekday: parts.weekday, minutes: Number(parts.hour) * 60 + Number(parts.minute) };
      };
      const isTradingWindow = () => {
        const { weekday, minutes } = shanghaiClock();
        return !['Sat', 'Sun'].includes(weekday) && minutes >= 9 * 60 + 15 && minutes <= 15 * 60 + 5;
      };
      const displaySource = (source) => String(source || 'stock-api').replace('@', ' v');
      const setStatus = (text, state = '') => {
        if (!liveStatus) return;
        liveStatus.textContent = text;
        liveStatus.classList.toggle('online', state === 'online');
        liveStatus.classList.toggle('error', state === 'error');
      };
      function applyLive(payload) {
        const liveMap = new Map((payload.items || []).map(item => [String(item.code), item]));
        const time = String(payload.generated_at || '').slice(11, 19) || '刚刚';
        const quoteMode = isTradingWindow() ? '盘中实时' : '最新快照';
        let updated = 0;
        for (const card of liveCards) {
          const code = card.dataset.code;
          const quote = liveMap.get(code);
          const price = numberOf(quote?.price);
          if (price === null) continue;
          const side = card.dataset.side;
          const actionLevel = numberOf(card.dataset.actionLevel);
          const stop = numberOf(card.dataset.stop);
          const priceNode = document.getElementById(`live-price-${code}`);
          const distanceNode = document.getElementById(`live-distance-${code}`);
          const metaNode = document.getElementById(`live-meta-${code}`);
          const triggerNode = document.getElementById(`live-trigger-${code}`);
          if (priceNode) {
            priceNode.textContent = price.toFixed(3);
            priceNode.classList.add('updated');
          }
          let triggered = false;
          let triggerText = '等待动作位';
          if (stop !== null && price <= stop) {
            triggered = true;
            triggerText = '破位撤退';
          } else if (actionLevel !== null && actionLevel > 0) {
            const gap = (price / actionLevel - 1) * 100;
            if (distanceNode) distanceNode.textContent = `${gap >= 0 ? '高于' : '低于'}动作位 ${Math.abs(gap).toFixed(1)}%`;
            if (side === 'harvest') {
              triggered = price >= actionLevel;
              triggerText = triggered ? '达到兑现位' : (Math.abs(gap) <= 3 ? '距兑现位≤3%' : '等待兑现触发');
            } else {
              triggered = price <= actionLevel;
              triggerText = triggered ? '进入伏击区' : (Math.abs(gap) <= 3 ? '距伏击位≤3%' : '等待伏击触发');
            }
          }
          if (triggerNode) {
            triggerNode.textContent = triggerText;
            triggerNode.classList.toggle('triggered', triggered);
          }
          if (metaNode) {
            const change = numberOf(quote?.change_pct);
            const changeText = change === null ? '' : ` · <span class="${change >= 0 ? 'market-up' : 'market-down'}">${change >= 0 ? '+' : ''}${change.toFixed(2)}%</span>`;
            metaNode.innerHTML = `${quoteMode} ${time} · ${displaySource(quote?.source || payload.source)}${changeText}`;
          }
          updated += 1;
        }
        setStatus(`${quoteMode} ${time} · ${updated}/${liveCards.length}`, 'online');
      }
      async function loadLive() {
        if (liveLoading || document.hidden) return;
        liveLoading = true;
        try {
          const response = await fetch(LIVE_QUERY_URL);
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          const payload = await response.json();
          if (!payload.ok || !Array.isArray(payload.items)) throw new Error('行情格式异常');
          applyLive(payload);
        } catch (error) {
          setStatus(`实时行情暂不可用 · 保留静态快照`, 'error');
          console.warn('ETF live quote overlay failed', error);
        } finally {
          liveLoading = false;
        }
      }
      document.addEventListener('visibilitychange', () => { if (!document.hidden) void loadLive(); });
      void loadLive();
      window.setInterval(loadLive, 30_000);
    </script>
  </body>
</html>
