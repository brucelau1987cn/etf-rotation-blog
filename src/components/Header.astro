---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
const isHome = Astro.url.pathname === '/';
---

<a class="skip-link" href="#main-content">跳到主要内容</a>
<header>
  <nav class="site-shell" aria-label="主导航">
    <a class:list={['brand', { active: isHome }]} href="/" aria-label={`${SITE_TITLE}首页`} aria-current={isHome ? 'page' : undefined}>
      <span class="mark">ETF</span>
      <span class="brand-copy"><strong>{SITE_TITLE}</strong><small>伏击 · 兑现 · 复盘</small></span>
    </a>
    <div class="nav-scroll">
      <div class="internal-links">
        <HeaderLink href="/a-compass/" activePaths={['/a-compass/', '/blog', '/a-momentum', '/a-macro']}>A股罗盘</HeaderLink>
        <HeaderLink href="/us-compass/" activePaths={['/us-compass/', '/us-momentum', '/us-macro']}>美股罗盘</HeaderLink>
        <HeaderLink href="/paper/">模拟盘</HeaderLink>
        <HeaderLink href="/login/" class="utility" aria-label="登录回测实验室">登录</HeaderLink>
      </div>
    </div>
  </nav>
</header>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const main = document.querySelector('main');
    if (main && !main.id) main.id = 'main-content';
  }, { once: true });
</script>
<style>
  header {
    position: sticky;
    top: 0;
    z-index: 20;
    margin: 0;
    padding: 0.62rem 0;
    background: rgba(250, 250, 247, 0.91);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(8px);
  }
  nav { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .brand { display: inline-flex; flex: 0 0 auto; align-items: center; gap: 0.65rem; color: rgb(var(--black)); text-decoration: none; }
  .mark { display: inline-flex; align-items: center; justify-content: center; width: 2.35rem; height: 2.35rem; border-radius: 11px; background: rgb(var(--black)); color: white; font-size: 0.75rem; font-weight: 900; letter-spacing: 0.04em; }
  .brand-copy { display: grid; line-height: 1.15; }
  .brand-copy strong { font-size: 0.96rem; }
  .brand-copy small { margin-top: 0.2rem; color: rgb(var(--gray)); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em; }
  .nav-scroll { min-width: 0; overflow-x: auto; scrollbar-width: none; }
  .nav-scroll::-webkit-scrollbar { display: none; }
  .internal-links { display: flex; align-items: center; gap: 0.25rem; width: max-content; margin-left: auto; }
  nav :global(a) { color: rgb(var(--gray-dark)); text-decoration: none; font-size: 0.88rem; font-weight: 750; padding: 0.5rem 0.68rem; border-radius: 999px; white-space: nowrap; }
  nav :global(a.active) { color: var(--accent-dark); background: var(--accent-soft); }
  nav :global(a:hover) { background: var(--warm); color: rgb(var(--black)); }
  nav :global(a.utility) { color: rgb(var(--gray)); border-left: 1px solid var(--border); border-radius: 0; margin-left: 0.2rem; }
  @media (max-width: 720px) {
    header { padding: 0.48rem 0; }
    nav.site-shell { width: min(100% - 0.75rem, 1120px); gap: 0.55rem; }
    .brand-copy small { display: none; }
    .mark { width: 2.15rem; height: 2.15rem; }
    .internal-links { gap: 0.1rem; }
    nav :global(a) { padding: 0.48rem 0.58rem; font-size: 0.84rem; }
  }
</style>
