---
import { SITE_AUTHOR, SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
  <div class="site-shell footer-inner">
    <div>
      <strong>{SITE_TITLE}</strong>
      <p>ETF花园信号、每日复盘、动量验证，由 {SITE_AUTHOR} 维护。</p>
    </div>
    <div class="footer-links">
      <a href="/garden">ETF花园</a>
      <a href="/blog">每日复盘</a>
      <a href="/about">策略框架</a>
      <a href="https://github.com/brucelau1987cn" target="_blank" rel="noreferrer">{SITE_AUTHOR}</a>
    </div>
  </div>
  <div class="site-shell copyright">© {today.getFullYear()} {SITE_AUTHOR}. Research notes only.</div>
</footer>
<style>
  footer { padding: 2.5rem 0 4rem; color: rgb(var(--gray)); background: var(--warm); border-top: 1px solid var(--border); }
  .footer-inner { display: flex; align-items: flex-start; justify-content: space-between; gap: 1.5rem; }
  footer strong { color: rgb(var(--black)); }
  footer p { margin: 0.35rem 0 0; font-size: 0.92rem; }
  .footer-links { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: flex-end; }
  .footer-links a { color: rgb(var(--gray-dark)); text-decoration: none; font-size: 0.92rem; font-weight: 700; }
  .footer-links a:hover { color: var(--accent); }
  .copyright { margin-top: 1.5rem; font-size: 0.82rem; color: rgb(var(--gray)); }
  @media (max-width: 720px) { .footer-inner { flex-direction: column; } .footer-links { justify-content: flex-start; } }
</style>
