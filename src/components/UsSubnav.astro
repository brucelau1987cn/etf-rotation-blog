---
const { active = '' } = Astro.props;
const links = [
  { key: 'garden', href: '/us-garden/', label: '今日动作' },
  { key: 'trend', href: '/us-momentum/', label: '趋势雷达' },
  { key: 'macro', href: '/us-macro/', label: '宏观雷达' },
  { key: 'history', href: '/us-garden/history/', label: '历史成绩' },
];
---
<nav class="us-subnav" aria-label="美股ETF二级导航">
  {links.map((link) => <a href={link.href} class:list={[active === link.key && 'active']}>{link.label}</a>)}
</nav>
<style>
  .us-subnav{display:flex;gap:.35rem;width:min(1180px,calc(100vw - 1.5rem));min-height:48px;box-sizing:border-box;margin:0 50% 1rem;padding:.35rem;border:1px solid var(--border);border-radius:14px;background:#fff;overflow-x:auto;scrollbar-width:none;transform:translateX(-50%)}.us-subnav::-webkit-scrollbar{display:none}.us-subnav a{display:flex;align-items:center;justify-content:center;flex:0 0 auto;min-height:36px;padding:.5rem .85rem;border-radius:10px;color:rgb(var(--gray-dark));font-size:.82rem;font-weight:850;line-height:1;text-decoration:none;white-space:nowrap}.us-subnav a:hover{background:#f1f5f9}.us-subnav a.active{background:#14243b;color:#fff}@media(max-width:620px){.us-subnav{width:calc(100vw - 1rem);position:sticky;top:.35rem;z-index:20;box-shadow:0 8px 20px rgba(15,23,42,.08)}}
</style>
