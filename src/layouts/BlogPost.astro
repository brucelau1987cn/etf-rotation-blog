---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR } from '../consts';
import { cleanDescription, renameCompassTerms } from '../lib/posts';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, appliesTo, dataAsOf, stage, heroImage, category } = Astro.props;
const displayTitle = renameCompassTerms(title);
const readableDescription = cleanDescription(description);
const displayStage = stage ? renameCompassTerms(stage) : stage;
const displayCategory = category ? renameCompassTerms(category) : category;
const articleUrl = new URL(Astro.url.pathname, Astro.site);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: displayTitle,
  description: readableDescription,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', name: SITE_AUTHOR },
  publisher: { '@type': 'Organization', name: 'ETF罗盘' },
  mainEntityOfPage: articleUrl.toString(),
  inLanguage: 'zh-CN',
};
---

<html lang="zh-CN">
  <head>
    <BaseHead title={displayTitle} description={readableDescription} type="article" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <style>
      main { width: min(1080px, calc(100% - 2rem)); }
      .hero-image { width: 100%; margin-top: 1rem; }
      .hero-image img { display: block; width: 100%; margin: 0 auto; border-radius: 20px; box-shadow: var(--box-shadow); }
      .title { margin: 1.5rem 0 1.35rem; padding: clamp(1.2rem, 4vw, 2rem); border-radius: 22px; border: 1px solid var(--border); background: linear-gradient(135deg, #fff 0%, var(--warm-2) 64%, var(--accent-soft) 100%); box-shadow: var(--box-shadow); }
      .title h1 { max-width: 900px; margin: 0.72rem 0; font-size: clamp(2rem, 4.5vw, 3.1rem); word-break: keep-all; overflow-wrap: anywhere; text-wrap: balance; }
      .description { max-width: 800px; margin-bottom: 0.6rem; color: rgb(var(--gray)); font-size: 1.04rem; line-height: 1.7; }
      .meta, .article-nav { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; }
      .article-nav { margin-top: 1rem; }
      .article-nav a { color: rgb(var(--gray-dark)); font-size: 0.84rem; font-weight: 800; text-decoration: none; }
      .last-updated-on { color: rgb(var(--gray)); font-size: 0.86rem; }
      .article-shell { display: grid; grid-template-columns: minmax(0, 1fr) 280px; gap: 1.5rem; align-items: start; }
      .prose { min-width: 0; padding: 0 0 1rem; color: rgb(var(--gray-dark)); }
      .sidebar { position: sticky; top: 5.3rem; padding: 0.9rem; }
      .sidebar summary { cursor: pointer; list-style: none; color: rgb(var(--black)); font-weight: 900; }
      .sidebar summary::-webkit-details-marker { display: none; }
      .sidebar summary::after { content: '⌄'; float: right; color: rgb(var(--gray)); }
      .toc { display: grid; gap: 0.15rem; margin-top: 0.7rem; }
      .toc a { display: block; color: rgb(var(--gray)); text-decoration: none; margin: 0.06rem 0; padding: 0.4rem 0.48rem; border-left: 3px solid transparent; border-radius: 8px; font-size: 0.86rem; font-weight: 700; line-height: 1.35; overflow-wrap: anywhere; }
      .toc a:hover { color: rgb(var(--black)); background: var(--warm); }
      .toc a.active { color: var(--accent-dark); border-left-color: var(--accent); background: var(--accent-soft); }
      .toc a.sub { padding-left: 1rem; font-size: 0.8rem; font-weight: 620; }
      .disclaimer { margin-top: 0.8rem; padding: 0.75rem; border-radius: 12px; background: var(--amber-soft); color: rgb(var(--gray-dark)); font-size: 0.8rem; line-height: 1.5; }
      .back-top { display: block; margin-top: 0.7rem; color: rgb(var(--gray)); font-size: 0.8rem; text-align: center; text-decoration: none; }
      .status-meta { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 0.8rem; }
      .prose > h2:first-child { margin-top: 0; padding: 1rem 1.1rem 0; border: 1px solid rgba(214,61,46,.22); border-bottom: 0; border-radius: 18px 18px 0 0; background: linear-gradient(135deg, var(--accent-soft), #fff); }
      .prose > h2:first-child + blockquote { margin-top: 0; border-radius: 0 0 18px 18px; border: 1px solid rgba(214,61,46,.22); border-top: 0; background: linear-gradient(135deg, var(--accent-soft), #fff); }
      @media (max-width: 960px) {
        .article-shell { grid-template-columns: 1fr; gap: 1rem; }
        .sidebar { position: static; order: -1; }
        .sidebar details:not([open]) .disclaimer, .sidebar details:not([open]) .back-top { display: none; }
      }
      @media (max-width: 620px) {
        main { width: min(100% - 1rem, 1080px); }
        .title { margin-top: 0.8rem; border-radius: 18px; }
        .title h1 { font-size: clamp(1.8rem, 9vw, 2.35rem); }
        .description { font-size: 0.96rem; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main id="top">
      <article>
        {heroImage && <div class="hero-image"><Image width={1020} height={510} src={heroImage} alt="" /></div>}
        <header class="title">
          <div class="meta">
            <span class="pill pill-red">{displayCategory ?? 'ETF研究'}</span>
            <span class="pill"><FormattedDate date={pubDate} /></span>
            <span class="pill">{SITE_AUTHOR}</span>
          </div>
          <h1>{displayTitle}</h1>
          <p class="description">{readableDescription}</p>
          {(appliesTo || dataAsOf || displayStage) && <div class="status-meta">
            {appliesTo && <span class="pill pill-red">适用交易日：{appliesTo}</span>}
            {dataAsOf && <span class="pill">数据截止：{dataAsOf}</span>}
            {displayStage && <span class="pill pill-amber">{displayStage}</span>}
          </div>}
          {updatedDate && <div class="last-updated-on">最后更新：<FormattedDate date={updatedDate} /></div>}
          <nav class="article-nav" aria-label="文章快捷导航"><a href="/garden">← A股罗盘</a><a href="/blog">全部A股复盘</a><a href="/momentum">A股趋势风控雷达</a></nav>
        </header>
        <div class="article-shell">
          <div class="prose" id="article-content"><slot /></div>
          <aside class="sidebar card" aria-label="本文目录">
            <details open>
              <summary>本文目录</summary>
              <nav class="toc" id="article-toc"><span class="last-updated-on">正在生成目录…</span></nav>
              <div class="disclaimer">仅供个人研究与策略复盘，不构成投资建议。数据可能延迟、缺失或错误；历史表现不代表未来收益，交易风险由使用者自行承担。</div>
              <a class="back-top" href="#top">返回顶部 ↑</a>
            </details>
          </aside>
        </div>
      </article>
    </main>
    <Footer />
    <script>
      const renameCompassTerms = (text) => text
        .replaceAll('观察不种', '仅观察不升级')
        .replaceAll('准备种花', '候场')
        .replaceAll('准备摘花', '止盈观察')
        .replaceAll('失效退出', '破位撤退')
        .replaceAll('07:30早盘版', '08:30盘前版')
        .replaceAll('07:30 早盘预测', '08:30 盘前预测')
        .replaceAll('07:30早盘预测', '08:30盘前预测')
        .replaceAll('07:30准备信号', '08:30准备信号')
        .replaceAll('ETF花园', 'ETF罗盘')
        .replaceAll('花园信号', '罗盘信号')
        .replaceAll('回踩位', '伏击位')
        .replaceAll('目标位', '兑现位')
        .replaceAll('失效线', '防守线')
        .replaceAll('种花', '伏击')
        .replaceAll('摘花', '兑现');
      const content = document.querySelector('#article-content');
      if (content) {
        const walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT);
        const nodes = [];
        while (walker.nextNode()) nodes.push(walker.currentNode);
        for (const node of nodes) {
          const next = renameCompassTerms(node.nodeValue || '');
          if (next !== node.nodeValue) node.nodeValue = next;
        }
      }
      const toc = document.querySelector('#article-toc');
      if (content && toc) {
        const headings = [...content.querySelectorAll('h2, h3')].filter((heading) => heading.id);
        toc.innerHTML = headings.length
          ? headings.map((heading) => `<a class="${heading.tagName === 'H3' ? 'sub' : ''}" href="#${heading.id}">${heading.textContent || ''}</a>`).join('')
          : '<span class="last-updated-on">本文暂无分节目录</span>';
        const links = [...toc.querySelectorAll('a')];
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
            if (!visible) return;
            links.forEach((link) => link.classList.toggle('active', link.getAttribute('href') === `#${visible.target.id}`));
          }, { rootMargin: '-18% 0px -72% 0px' });
          headings.forEach((heading) => observer.observe(heading));
        }
        content.querySelectorAll('table').forEach((table) => {
          const hint = document.createElement('p');
          hint.className = 'table-hint';
          hint.textContent = '表格可左右滑动查看完整内容';
          table.before(hint);
        });
      }
    </script>
  </body>
</html>
