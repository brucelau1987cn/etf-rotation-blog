{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://etf.peekabo.cc/schemas/data-catalog.schema.json",
  "title": "ETF Compass public data catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "batch_id", "contract_url", "generated_at", "datasets"],
  "properties": {
    "schema_version": {"const": "data-catalog-v1"},
    "batch_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "contract_url": {"const": "/schemas/data-catalog.schema.json"},
    "generated_at": {"type": "string", "format": "date-time"},
    "datasets": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["dataset_id", "role", "market", "schema_version", "observation_date", "generated_at", "completeness", "degradation", "source_categories", "semantic_sha256", "sha256", "bytes", "public_url"],
        "properties": {
          "dataset_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "role": {"enum": ["production", "shadow", "history", "runtime", "export"]},
          "market": {"enum": ["CN", "US", "MULTI"]},
          "schema_version": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "integer", "minimum": 1}]},
          "observation_date": {"type": "string", "format": "date"},
          "generated_at": {"type": ["string", "null"]},
          "completeness": {
            "type": "object", "additionalProperties": false,
            "required": ["status", "ratio", "observed", "expected", "reason"],
            "properties": {
              "status": {"enum": ["known", "unknown"]},
              "ratio": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
              "observed": {"type": ["integer", "null"], "minimum": 0},
              "expected": {"type": ["integer", "null"], "minimum": 0},
              "reason": {"type": ["string", "null"]}
            }
          },
          "degradation": {
            "type": "object", "additionalProperties": false,
            "required": ["status", "reasons"],
            "properties": {"status": {"enum": ["normal", "degraded", "unknown"]}, "reasons": {"type": "array", "items": {"type": "string"}}}
          },
          "source_categories": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["market_data", "historical_market_data", "official_statistics", "public_events", "derived_research", "model_output", "simulated_execution", "publication_receipt"]}},
          "semantic_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 1},
          "public_url": {"type": "string", "pattern": "^/data/[A-Za-z0-9._/-]+\\.json$"}
        }
      }
    }
  }
}
