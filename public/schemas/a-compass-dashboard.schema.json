{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://etf.peekabo.cc/schemas/a-compass-dashboard.schema.json",
  "title": "A-share ETF Compass browser dashboard",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "batch_id", "contract_url", "generated_at", "run_date", "evaluation_date", "latest_trade_date", "summary", "market_regime", "realtime_scope", "snapshot_scope", "all_rows"],
  "properties": {
    "schema_version": {"const": "a-compass-dashboard-v1"},
    "batch_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "contract_url": {"const": "/schemas/a-compass-dashboard.schema.json"},
    "generated_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}[ T].+"},
    "run_date": {"type": "string", "format": "date"},
    "evaluation_date": {"type": "string", "format": "date"},
    "latest_trade_date": {"type": "string", "format": "date"},
    "summary": {"type": "object"},
    "market_regime": {"type": "object"},
    "realtime_scope": {"type": "array", "items": {"type": "string"}},
    "snapshot_scope": {"type": "array", "items": {"type": "string"}},
    "all_rows": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["code", "name", "type", "theme", "status", "price", "ret5", "ret20", "close_position", "signal_score", "strength_level", "trading_risk_score", "trade_state", "action", "cooldown_state", "risk_flags", "risk_level", "agent_bull", "agent_bear", "agent_scores"],
        "properties": {
          "code": {"type": "string", "pattern": "^[0-9]{6}$"}, "name": {"type": "string", "minLength": 1},
          "type": {"type": ["string", "null"]}, "theme": {"type": ["string", "null"]}, "status": {"type": ["string", "null"]},
          "price": {"type": ["number", "null"]}, "ret5": {"type": ["number", "null"]}, "ret20": {"type": ["number", "null"]},
          "close_position": {"type": ["number", "null"]}, "signal_score": {"type": ["number", "null"]}, "strength_level": {"type": ["string", "null"]},
          "trading_risk_score": {"type": ["number", "null"]}, "trade_state": {"type": ["string", "null"]}, "action": {"type": ["string", "null"]},
          "cooldown_state": {"type": ["string", "null"]}, "risk_flags": {"type": "array", "items": {"type": "string"}}, "risk_level": {"type": ["string", "null"]},
          "agent_bull": {"type": "array", "items": {"type": "string"}}, "agent_bear": {"type": "array", "items": {"type": "string"}}, "agent_scores": {"type": "object"}
        }
      }
    }
  }
}
